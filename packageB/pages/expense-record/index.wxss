/* 页面整体布局 */
.page-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 自定义导航栏 - 橙色主题 */
.navbar {
  background: linear-gradient(135deg, #FFB84D, #FFB84D);
  border-bottom: none;
  padding-top: 44px;
  padding-top: env(safe-area-inset-top);
  box-shadow: 0 2rpx 16rpx rgba(255, 184, 77, 0.3);
}

.t-navbar {
  --td-navbar-bg-color: transparent;
}

.navbar .t-navbar__title,
.navbar .t-navbar__center,
.navbar .t-navbar__center text,
.navbar .t-navbar__center .t-navbar__title {
  color: white !important;
  font-size: 34rpx !important;
  font-weight: 500 !important;
}

.navbar .t-icon,
.navbar .t-navbar__left .t-icon,
.navbar .t-navbar__right .t-icon {
  color: white !important;
}

.custom-back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  transition: all 0.3s;
}

.custom-back-btn:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.95);
}

/* 内容区域 */
.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 日期选择区域 */
.date-section {
  background: white;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.date-selector {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 18rpx 28rpx;
  background: linear-gradient(135deg, var(--color-white-pure) 0%, #f8f8f8 100%);
  border: 1rpx solid rgba(255, 143, 0, 0.05);
  border-radius: 30rpx;
  min-width: 200rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.date-selector:active {
  background: linear-gradient(135deg, #f8f8f8 0%, #f0f0f0 100%);
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.08);
}

.date-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.quick-input-btns {
  display: flex;
  gap: 16rpx;
}

.add-record-btn {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F2E 100%);
  border: none;
}

/* 滚动容器 */
.scroll-container {
  flex: 1;
  height: 0;
  width: 100%;
}

.form-container {
  padding: 24rpx 30rpx;
  padding-bottom: 40rpx;
}

/* 费用统计卡片 */
.expense-summary {
  background: linear-gradient(135deg, rgba(255, 184, 77, 0.1) 0%, rgba(255, 184, 77, 0.05) 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(255, 184, 77, 0.2);
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255, 184, 77, 0.2);
}

.summary-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.summary-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.summary-count {
  font-size: 26rpx;
  color: #666;
  background: rgba(255, 184, 77, 0.15);
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
}

.summary-total {
  display: flex;
  align-items: center;
}

.total-amount {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF9800;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto;
}

.expense-breakdown {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
}

.breakdown-item {
  flex: 1;
  min-width: 150rpx;
  background: rgba(255, 255, 255, 0.6);
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.breakdown-label {
  font-size: 24rpx;
  color: #666;
}

.breakdown-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF9800;
}

/* 费用记录列表 */
.expense-records-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.expense-record-item {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}

.expense-record-item:active {
  transform: scale(0.98);
}

.record-content {
  padding: 24rpx;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.expense-type-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 152, 0, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
}

.type-text {
  font-size: 26rpx;
  color: #FF9800;
  font-weight: 500;
}

.expense-amount {
  display: flex;
  align-items: center;
}

.amount-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF9800;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto;
}

.record-details {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.detail-label {
  font-size: 26rpx;
  color: #999;
}

.detail-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

.notes-preview {
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.notes-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  flex: 1;
}

.temp-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.temp-btn {
  flex: 1;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: white;
  transition: all 0.3s;
}

.edit-temp-btn {
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 77, 0.3);
}

.edit-temp-btn:active {
  background: linear-gradient(135deg, #FF9F2E 0%, #FF9F2E 100%);
  transform: scale(0.96);
}

.delete-temp-btn {
  background: linear-gradient(135deg, #757575 0%, #616161 100%);
  box-shadow: 0 4rpx 12rpx rgba(117, 117, 117, 0.3);
}

.delete-temp-btn:active {
  background: linear-gradient(135deg, #616161 0%, #424242 100%);
  transform: scale(0.96);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  background: white;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-top: 24rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #ccc;
  margin-top: 12rpx;
}

/* 费用记录弹窗样式 */
.expense-popup-content {
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
}

.expense-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 40rpx 20rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: linear-gradient(135deg, rgba(255, 184, 77, 0.05) 0%, rgba(255, 184, 77, 0.08) 100%);
}

.expense-popup-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.expense-popup-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.3s;
}

.expense-popup-close:active {
  background: #f5f5f5;
}

.expense-form-container {
  flex: 1;
  min-height: 200rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.expense-form-content {
  padding: 40rpx;
  padding-bottom: 20rpx;
}

/* 表单区块 */
.form-section {
  margin-bottom: 40rpx;
}

.section-label {
  display: block;
  font-size: 30rpx;
  color: #FFB84D;
  font-weight: 600;
  margin-bottom: 24rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid rgba(255, 184, 77, 0.1);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

/* 选项卡片布局 */
.option-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.option-card {
  position: relative;
  flex: 0 0 calc(25% - 46rpx);
  padding: 20rpx 16rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.option-card:active {
  transform: scale(0.96);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.08);
}

.option-card-active {
  background: linear-gradient(135deg, rgba(255, 152, 0, 0.1) 0%, rgba(255, 152, 0, 0.05) 100%);
  border: 2rpx solid #FF9800;
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.2);
}

.option-card-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.option-card-active .option-card-text {
  color: #FF9800;
  font-weight: 600;
}

.option-check-icon {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
}

.form-input {
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.form-input:focus-within {
  background: white;
  border-color: #FFB84D;
  box-shadow: 0 0 0 4rpx rgba(255, 184, 77, 0.1);
}

.form-textarea {
  width: 100%;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
  min-height: 120rpx;
}

.form-textarea:focus-within {
  background: white;
  border-color: #FFB84D;
  box-shadow: 0 0 0 4rpx rgba(255, 184, 77, 0.1);
}

/* 选择器输入框 */
.picker-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.picker-input:active {
  background: white;
  border-color: #FFB84D;
  box-shadow: 0 0 0 4rpx rgba(255, 184, 77, 0.1);
}

.picker-text {
  font-size: 28rpx;
  color: #333;
}

/* 弹窗底部按钮 */
.expense-popup-buttons {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 40rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: white;
  border-top: 1rpx solid #f0f0f0;
}

.expense-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.expense-cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.expense-cancel-btn:active {
  background: #e8e8e8;
  transform: scale(0.96);
}

.expense-confirm-btn {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F2E 100%);
  color: white;
  box-shadow: 0 8rpx 24rpx rgba(255, 184, 77, 0.4);
}

.expense-confirm-btn:active {
  background: linear-gradient(135deg, #FF9F2E 0%, #FF8F1F 100%);
  transform: scale(0.96);
}

/* 浮动按钮 */
.floating-next-btn {
  position: fixed;
  right: 40rpx;
  bottom: calc(env(safe-area-inset-bottom) + 580rpx);
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F2E 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 184, 77, 0.5);
  z-index: 99999;
  animation: bounceIn 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  animation-fill-mode: both;
  will-change: transform;
}

.floating-next-btn:active {
  transform: scale(0.9);
  box-shadow: 0 4rpx 16rpx rgba(255, 184, 77, 0.6);
}

@keyframes bounceIn {
  0% {
    opacity: 0;
    transform: scale(0.3);
  }

  50% {
    opacity: 1;
    transform: scale(1.05);
  }

  70% {
    transform: scale(0.9);
  }

  100% {
    transform: scale(1);
  }
}

/* 自定义日期选择器样式 - 橙色主题 */
.custom-date-picker {
  --td-picker-title-color: var(--color-orange-600);
  --td-picker-confirm-btn-color: var(--color-orange-600);
  --td-picker-cancel-btn-color: #666;
  --td-picker-item-color: #333;
  --td-picker-item-selected-color: var(--color-orange-600);
  --td-picker-toolbar-bg-color: var(--color-white-pure);
  --td-picker-bg-color: var(--color-white-pure);
  --td-popup-border-radius: 24rpx 24rpx 0 0;
}

/* 全局覆盖所有日期选择器确定按钮样式 - 橙色主题 */
page .t-date-time-picker .t-picker__toolbar .t-button--primary,
page .t-picker .t-button--primary,
page .t-date-time-picker__confirm,
page .t-picker__confirm {
  width: 137rpx;
  height: 80rpx;
  color: var(--color-white-pure) !important;
  background: linear-gradient(135deg, var(--color-orange-600) 0%, var(--color-orange-700) 100%) !important;
  border-radius: 12rpx !important;
  font-weight: 500 !important;
  box-shadow: 0 4rpx 12rpx rgba(255, 143, 0, 0.3) !important;
  border: 2rpx solid rgba(255, 255, 255, 0.4) !important;
  transition: all 0.3s !important;
  padding: 12rpx 24rpx !important;
}

page .t-date-time-picker .t-picker__toolbar .t-button--primary:active,
page .t-picker .t-button--primary:active,
page .t-date-time-picker__confirm:active,
page .t-picker__confirm:active {
  background: linear-gradient(135deg, var(--color-orange-700) 0%, #FF9800 100%) !important;
  transform: scale(0.96) !important;
  box-shadow: 0 2rpx 8rpx rgba(255, 143, 0, 0.4) !important;
}

/* 日期选择器工具栏 - 橙色主题 */
.t-picker__toolbar {
  background: linear-gradient(135deg, rgba(255, 143, 0, 0.05) 0%, rgba(245, 124, 0, 0.08) 50%, rgba(255, 255, 255, 0.95) 100%) !important;
  border-bottom: 1rpx solid rgba(255, 143, 0, 0.15) !important;
  padding: 20rpx 30rpx !important;
  box-shadow: 0 2rpx 8rpx rgba(255, 143, 0, 0.08) !important;
}

/* 优化日期选择器标题 - 橙色主题 */
.t-date-time-picker .t-picker__title {
  font-size: 32rpx !important;
  font-weight: 600 !important;
  color: var(--color-orange-600) !important;
  text-shadow: 0 1rpx 3rpx rgba(255, 143, 0, 0.1) !important;
}

/* 日期选择器选中项 - 橙色主题 */
.t-date-time-picker .t-picker-item--selected {
  color: var(--color-orange-600) !important;
  font-weight: 500 !important;
}

/* 日期选择器取消按钮 */
.t-date-time-picker .t-picker__cancel {
  color: #666 !important;
}

/* 日期选择器容器 */
.t-date-time-picker .t-popup__content {
  border-radius: 24rpx 24rpx 0 0 !important;
}