<view class="page-container">
  <!-- 自定义导航栏 -->
  <t-navbar title="费用记录" class="navbar" style="--td-navbar-title-color: white; --td-navbar-title-font-size: 34rpx; --td-navbar-title-font-weight: 500;">
    <view slot="left" class="custom-back-btn" bindtap="navigateBack">
      <t-icon name="chevron-left" size="48rpx" color="white" />
    </view>
  </t-navbar>
  <!-- 内容区域 -->
  <view class="content">
    <!-- 日期选择区域 -->
    <view class="date-section">
      <view class="date-selector" bindtap="showDatePicker">
        <text class="date-text">{{selectedDate}}</text>
        <t-icon name="caret-down" size="24rpx" color="#666" />
      </view>
      <view class="quick-input-btns">
        <t-button theme="primary" size="small" icon="add" bindtap="addExpenseRecord" class="add-record-btn">
          添加记录
        </t-button>
      </view>
    </view>
    <!-- 滚动容器 -->
    <scroll-view class="scroll-container" scroll-y>
      <view class="form-container">
        <!-- 今日费用统计 -->
        <view class="expense-summary" wx:if="{{expenseRecords.length > 0}}">
          <view class="summary-header">
            <view class="summary-info">
              <text class="summary-title">今日费用</text>
              <text class="summary-count">{{expenseRecords.length}} 笔</text>
            </view>
            <view class="summary-total">
              <text class="total-amount">￥{{totalAmount}}</text>
            </view>
          </view>
          <view class="expense-breakdown">
            <view class="breakdown-item" wx:if="{{medicalInsurance > 0}}">
              <text class="breakdown-label">医保支付</text>
              <text class="breakdown-value">￥{{medicalInsurance}}</text>
            </view>
            <view class="breakdown-item" wx:if="{{selfPay > 0}}">
              <text class="breakdown-label">自费支付</text>
              <text class="breakdown-value">￥{{selfPay}}</text>
            </view>
            <view class="breakdown-item" wx:if="{{commercialInsurance > 0}}">
              <text class="breakdown-label">商保支付</text>
              <text class="breakdown-value">￥{{commercialInsurance}}</text>
            </view>
          </view>
        </view>
        <!-- 费用记录列表 -->
        <view class="expense-records-list" wx:if="{{expenseRecords.length > 0}}">
          <view class="expense-record-item" wx:for="{{expenseRecords}}" wx:key="_id">
            <view class="record-content">
              <view class="record-header">
                <view class="expense-type-badge">
                  <t-icon name="wallet" size="28rpx" color="#FF9800" />
                  <text class="type-text">{{item.expenseType}}</text>
                </view>
                <view class="expense-amount">
                  <text class="amount-value">￥{{item.amount}}</text>
                </view>
              </view>
              <view class="record-details">
                <view class="detail-row" wx:if="{{item.projectName}}">
                  <t-icon name="assignment" size="24rpx" color="#FF9800" />
                  <text class="detail-label">项目：</text>
                  <text class="detail-value">{{item.projectName}}</text>
                </view>
                <view class="detail-row" wx:if="{{item.hospital}}">
                  <t-icon name="location" size="24rpx" color="#FF9800" />
                  <text class="detail-label">医院：</text>
                  <text class="detail-value">{{item.hospital}}</text>
                </view>
                <view class="detail-row">
                  <t-icon name="wallet" size="24rpx" color="#FF9800" />
                  <text class="detail-label">支付：</text>
                  <text class="detail-value">{{item.paymentMethod}}</text>
                </view>
                <view class="detail-row" wx:if="{{item.time}}">
                  <t-icon name="time" size="24rpx" color="#FF9800" />
                  <text class="detail-label">时间：</text>
                  <text class="detail-value">{{item.time}}</text>
                </view>
              </view>
              <!-- 备注预览 -->
              <view class="notes-preview" wx:if="{{item.notes}}">
                <t-icon name="chat" size="24rpx" color="#8D6E63" />
                <text class="notes-text">{{item.notesPreview}}</text>
              </view>
              <!-- 操作按钮 -->
              <view class="temp-actions">
                <view class="temp-btn edit-temp-btn" catchtap="editRecord" data-id="{{item._id}}">
                  编辑
                </view>
                <view class="temp-btn delete-temp-btn" catchtap="deleteRecord" data-id="{{item._id}}">
                  删除
                </view>
              </view>
            </view>
          </view>
        </view>
        <!-- 空状态 -->
        <view class="empty-state" wx:if="{{expenseRecords.length === 0}}">
          <t-icon name="wallet" size="120rpx" color="#ddd" />
          <text class="empty-text">暂无费用记录</text>
          <text class="empty-hint">点击右上角添加费用记录</text>
        </view>
      </view>
    </scroll-view>
  </view>
  <!-- 费用记录弹窗 -->
  <t-popup visible="{{showExpenseDialog}}" placement="bottom" bind:visible-change="onDialogVisibleChange">
    <view class="expense-popup-content">
      <view class="expense-popup-header">
        <text class="expense-popup-title">{{isEditMode ? '编辑费用记录' : '添加费用记录'}}</text>
        <view class="expense-popup-close" bindtap="closeExpenseDialog">
          <t-icon name="close" size="32rpx" color="#999" />
        </view>
      </view>
      <scroll-view class="expense-form-container" scroll-y>
        <view class="expense-form-content">
          <view class="form-section">
            <view class="form-item" bindtap="setPopupFocus" data-index="0">
              <text class="form-label">费用金额 (元)</text>
              <t-input value="{{expenseForm.amount}}" placeholder="请输入费用金额" bind:change="onFormInput" data-field="amount" class="form-input" type="digit" bind:focus="onPopupInputFocus" bind:blur="onPopupInputBlur" data-index="0" data-total="3" />
            </view>
            <view class="form-item" bindtap="setPopupFocus" data-index="1">
              <text class="form-label">项目名称</text>
              <t-input value="{{expenseForm.projectName}}" placeholder="如：血常规检查、化疗药物等" bind:change="onFormInput" data-field="projectName" class="form-input" bind:focus="onPopupInputFocus" bind:blur="onPopupInputBlur" data-index="1" data-total="3" />
            </view>
            <view class="form-item" bindtap="setPopupFocus" data-index="2">
              <text class="form-label">医院/机构</text>
              <t-input value="{{expenseForm.hospital}}" placeholder="请输入医院或机构名称" bind:change="onFormInput" data-field="hospital" class="form-input" bind:focus="onPopupInputFocus" bind:blur="onPopupInputBlur" data-index="2" data-total="3" />
            </view>
          </view>
          <!-- 费用分类 -->
          <view class="form-section">
            <text class="section-label">费用分类</text>
            <!-- 费用类型 - 卡片选择 -->
            <view class="form-item">
              <text class="form-label">费用类型</text>
              <view class="option-cards">
                <view class="option-card {{expenseForm.expenseType === item.value ? 'option-card-active' : ''}}" wx:for="{{expenseTypeOptions}}" wx:key="value" bindtap="onExpenseTypeSelect" data-value="{{item.value}}">
                  <text class="option-card-text">{{item.label}}</text>
                  <t-icon wx:if="{{expenseForm.expenseType === item.value}}" name="check-circle-filled" size="32rpx" color="#FF9800" class="option-check-icon" />
                </view>
              </view>
            </view>
            <!-- 支付方式 - 卡片选择 -->
            <view class="form-item">
              <text class="form-label">支付方式</text>
              <view class="option-cards">
                <view class="option-card {{expenseForm.paymentMethod === item.value ? 'option-card-active' : ''}}" wx:for="{{paymentMethodOptions}}" wx:key="value" bindtap="onPaymentMethodSelect" data-value="{{item.value}}">
                  <text class="option-card-text">{{item.label}}</text>
                  <t-icon wx:if="{{expenseForm.paymentMethod === item.value}}" name="check-circle-filled" size="32rpx" color="#FF9800" class="option-check-icon" />
                </view>
              </view>
            </view>
          </view>
          <view class="form-section">
            <view class="form-item" bindtap="setPopupFocus" data-index="3">
              <text class="form-label">备注</text>
              <t-textarea value="{{expenseForm.notes}}" placeholder="其他需要记录的信息" bind:change="onFormInput" data-field="notes" class="form-textarea" maxlength="200" indicator bind:focus="onPopupInputFocus" bind:blur="onPopupInputBlur" data-index="3" data-total="3" />
            </view>
          </view>
        </view>
      </scroll-view>
      <view class="expense-popup-buttons">
        <view class="expense-btn expense-cancel-btn" bindtap="closeExpenseDialog">取消</view>
        <view class="expense-btn expense-confirm-btn" bindtap="saveExpenseRecord">
          {{isEditMode ? '保存' : '添加'}}
        </view>
      </view>
    </view>
  </t-popup>
  <!-- 浮动的下一项/完成按钮（弹窗中） - 移到弹窗外以正确fixed定位 -->
  <view wx:if="{{popupFocusIndex >= 0 && showExpenseDialog}}" class="floating-next-btn" catchtap="{{popupFocusIndex === 3 ? 'completePopupInput' : 'goToNextPopupInput'}}" data-index="{{popupFocusIndex}}">
    <t-icon name="{{popupFocusIndex === 3 ? 'check' : 'chevron-down'}}" size="48rpx" color="white" />
  </view>
  <!-- 日期选择器 -->
  <t-date-time-picker title="选择日期" visible="{{datePickerVisible}}" mode="date" value="{{selectedDate}}" bind:confirm="onDateConfirm" bind:cancel="onDateCancel" confirm-btn="确定" cancel-btn="取消" class="custom-date-picker" />
</view>