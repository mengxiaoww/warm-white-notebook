page {
  background: #F5F5F5;
}

.page {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* ==================== 表单列表 ==================== */
.form-list {
  background: #FFF;
}

.form-cell {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  background: #FFF;
  border-bottom: 1rpx solid #F0F0F0;
  min-height: 88rpx;
  box-sizing: border-box;
}

.form-cell:last-child {
  border-bottom: none;
}

.cell-label {
  width: 180rpx;
  font-size: 30rpx;
  color: #333;
  flex-shrink: 0;
}

.star {
  color: #FF6B6B;
  margin-left: 4rpx;
}

.cell-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  text-align: right;
}

.cell-value {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  text-align: right;
  margin-right: 8rpx;
}

.cell-value.placeholder {
  color: #C0C0C0;
}

/* 性别选择 */
.gender-box {
  flex: 1;
  display: flex;
  gap: 16rpx;
}

.gender-item {
  flex: 1;
  height: 64rpx;
  background: #F7F7F7;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}

.gender-item.on {
  background: linear-gradient(135deg, #FFB84D, #FFA726);
  color: #FFF;
  font-weight: 600;
}

/* 开关行 */
.switch-cell {
  justify-content: space-between;
}

/* 箭头 */
.arrow {
  position: relative;
}

/* 保存按钮 */
.btn-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 30rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #FFF;
  border-top: 1rpx solid #F0F0F0;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #FFB84D, #FFA726);
  border-radius: 44rpx;
  color: #FFF;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin: 0;
  padding: 0;
  box-shadow: 0 4rpx 16rpx rgba(255, 184, 77, 0.3);
}

.save-btn::after {
  border: none;
}

/* 弹窗 */
.popup-wrap {
  background: #FFF;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.popup-hd {
  display: flex;
  align-items: center;
  height: 100rpx;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
  flex-shrink: 0;
}

.popup-back,
.popup-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.popup-tit {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.popup-bd {
  box-sizing: border-box;
  padding: 30rpx;
  height: calc(85vh - 100rpx); /* 弹窗总高度减去头部高度 */
}

.cat-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.cat {
  height: 80rpx;
  background: #F7F7F7;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #333;
  transition: all 0.2s;
  padding: 0 8rpx;
}

.cat.cur {
  background: linear-gradient(135deg, #FFF9F0, #FFE8CC);
  color: #FFA726;
  font-weight: 600;
  border: 2rpx solid #FFB84D;
}