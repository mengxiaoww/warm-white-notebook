<!-- pages/add-profile/index.wxml -->
<view class="page">
  <!-- 表单区 -->
  <view class="form-list">
    <!-- 姓名 -->
    <view class="form-cell">
      <view class="cell-label">
        姓名
        <text class="star">*</text>
      </view>
      <input class="cell-input" type="nickname" value="{{profileForm.realName}}" bindinput="onRealNameInput" placeholder="请输入姓名" maxlength="20" />
    </view>
    <!-- 性别 -->
    <view class="form-cell">
      <view class="cell-label">
        性别
        <text class="star">*</text>
      </view>
      <view class="gender-box">
        <view class="gender-item {{profileForm.gender === 'male' ? 'on' : ''}}" bindtap="selectGender" data-gender="male">
          <t-icon name="gender-male" size="32rpx" />
          <text>男</text>
        </view>
        <view class="gender-item {{profileForm.gender === 'female' ? 'on' : ''}}" bindtap="selectGender" data-gender="female">
          <t-icon name="gender-female" size="32rpx" />
          <text>女</text>
        </view>
      </view>
    </view>
    <!-- 年龄 -->
    <view class="form-cell">
      <view class="cell-label">
        年龄
        <text class="star">*</text>
      </view>
      <input class="cell-input" type="number" value="{{profileForm.age}}" bindinput="onAgeInput" placeholder="请输入年龄" maxlength="3" />
    </view>
    <!-- 疾病类型 -->
    <view class="form-cell arrow" bindtap="showDiseaseSelector">
      <view class="cell-label">疾病类型</view>
      <view class="cell-value {{profileForm.disease ? '' : 'placeholder'}}">
        {{profileForm.disease || '请选择'}}
      </view>
      <t-icon name="chevron-right" size="32rpx" color="#C0C0C0" />
    </view>
    <!-- 就诊医院 -->
    <view class="form-cell">
      <view class="cell-label">就诊医院</view>
      <input class="cell-input" value="{{profileForm.hospital}}" bindinput="onHospitalInput" placeholder="请输入医院名称" />
    </view>
    <!-- 默认档案 -->
    <view class="form-cell switch-cell" wx:if="{{!shouldDisableDefaultSwitch || isOnlyProfile}}">
      <view class="cell-label">设为默认档案</view>
      <switch checked="{{profileForm.isDefault}}" bindchange="onDefaultSwitchChange" color="#FFB84D" disabled="{{shouldDisableDefaultSwitch}}" />
    </view>
  </view>
  <!-- 保存按钮 -->
  <view class="btn-area">
    <button class="save-btn" bindtap="saveProfile">{{saveBtnText}}</button>
  </view>
</view>
<!-- 疾病选择弹窗 -->
<t-popup visible="{{showDiseasePopup}}" bind:visible-change="closeDiseasePopup" placement="bottom">
  <view class="popup-wrap">
    <view class="popup-hd">
      <view class="popup-back" wx:if="{{currentLevel === 'secondary'}}" bindtap="backToPrimary">
        <t-icon name="chevron-left" size="40rpx" color="#333" />
      </view>
      <view class="popup-tit">
        {{currentLevel === 'primary' ? '选择疾病分类' : browsingPrimaryCategory.name}}
      </view>
      <view class="popup-close" bindtap="closeDiseasePopup">
        <t-icon name="close" size="32rpx" color="#666" />
      </view>
    </view>
    <scroll-view scroll-y class="popup-bd">
      <view wx:if="{{currentLevel === 'primary'}}" class="cat-grid">
        <view wx:for="{{diseaseCategories}}" wx:key="id" class="cat {{browsingPrimaryCategory && browsingPrimaryCategory.id === item.id ? 'cur' : ''}}" bindtap="selectPrimaryCategory" data-id="{{item.id}}">
          {{item.name}}
        </view>
      </view>
      <view wx:if="{{currentLevel === 'secondary' && browsingPrimaryCategory}}" class="cat-grid">
        <view wx:for="{{browsingPrimaryCategory.children}}" wx:key="id" class="cat {{browsingSecondaryCategory && browsingSecondaryCategory.id === item.id ? 'cur' : ''}}" bindtap="selectSecondaryCategory" data-id="{{item.id}}">
          {{item.name}}
        </view>
      </view>
    </scroll-view>
  </view>
</t-popup>