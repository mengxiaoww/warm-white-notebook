/* 页面整体布局 */
.page-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 自定义导航栏 - 橙色主题 */
.navbar {
  background: linear-gradient(135deg, #FFB84D, #FFB84D);
  border-bottom: none;
  padding-top: 44px;
  padding-top: env(safe-area-inset-top);
  box-shadow: 0 2rpx 16rpx var(--primary-alpha-20);
}

.navbar-right {
  padding-right: 30rpx;
}

/* 修复导航栏样式 */
.t-navbar__placeholder {
  visibility: hidden;
}

.t-navbar {
  --td-navbar-bg-color: transparent;
}

/* 强制设置导航栏标题样式 - 使用更具体的选择器 */
.navbar .t-navbar__title,
.navbar .t-navbar__center,
.navbar .t-navbar__center text,
.navbar .t-navbar__center .t-navbar__title {
  color: white !important;
  font-size: 34rpx !important;
  font-weight: 500 !important;
}

/* 导航栏所有图标颜色 */
.navbar .t-icon,
.navbar .t-navbar__left .t-icon,
.navbar .t-navbar__right .t-icon {
  color: white !important;
}

/* 更强的选择器确保样式生效 */
.page-container .navbar .t-navbar__title {
  color: white !important;
  font-size: 34rpx !important;
  font-weight: 500 !important;
}

/* 确保时间选择器显示在弹窗上层 */
.t-picker__wrapper {
  z-index: 11500 !important;
}

.t-date-time-picker {
  z-index: 11500 !important;
}

/* 时间选择器的遮罩层 */
.t-picker__mask {
  z-index: 11499 !important;
}

/* 弹窗内容降低层级 */
.stool-popup-content {
  position: relative;
  z-index: 10000;
}

/* 自定义返回按钮样式 */
.custom-back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  transition: all 0.3s;
}

.custom-back-btn:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.95);
}

/* 内容区域 */
.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  height: 0;
}

/* 日期选择区域 */
.date-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 30rpx 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.9);
  margin: 20rpx 20rpx 0 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx var(--primary-alpha-10);
  border: 1rpx solid var(--primary-alpha-10);
}

.date-selector {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: rgba(141, 110, 99, 0.05);
  border-radius: 16rpx;
  border: 2rpx solid var(--primary-alpha-20);
  transition: all 0.3s;
}

.date-selector:active {
  background: var(--primary-alpha-10);
  border-color: #FFB84D;
}

.date-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.quick-input-btns {
  display: flex;
  gap: 20rpx;
}

.quick-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%);
  color: white;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(141, 110, 99, 0.3);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  transition: all 0.3s;
}

.quick-btn:active {
  background: linear-gradient(135deg, #FFB84D 0%, #5D4037 100%);
  transform: scale(0.95);
}

.quick-btn text {
  color: white;
  font-weight: 500;
}

/* 滚动容器 */
.scroll-container {
  height: calc(100vh - 160rpx);
  width: 100%;
  background: #f5f5f5;
}

/* 表单容器 */
.form-container {
  padding: 20rpx;
  padding-bottom: 90rpx;
}

/* 排便统计卡片 */
.stool-summary {
  background: linear-gradient(135deg, #F5F0E8 0%, #EDE7D3 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--primary-alpha-10);
  box-shadow: 0 4rpx 20rpx var(--primary-alpha-10);
}

.summary-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.summary-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.summary-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.summary-count {
  font-size: 28rpx;
  color: #FFB84D;
  background: var(--primary-alpha-10);
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

.summary-status {
  display: flex;
  align-items: center;
}

.status-indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 12rpx 20rpx;
  border-radius: 16rpx;
  font-weight: 600;
  border: 1rpx solid;
  min-width: 78rpx;
  min-height: 20rpx;
}

.status-normal {
  background: rgba(82, 196, 26, 0.1);
  border-color: rgba(82, 196, 26, 0.2);
}

.status-warning {
  background: rgba(255, 107, 53, 0.1);
  border-color: rgba(255, 107, 53, 0.2);
}

.status-text {
  line-height: 1.2;
  font-size: 26rpx;
}

.status-normal .status-text {
  color: #52c41a;
}

.status-warning .status-text {
  color: #ff6b35;
}

/* 排便记录列表 */
.stool-records-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.stool-record-item {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid var(--primary-alpha-10);
}

.record-content {
  padding: 32rpx 28rpx;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.record-content::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, var(--primary-alpha-30) 50%, transparent 100%);
  z-index: 1;
}

.record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--primary-alpha-10);
}

.time-info {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.record-time {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.type-info {
  display: flex;
  align-items: center;
}

.type-badge {
  font-size: 26rpx;
  color: #FFB84D;
  font-weight: 600;
  background: var(--primary-alpha-10);
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--primary-alpha-20);
}

.record-details {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
  background: rgba(141, 110, 99, 0.05);
  border-radius: 12rpx;
  border: 1rpx solid var(--primary-alpha-10);
}

.detail-label {
  font-size: 24rpx;
  color: #FFB84D;
  font-weight: 600;
}

.detail-value {
  font-size: 24rpx;
  color: #555;
  font-weight: 500;
}

/* 异常指标 */
.abnormal-indicators {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
  flex-wrap: wrap;
}

.abnormal-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 12rpx;
  background: rgba(255, 71, 87, 0.1);
  border: 1rpx solid rgba(255, 71, 87, 0.2);
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #ff4757;
  font-weight: 600;
}

.notes-preview {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-bottom: 20rpx;
  padding: 16rpx;
  background: rgba(141, 110, 99, 0.05);
  border-radius: 12rpx;
  border-left: 4rpx solid #FFB84D;
}

.notes-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.5;
  flex: 1;
}

/* 临时操作按钮 */
.temp-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.temp-btn {
  flex: 1;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: white;
  transition: all 0.3s;
}

.edit-temp-btn {
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%);
  box-shadow: 0 4rpx 12rpx rgba(141, 110, 99, 0.3);
}

.edit-temp-btn:active {
  background: linear-gradient(135deg, #FFB84D 0%, #5D4037 100%);
  transform: scale(0.96);
}

.delete-temp-btn {
  background: linear-gradient(135deg, #757575 0%, #616161 100%);
  box-shadow: 0 4rpx 12rpx rgba(117, 117, 117, 0.3);
}

.delete-temp-btn:active {
  background: linear-gradient(135deg, #616161 0%, #424242 100%);
  transform: scale(0.96);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  background: white;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-top: 24rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #ccc;
  margin-top: 12rpx;
}



/* 排便记录弹窗样式 */
.stool-popup-content {
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
}

.stool-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 40rpx 20rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: linear-gradient(135deg, rgba(255, 152, 0, 0.05) 0%, rgba(245, 124, 0, 0.08) 100%);
}

.stool-popup-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.stool-popup-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.3s;
}

.stool-popup-close:active {
  background: #f5f5f5;
}

.stool-form-container {
  flex: 1;
  min-height: 200rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.stool-form-content {
  padding: 40rpx;
  padding-bottom: 20rpx;
}

/* 表单区块 */
.form-section {
  margin-bottom: 40rpx;
}

.section-label {
  display: block;
  font-size: 30rpx;
  color: #FFB84D;
  font-weight: 600;
  margin-bottom: 24rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid var(--primary-alpha-10);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

/* 选项卡片布局 */
.option-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.option-card {
  position: relative;
  flex: 0 0 calc(25% - 46rpx);
  padding: 20rpx 16rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.option-card:active {
  transform: scale(0.96);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.08);
}

.option-card-active {
  background: linear-gradient(135deg, rgba(255, 152, 0, 0.1) 0%, rgba(255, 152, 0, 0.05) 100%);
  border: 2rpx solid #FF9800;
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.2);
}

.option-card-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.option-card-active .option-card-text {
  color: #FF9800;
  font-weight: 600;
}

.option-check-icon {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
}

.form-input {
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.form-input:focus-within {
  background: white;
  border-color: #FFB84D;
  box-shadow: 0 0 0 4rpx var(--primary-alpha-10);
}

.form-textarea {
  width: 100%;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
  min-height: 120rpx;
}

.form-textarea:focus-within {
  background: white;
  border-color: #FFB84D;
  box-shadow: 0 0 0 4rpx var(--primary-alpha-10);
}

/* 选择器输入框 */
.picker-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.picker-input:active {
  background: white;
  border-color: #FFB84D;
  box-shadow: 0 0 0 4rpx var(--primary-alpha-10);
}

.picker-text {
  font-size: 28rpx;
  color: #333;
}

/* 开关项 */
.switch-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid var(--primary-alpha-10);
}

.switch-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.switch-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 弹窗按钮区域 */
.stool-popup-buttons {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  background: #f8f8f8;
}

.stool-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

/* 取消按钮 */
.stool-cancel-btn {
  background: linear-gradient(135deg, #f0f0f0 0%, #e6e6e6 100%);
  color: #666;
  box-shadow:
    0 8rpx 24rpx rgba(102, 102, 102, 0.2),
    0 4rpx 12rpx rgba(230, 230, 230, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.8);
  border: 2rpx solid rgba(255, 255, 255, 0.6);
}

.stool-cancel-btn:active {
  background: linear-gradient(135deg, #e6e6e6 0%, #d9d9d9 100%);
  transform: scale(0.96) translateY(2rpx);
}

/* 确认按钮 */
.stool-confirm-btn {
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%);
  color: white;
  box-shadow:
    0 8rpx 24rpx rgba(141, 110, 99, 0.4),
    0 4rpx 12rpx rgba(109, 76, 65, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3);
  border: 2rpx solid rgba(255, 255, 255, 0.4);
}

.stool-confirm-btn:active {
  background: linear-gradient(135deg, #FFB84D 0%, #5D4037 100%);
  transform: scale(0.96) translateY(2rpx);
}

/* 时间选择器样式 - 橙色主题 */
.t-date-time-picker__confirm {
  color: white !important;
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%) !important;
  border-radius: 12rpx !important;
  padding: 12rpx 24rpx !important;
  font-weight: 500 !important;
  box-shadow: 0 4rpx 12rpx var(--primary-alpha-30) !important;
  border: 2rpx solid rgba(255, 255, 255, 0.4) !important;
  transition: all 0.3s !important;
}

.t-date-time-picker__confirm:active {
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%) !important;
  transform: scale(0.96) !important;
  box-shadow: 0 2rpx 8rpx var(--primary-alpha-40) !important;
}

/* 全局覆盖所有时间选择器确定按钮样式 - 橙色主题 */
page .t-date-time-picker .t-picker__toolbar .t-button--primary,
page .t-picker .t-button--primary,
page .t-date-time-picker__confirm,
page .t-picker__confirm {
  width: 137rpx;
  height: 80rpx;
  color: #fff !important;
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%) !important;
  border-radius: 12rpx !important;
  font-weight: 500 !important;
  box-shadow: 0 4rpx 12rpx var(--primary-alpha-30) !important;
  border: 2rpx solid rgba(255, 255, 255, 0.4) !important;
  transition: all 0.3s !important;
  padding: 12rpx 24rpx !important;
}

/* 时间选择器工具栏 - 橙色主题 */
.t-picker__toolbar {
  background: linear-gradient(135deg, rgba(255, 152, 0, 0.05) 0%, rgba(245, 124, 0, 0.08) 50%, rgba(255, 255, 255, 0.95) 100%) !important;
  border-bottom: 1rpx solid var(--primary-alpha-15) !important;
  padding: 20rpx 30rpx !important;
  box-shadow: 0 2rpx 8rpx var(--primary-alpha-08) !important;
}

/* 优化时间选择器标题 - 橙色主题 */
.t-date-time-picker .t-picker__title {
  font-size: 32rpx !important;
  font-weight: 600 !important;
  color: #FFB84D !important;
  text-shadow: 0 1rpx 3rpx var(--primary-alpha-10) !important;
}

/* 时间选择器选中项 - 橙色主题 */
.t-date-time-picker .t-picker-item--selected {
  color: #FFB84D !important;
  font-weight: 500 !important;
}

/* 时间选择器取消按钮 */
.t-date-time-picker .t-picker__cancel {
  color: #666 !important;
}

/* 时间选择器容器 */
.t-date-time-picker .t-popup__content {
  border-radius: 24rpx 24rpx 0 0 !important;
}

/* 确保时间选择器显示在最上层 */
.t-date-time-picker {
  z-index: 12000 !important;
}

.t-date-time-picker .t-popup {
  z-index: 12000 !important;
}

.t-date-time-picker .t-popup__content {
  z-index: 12001 !important;
}

/* 时间选择器确认按钮橙色主题 */
.t-date-time-picker .t-button--primary {
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%) !important;
  color: white !important;
  border: none !important;
  border-radius: 8rpx !important;
  font-weight: 500 !important;
}

.t-date-time-picker .t-button--primary:hover {
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%) !important;
}


/* 选择器弹窗样式 */
.picker-popup {
  background: white;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: linear-gradient(135deg, rgba(255, 152, 0, 0.05) 0%, rgba(245, 124, 0, 0.08) 100%);
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.picker-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.3s;
}

.picker-close:active {
  background: #f5f5f5;
}

.picker-options {
  max-height: 60vh;
  overflow-y: auto;
  padding: 20rpx;
}

.picker-option-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.picker-option-item:last-child {
  margin-bottom: 0;
}

.picker-option-item:active {
  background: var(--primary-alpha-10);
  border-color: rgba(141, 110, 99, 0.3);
}

.picker-option-active {
  background: var(--primary-alpha-10) !important;
  border-color: #FFB84D !important;
}

.option-text {
  font-size: 30rpx;
  color: #333;
