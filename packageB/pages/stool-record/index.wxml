<view class="page-container">
  <!-- 自定义导航栏 -->
  <t-navbar title="排便记录" class="navbar" style="--td-navbar-title-color: white; --td-navbar-title-font-size: 34rpx; --td-navbar-title-font-weight: 500;">
    <view slot="left" class="custom-back-btn" bindtap="navigateBack">
      <t-icon name="chevron-left" size="48rpx" color="white" />
    </view>
  </t-navbar>
  <!-- 内容区域 -->
  <view class="content">
    <!-- 日期选择区域 -->
    <view class="date-section">
      <view class="date-selector" bindtap="showDatePicker">
        <text class="date-text">{{selectedDate}}</text>
        <t-icon name="calendar" size="32rpx" color="#666" />
      </view>
      <view class="quick-input-btns">
        <t-button theme="primary" size="small" icon="add" bindtap="addStoolRecord" class="add-record-btn">
          添加记录
        </t-button>
      </view>
    </view>
    <!-- 滚动容器 -->
    <scroll-view class="scroll-container" scroll-y>
      <view class="form-container">
        <!-- 今日排便统计 -->
        <view class="stool-summary" wx:if="{{stoolRecords.length > 0}}">
          <view class="summary-header">
            <view class="summary-info">
              <text class="summary-title">今日排便</text>
              <text class="summary-count">{{stoolRecords.length}} 次</text>
            </view>
            <view class="summary-status">
              <view class="status-indicator {{hasAbnormal ? 'status-warning' : 'status-normal'}}">
                <view class="status-text">{{hasAbnormal ? '有异常' : '无异常'}}</view>
              </view>
            </view>
          </view>
        </view>
        <!-- 排便记录列表 -->
        <view class="stool-records-list" wx:if="{{stoolRecords.length > 0}}">
          <view class="stool-record-item" wx:for="{{stoolRecords}}" wx:key="_id">
            <view class="record-content">
              <view class="record-header">
                <view class="time-info">
                  <t-icon name="time" size="28rpx" color="#FF9800" />
                  <text class="record-time">{{item.time}}</text>
                </view>
                <view class="type-info">
                  <text class="type-badge">{{item.type}}</text>
                </view>
              </view>
              <view class="record-details">
                <view class="detail-item" wx:if="{{item.color}}">
                  <t-icon name="palette" size="24rpx" color="#FF9800" />
                  <text class="detail-label">颜色：</text>
                  <text class="detail-value">{{item.color}}</text>
                </view>
                <view class="detail-item" wx:if="{{item.consistency}}">
                  <t-icon name="layers" size="24rpx" color="#FF9800" />
                  <text class="detail-label">硬度：</text>
                  <text class="detail-value">{{item.consistency}}</text>
                </view>
                <!-- 异常指标 -->
                <view class="abnormal-indicators" wx:if="{{item.hasBlood || item.hasMucus}}">
                  <view class="abnormal-tag" wx:if="{{item.hasBlood}}">
                    <t-icon name="error-circle-filled" size="24rpx" color="#ff4757" />
                    <text>有血液</text>
                  </view>
                  <view class="abnormal-tag" wx:if="{{item.hasMucus}}">
                    <t-icon name="error-circle-filled" size="24rpx" color="#ff6348" />
                    <text>有粘液</text>
                  </view>
                </view>
              </view>
              <!-- 备注预览 -->
              <view class="notes-preview" wx:if="{{item.notes}}">
                <t-icon name="chat" size="24rpx" color="#8D6E63" />
                <text class="notes-text">{{item.notesPreview}}</text>
              </view>
              <!-- 操作按钮 -->
              <view class="temp-actions">
                <view class="temp-btn edit-temp-btn" catchtap="editRecord" data-id="{{item._id}}">
                  编辑
                </view>
                <view class="temp-btn delete-temp-btn" catchtap="deleteRecord" data-id="{{item._id}}">
                  删除
                </view>
              </view>
            </view>
          </view>
        </view>
        <!-- 空状态 -->
        <view class="empty-state" wx:if="{{stoolRecords.length === 0}}">
          <t-icon name="view-module" size="120rpx" color="#ddd" />
          <text class="empty-text">暂无排便记录</text>
          <text class="empty-hint">点击右上角添加排便记录</text>
        </view>
      </view>
    </scroll-view>
  </view>
  <!-- 日期选择器 -->
  <t-date-time-picker visible="{{datePickerVisible}}" value="{{selectedDateTimestamp}}" mode="date" title="选择日期" confirm-btn="确定" cancel-btn="取消" bind:confirm="onDateConfirm" bind:cancel="onDateCancel" bind:visible-change="onDateVisibleChange" />
  <!-- 排便记录弹窗 -->
  <t-popup visible="{{showStoolDialog}}" placement="bottom" bind:visible-change="onDialogVisibleChange">
    <view class="stool-popup-content">
      <view class="stool-popup-header">
        <text class="stool-popup-title">{{isEditMode ? '编辑排便记录' : '添加排便记录'}}</text>
        <view class="stool-popup-close" bindtap="closeStoolDialog">
          <t-icon name="close" size="32rpx" color="#999" />
        </view>
      </view>
      <scroll-view class="stool-form-container" scroll-y>
        <view class="stool-form-content">
          <view class="form-section">
            <view class="form-item">
              <text class="form-label">记录时间</text>
              <picker mode="time" value="{{stoolForm.time}}" bindchange="onTimePickerChange">
                <view class="picker-input">
                  <text class="picker-text">{{stoolForm.time || '请选择记录时间'}}</text>
                  <t-icon name="chevron-down" size="32rpx" color="#999" />
                </view>
              </picker>
            </view>
            <!-- 粪便性状 - 卡片选择 -->
            <view class="form-item">
              <text class="form-label">粪便性状</text>
              <view class="option-cards">
                <view class="option-card {{stoolForm.type === item.value ? 'option-card-active' : ''}}" wx:for="{{typeOptions}}" wx:key="value" bindtap="onTypeSelect" data-value="{{item.value}}">
                  <text class="option-card-text">{{item.label}}</text>
                  <t-icon wx:if="{{stoolForm.type === item.value}}" name="check-circle-filled" size="32rpx" color="#FF9800" class="option-check-icon" />
                </view>
              </view>
            </view>
            <!-- 粪便颜色 - 卡片选择 -->
            <view class="form-item">
              <text class="form-label">粪便颜色</text>
              <view class="option-cards">
                <view class="option-card {{stoolForm.color === item.value ? 'option-card-active' : ''}}" wx:for="{{colorOptions}}" wx:key="value" bindtap="onColorSelect" data-value="{{item.value}}">
                  <text class="option-card-text">{{item.label}}</text>
                  <t-icon wx:if="{{stoolForm.color === item.value}}" name="check-circle-filled" size="32rpx" color="#FF9800" class="option-check-icon" />
                </view>
              </view>
            </view>
            <!-- 粪便硬度 - 卡片选择 -->
            <view class="form-item">
              <text class="form-label">粪便硬度</text>
              <view class="option-cards">
                <view class="option-card {{stoolForm.consistency === item.value ? 'option-card-active' : ''}}" wx:for="{{consistencyOptions}}" wx:key="value" bindtap="onConsistencySelect" data-value="{{item.value}}">
                  <text class="option-card-text">{{item.label}}</text>
                  <t-icon wx:if="{{stoolForm.consistency === item.value}}" name="check-circle-filled" size="32rpx" color="#FF9800" class="option-check-icon" />
                </view>
              </view>
            </view>
          </view>
          <!-- 异常检测 -->
          <view class="form-section">
            <text class="section-label">异常检测</text>
            <view class="form-item switch-item">
              <view class="switch-label">
                <t-icon name="error-circle" size="28rpx" color="#ff4757" />
                <text class="switch-text">是否有血液</text>
              </view>
              <t-switch value="{{stoolForm.hasBlood}}" bind:change="onSwitchChange" data-field="hasBlood" colors="{{['#ff4757', '#ddd']}}" />
            </view>
            <view class="form-item switch-item">
              <view class="switch-label">
                <t-icon name="error-circle" size="28rpx" color="#ff6348" />
                <text class="switch-text">是否有粘液</text>
              </view>
              <t-switch value="{{stoolForm.hasMucus}}" bind:change="onSwitchChange" data-field="hasMucus" colors="{{['#ff6348', '#ddd']}}" />
            </view>
          </view>
          <view class="form-section">
            <view class="form-item">
              <text class="form-label">备注</text>
              <t-textarea value="{{stoolForm.notes}}" placeholder="其他需要记录的信息" bind:change="onFormInput" data-field="notes" class="form-textarea" maxlength="200" indicator />
            </view>
          </view>
        </view>
      </scroll-view>
      <view class="stool-popup-buttons">
        <view class="stool-btn stool-cancel-btn" bindtap="closeStoolDialog">取消</view>
        <view class="stool-btn stool-confirm-btn" bindtap="saveStoolRecord">
          {{isEditMode ? '保存' : '添加'}}
        </view>
      </view>
    </view>
  </t-popup>
</view>