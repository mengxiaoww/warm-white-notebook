/* 筛选弹窗 - 现代设计 */
.filter-popup {
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  box-shadow:
    0 12rpx 48rpx rgba(255, 184, 77, 0.2),
    0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  position: relative;
  overflow: hidden;
}

.popup-3d-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.02) 0%,
      rgba(193, 149, 85, 0.05) 50%,
      rgba(255, 184, 77, 0.02) 100%);
  z-index: 0;
}

.filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 40rpx 32rpx;
  border-bottom: 2rpx solid rgba(255, 184, 77, 0.1);
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.08) 0%,
      rgba(193, 149, 85, 0.12) 100%);
  position: relative;
  z-index: 1;
}

.header-icon-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-icon-glow {
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 184, 77, 0.3) 0%, transparent 70%);
  opacity: 0.6;
}

.filter-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary-color);
  text-shadow: 0 1rpx 3rpx rgba(255, 184, 77, 0.2);
  margin-left: 16rpx;
}

.filter-close {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.close-hover {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 184, 77, 0.1);
  border-radius: 50%;
  transform: scale(0);
  transition: transform 0.3s ease;
}

.filter-close:active {
  transform: scale(0.95);
}

.filter-close:active .close-hover {
  transform: scale(1);
}

.filter-options {
  flex: 1;
  padding: 20rpx 0;
  overflow-y: auto;
  position: relative;
  z-index: 1;
}

.filter-option {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 40rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border-bottom: 1rpx solid rgba(255, 184, 77, 0.1);
  position: relative;
  overflow: hidden;
}

.filter-option::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 184, 77, 0.1) 50%,
      transparent 100%);
  transition: left 0.5s ease;
}

.filter-option:last-child {
  border-bottom: none;
}

.filter-option:active {
  background: rgba(255, 184, 77, 0.08);
}

.filter-option:active::before {
  left: 100%;
}

.option-indicator {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(255, 184, 77, 0.3);
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.option-active {
  background: rgba(255, 184, 77, 0.12) !important;
  border-left: 6rpx solid var(--primary-color);
}

.option-active .option-indicator {
  background: var(--primary-color);
  box-shadow: 0 0 12rpx rgba(255, 184, 77, 0.5);
}

.option-text {
  font-size: 30rpx;
  color: #333;
  flex: 1;
  font-weight: 500;
}

.option-active .option-text {
  color: var(--primary-color);
  font-weight: 700;
}

.option-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 184, 77, 0.1);
  border: 2rpx solid rgba(255, 184, 77, 0.3);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  transform: scale(0);
}

.option-check.checked {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-color: var(--primary-color);
  transform: scale(1);
  box-shadow:
    0 4rpx 16rpx rgba(255, 184, 77, 0.3),
    0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

