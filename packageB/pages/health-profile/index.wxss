/* 健康档案页面已使用全局 .function-item 样式，所有功能项目样式已移至 app.wxss */

/* ========== 检查报告档案样式 ========== */

.check-report-archive {
  position: relative;
}

.check-report-content {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 报告头部区域 */
.report-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.report-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.report-icon-wrapper {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, rgba(255, 184, 77, 0.2) 0%, rgba(255, 184, 77, 0.1) 100%);
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 77, 0.15);
  border: 2rpx solid rgba(255, 184, 77, 0.2);
}

.report-project-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  line-height: 1.4;
  flex: 1;
}

/* 元数据信息区域 */
.report-meta-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid rgba(255, 184, 77, 0.1);
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.meta-label {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}

.meta-value {
  font-size: 24rpx;
  color: #666;
  font-weight: 600;
}

/* 检查报告图片展示 */
.report-images {
  display: grid;
  gap: 12rpx;
  margin-top: 12rpx;
  width: 100%;
}

/* 单张图片 - 大图显示 */
.report-images-count-1 {
  grid-template-columns: 1fr;
}

.report-images-count-1 .report-image {
  width: 100%;
  height: 360rpx;
}

/* 两张图片 - 并排显示 */
.report-images-count-2 {
  grid-template-columns: repeat(2, 1fr);
}

.report-images-count-2 .report-image {
  width: 100%;
  height: 200rpx;
}

/* 三张图片 - 第一张占整行，后两张并排 */
.report-images-count-3 {
  grid-template-columns: repeat(2, 1fr);
}

.report-images-count-3 .report-image:first-child {
  grid-column: 1 / -1;
  width: 100%;
  height: 280rpx;
}

.report-images-count-3 .report-image:not(:first-child) {
  width: 100%;
  height: 200rpx;
}

/* 四张及以上图片 - 2x2网格 */
.report-images-count-4,
.report-images-count-5,
.report-images-count-6,
.report-images-count-7,
.report-images-count-8,
.report-images-count-9 {
  grid-template-columns: repeat(2, 1fr);
}

.report-images-count-4 .report-image,
.report-images-count-5 .report-image,
.report-images-count-6 .report-image,
.report-images-count-7 .report-image,
.report-images-count-8 .report-image,
.report-images-count-9 .report-image {
  width: 100%;
  height: 200rpx;
}

/* 图片通用样式 */
.report-image {
  border-radius: 12rpx;
  border: 2rpx solid rgba(255, 184, 77, 0.2);
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 77, 0.1);
  background: #f5f5f5;
  transition: all 0.3s ease;
}

.report-image:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 77, 0.15);
}

/* 状态徽章 - 移到右上角 */
.result-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.result-badge.result-normal {
  background: linear-gradient(135deg, rgba(82, 196, 26, 0.9) 0%, rgba(102, 221, 55, 0.8) 100%);
  color: #fff;
}

.result-badge.result-abnormal {
  background: linear-gradient(135deg, rgba(255, 77, 79, 0.9) 0%, rgba(255, 107, 107, 0.8) 100%);
  color: #fff;
}

.result-badge.result-borderline {
  background: linear-gradient(135deg, rgba(255, 184, 77, 0.9) 0%, rgba(255, 152, 0, 0.8) 100%);
  color: #fff;
}

.result-badge.result-pending {
  background: linear-gradient(135deg, rgba(24, 144, 255, 0.9) 0%, rgba(64, 169, 255, 0.8) 100%);
  color: #fff;
}

.result-badge.result-inconclusive {
  background: linear-gradient(135deg, rgba(153, 153, 153, 0.9) 0%, rgba(179, 179, 179, 0.8) 100%);
  color: #fff;
}

.result-detail {
  padding: 16rpx;
  background: rgba(255, 184, 77, 0.05);
  border-radius: 12rpx;
  border-left: 4rpx solid var(--primary-color);
}

.result-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  word-break: break-all;
}

/* 健康监测容器 */
.health-monitoring {
  position: relative;
  padding-top: 20rpx;
}

/* 筛选区域样式 */
.filter-row {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

/* 悬浮视图切换按钮 */
.floating-toggle {
  position: fixed;
  bottom: 165rpx;
  right: 15rpx;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.floating-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
  opacity: .7;
  border-radius: 50%;
  transition: all 0.3s ease;
  cursor: pointer;
}

.floating-btn:active {
  transform: scale(0.9);
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.6);
}

.floating-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 32rpx rgba(255, 152, 0, 0.5);
}

.floating-tooltip {
  background: rgba(0, 0, 0, 0.8);
  color: white;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  white-space: nowrap;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  transform: translateY(10rpx);
}

.floating-toggle:hover .floating-tooltip {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

/* 旧的视图模式切换样式已移除，使用新的紧凑型设计 */

/* 检测项目选择器样式 */
.test-type-selector {
  margin-top: 16rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  padding: 12rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(255, 184, 77, 0.15);
  backdrop-filter: blur(10rpx);
}

.test-type-scroll {
  width: 100%;
}

.test-type-list {
  display: flex;
  gap: 12rpx;
  padding: 0 8rpx;
}

.test-type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  background: rgba(255, 184, 77, 0.1);
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  cursor: pointer;
  min-width: 90rpx;
  flex-shrink: 0;
}

.test-type-item.active {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9800 100%);
  border-color: #FF9800;
  box-shadow: 0 4rpx 16rpx rgba(255, 184, 77, 0.4);
  transform: translateY(-2rpx);
}

.test-type-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  transition: all 0.3s ease;
}

.test-type-item.active .test-type-icon {
  background: rgba(255, 255, 255, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.test-type-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #FF9800;
  transition: color 0.3s ease;
  text-align: center;
  white-space: nowrap;
}

.test-type-item.active .test-type-name {
  color: white;
  font-weight: 600;
}

/* 简洁美观的表格设计 */
.health-table {
  margin: 0 24rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(255, 184, 77, 0.15);
  position: relative;
  transform: translateZ(0);
  z-index: 10;
  /* 确保表格在合适的层级 */
}

.scroll-hint {
  padding: 16rpx 0;
  text-align: center;
  background: rgba(255, 152, 0, 0.1);
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 152, 0, 0.2);
}

.scroll-hint-text {
  font-size: 24rpx;
  color: #FF9800;
  font-weight: 500;
}

.table-scroll {
  width: 100%;
  max-height: 700rpx;
  /* 限制高度，超出时显示y轴滚动条 */
  overflow-x: auto;
  overflow-y: auto;
  /* 使用原生CSS滚动，x轴和y轴都显示滚动条 */
  -webkit-overflow-scrolling: touch;
  position: relative;
  /* 为sticky定位提供正确的上下文 */
}

/* 自定义滚动条样式 - x轴和y轴都使用相同效果 */
.table-scroll::-webkit-scrollbar {
  width: 8rpx;
  height: 8rpx;
  background: rgba(0, 0, 0, 0.1);
}

.table-scroll::-webkit-scrollbar-thumb {
  background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
  border-radius: 4rpx;
}

.table-scroll::-webkit-scrollbar-track {
  background: rgba(255, 184, 77, 0.1);
  border-radius: 4rpx;
}

/* 滚动条交叉点样式 */
.table-scroll::-webkit-scrollbar-corner {
  background: rgba(255, 184, 77, 0.2);
}

/* 当不需要滚动时，表格填充整个宽度 */
.table-scroll.no-scroll .table-container {
  width: 100%;
  min-width: 100%;
}

.table-scroll.no-scroll .table-header,
.table-scroll.no-scroll .table-row {
  width: 100%;
  min-width: 100%;
}

/* 确保列数较少时表格也能撑满宽度 */
.table-container:not(.many-columns) {
  width: 100%;
  min-width: 100%;
}

.table-container:not(.many-columns) .table-header,
.table-container:not(.many-columns) .table-row {
  width: 100%;
  min-width: 100%;
}

.table-container:not(.many-columns) .table-cell {
  flex: 1;
  /* 平均分配宽度 */
  min-width: 80rpx;
}

/* 已删除自定义滚动指示器，使用原生滚动条 */

.table-container {
  display: flex;
  flex-direction: column;
  width: 100%;
  /* 默认撑满整个宽度 */
  min-width: 100%;
  /* 确保至少撑满容器宽度 */
  position: relative;
  white-space: nowrap;
  height: 100%;
  /* 确保容器高度正确 */
}



/* 当列数较多时，强制使用固定宽度触发滚动 */
.table-container.many-columns {
  min-width: 100%;
  /* 确保至少撑满容器宽度 */
  width: max-content;
  /* 根据内容自动调整宽度 */
}

.table-container.many-columns .table-cell {
  flex: 0 0 140rpx;
  /* 固定列宽，防止压缩 */
}

.table-container.many-columns .date-cell {
  flex: 0 0 120rpx;
  /* 日期列固定宽度 */
}

.table-header {
  display: flex;
  background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
  color: white;
  font-weight: 700;
  font-size: 28rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  width: 100%;
  min-width: 100%;
  /* 确保表头至少撑满容器宽度 */
  white-space: nowrap;
  /* 防止表头内容换行 */
  min-height: 90rpx;
  /* 确保表头有足够高度 */
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.3);
}

.table-body {
  background: #fff;
  position: relative;
  display: block;
  /* 确保行垂直排列 */
}

.table-row {
  display: flex;
  border-bottom: 2rpx solid rgba(255, 184, 77, 0.08);
  width: 100%;
  min-width: 100%;
  /* 确保行至少撑满容器宽度 */
  white-space: nowrap;
  /* 防止行内容换行，确保触发横向滚动 */
  position: relative;
  transform: translateZ(0);
  transition: all 0.2s ease;
}

.table-row:hover {
  background: rgba(255, 184, 77, 0.08);
}

.table-row:nth-child(even) {
  background: rgba(255, 248, 240, 0.3);
}

.table-row:nth-child(even):hover {
  background: rgba(255, 184, 77, 0.12);
}

.table-row:last-child {
  border-bottom: none;
}

.table-cell {
  flex: 1;
  /* 默认自适应列宽，平均分配空间 */
  min-width: 100rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  /* 内容居中 */
  padding: 24rpx 12rpx;
  font-size: 26rpx;
  text-align: center;
  min-height: 70rpx;
  border-right: 1rpx solid rgba(255, 184, 77, 0.15);
  word-wrap: break-word;
  overflow-wrap: break-word;
}

.table-cell:last-child {
  border-right: none;
}

.table-header .table-cell {
  background: transparent;
  color: white;
  font-weight: 700;
  padding: 20rpx 12rpx;
  border-right: 2rpx solid rgba(255, 255, 255, 0.4);
  min-height: 90rpx;
  /* 确保表头单元格有足够高度 */
  display: flex;
  align-items: center;
  justify-content: center;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

/* 日期列固定在左侧不滚动 */
.date-cell {
  flex: 0 0 120rpx;
  min-width: 120rpx;
  font-weight: 600;
  color: #333;
  font-size: 26rpx;
  position: sticky;
  left: 0;
  z-index: 10;
  background: #fff;
  box-shadow: 4rpx 0 8rpx rgba(0, 0, 0, 0.05);
}

.table-header .date-cell {
  color: white;
  font-size: 28rpx;
  font-weight: 700;
  border-right: 2rpx solid rgba(255, 255, 255, 0.4);
  background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
  z-index: 101;
  box-shadow: 4rpx 0 12rpx rgba(255, 152, 0, 0.3);
}

/* 默认情况下，数据列使用自适应宽度 */
.data-cell {
  /* flex: 1 继承自 .table-cell */
}

/* 多列情况下，数据列使用固定宽度 */
.table-container.many-columns .data-cell {
  flex: 0 0 140rpx;
  min-width: 140rpx;
}

.cell-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  /* 内容居中 */
  width: 100%;
  gap: 6rpx;
}

.cell-label {
  font-size: 26rpx;
  font-weight: 700;
  color: white;
  text-align: center;
  width: 100%;
  /* 撑满整个列宽 */
  line-height: 1.3;
}

.cell-unit {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
  width: 100%;
  /* 撑满整个列宽 */
  font-weight: 500;
  line-height: 1.2;
}

.cell-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  word-break: break-all;
  line-height: 1.4;
  width: 100%;
  /* 撑满整个列宽 */
  display: block;
  /* 确保作为块级元素占满宽度 */
}

.abnormal-row {
  background: rgba(255, 107, 53, 0.05);
}

.abnormal-row .cell-value {
  color: #FF6B35;
  font-weight: 600;
}

.cell-title {
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.cell-subcols {
  display: flex;
  width: 100%;
  gap: 2rpx;
}

.subcol {
  flex: 1;
  font-size: 20rpx;
  padding: 4rpx 2rpx;
  text-align: center;
  border-radius: 4rpx;
}

.table-header .subcol {
  background: rgba(255, 255, 255, 0.2);
  color: white;
  font-weight: 500;
}

.table-row .subcol {
  background: rgba(255, 184, 77, 0.05);
  color: #666;
}

/* 表格数据值样式 */
.table-row .table-cell {
  color: #333;
  font-weight: 600;
}

/* 日期列数据行样式优化 */
.table-row .date-cell {
  font-weight: 700;
  color: #FF8F00;
  background: rgba(255, 248, 240, 0.5);
}

.table-row:nth-child(even) .date-cell {
  background: rgba(255, 248, 240, 0.7);
}

.table-row .single-cell {
  font-size: 20rpx;
  color: #666;
}


.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.6);
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  min-width: 200rpx;
}

.legend-label {
  font-size: 22rpx;
  color: #666;
  font-weight: 500;
}

.legend-range {
  font-size: 22rpx;
  color: #FF9800;
  font-weight: 600;
}

/* ==================== 费用记录样式 ==================== */

/* 费用统计卡片 */
.expense-stats-card {
  margin: 24rpx 24rpx 16rpx;
  background: linear-gradient(135deg, #FFF8F0 0%, #FFE8D6 50%, #FFF5EB 100%);
  border-radius: 28rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(255, 152, 0, 0.18),
    0 4rpx 12rpx rgba(255, 107, 0, 0.12),
    inset 0 -2rpx 0 rgba(255, 255, 255, 0.5);
  position: relative;
  overflow: hidden;
  border: 2rpx solid rgba(255, 184, 77, 0.3);
  animation: card-float 3s ease-in-out infinite;
}

@keyframes card-float {

  0%,
  100% {
    transform: translateY(0);
  }

  50% {
    transform: translateY(-4rpx);
  }
}

.expense-stats-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.25) 0%, rgba(255, 255, 255, 0.1) 40%, transparent 70%);
  border-radius: 50%;
  animation: orb-pulse 4s ease-in-out infinite;
}

@keyframes orb-pulse {

  0%,
  100% {
    transform: scale(1);
    opacity: 0.8;
  }

  50% {
    transform: scale(1.1);
    opacity: 1;
  }
}

.expense-stats-card::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255, 184, 77, 0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.expense-stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
  position: relative;
  z-index: 2;
}

.stats-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.stats-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #FF8F00;
  letter-spacing: 1rpx;
}

.stats-period {
  font-size: 24rpx;
  color: #FF9800;
  background: rgba(255, 255, 255, 0.6);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.expense-stats-main {
  text-align: center;
  margin-bottom: 32rpx;
  position: relative;
  z-index: 2;
}

.total-expense-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 12rpx;
}

.expense-currency {
  font-size: 44rpx;
  color: #FF6B00;
  font-weight: 700;
  margin-right: 8rpx;
}

.expense-amount {
  font-size: 80rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #FF6B00 0%, #FF8F00 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
  text-shadow: 0 4rpx 16rpx rgba(255, 107, 0, 0.3);
  animation: number-shine 2s ease-in-out infinite;
}

@keyframes number-shine {

  0%,
  100% {
    opacity: 1;
  }

  50% {
    opacity: 0.9;
  }
}

.expense-label {
  font-size: 26rpx;
  color: #FF8F00;
  font-weight: 500;
  letter-spacing: 2rpx;
  text-align: center;
  width: 100%;
}

.expense-breakdown-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  position: relative;
  z-index: 2;
}

.breakdown-grid-item {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.7) 0%, rgba(255, 255, 255, 0.9) 100%);
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  backdrop-filter: blur(12rpx);
  box-shadow: 0 4rpx 16rpx rgba(255, 152, 0, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  transition: all 0.3s ease;
}

.breakdown-grid-item:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.15);
}

.breakdown-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(255, 255, 255, 1) 0%, rgba(255, 255, 255, 0.9) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.1),
    inset 0 -2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.breakdown-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  text-align: center;
  width: 100%;
}

.breakdown-label {
  font-size: 22rpx;
  color: #666;
  font-weight: 500;
  text-align: center;
  width: 100%;
}

.breakdown-amount {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  letter-spacing: 0.5rpx;
  text-align: center;
  width: 100%;
}

/* 费用记录每日汇总 */
.expense-day-summary {
  padding: 28rpx;
}

.expense-day-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid rgba(255, 152, 0, 0.15);
  position: relative;
}

.expense-day-header::after {
