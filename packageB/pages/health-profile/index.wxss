/* pages/health-profile/index.wxss
   现代轻奢健康档案页面 - 温暖米金色主题 */

/* ==================== 骨架屏加载动画 ==================== */
.skeleton-wrapper {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  padding: 24rpx;
  background: linear-gradient(180deg, #FDFCFA 0%, #FAF8F4 100%);
  animation: skeleton-fade-in 0.3s ease-out;
  overflow-y: auto;
}

@keyframes skeleton-fade-in {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

.content-hidden {
  opacity: 0;
  pointer-events: none;
}

.content-visible {
  opacity: 1;
  animation: content-fade-in 0.4s ease-out;
}

@keyframes content-fade-in {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.skeleton-shimmer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.6) 50%,
      transparent 100%);
  animation: skeleton-shimmer 1.5s infinite;
}

@keyframes skeleton-shimmer {
  0% {
    transform: translateX(-100%);
  }

  100% {
    transform: translateX(100%);
  }
}

.skeleton-text {
  background: linear-gradient(90deg, #E8E4DD 0%, #F0EDE8 50%, #E8E4DD 100%);
  border-radius: 8rpx;
  height: 28rpx;
  margin: 8rpx 0;
}

.skeleton-text-short {
  width: 40%;
}

.skeleton-text-medium {
  width: 60%;
}

.skeleton-text-long {
  width: 85%;
}

.skeleton-text-date {
  width: 100rpx;
}

.skeleton-circle-small {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8E4DD 0%, #F0EDE8 100%);
}

/* Tab骨架 */
.skeleton-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 12rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
}

.skeleton-tab {
  flex: 1;
  height: 72rpx;
  background: linear-gradient(135deg, #E8E4DD 0%, #F0EDE8 100%);
  border-radius: 16rpx;
}

/* 筛选器骨架 */
.skeleton-filters {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.skeleton-filter-item {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
}

/* 统计卡片骨架 */
.skeleton-stats {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
}

.skeleton-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

/* 记录列表骨架 */
.skeleton-records {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.skeleton-record-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(212, 165, 116, 0.08);
}

.skeleton-record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.skeleton-badge {
  width: 60rpx;
  height: 32rpx;
  background: linear-gradient(135deg, #E8E4DD 0%, #F0EDE8 100%);
  border-radius: 16rpx;
}

.skeleton-record-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* 🔥 表格视图骨架 */
.skeleton-table {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(212, 165, 116, 0.1);
}

.skeleton-table-container {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.skeleton-table-header {
  display: flex;
  gap: 0;
  border-bottom: 2rpx solid #F0EDE8;
  padding-bottom: 16rpx;
  margin-bottom: 12rpx;
}

.skeleton-table-header-cell {
  padding: 12rpx 8rpx;
}

.skeleton-table-row {
  display: flex;
  gap: 0;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F3EF;
  position: relative;
  overflow: hidden;
}

.skeleton-table-row:last-child {
  border-bottom: none;
}

.skeleton-table-cell {
  flex: 1;
  min-width: 80rpx;
  padding: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.skeleton-table-cell:first-child {
  flex: 1.2;
  min-width: 100rpx;
}

.skeleton-table-cell .skeleton-text {
  width: 80%;
  min-width: 40rpx;
}

.skeleton-table-header-cell .skeleton-text {
  width: 70%;
  height: 24rpx;
  background: linear-gradient(135deg, #D4A574 20%, #E8C89A 100%);
}

/* 页面根容器 */
page {
  background-color: #FDFCFA;
  /* 温暖白色背景 */
}

/* 基础页面容器 */
.page-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: linear-gradient(180deg,
      #FDFCFA 0%,
      #FAF8F4 100%);
  /* 渐变温暖白色背景 */
}

/* 自定义导航栏 - 温暖米金色主题 */
page {
  --td-navbar-bg-color: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  --td-navbar-title-color: white;
  --td-navbar-title-font-size: 36rpx;
  --td-navbar-title-font-weight: 600;
}

.t-navbar {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%) !important;
  border-bottom: none !important;
  box-shadow: 0 8rpx 32rpx rgba(255, 184, 77, 0.3) !important;
  position: relative;
  z-index: 10;
}

.t-navbar::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.9) 20%,
      rgba(255, 255, 255, 0.7) 50%,
      rgba(255, 255, 255, 0.9) 80%,
      transparent 100%);
}

.t-navbar__title,
.t-navbar__center,
.t-navbar__center text {
  color: white !important;
  font-size: 36rpx !important;
  font-weight: 600 !important;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3) !important;
}

.t-navbar .t-icon,
.t-navbar__left .t-icon,
.t-navbar__right .t-icon {
  color: white !important;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.3));
}

/* 内容包裹器 */
.content-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 背景装饰 */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
}

.bg-gradient {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 600rpx;
  background: linear-gradient(180deg, rgba(255, 143, 0, 0.03) 0%, transparent 100%);
}

.bg-orbs {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
}

.orb {
  position: absolute;
  border-radius: 50%;
  opacity: 0.4;
  filter: blur(80rpx);
  animation: orb-float 20s infinite ease-in-out;
}

.orb-1 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255, 143, 0, 0.15) 0%, transparent 70%);
  top: -100rpx;
  left: -100rpx;
  animation-delay: 0s;
}

.orb-2 {
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255, 183, 77, 0.12) 0%, transparent 70%);
  top: 200rpx;
  right: -50rpx;
  animation-delay: -5s;
}

.orb-3 {
  width: 350rpx;
  height: 350rpx;
  background: radial-gradient(circle, rgba(255, 152, 0, 0.1) 0%, transparent 70%);
  bottom: 100rpx;
  left: 50%;
  transform: translateX(-50%);
  animation-delay: -10s;
}

@keyframes orb-float {

  0%,
  100% {
    transform: translate(0, 0) scale(1);
  }

  33% {
    transform: translate(30rpx, -30rpx) scale(1.1);
  }

  66% {
    transform: translate(-20rpx, 20rpx) scale(0.9);
  }
}

/* 内容容器 */
.content-container {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 230rpx;
  position: relative;
  z-index: 1;
  background: #FAF8F4;
  /* 温暖白色 */
}

/* Tab切换样式 - 现代轻奢设计 */
.tab-container {
  display: flex;
  background: #FFFFFF;
  /* 纯白卡片背景 */
  margin: 24rpx 24rpx 0 24rpx;
  border-radius: 20rpx;
  /* 现代圆角 */
  box-shadow:
    0 4rpx 20rpx rgba(255, 184, 77, 0.15),
    0 1rpx 3rpx rgba(0, 0, 0, 0.05);
  /* 现代阴影 */
  border: 1rpx solid rgba(255, 184, 77, 0.2);
  position: relative;
  overflow: hidden;
}

.tab-background {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.05) 0%,
      rgba(193, 149, 85, 0.08) 50%,
      rgba(255, 184, 77, 0.05) 100%);
  border-radius: 20rpx;
}

.tab-indicator {
  position: absolute;
  width: calc(25% - 8rpx);
  height: calc(100% - 16rpx);
  top: 8rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 16rpx;
  box-shadow:
    0 4rpx 16rpx rgba(255, 184, 77, 0.4),
    0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 1;
}

.tab-indicator-health {
  left: 4rpx;
}

.tab-indicator-medication {
  left: calc(25% + 4rpx);
}

.tab-indicator-checkReport {
  left: calc(50% + 4rpx);
}

.tab-indicator-expense {
  left: calc(75% + 4rpx);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 16rpx 8rpx;
  border-radius: 16rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  z-index: 2;
  text-align: center;
}

.tab-icon-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  margin: 0 auto;
}

.tab-pulse {
  position: absolute;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 184, 77, 0.3);
  opacity: 0;
  transform: scale(0.8);
  transition: all 0.3s ease;
  left: 50%;
  top: 50%;
  margin-left: -40rpx;
  margin-top: -40rpx;
}

.tab-pulse.active {
  opacity: 0.3;
}

.tab-text {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--primary-color);
  transition: all 0.3s ease;
  position: relative;
  text-align: center;
  width: 100%;
  display: block;
  line-height: 1.2;
}

.tab-active .tab-text {
  color: white;
  font-weight: 700;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.tab-item:active {
  transform: scale(0.98);
}

/* 确保TDesign图标居中 */
.tab-icon-wrapper .t-icon {
  display: block !important;
  margin: 0 auto !important;
}

/* 筛选区域 */
.filter-section {
  display: flex;
  gap: 20rpx;
  margin: 32rpx 24rpx 24rpx 24rpx;
}

.filter-item {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  /* 纯白背景 */
  border-radius: 16rpx;
  /* 现代圆角 */
  box-shadow:
    0 4rpx 16rpx rgba(255, 184, 77, 0.12),
    0 2rpx 4rpx rgba(0, 0, 0, 0.04);
  /* 精致阴影 */
  border: 1rpx solid rgba(255, 184, 77, 0.15);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.filter-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 184, 77, 0.1) 50%,
      transparent 100%);
  transition: left 0.5s ease;
}

.filter-item:active {
  background: rgba(255, 184, 77, 0.08);
  border-color: var(--primary-color);
  transform: scale(0.98);
  box-shadow:
    0 2rpx 8rpx rgba(255, 184, 77, 0.15),
    0 1rpx 3rpx rgba(0, 0, 0, 0.1);
}

.filter-item:active::before {
  left: 100%;
}

.filter-icon-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.filter-icon-glow {
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 184, 77, 0.3) 0%, transparent 70%);
  opacity: 0.6;
}

.filter-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.filter-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.3s ease;
}

.filter-item:active .filter-arrow {
  transform: rotate(180deg);
}

/* 紧凑统计栏设计 */
.compact-stats-bar {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(255, 184, 77, 0.08) 0%, rgba(255, 184, 77, 0.12) 100%);
  border-radius: 16rpx;
  margin: 24rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(255, 184, 77, 0.15);
  box-shadow: 0 4rpx 16rpx rgba(255, 184, 77, 0.08);
}

.compact-stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  text-align: center;
}

.compact-number {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--primary-color);
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
  text-align: center;
  width: 100%;
}

.compact-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 500;
  text-align: center;
  width: 100%;
}

.stat-divider {
  width: 2rpx;
  height: 40rpx;
  background: linear-gradient(180deg,
      transparent 0%,
      rgba(255, 184, 77, 0.3) 20%,
      rgba(255, 184, 77, 0.5) 50%,
      rgba(255, 184, 77, 0.3) 80%,
      transparent 100%);
  margin: 0 16rpx;
}

/* 旧的卡片样式已删除，统一使用紧凑统计栏 */

/* 用药概览使用统一的紧凑统计栏 */

.section-icon-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.section-icon-pulse {
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255, 184, 77, 0.3);
  opacity: 0.3;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  text-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.1);
}

.section-decoration {
  flex: 1;
  height: 4rpx;
  background: linear-gradient(90deg,
      rgba(255, 184, 77, 0.8) 0%,
      rgba(193, 149, 85, 0.4) 50%,
      transparent 100%);
  border-radius: 2rpx;
  margin-left: 20rpx;
}

/* 健康记录时间轴（朋友圈风格） */
.health-timeline {
  position: relative;
  padding: 40rpx 0 40rpx 88rpx;
  background: linear-gradient(to bottom,
      rgba(255, 248, 240, 0.3) 0%,
      rgba(255, 252, 248, 0.1) 50%,
      transparent 100%);
}

/* 时间轴主线 - 高级渐变效果 */
.health-timeline::before {
  content: '';
  position: absolute;
  left: 40rpx;
  top: 20rpx;
  bottom: 20rpx;
  width: 6rpx;
  background: linear-gradient(to bottom,
      transparent 0%,
      rgba(255, 184, 77, 0.6) 10%,
      rgba(255, 184, 77, 0.8) 30%,
      rgba(255, 184, 77, 0.4) 50%,
      rgba(255, 184, 77, 0.8) 70%,
      rgba(255, 184, 77, 0.6) 90%,
      transparent 100%);
  border-radius: 3rpx;
  filter: blur(0.5rpx);
}

/* 时间轴主线内核 */
.health-timeline::after {
  content: '';
  position: absolute;
  left: 42rpx;
  top: 20rpx;
  bottom: 20rpx;
  width: 2rpx;
  background: linear-gradient(to bottom,
      rgba(255, 184, 77, 0.8) 0%,
      rgba(255, 204, 128, 0.6) 50%,
      rgba(255, 184, 77, 0.8) 100%);
  border-radius: 1rpx;
}

/* 时间轴项目 - 优化间距 */
.timeline-item {
  position: relative;
  margin-bottom: 40rpx;
  opacity: 0;
  transform: translateX(20rpx);
  animation: slideInTimeline 0.6s ease forwards;
  width: 92%;
}

.timeline-item:nth-child(1) {
  animation-delay: 0.1s;
}

.timeline-item:nth-child(2) {
  animation-delay: 0.2s;
}

.timeline-item:nth-child(3) {
  animation-delay: 0.3s;
}

.timeline-item:nth-child(4) {
  animation-delay: 0.4s;
}

.timeline-item:nth-child(5) {
  animation-delay: 0.5s;
}

.timeline-item:last-child {
  margin-bottom: 0;
}

@keyframes slideInTimeline {
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

/* 时间轴点 - 高级立体效果 */
.timeline-dot {
  position: absolute;
  left: -56rpx;
  top: 12rpx;
  width: 20rpx;
  height: 20rpx;
  background: radial-gradient(circle at 30% 30%,
      rgba(255, 255, 255, 1) 0%,
      rgba(255, 248, 240, 0.9) 30%,
      var(--primary-color) 70%,
      rgba(255, 152, 0, 0.8) 100%);
  border: 3rpx solid #FFFFFF;
  border-radius: 50%;
  box-shadow:
    0 0 0 3rpx rgba(255, 184, 77, 0.2),
    0 0 0 6rpx rgba(255, 184, 77, 0.1),
    0 4rpx 12rpx rgba(255, 184, 77, 0.4),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3);
  z-index: 2;
  animation: pulseGlow 3s ease-in-out infinite;
}

@keyframes pulseGlow {

  0%,
  100% {
    box-shadow:
      0 0 0 3rpx rgba(255, 184, 77, 0.2),
      0 0 0 6rpx rgba(255, 184, 77, 0.1),
      0 4rpx 12rpx rgba(255, 184, 77, 0.4),
      inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3);
  }

  50% {
    box-shadow:
      0 0 0 4rpx rgba(255, 184, 77, 0.3),
      0 0 0 8rpx rgba(255, 184, 77, 0.15),
      0 6rpx 16rpx rgba(255, 184, 77, 0.5),
      inset 0 2rpx 6rpx rgba(255, 255, 255, 0.4);
  }
}

/* 时间轴内容区域 - 高级玻璃拟态效果 */
.timeline-content {
  background: linear-gradient(135deg,
      rgba(255, 255, 255, 0.95) 0%,
      rgba(255, 248, 240, 0.9) 100%);
  backdrop-filter: blur(20rpx) saturate(180%);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow:
    0 8rpx 32rpx rgba(255, 184, 77, 0.08),
    0 4rpx 16rpx rgba(0, 0, 0, 0.04),
    0 2rpx 8rpx rgba(0, 0, 0, 0.02),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
  border: 1rpx solid rgba(255, 184, 77, 0.1);
  position: relative;
  transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
}

/* 卡片顶部装饰线 */
.timeline-content::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 184, 77, 0.6) 20%,
      rgba(255, 184, 77, 0.8) 50%,
      rgba(255, 184, 77, 0.6) 80%,
      transparent 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.timeline-content:hover::before {
  opacity: 1;
}

.timeline-content:active {
  transform: translateY(-4rpx) scale(0.995);
  box-shadow:
    0 12rpx 40rpx rgba(255, 184, 77, 0.12),
    0 8rpx 24rpx rgba(0, 0, 0, 0.08),
    0 4rpx 12rpx rgba(0, 0, 0, 0.04),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.4);
  border-color: rgba(255, 184, 77, 0.15);
}

/* 时间轴头部 - 紧凑优化 */
.timeline-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx 16rpx;
  background: linear-gradient(135deg,
      rgba(255, 248, 240, 0.95) 0%,
      rgba(255, 252, 248, 0.7) 50%,
      rgba(255, 255, 255, 0.8) 100%);
  border-bottom: 1rpx solid rgba(255, 184, 77, 0.08);
  position: relative;
}

/* 头部装饰元素 */
.timeline-header::before {
  content: '';
  position: absolute;
  top: 0;
  left: 24rpx;
  right: 24rpx;
  height: 1rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 184, 77, 0.3) 50%,
      transparent 100%);
}

/* 时间轴左侧布局 */
.timeline-left {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 2rpx;
}

/* 完整日期显示 */
.timeline-full-date {
  font-size: 24rpx;
  color: rgba(255, 184, 77, 0.8);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.timeline-date {
  font-size: 36rpx;
  color: rgba(255, 184, 77, 0.8);
  line-height: 1.2;
  letter-spacing: 0.5rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.timeline-weekday {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 600;
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.9) 0%,
      rgba(255, 204, 128, 0.8) 100%);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  box-shadow:
    0 2rpx 8rpx rgba(255, 184, 77, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

/* 健康记录列表 - 紧凑布局 */
.health-records-list {
  padding: 4rpx 0;
}

/* 健康记录项目 - 紧凑优化 */
.health-record-item {
  display: flex;
  align-items: center;
  padding: 18rpx 24rpx;
  position: relative;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.08);
  cursor: pointer;
}

.health-record-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 0;
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.1) 0%,
      rgba(255, 204, 128, 0.05) 100%);
  transition: width 0.3s ease;
}

.health-record-item:last-child {
  border-bottom: none;
}

.health-record-item:hover::before {
  width: 8rpx;
}

.health-record-item:active {
  background: rgba(0, 0, 0, 0.02);
  transform: scale(0.98);
}

.health-record-item:active::before {
  width: 0;
}

/* 记录图标 - 紧凑优化 */
.record-icon {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg,
      rgba(255, 255, 255, 1) 0%,
      rgba(255, 248, 240, 0.9) 100%);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 32rpx;
  box-shadow:
    0 4rpx 16rpx rgba(0, 0, 0, 0.08),
    0 2rpx 8rpx rgba(0, 0, 0, 0.04),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.4),
    inset 0 -1rpx 0 rgba(0, 0, 0, 0.02);
  border: 1rpx solid rgba(255, 184, 77, 0.1);
  position: relative;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  overflow: hidden;
  flex-shrink: 0;
}

.record-icon::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(45deg,
      transparent 30%,
      rgba(255, 255, 255, 0.1) 50%,
      transparent 70%);
  transform: rotate(45deg);
  transition: transform 0.6s ease;
}

.health-record-item:active .record-icon {
  transform: scale(0.95);
  opacity: 0.8;
}

/* 记录内容 - 紧凑优化 */
.record-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
  padding-right: 12rpx;
}

.record-title {
  font-size: 26rpx;
  font-weight: 700;
  background: linear-gradient(135deg,
      #2C3E50 0%,
      #34495E 70%,
      #2C3E50 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  line-height: 1.25;
  letter-spacing: 0.3rpx;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 0;
}

.record-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx 12rpx;
  align-items: center;
  line-height: 1.3;
}

/* 紧凑网格布局 */
.compact-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140rpx, 1fr));
  gap: 12rpx 16rpx;
  align-items: start;
  width: 100%;
}

/* 数据项样式 */
.summary-data-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.data-label {
  text-align: center;
  font-size: 20rpx;
  color: #999;
  font-weight: 500;
  letter-spacing: 0.3rpx;
}

.data-value {
  font-size: 24rpx;
  color: #2C3E50;
  font-weight: 700;
  line-height: 1.3;
  letter-spacing: 0.2rpx;
}

.summary-item {
  font-size: 22rpx;
  color: #5D6D7E;
  font-weight: 500;
  position: relative;
  transition: color 0.2s ease;
}

.summary-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: -12rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 4rpx;
  height: 4rpx;
  background: rgba(255, 184, 77, 0.4);
  border-radius: 50%;
}

.health-record-item:active .summary-item {
  color: #34495E;
}

/* 状态徽章 - 高级渐变效果 */
.status-badge {
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 700;
  position: relative;
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
  transform: translateZ(0);
}

.status-badge::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.3) 50%,
      transparent 100%);
  transition: left 0.5s ease;
}

.status-badge.negative,
.status-badge.normal,
.status-badge.status-normal {
  background: linear-gradient(135deg,
      rgba(82, 196, 26, 0.9) 0%,
      rgba(102, 221, 55, 0.8) 100%);
  color: #FFFFFF;
  box-shadow:
    0 2rpx 8rpx rgba(82, 196, 26, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
}

.status-badge.positive,
.status-badge.abnormal,
.status-badge.status-abnormal {
  background: linear-gradient(135deg,
      rgba(255, 77, 79, 0.9) 0%,
      rgba(255, 107, 107, 0.8) 100%);
  color: #FFFFFF;
  box-shadow:
    0 2rpx 8rpx rgba(255, 77, 79, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
}

.status-badge.status-borderline {
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.9) 0%,
      rgba(255, 152, 0, 0.8) 100%);
  color: #FFFFFF;
  box-shadow:
    0 2rpx 8rpx rgba(255, 152, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
}

.status-badge.status-pending {
  background: linear-gradient(135deg,
      rgba(24, 144, 255, 0.9) 0%,
      rgba(64, 169, 255, 0.8) 100%);
  color: #FFFFFF;
  box-shadow:
    0 2rpx 8rpx rgba(24, 144, 255, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
}

.status-badge.status-inconclusive,
.status-badge.status-unknown {
  background: linear-gradient(135deg,
      rgba(153, 153, 153, 0.9) 0%,
      rgba(179, 179, 179, 0.8) 100%);
  color: #FFFFFF;
  box-shadow:
    0 2rpx 8rpx rgba(153, 153, 153, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
}

.health-record-item:active .status-badge::before {
  left: 100%;
}

/* 箭头 - 高级动画效果 */
.record-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
  margin-left: 16rpx;
  background: linear-gradient(135deg,
      rgba(255, 255, 255, 0.8) 0%,
      rgba(255, 248, 240, 0.6) 100%);
  border-radius: 50%;
  opacity: 0.6;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  box-shadow:
    0 2rpx 8rpx rgba(0, 0, 0, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.4);
  border: 1rpx solid rgba(255, 184, 77, 0.1);
  position: relative;
  overflow: hidden;
}

.record-arrow::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 184, 77, 0.2) 50%,
      transparent 100%);
  transition: left 0.4s ease;
}

.health-record-item:active .record-arrow {
  opacity: 0.8;
  transform: scale(0.9);
}


/* 微交互动画 */
@keyframes breathe {

  0%,
  100% {
    opacity: 0.6;
  }

  50% {
    opacity: 1;
  }
}

@keyframes shimmerEffect {
  0% {
    transform: translateX(-100%);
  }

  100% {
    transform: translateX(100%);
  }
}

.timeline-content::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.4) 50%,
      transparent 100%);
  transform: skewX(-25deg);
  transition: left 0.6s ease;
  opacity: 0;
}

.timeline-content:active::after {
  left: 100%;
  opacity: 1;
}

