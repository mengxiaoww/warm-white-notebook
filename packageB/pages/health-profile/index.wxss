    0 4rpx 16rpx rgba(255, 184, 77, 0.15),
    0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.bottom-option-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.bottom-option-indicator {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  opacity: 0.6;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 77, 0.3);
}

.bottom-filter-option.selected .bottom-option-indicator {
  opacity: 1;
  transform: scale(1.2);
  box-shadow: 0 6rpx 16rpx rgba(255, 184, 77, 0.4);
}

.bottom-option-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  transition: all 0.3s ease;
}

.bottom-filter-option.selected .bottom-option-text {
  color: var(--primary-color);
  font-weight: 700;
}

.bottom-option-check {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 184, 77, 0.1);
  border: 2rpx solid rgba(255, 184, 77, 0.2);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.bottom-option-check.checked {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-color: var(--primary-color);
  box-shadow:
    0 4rpx 16rpx rgba(255, 184, 77, 0.3),
    0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transform: scale(1.1);
}

/* 各种状态详情样式 - 使用新的颜色主题 */
.ebv-results,
.cmv-results,
.urine-summary,
.stool-detail {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.ebv-item,
.cmv-item,
.summary-item,
.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.06) 0%,
      rgba(193, 149, 85, 0.04) 100%);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 184, 77, 0.15);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.ebv-item::before,
.cmv-item::before,
.summary-item::before,
.detail-row::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 6rpx;
  height: 100%;
  background: linear-gradient(180deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.ebv-item:hover::before,
.cmv-item:hover::before,
.summary-item:hover::before,
.detail-row:hover::before {
  opacity: 1;
}

.ebv-name,
.cmv-name,
.summary-label,
.detail-label {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.ebv-value,
.cmv-value,
.summary-value,
.detail-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 700;
}

.summary-value {
  color: var(--primary-color);
}

.ebv-value.abnormal,
.cmv-value.abnormal,
.detail-value.abnormal {
  color: #F44336;
  font-weight: 800;
}

.ebv-value.normal,
.cmv-value.normal,
.detail-value.normal {
  color: #4CAF50;
  font-weight: 700;
}

/* 备注信息样式 */
.notes-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  padding: 32rpx;
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.04) 0%,
      rgba(193, 149, 85, 0.02) 100%);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 184, 77, 0.1);
  margin-top: 8rpx;
}

/* 用药状态样式 */
.status-completed,
.status-partial,
.status-missed,
.status-ongoing,
.status-planned {
  padding: 2rpx 8rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 500;
  border: 1rpx solid;
}

.status-completed {
  color: #999;
  background: rgba(82, 196, 26, 0.1);
  border-color: rgba(82, 196, 26, 0.2);
}

.status-partial,
.status-ongoing {
  color: #999;
  background: rgba(255, 184, 77, 0.1);
  border-color: rgba(255, 184, 77, 0.2);
}

.status-missed {
  color: #999;
  background: rgba(255, 71, 87, 0.1);
  border-color: rgba(255, 71, 87, 0.2);
}

.status-planned {
  color: #722ed1;
  background: rgba(114, 46, 209, 0.1);
  border-color: rgba(114, 46, 209, 0.2);
}

/* 用药状态信息容器 */
.medication-status-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  align-items: flex-end;
}

.status-badge {
  display: inline-block;
}

/* 日期记录相关样式 */
.daily-medication-records {
  margin-top: 20rpx;
}

.daily-records-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0 20rpx;
}

.daily-record-item {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow:
    0 4rpx 16rpx rgba(255, 184, 77, 0.08),
    0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(255, 184, 77, 0.1);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
}

.daily-record-item:active {
  transform: scale(0.98);
  box-shadow:
    0 2rpx 8rpx rgba(255, 184, 77, 0.1),
    0 1rpx 4rpx rgba(0, 0, 0, 0.05);
}

.daily-record-wrapper {
  padding: 32rpx;
  position: relative;
}

.daily-record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid rgba(255, 184, 77, 0.1);
}

.date-display {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.date-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.date-indicator {
  padding: 8rpx 16rpx;
  background: rgba(255, 184, 77, 0.1);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 184, 77, 0.3);
  font-size: 24rpx;
  color: #666;
  font-weight: 600;
}

.record-summary {
  display: flex;
  align-items: center;
  border-radius: 16rpx;
}

.summary-text {
  font-size: 26rpx;
  color: #666;
  font-weight: 600;
}

.daily-medicines-preview {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.medicine-preview-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.08) 0%,
      rgba(255, 255, 255, 0.8) 100%);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 184, 77, 0.15);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.medicine-preview-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: linear-gradient(180deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 0 2rpx 2rpx 0;
}

.medicine-preview-item:active {
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.1) 0%,
      rgba(255, 255, 255, 0.9) 100%);
  transform: translateX(4rpx);
}

.medicine-info {
  display: flex;
  gap: 16rpx;
  flex: 1;
}

.medicine-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.3;
}

.medicine-dosage {
  font-size: 26rpx;
  color: #999;
  font-weight: 500;
  background: rgba(255, 184, 77, 0.1);
  padding: 2rpx 8rpx;
  border-radius: 10rpx;
  align-self: flex-start;
  border: 1rpx solid rgba(255, 184, 77, 0.2);
}

.medicine-times {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.times-text {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
  text-align: right;
  max-width: 200rpx;
  line-height: 1.4;
}

.completion-indicator {
  padding: 6rpx 12rpx;
  background: linear-gradient(135deg,
      rgba(255, 193, 7, 0.2) 0%,
      rgba(255, 184, 77, 0.15) 100%);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 193, 7, 0.3);
}

.completion-text {
  font-size: 22rpx;
  color: #666;
  font-weight: 700;
}

/* 空状态样式适配 */
.daily-medication-records .empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.03) 0%,
      rgba(193, 149, 85, 0.08) 50%,
      rgba(255, 184, 77, 0.03) 100%);
  position: relative;
  overflow: hidden;
  margin: 20rpx;
  border-radius: 16rpx;
}

.daily-medication-records .empty-text {
  display: block;
  font-size: 32rpx;
  color: var(--primary-color);
  margin: 32rpx 0 16rpx;
  font-weight: 700;
  text-shadow: 0 1rpx 3rpx rgba(255, 184, 77, 0.2);
}

.daily-medication-records .empty-hint {
  display: block;
  font-size: 26rpx;
  color: var(--primary-dark);
  font-weight: 500;
}

/* 响应式优化 */
@media (max-width: 750rpx) {
  .stats-cards {
    flex-direction: column;
    gap: 16rpx;
  }

  .stats-card {
    flex-direction: row;
    padding: 24rpx;
  }

  .stats-icon {
    width: 64rpx;
    height: 64rpx;
  }

  .indicators-grid-3d {
    grid-template-columns: 1fr;
  }

  .medication-overview {
    flex-direction: column;
    gap: 16rpx;
  }

  .overview-card {
    flex-direction: row;
    padding: 24rpx;
  }

  .daily-record-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 16rpx;
  }

  .record-summary {
    align-self: stretch;
    justify-content: center;
  }

  .medicine-preview-item {
    flex-direction: column;
    align-items: stretch;
    gap: 12rpx;
  }

  .medicine-times {
    align-items: flex-start;
  }

  .times-text {
    max-width: none;
    text-align: left;
  }
}

/* 滚动条优化 */
::-webkit-scrollbar {
  width: 8rpx;
}

::-webkit-scrollbar-track {
  background: rgba(255, 184, 77, 0.1);
  border-radius: 4rpx;
}

::-webkit-scrollbar-thumb {
  background: linear-gradient(180deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 4rpx;
}

::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(180deg, var(--primary-color) 0%, var(--primary-color) 100%);
}

/* 动画效果 */
.daily-record-item {
  animation: recordSlideIn 0.5s ease-out;
}

.daily-record-item:nth-child(2) {
  animation-delay: 0.1s;
}

.daily-record-item:nth-child(3) {
  animation-delay: 0.2s;
}

.daily-record-item:nth-child(4) {
  animation-delay: 0.3s;
}

@keyframes recordSlideIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes button-shine {
  0% {
    transform: translateX(-100%) translateY(-100%) rotate(-45deg);
  }

  50% {
    transform: translateX(100%) translateY(100%) rotate(-45deg);
  }

  100% {
    transform: translateX(200%) translateY(200%) rotate(-45deg);
  }
}

/* ========== 用药档案时间轴样式 ========== */

/* 用药档案时间轴容器 */
.medication-timeline {
  position: relative;
  padding: 40rpx 0 40rpx 80rpx;
}

.medication-timeline::before {
  content: '';
  position: absolute;
  left: 40rpx;
  top: 0;
  bottom: 0;
  width: 2rpx;
  background: linear-gradient(to bottom,
      rgba(255, 184, 77, 0.3) 0%,
      rgba(255, 184, 77, 0.6) 50%,
      rgba(255, 184, 77, 0.3) 100%);
}

/* 统一的时间轴卡片 */
.unified-timeline-card {
  background: #FAFAFA;
  border-radius: 12rpx;
  border-left: 4rpx solid #FFB84D;
  overflow: hidden;
}

.timeline-header-integrated {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: rgba(255, 184, 77, 0.05);
  border-bottom: 1rpx solid rgba(255, 184, 77, 0.1);
}

.medication-records-integrated {
  display: flex;
  flex-direction: column;
}

.medication-record-unified {
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.medication-record-unified:last-child {
  border-bottom: none;
}

.medicine-main-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.medicine-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.medicine-dosage {
  font-size: 28rpx;
  color: #FFB84D;
  font-weight: 500;
  background: rgba(255, 184, 77, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.medicine-details {
  display: flex;
  gap: 32rpx;
}

.medicine-time-info,
.medicine-progress-info {
