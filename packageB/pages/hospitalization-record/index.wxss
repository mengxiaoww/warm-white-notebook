.page-container {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: #f5f5f5;
  display: flex; flex-direction: column;
}

.navbar {
  background: linear-gradient(135deg, var(--color-orange-500), var(--color-orange-700));
  padding-top: env(safe-area-inset-top);
  box-shadow: 0 2rpx 16rpx var(--primary-alpha-20);
}
.navbar .t-navbar { --td-navbar-bg-color: transparent; }
.navbar .t-navbar__title, .navbar .t-navbar__center text {
  color: white !important; font-size: 34rpx !important; font-weight: 500 !important;
}
.custom-back-btn {
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 50%; background: rgba(255,255,255,0.2);
}
.custom-back-btn:active { background: rgba(255,255,255,0.3); }

.content { flex: 1; display: flex; flex-direction: column; height: 0; }

.top-bar {
  background: white; padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}
.add-record-btn {
  box-shadow: 0 8rpx 24rpx var(--primary-alpha-40) !important;
  border-radius: 30rpx !important; color: white !important; font-weight: 500 !important;
}

.scroll-container { flex: 1; height: 0; }
.list-container { padding: 20rpx; padding-bottom: 40rpx; }

.summary-card {
  background: linear-gradient(135deg, var(--color-orange-50), var(--color-orange-100));
  border-radius: 20rpx; padding: 30rpx; margin-bottom: 20rpx;
  border: 1rpx solid var(--primary-alpha-10);
}
.summary-title { font-size: 32rpx; color: #333; font-weight: 600; display: block; }
.summary-sub { font-size: 26rpx; color: #999; margin-top: 6rpx; display: block; }

.record-list { display: flex; flex-direction: column; gap: 20rpx; }

.record-item {
  background: white; border-radius: 20rpx; overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  display: flex;
}
.record-type-bar { width: 8rpx; flex-shrink: 0; }
.record-type-bar.type-normal { background: var(--color-orange-500); }
.record-type-bar.type-ward { background: #9C27B0; }

.record-body { flex: 1; padding: 28rpx; }

.period-row { margin-bottom: 16rpx; }
.period-label { font-size: 24rpx; color: #999; display: block; margin-bottom: 8rpx; }
.period-dates { display: flex; align-items: center; gap: 12rpx; }
.period-date {
  font-size: 26rpx; color: #333; font-weight: 500;
  background: #f5f5f5; padding: 8rpx 16rpx; border-radius: 8rpx;
}
.period-sep { font-size: 24rpx; color: #999; }

.hospital-name { font-size: 32rpx; color: var(--color-orange-500); font-weight: 700; display: block; margin-bottom: 10rpx; }

.dept-tag {
  display: inline-block; padding: 6rpx 16rpx;
  background: rgba(255,152,0,0.08); border: 1rpx solid rgba(255,152,0,0.2);
  border-radius: 20rpx; font-size: 24rpx; color: #FF9800; margin-bottom: 14rpx;
}

.cost-row { margin-bottom: 10rpx; }
.cost-label { font-size: 24rpx; color: #999; margin-right: 8rpx; }
.cost-value { font-size: 28rpx; color: var(--color-orange-500); font-weight: 600; }

.notes-row { margin-bottom: 10rpx; }
.notes-text { font-size: 24rpx; color: #999; font-style: italic; }

.record-actions {
  display: flex; gap: 12rpx; margin-top: 16rpx;
  padding-top: 16rpx; border-top: 1rpx solid #f0f0f0;
  justify-content: flex-end;
}
.action-btn {
  padding: 10rpx 24rpx; border-radius: 20rpx;
  font-size: 24rpx; font-weight: 500; min-width: 80rpx; text-align: center;
}
.edit-btn {
  background: linear-gradient(135deg, var(--color-orange-500), var(--color-orange-700));
  color: white; box-shadow: 0 2rpx 8rpx var(--primary-alpha-20);
}
.edit-btn:active { transform: scale(0.96); }
.delete-btn { background: #f5f5f5; color: #666; border: 1rpx solid #e0e0e0; }
.delete-btn:active { background: #e0e0e0; }

.empty-state {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; padding: 100rpx 40rpx;
  background: white; border-radius: 20rpx;
}
.empty-text { font-size: 32rpx; color: #999; margin-top: 24rpx; }
.empty-hint { font-size: 28rpx; color: #ccc; margin-top: 12rpx; }

/* 弹窗 */
.popup-content {
  background: white; border-radius: 32rpx 32rpx 0 0;
  overflow: hidden; max-height: 90vh; display: flex; flex-direction: column;
}
.popup-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 40rpx 40rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: linear-gradient(135deg, rgba(255,152,0,0.05), rgba(245,124,0,0.08));
}
.popup-title { font-size: 36rpx; font-weight: 600; color: #333; }
.popup-close {
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center; border-radius: 50%;
}
.popup-close:active { background: #f5f5f5; }

.form-scroll { flex: 1; min-height: 200rpx; max-height: 65vh; }
.form-content { padding: 40rpx; padding-bottom: 20rpx; }

.form-item { margin-bottom: 32rpx; }
.form-label { display: block; font-size: 28rpx; color: #333; margin-bottom: 14rpx; font-weight: 500; }
.required-label::before { content: '* '; color: #ff4757; }

.type-selector { display: flex; gap: 16rpx; }
.type-option {
  flex: 1; display: flex; align-items: center; justify-content: center; gap: 8rpx;
  padding: 24rpx 16rpx; background: #f8f9fa; border: 2rpx solid #e0e0e0;
  border-radius: 16rpx; font-size: 28rpx; color: #333;
}
.type-option:active { transform: scale(0.97); }
.type-option-active {
  background: linear-gradient(135deg, rgba(255,152,0,0.1), rgba(255,152,0,0.05));
  border-color: #FF9800; color: #FF9800; font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255,152,0,0.2);
}

.date-input {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx; background: #f8f8f8;
  border-radius: 12rpx; border: 2rpx solid transparent;
}
.date-input:active { background: white; border-color: var(--color-orange-500); }
.date-text { font-size: 28rpx; color: #333; }
.placeholder-text { font-size: 28rpx; color: #999; }

.form-input {
  width: 100%; box-sizing: border-box;
  background: #f8f8f8; border-radius: 12rpx; border: 2rpx solid transparent;
}
.form-input:focus-within { background: white; border-color: var(--color-orange-500); }

.form-textarea {
  width: 100%; box-sizing: border-box;
  background: #f8f9fa; border-radius: 12rpx; border: 2rpx solid #e0e0e0;
  min-height: 160rpx; padding: 24rpx; font-size: 30rpx; color: #333; line-height: 1.6; display: block;
}
.form-textarea:focus-within { background: white; border-color: var(--color-orange-500); }

.popup-buttons {
  display: flex; gap: 20rpx; padding: 20rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  background: #f8f8f8;
}
.popup-btn {
  flex: 1; height: 88rpx; display: flex; align-items: center; justify-content: center;
  border-radius: 12rpx; font-size: 30rpx; font-weight: 500;
}
.cancel-btn { background: linear-gradient(135deg, #f0f0f0, #e6e6e6); color: #666; }
.cancel-btn:active { background: #d9d9d9; transform: scale(0.96); }
.confirm-btn {
  background: linear-gradient(135deg, var(--color-orange-500), var(--color-orange-700));
  color: white; box-shadow: 0 8rpx 24rpx var(--primary-alpha-40);
}
.confirm-btn:active { transform: scale(0.96); }

page .t-date-time-picker .t-picker__toolbar .t-button--primary,
page .t-picker__confirm {
  color: white !important;
  background: linear-gradient(135deg, var(--color-orange-500), var(--color-orange-700)) !important;
  border-radius: 12rpx !important; font-weight: 500 !important;
}
