/* pages/virus-record/index.wxss */
.page-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 自定义导航栏 - 紫色主题 */
page {
  --td-navbar-bg-color: linear-gradient(135deg, #9C27B0, #7B1FA2);
  --td-navbar-title-color: white;
  --td-navbar-title-font-size: 34rpx;
  --td-navbar-title-font-weight: 500;
}

.t-navbar {
  background: linear-gradient(135deg, #9C27B0, #7B1FA2) !important;
  border-bottom: none !important;
  box-shadow: 0 2rpx 16rpx rgba(156, 39, 176, 0.2) !important;
  --td-navbar-bg-color: linear-gradient(135deg, #9C27B0, #7B1FA2);
  --td-navbar-title-color: white;
  --td-navbar-title-font-size: 34rpx;
  --td-navbar-title-font-weight: 500;
}

/* 强制设置导航栏标题样式 */
.t-navbar__title,
.t-navbar__center,
.t-navbar__center text {
  color: white !important;
  font-size: 34rpx !important;
  font-weight: 500 !important;
}

/* 导航栏所有图标颜色 */
.t-navbar .t-icon,
.t-navbar__left .t-icon,
.t-navbar__right .t-icon {
  color: white !important;
}

.content-container {
  flex: 1;
  padding: 20rpx;
  padding-top: 40rpx;
  overflow-y: auto;
  padding-bottom: 160rpx;
}

/* 今日统计 */
.today-stats {
  background: linear-gradient(135deg, #9C27B0 0%, #E1BEE7 100%);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(156, 39, 176, 0.25);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  position: relative;
  overflow: hidden;
}

.today-stats::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 255, 255, 0.8) 50%, 
    transparent 100%
  );
  border-radius: 20rpx 20rpx 0 0;
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.stats-title {
  color: white;
  font-size: 34rpx;
  font-weight: 600;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.stats-count {
  color: white;
  font-size: 28rpx;
  font-weight: 500;
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.stats-details {
  margin-top: 16rpx;
}

.stats-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.stats-item:last-child {
  margin-bottom: 0;
}

.stats-label {
  color: rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
  margin-right: 12rpx;
}

.stats-status {
  display: flex;
  align-items: center;
}

.status-indicator {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.status-normal .status-indicator {
  background-color: #4CAF50;
}

.status-warning .status-indicator {
  background-color: #FF5722;
}

.status-text {
  color: white;
  font-size: 24rpx;
}

.abnormal-info {
  color: #FFEB3B;
  font-size: 24rpx;
  font-weight: 500;
  background: rgba(255, 235, 59, 0.2);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 235, 59, 0.3);
}

/* 记录列表 */
.records-section {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(156, 39, 176, 0.1);
}

.section-header {
  background: linear-gradient(135deg, rgba(156, 39, 176, 0.05) 0%, rgba(225, 190, 231, 0.15) 100%);
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(156, 39, 176, 0.1);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.records-list {
  background: white;
}

.record-item {
  padding: 32rpx;
  border-bottom: 1rpx solid #f8f8f8;
  transition: all 0.3s ease;
  position: relative;
}

.record-item:last-child {
  border-bottom: none;
}

.record-item:active {
  background: linear-gradient(135deg, rgba(156, 39, 176, 0.02) 0%, rgba(225, 190, 231, 0.08) 100%);
  transform: scale(0.99);
}

.record-abnormal {
  border-left: 6rpx solid #FF5722;
  background: linear-gradient(90deg, rgba(255, 87, 34, 0.05) 0%, rgba(255, 87, 34, 0) 20%);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.record-date-time {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.record-date {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.record-time {
  font-size: 24rpx;
  color: #666;
  background: rgba(156, 39, 176, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.record-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
  border: 1rpx solid;
}

.status-normal {
  background: rgba(76, 175, 80, 0.1);
  border-color: rgba(76, 175, 80, 0.3);
}

.status-warning {
  background: rgba(255, 87, 34, 0.1);
  border-color: rgba(255, 87, 34, 0.3);
}

.status-indicator-small {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.status-normal .status-indicator-small {
  background-color: #4CAF50;
}

.status-warning .status-indicator-small {
  background-color: #FF5722;
}

.status-normal .status-text {
  color: #4CAF50;
  font-weight: 500;
}

.status-warning .status-text {
  color: #FF5722;
  font-weight: 500;
}

.record-content {
  margin-top: 16rpx;
}

.virus-results {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0;
  margin-bottom: 16rpx;
}

.virus-item {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(156, 39, 176, 0.05);
  padding: 6rpx 10rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(156, 39, 176, 0.15);
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.virus-label {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
  white-space: nowrap;
}

.virus-result {
  font-size: 24rpx;
  font-weight: 500;
  padding: 0 10rpx;
  border-radius: 10rpx;
  border: 1rpx solid;
  display: inline-block;
  line-height: 30rpx;
  white-space: nowrap;
  height: 30rpx;
  box-sizing: border-box;
  vertical-align: middle;
  text-align: center;
}

.result-positive {
  color: #FF5722;
  background: rgba(255, 87, 34, 0.1);
  border-color: rgba(255, 87, 34, 0.3);
}

.result-negative {
  color: #4CAF50;
  background: rgba(76, 175, 80, 0.1);
  border-color: rgba(76, 175, 80, 0.3);
}

.record-extra {
  margin-top: 12rpx;
  background: rgba(156, 39, 176, 0.02);
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(156, 39, 176, 0.08);
}

.extra-info {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.extra-info:last-child {
  margin-bottom: 0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  background: linear-gradient(135deg, rgba(156, 39, 176, 0.02) 0%, rgba(225, 190, 231, 0.08) 100%);
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin: 32rpx 0 16rpx;
  font-weight: 500;
}

.empty-hint {
  display: block;
  font-size: 24rpx;
  color: #ccc;
}

/* 添加按钮 */
.add-button-container {
  position: fixed;
  bottom: 80rpx;
  left: 40rpx;
  right: 40rpx;
  z-index: 100;
}

.add-button-container .t-button {
  height: 92rpx !important;
  font-size: 30rpx !important;
  font-weight: 500 !important;
  background: linear-gradient(135deg, #9C27B0 0%, #7B1FA2 100%) !important;
  box-shadow: 
    0 8rpx 24rpx rgba(156, 39, 176, 0.4),
    0 4rpx 12rpx rgba(123, 31, 162, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3) !important;
  border: 2rpx solid rgba(255, 255, 255, 0.4) !important;
  border-radius: 12rpx !important;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
  position: relative !important;
  overflow: hidden !important;
  color: white !important;
}

.add-button-container .t-button::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 255, 255, 0.8) 50%, 
    transparent 100%
  );
  border-radius: 12rpx 12rpx 0 0;
}

.add-button-container .t-button:active {
  background: linear-gradient(135deg, #7B1FA2 0%, #4A148C 100%) !important;
  transform: scale(0.96) translateY(2rpx) !important;
  box-shadow: 
    0 4rpx 12rpx rgba(156, 39, 176, 0.5),
    0 2rpx 6rpx rgba(123, 31, 162, 0.4),
    inset 0 3rpx 6rpx rgba(255, 255, 255, 0.2) !important;
}

/* 弹窗样式 */
.virus-popup-content {
  background: white;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -8rpx 32rpx rgba(156, 39, 176, 0.15);
}

.virus-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(156, 39, 176, 0.1);
  background: linear-gradient(135deg, rgba(156, 39, 176, 0.05) 0%, rgba(225, 190, 231, 0.15) 100%);
}

.virus-popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #9C27B0;
}

.virus-popup-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.3s;
}

.virus-popup-close:active {
  background: rgba(156, 39, 176, 0.1);
  transform: scale(0.95);
}

.virus-form-container {
  flex: 1;
  max-height: calc(85vh - 200rpx);
  overflow-y: auto;
}

.virus-form-content {
  padding: 24rpx 32rpx;
}

.form-section {
  margin-bottom: 40rpx;
}

.section-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #9C27B0;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  background: rgba(156, 39, 176, 0.04);
  border: 1rpx solid rgba(156, 39, 176, 0.12);
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  transition: all 0.3s ease;
  width: 100%;
  box-sizing: border-box;
}

.form-input:focus {
  background: rgba(156, 39, 176, 0.08);
  border-color: rgba(156, 39, 176, 0.25);
  box-shadow: 0 0 0 4rpx rgba(156, 39, 176, 0.1);
}

.form-textarea {
  background: rgba(156, 39, 176, 0.04);
  border: 1rpx solid rgba(156, 39, 176, 0.12);
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  transition: all 0.3s ease;
  width: 100%;
  box-sizing: border-box;
  min-height: 120rpx;
}

.form-textarea:focus {
  background: rgba(156, 39, 176, 0.08);
  border-color: rgba(156, 39, 176, 0.25);
  box-shadow: 0 0 0 4rpx rgba(156, 39, 176, 0.1);
}

.picker-input {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(156, 39, 176, 0.05);
  border: 1rpx solid rgba(156, 39, 176, 0.15);
  border-radius: 12rpx;
  padding: 24rpx;
  min-height: 80rpx;
  box-sizing: border-box;
  transition: all 0.3s;
}

.picker-input:active {
  background: rgba(156, 39, 176, 0.08);
  border-color: rgba(156, 39, 176, 0.25);
}

.picker-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.virus-popup-buttons {
  display: flex;
  padding: 24rpx 32rpx 32rpx;
  gap: 20rpx;
  border-top: 1rpx solid rgba(156, 39, 176, 0.1);
  background: linear-gradient(135deg, rgba(156, 39, 176, 0.03) 0%, rgba(255, 255, 255, 0.95) 100%);
  flex-shrink: 0;
}

.virus-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 16rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 2rpx solid;
  position: relative;
  overflow: hidden;
}

.virus-cancel-btn {
  background: linear-gradient(135deg, #f8f8f8 0%, #e8e8e8 100%);
  color: #666;
  border-color: rgba(102, 102, 102, 0.3);
  box-shadow: 
    0 6rpx 20rpx rgba(0, 0, 0, 0.08),
    0 2rpx 8rpx rgba(0, 0, 0, 0.04),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.8);
}

.virus-cancel-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 255, 255, 0.9) 50%, 
    transparent 100%
  );
  border-radius: 16rpx 16rpx 0 0;
}

.virus-cancel-btn:active {
  background: linear-gradient(135deg, #e8e8e8 0%, #d8d8d8 100%);
  transform: scale(0.96) translateY(2rpx);
  box-shadow: 
    0 3rpx 10rpx rgba(0, 0, 0, 0.1),
    0 1rpx 4rpx rgba(0, 0, 0, 0.06);
}

.virus-confirm-btn {
  background: linear-gradient(135deg, #9C27B0 0%, #7B1FA2 100%);
  color: white;
  border-color: rgba(255, 255, 255, 0.4);
  box-shadow: 
    0 8rpx 24rpx rgba(156, 39, 176, 0.35),
    0 4rpx 12rpx rgba(123, 31, 162, 0.25),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3);
}

.virus-confirm-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 255, 255, 0.8) 50%, 
    transparent 100%
  );
  border-radius: 16rpx 16rpx 0 0;
}

.virus-confirm-btn:active {
  background: linear-gradient(135deg, #7B1FA2 0%, #4A148C 100%);
  transform: scale(0.96) translateY(2rpx);
  box-shadow: 
    0 4rpx 12rpx rgba(156, 39, 176, 0.4),
    0 2rpx 6rpx rgba(123, 31, 162, 0.3);
}

/* 详情弹窗 */
.record-detail-popup {
  background: white;
  border-radius: 24rpx;
  width: 96vw;
  max-width: 800rpx;
  max-height: 85vh;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  box-shadow: 
    0 24rpx 80rpx rgba(156, 39, 176, 0.25),
    0 8rpx 32rpx rgba(0, 0, 0, 0.1),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.8);
  overflow: hidden;
  position: relative;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 32rpx;
  border-bottom: 1rpx solid rgba(156, 39, 176, 0.15);
  background: linear-gradient(135deg, #9C27B0 0%, #E1BEE7 100%);
  position: relative;
}

.detail-header::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 255, 255, 0.8) 50%, 
    transparent 100%
  );
  border-radius: 24rpx 24rpx 0 0;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: white;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.detail-title::before {
  content: '🦠';
  font-size: 32rpx;
}

.detail-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  backdrop-filter: blur(10rpx);
}

.detail-close .t-icon {
  color: white !important;
}

.detail-close:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.95) rotate(90deg);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.detail-content {
  flex: 1;
  width: auto;
  max-height: calc(85vh - 260rpx);
  padding: 32rpx;
  background: linear-gradient(135deg, rgba(156, 39, 176, 0.02) 0%, rgba(255, 255, 255, 0.98) 50%, rgba(225, 190, 231, 0.05) 100%);
  overflow-y: auto;
}

.detail-section {
  margin-bottom: 36rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 
    0 8rpx 32rpx rgba(156, 39, 176, 0.12),
    0 2rpx 8rpx rgba(0, 0, 0, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  border: 1rpx solid rgba(156, 39, 176, 0.1);
  background: white;
}

.detail-section:last-child {
  margin-bottom: 0;
}

.detail-section-title {
  background: linear-gradient(135deg, #9C27B0 0%, #E1BEE7 100%);
  color: white;
  font-size: 28rpx;
  font-weight: 700;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 
    0 4rpx 16rpx rgba(156, 39, 176, 0.25),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
  position: relative;
}

.detail-section-title::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 255, 255, 0.6) 50%, 
    transparent 100%
  );
}

.detail-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(156, 39, 176, 0.06);
  background: linear-gradient(135deg, rgba(156, 39, 176, 0.01) 0%, rgba(255, 255, 255, 0.98) 100%);
  transition: all 0.3s ease;
  position: relative;
}

.detail-item:hover {
  background: linear-gradient(135deg, rgba(156, 39, 176, 0.03) 0%, rgba(255, 255, 255, 0.95) 100%);
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-text-item {
  flex-direction: column;
  align-items: flex-start;
  padding: 28rpx 24rpx;
}

.detail-label {
  font-size: 28rpx;
  color: #666;
  width: 200rpx;
  flex-shrink: 0;
  font-weight: 500;
  position: relative;
}

.detail-label::after {
  content: ':';
  position: absolute;
  right: -8rpx;
  color: #9C27B0;
}

.detail-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  flex: 1;
}

.detail-text-value {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  word-break: break-all;
  background: rgba(156, 39, 176, 0.05);
  padding: 16rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(156, 39, 176, 0.1);
  margin-top: 8rpx;
  width: 100%;
  box-sizing: border-box;
}

.result-highlight {
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid;
}

.result-highlight.result-positive {
  color: #FF5722;
  background: rgba(255, 87, 34, 0.1);
  border-color: rgba(255, 87, 34, 0.3);
}

.result-highlight.result-negative {
  color: #4CAF50;
  background: rgba(76, 175, 80, 0.1);
  border-color: rgba(76, 175, 80, 0.3);
}

/* 详情操作按钮 */
.detail-buttons {
  display: flex;
  padding: 32rpx;
  gap: 20rpx;
  border-top: 1rpx solid rgba(156, 39, 176, 0.15);
  background: linear-gradient(135deg, rgba(156, 39, 176, 0.03) 0%, rgba(255, 255, 255, 0.95) 100%);
  position: relative;
}

.detail-buttons::before {
  content: '';
  position: absolute;
  top: 0;
  left: 32rpx;
  right: 32rpx;
  height: 1rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(156, 39, 176, 0.3) 50%, 
    transparent 100%
  );
}

.detail-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 16rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 2rpx solid;
  position: relative;
  overflow: hidden;
}

.detail-edit-btn {
  background: linear-gradient(135deg, #2196F3 0%, #1976D2 100%);
  color: white;
  border-color: rgba(255, 255, 255, 0.4);
  box-shadow: 
    0 8rpx 24rpx rgba(33, 150, 243, 0.35),
    0 4rpx 12rpx rgba(25, 118, 210, 0.25),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3);
}

.detail-edit-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 255, 255, 0.8) 50%, 
    transparent 100%
  );
  border-radius: 16rpx 16rpx 0 0;
}

.detail-edit-btn:active {
  background: linear-gradient(135deg, #1976D2 0%, #1565C0 100%);
  transform: scale(0.96) translateY(2rpx);
  box-shadow: 
    0 4rpx 12rpx rgba(33, 150, 243, 0.4),
    0 2rpx 6rpx rgba(25, 118, 210, 0.3);
}

.detail-delete-btn {
  background: linear-gradient(135deg, #F44336 0%, #D32F2F 100%);
  color: white;
  border-color: rgba(255, 255, 255, 0.4);
  box-shadow: 
    0 8rpx 24rpx rgba(244, 67, 54, 0.35),
    0 4rpx 12rpx rgba(211, 47, 47, 0.25),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3);
}

.detail-delete-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 255, 255, 0.8) 50%, 
    transparent 100%
  );
  border-radius: 16rpx 16rpx 0 0;
}

.detail-delete-btn:active {
  background: linear-gradient(135deg, #D32F2F 0%, #B71C1C 100%);
  transform: scale(0.96) translateY(2rpx);
  box-shadow: 
    0 4rpx 12rpx rgba(244, 67, 54, 0.4),
    0 2rpx 6rpx rgba(211, 47, 47, 0.3);
}

.detail-close-btn {
  background: linear-gradient(135deg, #f8f8f8 0%, #e8e8e8 100%);
  color: #666;
  border-color: rgba(102, 102, 102, 0.3);
  box-shadow: 
    0 6rpx 20rpx rgba(0, 0, 0, 0.1),
    0 2rpx 8rpx rgba(0, 0, 0, 0.06),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.8);
}

.detail-close-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 255, 255, 0.9) 50%, 
    transparent 100%
  );
  border-radius: 16rpx 16rpx 0 0;
}

.detail-close-btn:active {
  background: linear-gradient(135deg, #e8e8e8 0%, #d8d8d8 100%);
  transform: scale(0.96) translateY(2rpx);
  box-shadow: 
    0 3rpx 10rpx rgba(0, 0, 0, 0.12),
    0 1rpx 4rpx rgba(0, 0, 0, 0.08);
}

/* 选择器弹窗样式 */
.picker-popup {
  background: white;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 60vh;
  box-shadow: 0 -8rpx 32rpx rgba(156, 39, 176, 0.15);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(156, 39, 176, 0.1);
  background: linear-gradient(135deg, rgba(156, 39, 176, 0.05) 0%, rgba(225, 190, 231, 0.15) 100%);
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #9C27B0;
}

.picker-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.3s;
}

.picker-close:active {
  background: rgba(156, 39, 176, 0.1);
  transform: scale(0.95);
}

.picker-options {
  max-height: 50vh;
  padding: 16rpx 0;
}

.picker-option-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  transition: all 0.3s;
  border-bottom: 1rpx solid rgba(156, 39, 176, 0.05);
}

.picker-option-item:active {
  background: rgba(156, 39, 176, 0.08);
}

.picker-option-active {
  background: rgba(156, 39, 176, 0.1) !important;
  border-left: 6rpx solid #9C27B0;
}

.option-text {
  font-size: 30rpx;
  color: #333;
}

.picker-option-active .option-text {
  color: #9C27B0;
  font-weight: 500;
}

/* 优化异常状态显示 */
.status-warning .status-text {
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

/* 日期选择器主题色 */
.t-date-time-picker {
  --td-brand-color: #9C27B0;
  --td-brand-color-light: #E1BEE7;
  --td-brand-color-disabled: rgba(156, 39, 176, 0.4);
}

/* 病毒结果标签高度修复 */
.virus-item .virus-result.result-negative,
.virus-item .virus-result.result-positive,
.virus-item .virus-result {
  height: 35rpx;
  line-height: 35rpx;
  padding: 0 10rpx;
  margin: 0;
  vertical-align: middle;
  text-align: center;
  display: inline-block;
  box-sizing: border-box;
}

/* 统一暖色主题关闭按钮 */
.milestone-close-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, 
    rgba(255, 184, 77, 0.08) 0%, 
    rgba(255, 167, 38, 0.12) 100%
  );
  border: 2rpx solid rgba(255, 184, 77, 0.15);
  border-radius: 50%;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 3rpx 12rpx rgba(255, 184, 77, 0.1);
  position: relative;
}

.milestone-close-btn::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, 
    rgba(255, 184, 77, 0.15) 0%, 
    rgba(255, 167, 38, 0.08) 100%
  );
  z-index: -1;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.milestone-close-btn:hover::before {
  opacity: 1;
}

.milestone-close-btn:active {
  background: linear-gradient(135deg, 
    rgba(255, 184, 77, 0.15) 0%, 
    rgba(255, 167, 38, 0.18) 100%
  );
  border-color: rgba(255, 184, 77, 0.25);
  transform: scale(0.94);
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 77, 0.2);
}