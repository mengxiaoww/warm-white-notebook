/* 统一暖色主题关闭按钮 */
.milestone-close-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.08) 0%,
      rgba(255, 167, 38, 0.12) 100%);
  border: 2rpx solid rgba(255, 184, 77, 0.15);
  border-radius: 50%;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 3rpx 12rpx rgba(255, 184, 77, 0.1);
  position: relative;
}

.milestone-close-btn::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  border-radius: 50%;
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.15) 0%,
      rgba(255, 167, 38, 0.08) 100%);
  z-index: -1;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.milestone-close-btn:hover::before {
  opacity: 1;
}

.milestone-close-btn:active {
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.15) 0%,
      rgba(255, 167, 38, 0.18) 100%);
  border-color: rgba(255, 184, 77, 0.25);
  transform: scale(0.94);
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 77, 0.2);
}

/* 浮动的下一项/完成按钮 - 固定在键盘上方右侧 */
.floating-next-btn {
  position: fixed;
  right: 40rpx;
  bottom: calc(env(safe-area-inset-bottom) + 580rpx);
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F2E 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 184, 77, 0.5);
  z-index: 99999;
  animation: bounceIn 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  animation-fill-mode: both;
  will-change: transform;
}

@keyframes bounceIn {
  0% {
    opacity: 0;
    transform: scale(0.3);
  }

  50% {
    opacity: 1;
    transform: scale(1.05);
  }

  70% {
    transform: scale(0.9);
  }

  100% {
    transform: scale(1);
  }
}