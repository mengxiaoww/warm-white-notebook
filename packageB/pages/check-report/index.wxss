.page-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
  padding-bottom: 50rpx;
}

/* 自定义导航栏 - 橙色主题 */
.navbar {
  background: linear-gradient(135deg, var(--color-orange-500), var(--color-orange-700));
  border-bottom: none;
  padding-top: 44px;
  padding-top: env(safe-area-inset-top);
  box-shadow: 0 2rpx 16rpx var(--primary-alpha-20);
}

/* 自定义返回按钮样式 */
.custom-back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  transition: all 0.3s;
}

.custom-back-btn:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.95);
}



.navbar-right {
  padding-right: 30rpx;
}

/* 内容区域 */
.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  height: 0;
}

/* 日期选择区域 */
.date-section {
  background: white;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.date-selector {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 18rpx 28rpx;
  background: linear-gradient(135deg, var(--color-white-pure) 0%, #f8f8f8 100%);
  border: 1rpx solid var(--primary-alpha-20);
  border-radius: 30rpx;
  min-width: 200rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.date-selector:active {
  background: linear-gradient(135deg, #f8f8f8 0%, #f0f0f0 100%);
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.08);
}

.date-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

/* 快捷输入按钮 */
.quick-input-btns {
  display: flex;
  gap: 24rpx;
}

.quick-input-btns .t-button {
  box-shadow:
    0 8rpx 24rpx var(--primary-alpha-40),
    0 4rpx 12rpx rgba(245, 124, 0, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3) !important;
  border-radius: 30rpx !important;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
  color: white !important;
  font-weight: 500 !important;
}

.quick-input-btns .t-button:active {
  transform: scale(0.96) translateY(2rpx) !important;
  box-shadow:
    0 4rpx 12rpx var(--primary-alpha-50),
    0 2rpx 6rpx rgba(245, 124, 0, 0.4),
    inset 0 3rpx 6rpx rgba(255, 255, 255, 0.2) !important;
}

/* 滚动容器 */
.scroll-container {
  height: calc(100vh - 160rpx);
  width: 100%;
  background: #f5f5f5;
}

/* 表单容器 */
.form-container {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 门诊统计卡片 */
.clinic-summary {
  background: linear-gradient(135deg, var(--color-orange-50) 0%, var(--color-orange-100) 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--primary-alpha-10);
  box-shadow: 0 4rpx 20rpx var(--primary-alpha-10);
}

.summary-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.summary-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.summary-count {
  font-size: 28rpx;
  color: var(--color-orange-500);
  background: var(--primary-alpha-10);
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

.summary-details {
  font-size: 24rpx;
  color: #666;
}

/* 门诊记录列表 */
.clinic-records-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.clinic-record-item {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid var(--primary-alpha-10);
}

.record-content {
  padding: 32rpx 28rpx;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.record-content::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, var(--primary-alpha-30) 50%, transparent 100%);
  z-index: 1;
}

.record-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--primary-alpha-10);
}

.hospital-info {
  flex: 1;
}

.hospital-name {
  font-size: 30rpx;
  color: var(--color-orange-500);
  font-weight: 700;
  display: block;
  margin-bottom: 10rpx;
  letter-spacing: 0.5rpx;
}

.department-name {
  font-size: 24rpx;
  color: var(--color-orange-500);
  background: linear-gradient(135deg, var(--primary-alpha-10) 0%, rgba(255, 152, 0, 0.05) 100%);
  padding: 6rpx 14rpx;
  border-radius: 14rpx;
  display: inline-block;
  border: 1rpx solid var(--primary-alpha-20);
  font-weight: 500;
}

.visit-time {
  font-size: 22rpx;
  color: #666;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  padding: 8rpx 14rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  margin-top: 4rpx;
}

.doctor-info {
  margin-bottom: 16rpx;
}

.doctor-section {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.doctor-name {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.doctor-title {
  font-size: 24rpx;
  color: var(--color-orange-500);
  background: var(--primary-alpha-10);
  padding: 4rpx 8rpx;
  border-radius: 8rpx;
}

/* 记录预览样式 - 优化版 */
.diagnosis-preview {
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.preview-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.preview-label text {
  font-size: 24rpx;
  color: var(--color-orange-500);
  font-weight: 600;
}

.preview-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.5;
  background: rgba(255, 152, 0, 0.05);
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  border-left: 3rpx solid var(--color-orange-500);
}

.record-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  gap: 12rpx;
}

.cost-preview,
.follow-up-preview {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 14rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid;
}

.cost-preview {
  background: linear-gradient(135deg, var(--primary-alpha-10) 0%, rgba(255, 152, 0, 0.05) 100%);
  color: var(--color-orange-500);
  border-color: var(--primary-alpha-20);
}

.follow-up-preview {
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.1) 0%, rgba(76, 175, 80, 0.05) 100%);
  color: #4CAF50;
  border-color: rgba(76, 175, 80, 0.2);
}

.detail-hint {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 22rpx;
  color: #999;
  margin-left: auto;
}

/* 门诊记录详情弹窗样式 */
.record-detail-popup {
  width: 90vw;
  max-width: 600rpx;
  max-height: 80vh;
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  background: linear-gradient(135deg, rgba(255, 152, 0, 0.05) 0%, rgba(245, 124, 0, 0.08) 100%);
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

.detail-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.3s;
}

.detail-close:active {
  background: rgba(153, 153, 153, 0.1);
}

.detail-content {
  flex: 1;
  max-height: 50vh;
  padding: 24rpx;
}

.detail-section {
  margin-bottom: 32rpx;
}

.detail-section:last-child {
  margin-bottom: 0;
}

.detail-section-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid var(--primary-alpha-10);
}

.detail-section-title text {
  font-size: 28rpx;
  color: var(--color-orange-500);
  font-weight: 600;
}

.detail-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
  word-wrap: break-word;
  overflow-wrap: break-word;
}

.detail-item:last-child {
  margin-bottom: 0;
}

.detail-text-item {
  flex-direction: column;
  align-items: flex-start;
}

.detail-label {
  font-size: 26rpx;
  color: #666;
  min-width: 120rpx;
  flex-shrink: 0;
  margin-bottom: 8rpx;
}

.detail-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
}

.detail-text-value {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  background: #f8f9fa;
  padding: 16rpx;
  border-radius: 12rpx;
  width: 100%;
  box-sizing: border-box;
  border-left: 4rpx solid #999;
  word-wrap: break-word;
  overflow-wrap: break-word;
}

.cost-highlight {
  color: var(--color-orange-500);
  font-weight: 600;
}

.follow-up-highlight {
  color: #4CAF50;
  font-weight: 600;
}

.detail-buttons {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #f8f8f8;
}

.detail-btn {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s;
}

.detail-edit-btn {
  background: linear-gradient(135deg, var(--color-orange-500) 0%, var(--color-orange-700) 100%);
  color: white;
  box-shadow: 0 4rpx 12rpx var(--primary-alpha-30);
}

.detail-edit-btn:active {
  background: linear-gradient(135deg, var(--color-orange-700) 0%, #FF9800 100%);
  transform: scale(0.96);
}

.detail-close-btn {
  background: linear-gradient(135deg, #f0f0f0 0%, #e6e6e6 100%);
  color: #666;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.detail-close-btn:active {
  background: linear-gradient(135deg, #e6e6e6 0%, #d9d9d9 100%);
  transform: scale(0.96);
}

/* 临时操作按钮 */
.temp-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.temp-btn {
  flex: 1;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: white;
  transition: all 0.3s;
}

.edit-temp-btn {
  background: linear-gradient(135deg, var(--color-orange-500) 0%, var(--color-orange-700) 100%);
  box-shadow: 0 4rpx 12rpx var(--primary-alpha-30);
}

.edit-temp-btn:active {
  background: linear-gradient(135deg, var(--color-orange-700) 0%, #FF9800 100%);
  transform: scale(0.96);
}

.delete-temp-btn {
  background: linear-gradient(135deg, #757575 0%, #616161 100%);
  box-shadow: 0 4rpx 12rpx rgba(117, 117, 117, 0.3);
}

.delete-temp-btn:active {
  background: linear-gradient(135deg, #616161 0%, #424242 100%);
  transform: scale(0.96);
}

/* 滑动操作按钮 */
.swipe-actions {
  display: flex;
  height: 100%;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: white;
  font-weight: 500;
}

.edit-btn {
  background: linear-gradient(135deg, var(--color-orange-500) 0%, var(--color-orange-700) 100%);
}

.delete-btn {
  background: linear-gradient(135deg, #757575 0%, #616161 100%);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  background: white;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-top: 24rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #ccc;
  margin-top: 12rpx;
}

/* 修复导航栏样式 */
.t-navbar__placeholder {
  visibility: hidden;
}

.t-navbar {
  --td-navbar-bg-color: transparent;
}

/* 强制设置导航栏标题样式 */
.navbar .t-navbar__title,
.navbar .t-navbar__center,
.navbar .t-navbar__center text,
.navbar .t-navbar__center .t-navbar__title {
  color: white !important;
  font-size: 34rpx !important;
  font-weight: 500 !important;
}

/* 导航栏所有图标颜色 */
.navbar .t-icon,
.navbar .t-navbar__left .t-icon,
.navbar .t-navbar__right .t-icon {
  color: white !important;
}

/* 门诊记录弹窗样式 */
.clinic-popup-content {
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
}

.clinic-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 40rpx 20rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: linear-gradient(135deg, rgba(255, 152, 0, 0.05) 0%, rgba(245, 124, 0, 0.08) 100%);
}

.clinic-popup-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.clinic-popup-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.3s;
}

.clinic-popup-close:active {
  background: #f5f5f5;
}

.clinic-form-container {
  flex: 1;
  min-height: 200rpx;
  max-height: 60vh;
}

.clinic-form-content {
  padding: 40rpx;
  padding-bottom: 20rpx;
}

/* 表单区块 */
.form-section {
  margin-bottom: 40rpx;
}

.section-label {
  display: block;
  font-size: 30rpx;
  color: var(--color-orange-500);
  font-weight: 600;
  margin-bottom: 24rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid var(--primary-alpha-10);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

/* 快捷提示词按钮 */
.suggestion-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.suggestion-btn {
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, rgba(255, 152, 0, 0.08) 0%, rgba(255, 152, 0, 0.05) 100%);
  border: 1.5rpx solid rgba(255, 152, 0, 0.25);
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #FF9800;
  font-weight: 500;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  white-space: nowrap;
}

.suggestion-btn:active {
  background: linear-gradient(135deg, rgba(255, 152, 0, 0.15) 0%, rgba(255, 152, 0, 0.1) 100%);
  transform: scale(0.96);
  border-color: rgba(255, 152, 0, 0.4);
}

.form-input {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.form-input:focus-within {
  background: white;
  border-color: var(--color-orange-500);
  box-shadow: 0 0 0 4rpx var(--primary-alpha-10);
}

.form-textarea {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  background: #f8f9fa;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  min-height: 280rpx;
  padding: 24rpx;
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  resize: none;
  outline: none;
  -webkit-appearance: none;
  -webkit-tap-highlight-color: transparent;
  display: block;
}

.form-textarea:focus-within {
  background: white;
  border-color: var(--color-orange-500);
  box-shadow: 0 0 0 4rpx var(--primary-alpha-10);
}

.form-textarea::placeholder {
  color: #999;
  font-size: 26rpx;
}

/* 就诊时间选择器 */
.visit-time-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.visit-time-input:active {
  background: white;
  border-color: var(--color-orange-500);
  box-shadow: 0 0 0 4rpx var(--primary-alpha-10);
}

.visit-time-text {
  font-size: 28rpx;
  color: #333;
}

/* 复诊时间选择器 */
.follow-up-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.follow-up-input:active {
  background: white;
  border-color: var(--color-orange-500);
  box-shadow: 0 0 0 4rpx var(--primary-alpha-10);
}

.follow-up-text {
  font-size: 28rpx;
  color: #333;
}

/* 弹窗按钮区域 */
.clinic-popup-buttons {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  background: #f8f8f8;
}

.clinic-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

/* 立体化取消按钮 */
.clinic-cancel-btn {
  background: linear-gradient(135deg, #f0f0f0 0%, #e6e6e6 100%);
  color: #666;
  box-shadow:
    0 8rpx 24rpx rgba(102, 102, 102, 0.2),
    0 4rpx 12rpx rgba(230, 230, 230, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.8);
  border: 2rpx solid rgba(255, 255, 255, 0.6);
}

.clinic-cancel-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.8) 50%,
      transparent 100%);
  border-radius: 12rpx 12rpx 0 0;
}

.clinic-cancel-btn:active {
  background: linear-gradient(135deg, #e6e6e6 0%, #d9d9d9 100%);
  transform: scale(0.96) translateY(2rpx);
  box-shadow:
    0 4rpx 12rpx rgba(102, 102, 102, 0.3),
    0 2rpx 6rpx rgba(230, 230, 230, 0.4),
    inset 0 3rpx 6rpx rgba(255, 255, 255, 0.6);
}

/* 立体化确认按钮 - 蓝色主题 */
.clinic-confirm-btn {
  background: linear-gradient(135deg, var(--color-orange-500) 0%, var(--color-orange-700) 100%);
  color: white;
  box-shadow:
    0 8rpx 24rpx var(--primary-alpha-40),
    0 4rpx 12rpx rgba(245, 124, 0, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3);
  border: 2rpx solid rgba(255, 255, 255, 0.4);
}

