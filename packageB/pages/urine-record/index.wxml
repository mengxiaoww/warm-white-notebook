<view class="page-container">
  <!-- 自定义导航栏 -->
  <t-navbar title="尿量记录" class="navbar" style="--td-navbar-title-color: white; --td-navbar-title-font-size: 34rpx; --td-navbar-title-font-weight: 500;">
    <view slot="left" class="custom-back-btn" bindtap="navigateBack">
      <t-icon name="chevron-left" size="48rpx" color="white" />
    </view>
  </t-navbar>
  <!-- 内容区域 -->
  <view class="content">
    <!-- 日期选择区域 -->
    <view class="date-section">
      <view class="date-selector" bindtap="showDatePicker">
        <text class="date-text">{{selectedDate}}</text>
        <t-icon name="calendar" size="32rpx" color="#666" />
      </view>
      <view class="quick-input-btns">
        <t-button theme="primary" size="small" icon="add" bindtap="addRecord" class="add-record-btn">
          添加记录
        </t-button>
      </view>
    </view>
    <!-- 滚动容器 -->
    <scroll-view class="scroll-container" scroll-y>
      <view class="form-container">
        <!-- 今日尿量统计 -->
        <view class="urine-summary" wx:if="{{urineRecords.length > 0}}">
          <view class="summary-header">
            <view class="summary-info">
              <text class="summary-title">今日尿量</text>
              <text class="summary-count">{{urineRecords.length}} 次</text>
            </view>
            <view class="summary-total">
              <text class="total-volume">总量: {{totalVolume}}ml</text>
            </view>
          </view>
        </view>
        <!-- 尿量记录列表 -->
        <view class="urine-records-list" wx:if="{{urineRecords.length > 0}}">
          <view class="urine-record-item" wx:for="{{urineRecords}}" wx:key="_id">
            <view class="record-content" bindtap="showRecordDetail" data-id="{{item._id}}">
              <view class="record-header">
                <view class="time-info">
                  <t-icon name="time" size="28rpx" color="#FF9800" />
                  <text class="record-time">{{item.time}}</text>
                </view>
                <view class="volume-info">
                  <text class="volume-amount">{{item.volume}}ml</text>
                </view>
              </view>
              <view class="record-details">
                <view class="detail-item" wx:if="{{item.color}}">
                  <t-icon name="palette" size="24rpx" color="#FF9800" />
                  <text class="detail-label">颜色：</text>
                  <text class="detail-value">{{item.color}}</text>
                </view>
                <view class="detail-item" wx:if="{{item.clarity}}">
                  <t-icon name="view" size="24rpx" color="#FF9800" />
                  <text class="detail-label">清澈度：</text>
                  <text class="detail-value">{{item.clarity}}</text>
                </view>
              </view>
              <!-- 备注预览 -->
              <view class="notes-preview" wx:if="{{item.notes}}">
                <t-icon name="chat" size="24rpx" color="#FF9800" />
                <text class="notes-text">{{item.notesPreview}}</text>
              </view>
              <!-- 操作按钮 -->
              <view class="temp-actions">
                <view class="temp-btn edit-temp-btn" catchtap="editRecord" data-id="{{item._id}}">
                  编辑
                </view>
                <view class="temp-btn delete-temp-btn" catchtap="deleteRecord" data-id="{{item._id}}">
                  删除
                </view>
              </view>
            </view>
          </view>
        </view>
        <!-- 空状态 -->
        <view class="empty-state" wx:if="{{urineRecords.length === 0}}">
          <t-icon name="fill-color-1" size="120rpx" color="#ddd" />
          <text class="empty-text">暂无尿量记录</text>
          <text class="empty-hint">点击右上角添加尿量记录</text>
        </view>
      </view>
    </scroll-view>
  </view>
  <!-- 日期选择器 -->
  <t-date-time-picker visible="{{datePickerVisible}}" value="{{selectedDateTimestamp}}" mode="date" title="选择日期" confirm-btn="确定" cancel-btn="取消" bind:confirm="onDateConfirm" bind:cancel="onDateCancel" bind:visible-change="onDateVisibleChange" />
  <!-- 尿量记录弹窗 -->
  <t-popup visible="{{showUrineDialog}}" placement="bottom" bind:visible-change="onDialogVisibleChange">
    <view class="urine-popup-content">
      <view class="urine-popup-header">
        <text class="urine-popup-title">{{isEditMode ? '编辑尿量记录' : '添加尿量记录'}}</text>
        <view class="urine-popup-close" bindtap="closeUrineDialog">
          <t-icon name="close" size="32rpx" color="#999" />
        </view>
      </view>
      <scroll-view class="urine-form-container" scroll-y>
        <view class="urine-form-content">
          <view class="form-section">
            <view class="form-item">
              <text class="form-label">记录时间</text>
              <picker mode="time" value="{{urineForm.time}}" bindchange="onTimePickerChange">
                <view class="picker-input">
                  <text class="picker-text">{{urineForm.time || '请选择记录时间'}}</text>
                  <t-icon name="time" size="32rpx" color="#999" />
                </view>
              </picker>
            </view>
            <view class="form-item" bindtap="setPopupFocus" data-index="0">
              <text class="form-label">尿量 (ml)</text>
              <t-input value="{{urineForm.volume}}" placeholder="请输入尿量" bind:change="onFormInput" data-field="volume" class="form-input" type="number" focus="{{focusVolumeInput}}" bind:blur="onVolumeInputBlur" bind:focus="onPopupInputFocus" data-index="0" data-total="2" />
            </view>
            <!-- 尿液颜色 - 卡片选择 -->
            <view class="form-item">
              <text class="form-label">尿液颜色</text>
              <view class="option-cards">
                <view class="option-card {{urineForm.color === item.value ? 'option-card-active' : ''}}" wx:for="{{colorOptions}}" wx:key="value" bindtap="onColorSelect" data-value="{{item.value}}">
                  <text class="option-card-text">{{item.label}}</text>
                  <t-icon wx:if="{{urineForm.color === item.value}}" name="check-circle-filled" size="32rpx" color="#FF9800" class="option-check-icon" />
                </view>
              </view>
            </view>
            <!-- 清澈度 - 卡片选择 -->
            <view class="form-item">
              <text class="form-label">清澈度</text>
              <view class="option-cards">
                <view class="option-card {{urineForm.clarity === item.value ? 'option-card-active' : ''}}" wx:for="{{clarityOptions}}" wx:key="value" bindtap="onClaritySelect" data-value="{{item.value}}">
                  <text class="option-card-text">{{item.label}}</text>
                  <t-icon wx:if="{{urineForm.clarity === item.value}}" name="check-circle-filled" size="32rpx" color="#FF9800" class="option-check-icon" />
                </view>
              </view>
            </view>
            <view class="form-item" bindtap="setPopupFocus" data-index="1">
              <text class="form-label">备注</text>
              <t-textarea value="{{urineForm.notes}}" placeholder="其他需要记录的信息" bind:change="onFormInput" data-field="notes" class="form-textarea" maxlength="200" indicator bind:focus="onPopupInputFocus" bind:blur="onPopupInputBlur" data-index="1" data-total="2" />
            </view>
          </view>
        </view>
      </scroll-view>
      <view class="urine-popup-buttons">
        <view class="urine-btn urine-cancel-btn" bindtap="closeUrineDialog">取消</view>
        <view class="urine-btn urine-confirm-btn" bindtap="saveUrineRecord">
          {{isEditMode ? '保存' : '添加'}}
        </view>
      </view>
    </view>
  </t-popup>
  <!-- 浮动的下一项/完成按钮（弹窗中） - 移到弹窗外以正确fixed定位 -->
  <view wx:if="{{popupFocusIndex >= 0 && showUrineDialog}}" class="floating-next-btn" catchtap="{{popupFocusIndex === 1 ? 'completePopupInput' : 'goToNextPopupInput'}}" data-index="{{popupFocusIndex}}">
    <t-icon name="{{popupFocusIndex === 1 ? 'check' : 'chevron-down'}}" size="48rpx" color="white" />
  </view>
  <!-- 尿量记录详情弹窗 -->
  <t-popup visible="{{showRecordDetailPopup}}" placement="center" bind:visible-change="onRecordDetailVisibleChange">
    <view class="record-detail-popup" wx:if="{{selectedRecord}}">
      <view class="detail-header">
        <view class="detail-title">尿量详情</view>
        <view class="detail-close" bindtap="closeRecordDetail">
          <t-icon name="close" size="32rpx" color="#999" />
        </view>
      </view>
      <scroll-view class="detail-content" scroll-y>
        <view class="detail-section">
          <view class="detail-item">
            <text class="detail-label">记录时间</text>
            <text class="detail-value">{{selectedRecord.time}}</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">尿量</text>
            <text class="detail-value volume-highlight">{{selectedRecord.volume}} ml</text>
          </view>
          <view class="detail-item" wx:if="{{selectedRecord.color}}">
            <text class="detail-label">尿液颜色</text>
            <text class="detail-value">{{selectedRecord.color}}</text>
          </view>
          <view class="detail-item" wx:if="{{selectedRecord.clarity}}">
            <text class="detail-label">清澈度</text>
            <text class="detail-value">{{selectedRecord.clarity}}</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">当日次数</text>
            <text class="detail-value frequency-highlight">第 {{selectedRecord.frequency}} 次</text>
          </view>
        </view>
        <!-- 备注 -->
        <view class="detail-section" wx:if="{{selectedRecord.notes}}">
          <view class="detail-item">
            <text class="detail-label">备注</text>
          </view>
          <view class="detail-item detail-text-item">
            <text class="detail-text-value">{{selectedRecord.notes}}</text>
          </view>
        </view>
      </scroll-view>
      <view class="detail-buttons">
        <view class="milestone-close-btn" bindtap="closeRecordDetail">
          <t-icon name="close" size="28rpx" />
        </view>
      </view>
    </view>
  </t-popup>
</view>