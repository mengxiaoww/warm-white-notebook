.marked-calendar {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, rgba(255, 152, 0, 0.05) 0%, rgba(245, 124, 0, 0.08) 100%);
  border-bottom: 1rpx solid rgba(255, 152, 0, 0.1);
}

.month-nav {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.3s;
}

.month-nav:active {
  background: rgba(255, 152, 0, 0.1);
}

.nav-arrow {
  font-size: 48rpx;
  color: #FF9800;
  font-weight: 300;
}

.month-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  padding: 20rpx 0;
  background: #fafafa;
}

.weekday {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}

.calendar-days {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4rpx;
  padding: 16rpx;
}

.day-cell {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.day-cell:active {
  background: rgba(255, 152, 0, 0.1);
}

.day-number {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.day-cell.other-month .day-number {
  color: #ccc;
}

.day-cell.today {
  background: linear-gradient(135deg, rgba(255, 152, 0, 0.1) 0%, rgba(245, 124, 0, 0.15) 100%);
}

.day-cell.today .day-number {
  color: #FF9800;
  font-weight: 700;
}

.record-dot {
  position: absolute;
  bottom: 8rpx;
  width: 8rpx;
  height: 8rpx;
  background: #FF9800;
  border-radius: 50%;
  box-shadow: 0 0 4rpx rgba(255, 152, 0, 0.5);
}

.day-cell.other-month .record-dot {
  opacity: 0.3;
}

.day-cell.has-record {
  border: 1rpx solid rgba(255, 152, 0, 0.2);
}
