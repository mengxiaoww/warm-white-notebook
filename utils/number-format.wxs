/**
 * 数值格式化工具（WXS模块）
 * 用于在小程序WXML中格式化数值显示
 */

/**
 * 智能格式化数值：有小数则显示小数，整数则不显示小数点
 * @param {Number|String} value - 要格式化的数值
 * @param {Number} maxDecimals - 最多保留几位小数（默认1位）
 * @returns {String} 格式化后的字符串
 */
function formatValue(value, maxDecimals) {
  // 默认保留1位小数
  if (maxDecimals === undefined || maxDecimals === null) {
    maxDecimals = 1;
  }

  // 处理空值
  if (value === null || value === undefined || value === '') {
    return '0';
  }

  // 转换为数字
  var num = parseFloat(value);

  // 无效数字返回原值
  if (isNaN(num)) {
    return value + '';
  }

  // 如果是整数，直接返回整数部分
  if (num === Math.floor(num)) {
    return Math.floor(num) + '';
  }

  // 如果有小数，保留指定位数
  var fixed = num.toFixed(maxDecimals);

  // 移除尾部的0
  var result = fixed;
  while (result.indexOf('.') > -1 && (result.charAt(result.length - 1) === '0' || result.charAt(result.length - 1) === '.')) {
    if (result.charAt(result.length - 1) === '.') {
      result = result.substring(0, result.length - 1);
      break;
    }
    result = result.substring(0, result.length - 1);
  }

  return result;
}

module.exports = {
  formatValue: formatValue
};
