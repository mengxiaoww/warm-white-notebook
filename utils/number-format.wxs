/**
 * 数值格式化工具（WXS模块）
 * 用于在小程序WXML中格式化数值显示
 */

/**
 * 智能格式化数值：保留原始精度，整数不显示小数点
 * @param {Number|String} value - 要格式化的数值
 * @returns {String} 格式化后的字符串
 */
function formatValue(value) {
  // 处理空值
  if (value === null || value === undefined || value === '') {
    return '0';
  }

  // 转换为数字
  var num = parseFloat(value);

  // 无效数字返回原值
  if (isNaN(num)) {
    return value + '';
  }

  // 直接返回原始字符串（保留原始精度）
  return value + '';
}

module.exports = {
  formatValue: formatValue
};
