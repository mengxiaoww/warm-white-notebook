/* ==================== 通用骨架屏样式 ==================== */

.skeleton-wrapper {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  padding: 120rpx 24rpx 24rpx;
  background: linear-gradient(180deg, #FDFCFA 0%, #FAF8F4 100%);
  animation: skeleton-fade-in 0.3s ease-out;
  overflow-y: auto;
}

@keyframes skeleton-fade-in {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

.content-hidden {
  opacity: 0;
  pointer-events: none;
}

.content-visible {
  opacity: 1;
  animation: content-fade-in 0.4s ease-out;
}

@keyframes content-fade-in {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.skeleton-shimmer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.6) 50%,
      transparent 100%);
  animation: skeleton-shimmer 1.5s infinite;
}

@keyframes skeleton-shimmer {
  0% {
    transform: translateX(-100%);
  }

  100% {
    transform: translateX(100%);
  }
}

.skeleton-text {
  background: linear-gradient(90deg, #E8E4DD 0%, #F0EDE8 50%, #E8E4DD 100%);
  border-radius: 8rpx;
  height: 28rpx;
  margin: 8rpx 0;
}

.skeleton-text-date {
  width: 160rpx;
  height: 36rpx;
}

.skeleton-text-label {
  width: 120rpx;
  height: 32rpx;
}

/* 日期选择骨架 */
.skeleton-date-section {
  margin-bottom: 32rpx;
}

.skeleton-date-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(212, 165, 116, 0.08);
}

/* 表单骨架 */
.skeleton-form {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.skeleton-form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(212, 165, 116, 0.06);
}

.skeleton-input {
  width: 200rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #E8E4DD 0%, #F0EDE8 100%);
  border-radius: 12rpx;
}

/* 按钮骨架 */
.skeleton-actions {
  display: flex;
  gap: 16rpx;
  position: fixed;
  bottom: 40rpx;
  left: 24rpx;
  right: 24rpx;
}

.skeleton-button {
  flex: 1;
  height: 92rpx;
  background: linear-gradient(135deg, #E8E4DD 0%, #F0EDE8 100%);
  border-radius: 46rpx;
}

.skeleton-button-config {
  flex: 0 0 180rpx;
}

.skeleton-button-save {
  background: linear-gradient(135deg, #FFD4A3 0%, #FFCC80 100%);
}