/**app.wxss**/

/* 全局颜色变量 - 统一橘黄主题 - 消除所有棕色 */
page {
  /* === 核心色彩系统 - 统一纯正橘黄色调 === */
  
  /* 主色调 - 纯正橘黄色（完全统一） */
  --primary-color: #FFB84D;        /* 主橘黄色 */
  --primary-light: #FFCC80;        /* 浅橘黄色 */
  --primary-dark: #FF9800;         /* 深橘黄色 */
  --primary-accent: #FFF4E6;       /* 极浅橘黄色 */
  
  /* 阴影和边框 - 使用橘黄色系替代棕色 */
  --shadow-primary: rgba(255, 184, 77, 0.15);
  --shadow-hover: rgba(255, 184, 77, 0.3);
  --shadow-active: rgba(255, 184, 77, 0.4);
  --border-primary: rgba(255, 184, 77, 0.2);
  --border-light: rgba(255, 184, 77, 0.1);
  --border-medium: rgba(255, 184, 77, 0.15);
  
  /* 背景色系 - 极简白色系 */
  --bg-color: #FFFFFF;             /* 主背景 - 纯白 */
  --bg-secondary: #FEFEFE;         /* 次背景 - 微白 */  
  --bg-tertiary: #FDFDFD;          /* 三级背景 - 浅白 */
  --bg-surface: #FFFFFF;           /* 卡片背景 - 纯白 */
  --bg-elevated: #FFFFFF;          /* 悬浮背景 - 纯白 */
  
  /* 文字色系 - 现代化层次 */
  --text-primary: #333333;         /* 主文字 - 深灰 */
  --text-secondary: #666666;       /* 次文字 - 中灰 */
  --text-tertiary: #999999;        /* 辅助文字 - 浅灰 */
  --text-hint: #CCCCCC;            /* 提示文字 - 极浅灰 */
  --text-white: #FFFFFF;           /* 白色文字 */
  --text-accent: #FF9800;          /* 强调文字 - 深橘黄 */
  
  /* 透明度变量 - 精细控制 */
  --primary-alpha-02: rgba(212, 165, 116, 0.02);
  --primary-alpha-03: rgba(212, 165, 116, 0.03);
  --primary-alpha-04: rgba(212, 165, 116, 0.04);
  --primary-alpha-05: rgba(212, 165, 116, 0.05);
  --primary-alpha-06: rgba(212, 165, 116, 0.06);
  --primary-alpha-08: rgba(212, 165, 116, 0.08);
  --primary-alpha-10: rgba(212, 165, 116, 0.10);
  --primary-alpha-12: rgba(212, 165, 116, 0.12);
  --primary-alpha-14: rgba(212, 165, 116, 0.14);
  --primary-alpha-15: rgba(212, 165, 116, 0.15);
  --primary-alpha-16: rgba(212, 165, 116, 0.16);
  --primary-alpha-18: rgba(212, 165, 116, 0.18);
  --primary-alpha-19: rgba(212, 165, 116, 0.19);
  --primary-alpha-20: rgba(212, 165, 116, 0.20);
  --primary-alpha-24: rgba(212, 165, 116, 0.24);
  --primary-alpha-25: rgba(212, 165, 116, 0.25);
  --primary-alpha-30: rgba(212, 165, 116, 0.30);
  --primary-alpha-40: rgba(212, 165, 116, 0.40);
  --primary-alpha-50: rgba(212, 165, 116, 0.50);
  --primary-alpha-60: rgba(212, 165, 116, 0.60);
  --primary-alpha-80: rgba(212, 165, 116, 0.80);
  --primary-alpha-90: rgba(212, 165, 116, 0.90);
  --primary-alpha-95: rgba(212, 165, 116, 0.95);
  
  /* 边框系统 - 微妙层次 */
  --border-color: rgba(212, 165, 116, 0.12);
  --border-light: rgba(212, 165, 116, 0.08);
  --border-subtle: rgba(0, 0, 0, 0.06);
  
  /* 阴影系统 - 现代化深度 */
  --shadow-primary: rgba(212, 165, 116, 0.08);
  --shadow-light: rgba(212, 165, 116, 0.05);
  --shadow-card: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  --shadow-elevated: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  --shadow-accent: 0 4rpx 16rpx rgba(212, 165, 116, 0.12);
  
  /* === 精美色值映射 === */
  --color-white-pure: #FFFFFF;
  --color-white-warm: #FEFEFE;     /* 温暖白 */
  --color-white-soft: #FDFDFD;     /* 柔和白 */
  --color-white-cream: #FCFCFC;    /* 奶白色 */
  
  /* 半透明背景变量 - 用于功能项 */
  --bg-function-item: rgba(255, 255, 255, 0.8); /* 功能项背景 */
  --bg-function-item-hover: rgba(255, 255, 255, 0.95); /* 悬浮态背景 */
  --bg-function-item-active: rgba(255, 255, 255, 1); /* 激活态背景 */
  
  /* 橘黄色系 - 淡雅渐变 */
  --color-orange-50: #FFF4E6;      /* 极浅橘黄 */
  --color-orange-100: #FFE0B2;     /* 浅橘黄 */
  --color-orange-200: #FFCC80;     /* 亮橘黄 */
  --color-orange-300: #FFB74D;     /* 标准橘黄 */
  --color-orange-400: #FFB84D;     /* 主橘黄 */
  --color-orange-500: #FFB84D;     /* 深橘黄 */
  --color-orange-600: #FFB84D;     /* 浓橘黄 */
  --color-orange-700: #FF9800;     /* 深沉橘黄 */
  --color-orange-800: #EF6C00;     /* 重橘黄 */
  --color-orange-900: #FF9800;     /* 最深橘黄 */
  
  /* 中性灰色系 - 温暖调性 */
  --color-gray-50: #FAFAFA;
  --color-gray-100: #F5F5F5;
  --color-gray-200: #EEEEEE;
  --color-gray-300: #E0E0E0;
  --color-gray-400: #BDBDBD;
  --color-gray-500: #9E9E9E;
  --color-gray-600: #757575;
  --color-gray-700: #616161;
  --color-gray-800: #424242;
  --color-gray-900: #212121;

  /* 圆角系统 - 现代化设计 */
  --border-radius-sm: 10rpx;
  --border-radius-md: 14rpx;
  --border-radius-lg: 18rpx;
  --border-radius-xl: 24rpx;
  --border-radius-2xl: 32rpx;
  
  /* === 语义化颜色 === */
  --success-color: #52C41A;        /* 成功色 */
  --warning-color: #FA8C16;        /* 警告色 */  
  --error-color: #FF4D4F;          /* 错误色 */
  --info-color: #1890FF;           /* 信息色 */
  
  /* === 立体渐变效果 === */
  --gradient-3d-primary: linear-gradient(135deg, 
    var(--primary-alpha-15) 0%,
    var(--primary-alpha-12) 50%,
    var(--primary-alpha-08) 100%
  );
  --gradient-3d-light: linear-gradient(135deg, 
    var(--primary-alpha-10) 0%,
    var(--primary-alpha-15) 50%,
    var(--primary-alpha-08) 100%
  );
  --gradient-3d-active: linear-gradient(135deg, 
    var(--primary-alpha-25) 0%,
    var(--primary-alpha-20) 50%,
    var(--primary-alpha-15) 100%
  );
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 200rpx;
  box-sizing: border-box;
}

/* ==================== 全局统一按钮样式 ==================== */
/* 圆形图标按钮风格 - 类似"我的"页面 */
.unified-btn-item {
  display: flex;
  align-items: center;
  padding: 28rpx 16rpx;
  background: var(--bg-surface);
  border: 1rpx solid var(--border-subtle);
  width: 100%;
  text-align: left;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border-radius: 16rpx;
  position: relative;
  margin-bottom: 12rpx;
  box-shadow: 
    0 2rpx 8rpx var(--primary-alpha-06),
    0 1rpx 4rpx var(--primary-alpha-04),
    0 1rpx 2rpx rgba(0, 0, 0, 0.02);
}

.unified-btn-item:hover {
  background: var(--primary-alpha-03);
  box-shadow: 
    0 4rpx 12rpx var(--primary-alpha-08),
    0 2rpx 6rpx var(--primary-alpha-06),
    0 1rpx 3rpx rgba(0, 0, 0, 0.04);
}

.unified-btn-item:active {
  transform: scale(0.98);
  background: var(--primary-alpha-08);
  box-shadow: 
    0 1rpx 4rpx var(--primary-alpha-06),
    0 1rpx 2rpx var(--primary-alpha-04),
    0 0rpx 1rpx rgba(0, 0, 0, 0.02);
}

.unified-btn-item:last-child {
  margin-bottom: 0;
}

/* 圆形图标容器 */
.unified-btn-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: var(--gradient-3d-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  box-shadow: 
    0 6rpx 16rpx var(--primary-alpha-15),
    0 3rpx 8rpx var(--primary-alpha-10),
    0 2rpx 4rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid var(--primary-alpha-20);
  position: relative;
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  flex-shrink: 0;
}

/* 圆形图标容器的高光效果 */
.unified-btn-icon::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 255, 255, 0.7) 50%, 
    transparent 100%
  );
  border-radius: 40rpx 40rpx 0 0;
}

/* 图标内的emoji或文字 */
.unified-btn-icon-text {
  font-size: 36rpx;
  color: var(--primary-color);
  font-weight: 700;
}

/* 按钮信息区 */
.unified-btn-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.unified-btn-title {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
  line-height: 1.3;
}

.unified-btn-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
  line-height: 1.3;
}

/* 箭头指示器 */
.unified-btn-arrow {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--gradient-3d-light);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 
    0 4rpx 12rpx var(--primary-alpha-12),
    0 2rpx 6rpx var(--primary-alpha-08);
  border: 1rpx solid var(--primary-alpha-20);
  transition: all 0.3s ease;
  color: var(--text-secondary);
  font-size: 28rpx;
  font-weight: 600;
}

.unified-btn-item:active .unified-btn-arrow {
  background: var(--gradient-3d-active);
  box-shadow: 
    0 2rpx 6rpx var(--primary-alpha-15),
    inset 0 2rpx 4rpx var(--primary-alpha-10);
  transform: scale(0.9);
  color: var(--primary-color);
}

.unified-btn-item:active .unified-btn-icon {
  background: var(--gradient-3d-active);
  box-shadow: 
    0 3rpx 8rpx var(--primary-alpha-18),
    0 2rpx 4rpx var(--primary-alpha-12),
    inset 0 2rpx 4rpx var(--primary-alpha-10);
  transform: scale(0.95);
}

/* ==================== 健康档案页面记录项优化样式 ==================== */
/* 记录标题样式优化 */
.record-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

/* 状态指示器全局样式 */
.status-indicator {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
  position: relative;
  animation: pulse 2s infinite;
}

.status-indicator.normal {
  background: var(--success-color);
  box-shadow: 0 0 8rpx rgba(82, 196, 26, 0.4);
}

.status-indicator.abnormal {
  background: var(--error-color);
  box-shadow: 0 0 8rpx rgba(255, 77, 79, 0.4);
}

@keyframes pulse {
  0%, 100% { 
    opacity: 1; 
    transform: scale(1);
  }
  50% { 
    opacity: 0.8; 
    transform: scale(1.1);
  }
}

/* 记录摘要样式优化 */
.record-summary {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

/* ==================== 统一功能项分隔线系统 ==================== */
/* 分隔线样式变量 - 根据新的布局调整 */
:root {
  --divider-gradient: linear-gradient(90deg, 
    var(--primary-alpha-15) 0%,
    var(--primary-alpha-08) 40%,
    var(--primary-alpha-03) 80%,
    transparent 100%
  );
  --divider-height: 1rpx;
  --divider-left-offset: 120rpx; /* 20rpx padding + 80rpx图标 + 20rpx间距 */
  --divider-right-offset: 60rpx; /* 增加右侧空间，给日期和箭头更多距离 */
  --divider-margin-bottom: 20rpx; /* 分隔线距离底部的距离 */
}

/* 统一功能项样式 - 高级统一风格 */
.function-item {
  box-sizing: border-box;
  position: relative !important;
  display: flex !important;
  align-items: center !important;
  padding: 32rpx 45rpx !important;
  background: linear-gradient(145deg, 
    #FFFFFF 0%, 
    #FEFEFE 50%, 
    #FCFCFC 100%
  ) !important;
  border: 1rpx solid rgba(212, 165, 116, 0.15) !important;
  box-shadow: 
    0 8rpx 24rpx rgba(212, 165, 116, 0.1),
    0 4rpx 12rpx rgba(212, 165, 116, 0.06),
    0 2rpx 6rpx rgba(0, 0, 0, 0.03) !important;
  width: calc(100% - 32rpx) !important;
  text-align: left !important;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
  border-radius: 24rpx !important;
  margin: 12rpx !important;
  backdrop-filter: blur(12rpx) !important;
  overflow: hidden !important;
}

.function-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 184, 77, 0.5) 50%, 
    transparent 100%
  );
  opacity: 0;
  transition: opacity 0.3s ease;
}

.function-item:active {
  transform: scale(0.98) translateY(2rpx) !important;
  background: linear-gradient(145deg, 
    #FFF8F0 0%, 
    #FFF5E6 50%, 
    #FFF2DC 100%
  ) !important;
  border-color: rgba(212, 165, 116, 0.2) !important;
  box-shadow: 
    0 4rpx 12rpx rgba(212, 165, 116, 0.12),
    0 2rpx 6rpx rgba(212, 165, 116, 0.08) !important;
}

.function-item:active::before {
  opacity: 1;
}

/* 功能项图标样式 - 高级质感 */
.function-icon {
  width: 80rpx !important;
  height: 80rpx !important;
  border-radius: 20rpx !important;
  background: linear-gradient(135deg, 
    rgba(255, 184, 77, 0.15) 0%, 
    rgba(255, 204, 128, 0.1) 100%
  ) !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  margin-right: 32rpx !important;
  box-shadow: 
    0 4rpx 12rpx rgba(255, 184, 77, 0.12),
    0 2rpx 6rpx rgba(255, 184, 77, 0.08),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.6) !important;
  border: 1rpx solid rgba(255, 184, 77, 0.1) !important;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
  position: relative !important;
  overflow: hidden !important;
  flex-shrink: 0 !important;
}

.function-icon::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 255, 255, 0.8) 50%, 
    transparent 100%
  );
  border-radius: 20rpx 20rpx 0 0;
}

.function-item:active .function-icon {
  transform: scale(1.05) rotate(2deg) !important;
  background: linear-gradient(135deg, 
    rgba(255, 184, 77, 0.25) 0%, 
    rgba(255, 204, 128, 0.18) 100%
  ) !important;
}

/* 功能项信息区域 - 提高权重确保显示 */
.function-info {
  margin-right: 10rpx;
  flex: 1 !important;
}

.function-title {
  display: block !important;
  font-size: 34rpx !important;
  background: linear-gradient(135deg, 
    #FF9800 0%, 
    #FFB84D 100%
  ) !important;
  background-clip: text !important;
  -webkit-background-clip: text !important;
  -webkit-text-fill-color: transparent !important;
  color: transparent !important;
  font-weight: 700 !important;
  margin-bottom: 8rpx !important;
  letter-spacing: 0.5rpx !important;
  line-height: 1.2 !important;
}

.function-desc {
  font-size: 26rpx !important;
  color: #999 !important;
  font-weight: 500 !important;
  opacity: 0.9 !important;
  line-height: 1.3 !important;
  letter-spacing: 0.3rpx !important;
}

/* 功能项箭头样式 - 精致设计 */
.function-arrow {
  width: 40rpx !important;
  height: 40rpx !important;
  border-radius: 50% !important;
  background: linear-gradient(135deg, 
    rgba(255, 184, 77, 0.08) 0%, 
    rgba(255, 204, 128, 0.05) 100%
  ) !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  box-shadow: 
    0 2rpx 6rpx rgba(255, 184, 77, 0.1),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.5) !important;
  border: 1rpx solid rgba(255, 184, 77, 0.08) !important;
  transition: all 0.3s ease !important;
}

.function-item:active .function-arrow {
  transform: scale(0.9) rotate(-5deg) !important;
  background: linear-gradient(135deg, 
    rgba(255, 184, 77, 0.15) 0%, 
    rgba(255, 204, 128, 0.1) 100%
  ) !important;
  box-shadow: 
    0 1rpx 3rpx rgba(255, 184, 77, 0.15),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.6) !important;
}

/* 统一分隔线样式 - 重新设计位置和样式 */
.function-item::after {
  content: '' !important;
  position: absolute !important;
  bottom: var(--divider-margin-bottom) !important; /* 不贴底部 */
  left: var(--divider-left-offset) !important;
  right: var(--divider-right-offset) !important;
  height: var(--divider-height) !important;
  background: var(--divider-gradient) !important;
  z-index: 1 !important;
  border-radius: 1rpx !important; /* 轻微圆角 */
}

/* 最后一个功能项不显示分隔线 */
.function-item:last-child::after {
  display: none !important;
}

/* 摘要标签全局样式 */
.summary-chip {
  font-size: 24rpx;
  color: var(--text-secondary);
  background: var(--gradient-3d-light);
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--primary-alpha-10);
  font-weight: 500;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.summary-chip::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, 
    transparent 0%, 
    var(--primary-alpha-08) 50%, 
    transparent 100%
  );
  transition: left 0.5s ease;
}

.unified-btn-item:active .summary-chip::before {
  left: 100%;
}

/* 特殊状态标签样式 */
.summary-chip.status-chip.normal {
  background: rgba(82, 196, 26, 0.1);
  border-color: rgba(82, 196, 26, 0.2);
  color: var(--success-color);
}

.summary-chip.status-chip.abnormal {
  background: rgba(255, 77, 79, 0.1);
  border-color: rgba(255, 77, 79, 0.2);
  color: var(--error-color);
}

/* 日期头部全局样式 */
.date-header {
  margin: 32rpx 0 20rpx 0;
  position: relative;
  display: flex;
  align-items: center;
}

/* 健康档案页面记录列表优化 */
.records-list {
  box-sizing: border-box;
  width: 100%;
  padding: 0 24rpx;
}

.day-record {
  margin-bottom: 32rpx;
}

.day-record:last-child {
  margin-bottom: 24rpx;
}

/* 记录项容器统一间距已在主定义中设置 */

.date-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-right: 16rpx;
}

.weekday-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  background: var(--gradient-3d-light);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

/* ==================== 用药档案页面优化样式 ==================== */
/* 日期显示优化 */
.date-display {
  flex: 1;
}

.date-display .date-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.date-indicator {
  font-size: 24rpx;
  color: var(--text-tertiary);
  background: var(--gradient-3d-light);
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  display: inline-block;
}

/* 用药记录项优化 */
.daily-record-item {
  background: var(--bg-surface);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--border-light);
  transition: all 0.3s ease;
  overflow: hidden;
}

.daily-record-item:active {
  transform: scale(0.98);
  background: var(--primary-alpha-04);
  border-color: var(--primary-alpha-12);
}

.daily-record-wrapper {
  padding: 20rpx;
}

.daily-record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

/* 用药预览优化 */
.daily-medicines-preview {
  background: var(--primary-alpha-04);
  border-radius: 12rpx;
  padding: 16rpx;
  border: 1rpx solid var(--border-light);
}

.medicine-preview-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.medicine-preview-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.medicine-info {
  flex: 1;
}

.medicine-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.medicine-dosage {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.medicine-times {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.times-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.completion-indicator {
  background: var(--gradient-3d-light);
  border-radius: 8rpx;
  padding: 2rpx 8rpx;
}

.completion-text {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--primary-color);
}

/* 统一添加按钮样式 - 高级质感 */
.add-record-btn {
  background: linear-gradient(135deg, 
    #FF9800 0%, 
    #FFB84D 50%, 
    #F57C00 100%
  ) !important;
  border: none !important;
  border-radius: 18rpx !important;
  padding: 12rpx 20rpx !important;
  font-size: 28rpx !important;
  font-weight: 600 !important;
  color: #FFFFFF !important;
  letter-spacing: 0.5rpx !important;
  box-shadow: 
    0 6rpx 16rpx rgba(255, 152, 0, 0.3),
    0 3rpx 8rpx rgba(255, 152, 0, 0.2),
    0 1rpx 4rpx rgba(0, 0, 0, 0.1) !important;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
  position: relative !important;
  overflow: hidden !important;
}

.add-record-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 255, 255, 0.8) 50%, 
    transparent 100%
  );
  border-radius: 18rpx 18rpx 0 0;
}

.add-record-btn:active {
  transform: scale(0.96) translateY(2rpx) !important;
  background: linear-gradient(135deg, 
    #E6850E 0%, 
    #FF9800 50%, 
    #CC6600 100%
  ) !important;
  box-shadow: 
    0 3rpx 8rpx rgba(255, 152, 0, 0.35),
    0 1rpx 4rpx rgba(255, 152, 0, 0.25) !important;
}

