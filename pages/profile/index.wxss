/* pages/profile/index.wxss */

/* ==================== 骨架屏加载动画 ==================== */
.page-wrapper {
  min-height: 100vh;
  background: linear-gradient(135deg, #FDFCFA 0%, #FAF8F4 30%, #F7F4EF 70%, #FDFCFA 100%);
  position: relative;
}

.skeleton-wrapper {
  padding: 32rpx 24rpx;
  animation: skeleton-fade-in 0.3s ease-out;
}

@keyframes skeleton-fade-in {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

.content-hidden {
  opacity: 0;
  pointer-events: none;
}

.content-visible {
  opacity: 1;
  animation: content-fade-in 0.4s ease-out;
}

@keyframes content-fade-in {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.skeleton-shimmer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.6) 50%,
      transparent 100%);
  animation: skeleton-shimmer 1.5s infinite;
}

@keyframes skeleton-shimmer {
  0% {
    transform: translateX(-100%);
  }

  100% {
    transform: translateX(100%);
  }
}

.skeleton-text {
  background: linear-gradient(90deg, #E8E4DD 0%, #F0EDE8 50%, #E8E4DD 100%);
  border-radius: 8rpx;
  height: 28rpx;
  margin: 8rpx 0;
}

.skeleton-text-name {
  width: 150rpx;
  height: 36rpx;
}

.skeleton-text-title {
  width: 120rpx;
}

.skeleton-text-short {
  width: 40%;
}

.skeleton-text-medium {
  width: 60%;
}

.skeleton-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8E4DD 0%, #F0EDE8 100%);
}

.skeleton-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8E4DD 0%, #F0EDE8 100%);
}

.skeleton-avatar-large {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8E4DD 0%, #F0EDE8 100%);
}

/* 用户卡片骨架 */
.skeleton-user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(212, 165, 116, 0.08);
}

.skeleton-user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* 档案列表骨架 */
.skeleton-section {
  margin-bottom: 24rpx;
}

.skeleton-section-header {
  padding: 16rpx 0;
  margin-bottom: 16rpx;
}

.skeleton-profile-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.skeleton-profile-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(212, 165, 116, 0.06);
}

.skeleton-profile-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.skeleton-tags {
  display: flex;
  gap: 8rpx;
}

.skeleton-tag {
  width: 80rpx;
  height: 32rpx;
  background: linear-gradient(135deg, #E8E4DD 0%, #F0EDE8 100%);
  border-radius: 16rpx;
}

/* 功能菜单骨架 */
.skeleton-menu {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.skeleton-menu-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(212, 165, 116, 0.06);
}

.container {
  padding: 20rpx 0 150rpx 0;
  background: linear-gradient(135deg, #FDFCFA 0%, #FAF8F4 30%, #F7F4EF 70%, #FDFCFA 100%);
  min-height: 100vh;
  overflow-y: auto;
  position: relative;
}

/* 容器背景装饰 */
.container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(circle at 85% 15%, rgba(212, 165, 116, 0.03) 0%, transparent 50%),
    radial-gradient(circle at 15% 85%, rgba(212, 165, 116, 0.02) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

/* 用户信息区域 */
.user-info-section {
  width: 712rpx;
  margin: 0 auto;
  display: flex;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.user-card {
  width: 100%;
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 50%, #FFB84D 100%);
  border-radius: 32rpx;
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  box-shadow:
    0 16rpx 40rpx rgba(212, 165, 116, 0.35),
    0 8rpx 20rpx rgba(212, 165, 116, 0.25),
    0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  position: relative;
  overflow: hidden;
  transform: translateZ(0);
}

/* 用户卡片现代化装饰效果 */
.user-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.8) 30%,
      rgba(255, 255, 255, 1) 50%,
      rgba(255, 255, 255, 0.8) 70%,
      transparent 100%);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 2;
}

.user-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(circle at 20% 30%, rgba(255, 255, 255, 0.15) 0%, transparent 40%),
    radial-gradient(circle at 80% 70%, rgba(255, 255, 255, 0.10) 0%, transparent 40%);
  border-radius: 32rpx;
  z-index: 1;
}


.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  margin-right: 40rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  box-shadow:
    0 12rpx 24rpx rgba(212, 165, 116, 0.4),
    0 6rpx 12rpx rgba(0, 0, 0, 0.15),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.5);
  position: relative;
  z-index: 3;
  flex-shrink: 0;
}

.user-details {
  flex: 1;
  color: white;
  position: relative;
  z-index: 3;
}

.edit-user-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 3;
  margin-left: 20rpx;
  flex-shrink: 0;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.edit-user-btn:active {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 0.3);
}

.user-name {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  letter-spacing: 1rpx;
}

.login-time {
  font-size: 28rpx;
  opacity: 0.9;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.2);
}

.login-prompt {
  width: 620rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 0 0 80rpx 0;
  text-align: center;
  box-shadow:
    0 20rpx 60rpx rgba(212, 165, 116, 0.2),
    0 12rpx 30rpx rgba(212, 165, 116, 0.15),
    0 6rpx 15rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  position: relative;
  transform: translateY(0);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  border: 1rpx solid rgba(212, 165, 116, 0.2);
  z-index: 1;
}

.login-prompt:hover {
  transform: translateY(-6rpx);
  box-shadow:
    0 24rpx 70rpx rgba(212, 165, 116, 0.25),
    0 16rpx 40rpx rgba(212, 165, 116, 0.18),
    0 8rpx 20rpx rgba(0, 0, 0, 0.1);
}

.login-background {
  background: linear-gradient(135deg,
      rgba(212, 165, 116, 0.08) 0%,
      rgba(212, 165, 116, 0.12) 50%,
      rgba(212, 165, 116, 0.06) 100%);
  padding: 70rpx 50rpx 50rpx 50rpx;
  position: relative;
  overflow: hidden;
}

.login-background::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(212, 165, 116, 0.3) 30%,
      rgba(212, 165, 116, 0.5) 50%,
      rgba(212, 165, 116, 0.3) 70%,
      transparent 100%);
  border-radius: 32rpx 32rpx 0 0;
}

.login-background::after {
  content: '';
  position: absolute;
  top: 20rpx;
  right: 30rpx;
  width: 100rpx;
  height: 100rpx;
  background:
    radial-gradient(circle at 30% 30%, rgba(212, 165, 116, 0.15) 0%, transparent 50%),
    radial-gradient(circle at 70% 70%, rgba(212, 165, 116, 0.08) 0%, transparent 50%);
  border-radius: 50%;
  opacity: 0.6;
}


.login-content {
  margin-bottom: 50rpx;
  position: relative;
  z-index: 2;
}

/* 登录卡片底部现代化装饰 */
.login-prompt::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 80rpx;
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%);
  z-index: 1;
  border-radius: 0 0 32rpx 32rpx;
  box-shadow:
    inset 0 3rpx 6rpx rgba(255, 255, 255, 0.3),
    0 8rpx 24rpx rgba(212, 165, 116, 0.4);
}

/* 现代化装饰图案 */
.login-prompt::before {
  content: '';
  position: absolute;
  bottom: 80rpx;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(212, 165, 116, 0.4) 20%,
      rgba(212, 165, 116, 0.6) 50%,
      rgba(212, 165, 116, 0.4) 80%,
      transparent 100%);
  z-index: 2;
}

/* 底部金色区域内的装饰 */
.login-background::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: 0;
  right: 0;
  height: 30rpx;
  background:
    radial-gradient(ellipse 60rpx 15rpx at 20% center, rgba(255, 255, 255, 0.2) 0%, transparent 100%),
    radial-gradient(ellipse 40rpx 10rpx at 80% center, rgba(255, 255, 255, 0.15) 0%, transparent 100%),
    radial-gradient(ellipse 80rpx 20rpx at 50% center, rgba(255, 255, 255, 0.1) 0%, transparent 100%);
  z-index: 3;
}

.login-icon-wrapper {
  margin-bottom: 40rpx;
  position: relative;
  display: inline-block;
}

.login-icon-wrapper::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 160rpx;
  background: radial-gradient(circle,
      rgba(212, 165, 116, 0.2) 0%,
      rgba(212, 165, 116, 0.1) 50%,
      transparent 70%);
  border-radius: 50%;
  opacity: 0.6;
  animation: gentlePulse 3s ease-in-out infinite;
}

@keyframes gentlePulse {

  0%,
  100% {
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.6;
  }

  50% {
    transform: translate(-50%, -50%) scale(1.05);
    opacity: 0.3;
  }
}

.login-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #FF9800 0%, #FF9800 100%);
  background-clip: text;
  -webkit-background-clip: text;
  color: transparent;
  margin-bottom: 20rpx;
  text-shadow: 0 3rpx 6rpx rgba(0, 0, 0, 0.15);
  position: relative;
  letter-spacing: 1rpx;
}

.login-title::after {
  content: '';
  position: absolute;
  bottom: -12rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 4rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(212, 165, 116, 0.6) 50%,
      transparent 100%);
  border-radius: 2rpx;
}

.login-subtitle {
  display: block;
  font-size: 30rpx;
  color: #FF9800;
  margin-bottom: 50rpx;
  line-height: 1.6;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.08);
  opacity: 0.95;
  font-weight: 400;
  letter-spacing: 0.5rpx;
}

.login-btn {
  margin-top: 50rpx;
  margin-bottom: 30rpx;
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%);
  color: white;
  padding: 32rpx 56rpx;
  text-align: center;
  border-radius: 50rpx;
  box-shadow:
    0 12rpx 32rpx rgba(212, 165, 116, 0.35),
    0 6rpx 16rpx rgba(212, 165, 116, 0.25),
    0 3rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  z-index: 4;
  border: none;
  outline: none;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.login-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.8) 50%,
      transparent 100%);
  border-radius: 50rpx 50rpx 0 0;
}

.login-btn:hover {
  transform: translateY(-3rpx);
  box-shadow:
    0 16rpx 40rpx rgba(212, 165, 116, 0.4),
    0 8rpx 20rpx rgba(212, 165, 116, 0.3),
    0 4rpx 12rpx rgba(0, 0, 0, 0.12);
}

.login-btn:active {
  transform: translateY(-1rpx) scale(0.98);
  box-shadow:
    0 8rpx 20rpx rgba(212, 165, 116, 0.3),
    0 4rpx 12rpx rgba(212, 165, 116, 0.2),
    0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.login-btn-text {
  margin-left: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.login-features {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.feature-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 10rpx;
  background: white;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.feature-item text {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.3;
}

.login-icon {
  margin-bottom: 20rpx;
}

.login-text {
  font-size: 32rpx;
  color: var(--text-secondary);
}

/* 个人档案区域 */
.profile-section {
  box-sizing: border-box;
  width: 712rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 20rpx;
  margin: 20rpx auto;
  box-shadow:
    0 16rpx 40rpx rgba(212, 165, 116, 0.15),
    0 8rpx 20rpx rgba(212, 165, 116, 0.12),
    0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(212, 165, 116, 0.15);
  position: relative;
  overflow: hidden;
  z-index: 1;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
  padding-bottom: 25rpx;
  border-bottom: none;
  position: relative;
}

/* 现代化装饰性下划线 */
.section-header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(212, 165, 116, 0.3) 20%,
      rgba(212, 165, 116, 0.6) 50%,
      rgba(212, 165, 116, 0.3) 80%,
      transparent 100%);
  border-radius: 2rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF9800;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 4rpx rgba(107, 91, 71, 0.1);
}

.add-profile-btn {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  background: var(--gradient-3d-primary);
  border-radius: 24rpx;
  color: #FF9800;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow:
    0 6rpx 16rpx rgba(212, 165, 116, 0.2),
    0 3rpx 8rpx rgba(212, 165, 116, 0.15),
    0 2rpx 4rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(212, 165, 116, 0.25);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  letter-spacing: 0.5rpx;
}

.add-profile-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.8) 50%,
      transparent 100%);
  border-radius: 24rpx 24rpx 0 0;
}

.add-profile-btn:active {
  background: var(--gradient-3d-active);
  box-shadow:
    0 3rpx 8rpx rgba(212, 165, 116, 0.25),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.6);
  transform: translateY(1rpx);
}

.add-profile-btn text {
  margin-left: 8rpx;
}

.profile-list {}

.profile-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 40rpx;
  border-bottom: none;
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow:
    0 8rpx 20rpx rgba(212, 165, 116, 0.12),
    0 4rpx 10rpx rgba(212, 165, 116, 0.08),
    0 2rpx 6rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(212, 165, 116, 0.1);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.profile-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.9) 50%,
      transparent 100%);
  border-radius: 20rpx 20rpx 0 0;
}

.profile-item:active {
  background: #FDFCFA;
  box-shadow:
    0 4rpx 12rpx rgba(212, 165, 116, 0.15),
    0 2rpx 6rpx rgba(212, 165, 116, 0.1),
    0 1rpx 3rpx rgba(0, 0, 0, 0.06);
  transform: translateY(1rpx) scale(0.995);
}

.profile-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
}

.profile-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.profile-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #FFB84D 0%, #FF9800 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  box-shadow:
    0 6rpx 16rpx rgba(212, 165, 116, 0.3),
    0 3rpx 8rpx rgba(212, 165, 116, 0.2),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3);
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  flex-shrink: 0;
}

.profile-initial {
  color: white;
  font-size: 36rpx;
  font-weight: 700;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
  letter-spacing: 1rpx;
}

.profile-details {
  flex: 1;
}

.profile-name {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #3C3C3C;
  margin-bottom: 10rpx;
  letter-spacing: 0.5rpx;
}

.profile-real-name {
  display: block;
  font-size: 28rpx;
  color: #FF9800;
  margin-bottom: 10rpx;
  font-weight: 400;
}

.profile-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  align-items: center;
  max-width: 100%;
}

.profile-tag {
  font-size: 22rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-weight: 500;
  letter-spacing: 0.5rpx;
  white-space: nowrap;
  flex-shrink: 0;
  height: auto;
}

.profile-tag:not(.current):not(.disease):not(.default) {
  color: #FF9800;
  background: rgba(212, 165, 116, 0.12);
  border: 1rpx solid rgba(212, 165, 116, 0.25);
}

.profile-tag.default {
  color: #FF9800;
  background: rgba(212, 165, 116, 0.18);
  font-weight: 600;
  border: 1rpx solid rgba(212, 165, 116, 0.35);
  box-shadow: 0 2rpx 4rpx rgba(212, 165, 116, 0.15);
}

.profile-tag.current {
  color: #FF9800;
  background: rgba(212, 165, 116, 0.15);
