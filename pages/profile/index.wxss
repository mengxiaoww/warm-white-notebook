  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
  transition: all 0.3s ease;
}

.back-icon:active {
  background: #e0e0e0;
  transform: scale(0.95);
}

.disease-popup-title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 1rpx;
}

.disease-close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
  transition: all 0.3s ease;
}

.disease-close-btn:active {
  background: #e0e0e0;
  transform: scale(0.95);
}

.disease-popup-scroll {
  flex: 1;
  background: #f5f5f5;
  overflow-y: scroll;
  -webkit-overflow-scrolling: touch;
}

.disease-popup-body {
  padding: 30rpx;
}

.level-content {
  opacity: 1;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateX(20rpx);
  }

  to {
    opacity: 1;
    transform: translateX(0);
  }
}

/* 分类网格 */
.category-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.category-item {
  position: relative;
  padding: 32rpx 24rpx;
  background: white;
  border-radius: 20rpx;
  text-align: center;
  border: 2rpx solid #f0f0f0;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.category-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-color) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.category-item:active {
  transform: scale(0.98);
}

.category-item.selected {
  background: white;
  border-color: var(--primary-dark);
  box-shadow: 0 4rpx 20rpx rgba(255, 143, 0, 0.2);
}

.category-item.selected::before {
  opacity: 0.08;
}

.category-item text {
  position: relative;
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 600;
  display: block;
  line-height: 1.4;
}

.category-item.selected text {
  color: var(--primary-dark);
}

.category-count {
  position: relative;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
  font-weight: normal;
}

.category-item.selected .category-count {
  color: var(--primary-light);
}

.category-code {
  position: relative;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
  font-weight: normal;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.category-item.selected .category-code {
  background: rgba(255, 143, 0, 0.1);
  color: var(--primary-dark);
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
  line-height: 1.6;
}

/* 反馈弹窗样式 */
.edit-form-scroll {
  flex: 1;
  background: white;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.edit-form {
  padding: 30rpx;
  background: white;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.feedback-textarea {
  width: 100%;
  min-height: 280rpx;
  background: #f8f9fa;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  resize: none;
  line-height: 1.6;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  -webkit-appearance: none;
  -webkit-tap-highlight-color: transparent;
  display: block;
  outline: none;
  color: var(--text-primary);
}

.feedback-textarea:focus {
  background: #FFFFFF;
  border-color: #FFB84D;
  box-shadow:
    0 4rpx 12rpx rgba(212, 165, 116, 0.15),
    0 2rpx 6rpx rgba(212, 165, 116, 0.1);
  transform: translateY(-1rpx);
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
}

/* 确保弹窗内容结构合理 */
.popup-content {
  background: white;
  border-radius: 24rpx 24rpx 0 0;
  width: 100vw;
  height: auto;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
  flex-shrink: 0;
  background: white;
}

.popup-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.close-btn {
  padding: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 开关容器样式 */
.switch-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.switch-hint {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-left: 20rpx;
}

/* 处理iOS设备的输入框样式 */
.form-input::placeholder,
.feedback-textarea::placeholder {
  color: var(--text-tertiary);
  font-size: 28rpx;
}

/* 确保在小屏幕设备上的显示 */
@media screen and (max-height: 600px) {
  .popup-content {
    max-height: 90vh;
  }
}

/* 立体化反馈提交按钮 */
.feedback-submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%);
  color: white;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow:
    0 8rpx 24rpx rgba(212, 165, 116, 0.3),
    0 4rpx 12rpx rgba(212, 165, 116, 0.2),
    0 2rpx 6rpx rgba(0, 0, 0, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  position: relative;
  overflow: hidden;
  user-select: none;
  -webkit-tap-highlight-color: transparent;
  letter-spacing: 1rpx;
}

.feedback-submit-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.8) 50%,
      transparent 100%);
  border-radius: 12rpx 12rpx 0 0;
}

.feedback-submit-btn:active {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9800 100%);
  transform: scale(0.96) translateY(2rpx);
  box-shadow:
    0 4rpx 16rpx rgba(212, 165, 116, 0.25),
    0 2rpx 8rpx rgba(212, 165, 116, 0.15),
    0 1rpx 4rpx rgba(0, 0, 0, 0.08);
}

/* 用户信息保存按钮 */
.user-info-save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #FFB84D, #FFA726);
  border-radius: 44rpx;
  color: #FFF;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(255, 184, 77, 0.3);
}

.user-info-save-btn:active {
  opacity: 0.9;
}

/* 🎨 用户信息编辑弹窗样式 */
.user-edit-popup-content {
  background: linear-gradient(to bottom, #FFFBF5 0%, #FFFFFF 100%);
  border-radius: 40rpx 40rpx 0 0;
  padding: 0;
  max-height: 80vh;
  overflow: hidden;
}

.user-edit-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 48rpx 40rpx 32rpx;
  background: linear-gradient(135deg, #FFF9F0 0%, #FFFFFF 100%);
  border-bottom: 2rpx solid rgba(255, 184, 0, 0.1);
  position: relative;
}

.user-edit-header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 40rpx;
  right: 40rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 184, 0, 0.3) 50%, transparent 100%);
}

.user-edit-header-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-edit-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB800 0%, #FF9800 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 184, 0, 0.25), 0 4rpx 12rpx rgba(255, 184, 0, 0.15);
}

.user-edit-header-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.user-edit-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #3C3C3C;
  letter-spacing: 0.5rpx;
}

.user-edit-subtitle {
  font-size: 24rpx;
  color: #999;
  font-weight: 400;
}

.user-edit-close-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.user-edit-close-btn:active {
  background: rgba(0, 0, 0, 0.08);
  transform: scale(0.9);
}

/* 编辑主体区域 */
.user-edit-body {
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 60rpx;
}

/* 头像编辑区域 */
.user-avatar-edit-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.user-avatar-edit-btn {
  width: 200rpx !important;
  height: 200rpx;
  border-radius: 100rpx;
  position: relative;
  overflow: hidden;
  padding: 0;
  background: linear-gradient(135deg, #FFB800 0%, #FF9800 100%);
  box-shadow: 0 12rpx 32rpx rgba(255, 184, 0, 0.3), 0 6rpx 16rpx rgba(255, 184, 0, 0.2), inset 0 -4rpx 8rpx rgba(0, 0, 0, 0.1);
  border: 6rpx solid white;
  transition: all 0.3s ease;
}

.user-avatar-edit-btn::after {
  border: none;
}

.user-avatar-edit-btn:active {
  transform: scale(0.95);
  box-shadow: 0 8rpx 24rpx rgba(255, 184, 0, 0.25), 0 4rpx 12rpx rgba(255, 184, 0, 0.15);
}

.user-avatar-edit-preview {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.user-avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
}

.user-avatar-edit-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.user-avatar-edit-btn:active .user-avatar-edit-overlay {
  opacity: 1;
}

.user-avatar-edit-text {
  font-size: 24rpx;
  color: white;
  font-weight: 500;
}

.user-avatar-hint {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

/* 昵称编辑区域 */
.user-nickname-edit-wrapper {
  display: flex;
  align-items: center;
  background: #FAFAFA;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.user-nickname-edit-wrapper:focus-within {
  border-color: #FFB800;
  background: #FFFBF5;
}

.user-nickname-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.user-nickname-label-text {
  font-size: 30rpx;
  color: #666;
  font-weight: 500;
}

.user-nickname-input-wrapper {
  flex: 1;
}

.user-nickname-input {
  width: 100%;
  font-size: 30rpx;
  color: #333;
  background: transparent;
}

.user-nickname-placeholder {
  color: #C0C0C0;
}

/* 底部操作区 */
.user-edit-footer {
  padding: 32rpx 40rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  background: #FAFAFA;
}

.user-info-save-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FFB800 0%, #FF9800 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 12rpx 32rpx rgba(255, 184, 0, 0.3), 0 6rpx 16rpx rgba(255, 184, 0, 0.2);
  transition: all 0.3s ease;
  color: white;
  font-size: 32rpx;
  font-weight: 600;
}

.user-info-save-btn:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 24rpx rgba(255, 184, 0, 0.25), 0 4rpx 12rpx rgba(255, 184, 0, 0.15);
}

/* 修复安卓设备可能的输入框问题 */