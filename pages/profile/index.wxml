<!-- pages/profile/index.wxml -->
<view class="page-wrapper">
  <!-- 骨架屏加载 -->
  <view class="skeleton-wrapper" wx:if="{{isPageLoading}}">
    <!-- 用户信息骨架 -->
    <view class="skeleton-user-card">
      <view class="skeleton-avatar-large"></view>
      <view class="skeleton-user-info">
        <view class="skeleton-text skeleton-text-name"></view>
        <view class="skeleton-text skeleton-text-short"></view>
      </view>
    </view>
    <!-- 档案列表骨架 -->
    <view class="skeleton-section">
      <view class="skeleton-section-header">
        <view class="skeleton-text skeleton-text-title"></view>
      </view>
      <view class="skeleton-profile-list">
        <view class="skeleton-profile-item" wx:for="{{[1,2]}}" wx:key="*this">
          <view class="skeleton-avatar"></view>
          <view class="skeleton-profile-info">
            <view class="skeleton-text skeleton-text-medium"></view>
            <view class="skeleton-tags">
              <view class="skeleton-tag" wx:for="{{[1,2]}}" wx:key="*this"></view>
            </view>
          </view>
          <view class="skeleton-shimmer"></view>
        </view>
      </view>
    </view>
    <!-- 功能菜单骨架 -->
    <view class="skeleton-menu">
      <view class="skeleton-menu-item" wx:for="{{[1,2,3,4]}}" wx:key="*this">
        <view class="skeleton-circle"></view>
        <view class="skeleton-text skeleton-text-medium"></view>
        <view class="skeleton-shimmer"></view>
      </view>
    </view>
  </view>
  <!-- 实际内容 -->
  <scroll-view scroll-y="{{true}}" class="container {{isPageLoading ? 'content-hidden' : 'content-visible'}}" enhanced="{{true}}" show-scrollbar="{{false}}">
    <!-- 用户信息区域 -->
    <view class="user-info-section">
      <view class="user-card" wx:if="{{isLoggedIn}}">
        <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
        <view class="user-details">
          <text class="user-name">{{userInfo.nickName}}</text>
          <text class="login-time">已登录</text>
        </view>
        <view class="edit-user-btn" bindtap="showEditUserPopup">
          <t-icon name="edit" size="32rpx" color="white" />
        </view>
      </view>
      <view class="login-prompt" wx:else bindtap="handleLogin">
        <view class="login-background">
          <view class="login-content">
            <view class="login-icon-wrapper">
              <t-icon name="user-circle" size="100rpx" color="#FFB800" />
            </view>
            <text class="login-title">欢迎使用暖白记事本</text>
            <text class="login-subtitle">管理您的健康档案，记录每一天</text>
            <view class="login-btn" bindtap="handleLogin">
              <t-icon name="wechat" size="32rpx" color="white" />
              <text class="login-btn-text">{{loginBtnText}}</text>
            </view>
            <view class="privacy-hint" catchtap="togglePrivacyAgreed">
              <view class="privacy-checkbox {{privacyAgreed ? 'checked' : ''}}">
                <t-icon wx:if="{{privacyAgreed}}" name="check" size="24rpx" color="#fff" />
              </view>
              <text class="privacy-hint-text">我已阅读并同意</text>
              <text class="privacy-hint-link" catchtap="showUserAgreement">《用户协议》</text>
              <text class="privacy-hint-text">和</text>
              <text class="privacy-hint-link" catchtap="showPrivacyPolicy">《隐私政策》</text>
            </view>
          </view>
        </view>
      </view>
    </view>
    <!-- 个人档案区域 -->
    <view class="profile-section" wx:if="{{isLoggedIn}}">
      <view class="section-header">
        <text class="section-title">个人档案</text>
        <view class="add-profile-btn" bindtap="showAddProfilePopup" wx:if="{{profiles.length < 5}}">
          <t-icon name="add" size="32rpx" color="#FFB800" />
          <text>添加档案</text>
        </view>
      </view>
      <view class="profile-list">
        <view class="profile-item" wx:for="{{profiles}}" wx:key="id">
          <view class="profile-info">
            <view class="profile-avatar">
              <view class="profile-initial">{{item.realName[0] || item.name[0] || '无'}}</view>
            </view>
            <view class="profile-details">
              <view class="profile-name">{{item.realName || item.name || '未命名'}}</view>
              <view class="profile-tags">
                <view class="profile-tag default" wx:if="{{item.isDefault}}">默认档案</view>
                <view class="profile-tag disease" wx:if="{{item.disease}}">{{item.disease}}</view>
                <view class="profile-tag hospital" wx:if="{{item.hospital}}">
                  {{item.hospital}}
                </view>
              </view>
            </view>
          </view>
          <view class="profile-actions">
            <view class="profile-action-btn default-action-btn" wx:if="{{!item.isDefault}}" catchtap="setDefaultProfile" data-id="{{item.id}}">
              <t-icon name="star" size="24rpx" color="white" />
            </view>
            <view class="profile-action-btn edit-action-btn" catchtap="editProfile" data-id="{{item.id}}">
              <t-icon name="edit" size="24rpx" color="white" />
            </view>
            <view class="profile-action-btn delete-action-btn" catchtap="deleteProfile" data-id="{{item.id}}" wx:if="{{profiles.length > 1 && !item.isDefault}}">
              <t-icon name="delete" size="24rpx" color="white" />
            </view>
          </view>
        </view>
      </view>
    </view>
    <!-- 其他功能区域 -->
    <view class="other-section" wx:if="{{isLoggedIn}}">
      <view class="section-header">
        <text class="section-title">其他</text>
      </view>
      <view class="function-list">
        <view class="function-item" bindtap="showFeedbackPopup">
          <view class="function-icon">
            <t-icon name="chat-bubble" size="40rpx" color="#FF8F00" />
          </view>
          <view class="function-info">
            <text class="function-title">意见反馈</text>
            <text class="function-desc">告诉我们您的使用体验</text>
          </view>
          <view class="function-arrow">
            <t-icon name="chevron-right" size="28rpx" color="#999" />
          </view>
        </view>
        <button class="function-item share-button" open-type="share" hover-class="none">
          <view class="function-icon">
            <t-icon name="share" size="40rpx" color="#FF8F00" />
          </view>
          <view class="function-info">
            <text class="function-title">推荐给好友</text>
            <text class="function-desc">分享给更多朋友一起使用</text>
          </view>
          <view class="function-arrow">
            <t-icon name="chevron-right" size="28rpx" color="#999" />
          </view>
        </button>
        <view class="function-item" bindtap="showUserAgreement">
          <view class="function-icon">
            <t-icon name="file-paste" size="40rpx" color="#FF8F00" />
          </view>
          <view class="function-info">
            <text class="function-title">用户协议</text>
            <text class="function-desc">了解您的权利与义务</text>
          </view>
          <view class="function-arrow">
            <t-icon name="chevron-right" size="28rpx" color="#999" />
          </view>
        </view>
        <view class="function-item" bindtap="showPrivacyPolicy">
          <view class="function-icon">
            <t-icon name="secured" size="40rpx" color="#FF8F00" />
          </view>
          <view class="function-info">
            <text class="function-title">隐私政策</text>
            <text class="function-desc">了解我们如何保护您的信息</text>
          </view>
          <view class="function-arrow">
            <t-icon name="chevron-right" size="28rpx" color="#999" />
          </view>
        </view>
        <view class="function-item" bindtap="logout">
          <view class="function-icon">
            <t-icon name="logout" size="40rpx" color="#FF8F00" />
          </view>
          <view class="function-info">
            <text class="function-title">退出登录</text>
            <text class="function-desc">退出当前账号</text>
          </view>
          <view class="function-arrow">
            <t-icon name="chevron-right" size="28rpx" color="#999" />
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
  <!-- 编辑用户信息弹窗 -->
  <t-popup visible="{{showEditUserPopup}}" bind:visible-change="closeEditUserPopup" placement="bottom" show-overlay="{{true}}">
    <view class="user-edit-popup-content">
      <view class="user-edit-header">
        <view class="user-edit-header-left">
          <view class="user-edit-header-text">
            <text class="user-edit-title">编辑个人信息</text>
            <text class="user-edit-subtitle">更新您的头像和昵称</text>
          </view>
        </view>
        <view class="user-edit-close-btn" bindtap="closeEditUserPopup">
          <t-icon name="close" size="32rpx" color="#666" />
        </view>
      </view>
      <view class="user-edit-body">
        <!-- 头像编辑区域 -->
        <view class="user-avatar-edit-wrapper">
          <button class="user-avatar-edit-btn" open-type="chooseAvatar" bindchooseavatar="onChooseUserAvatar">
            <image class="user-avatar-edit-preview" src="{{editUserForm.avatarUrl}}" mode="aspectFill" wx:if="{{editUserForm.avatarUrl}}" />
            <view class="user-avatar-placeholder" wx:else>
              <t-icon name="user-avatar" size="80rpx" color="#ccc" />
            </view>
            <view class="user-avatar-edit-overlay">
              <t-icon name="camera" size="48rpx" color="white" />
              <text class="user-avatar-edit-text">更换头像</text>
            </view>
          </button>
          <text class="user-avatar-hint">点击选择新头像</text>
        </view>
        <!-- 昵称编辑区域 -->
        <view class="user-nickname-edit-wrapper">
          <view class="user-nickname-label">
            <text class="user-nickname-label-text">昵称</text>
          </view>
          <view class="user-nickname-input-wrapper">
            <input class="user-nickname-input" type="nickname" value="{{editUserForm.nickName}}" bindinput="onUserNicknameInput" placeholder="请输入昵称" placeholder-class="user-nickname-placeholder" />
          </view>
        </view>
      </view>
      <view class="user-edit-footer">
        <view class="user-info-save-btn" bindtap="saveUserInfo">
          <text>保存更改</text>
        </view>
      </view>
    </view>
  </t-popup>
  <!-- 反馈弹窗 -->
  <t-popup visible="{{showFeedbackPopup}}" bind:visible-change="closeFeedbackPopup" placement="bottom" show-overlay="{{true}}">
    <view class="popup-content">
      <view class="popup-header">
        <text class="popup-title">意见反馈</text>
        <view class="milestone-close-btn" bindtap="closeFeedbackPopup">
          <t-icon name="close" size="28rpx" />
        </view>
      </view>
      <scroll-view scroll-y="{{true}}" class="edit-form-scroll" enhanced="{{true}}" show-scrollbar="{{true}}">
        <view class="edit-form">
          <view class="form-item">
            <text class="form-label">反馈内容</text>
            <textarea class="feedback-textarea" value="{{feedbackContent}}" bindinput="onFeedbackInput" placeholder="请告诉我们您的使用体验、遇到的问题或改进建议..." maxlength="500" />
            <text class="char-count">{{feedbackContent.length}}/500</text>
          </view>
          <view class="form-item">
            <text class="form-label">联系方式（可选）</text>
            <input class="form-input" value="{{feedbackContact}}" bindinput="onContactInput" placeholder="留下您的联系方式，方便我们与您沟通" />
          </view>
        </view>
      </scroll-view>
      <view class="popup-footer">
        <view class="feedback-submit-btn" bindtap="submitFeedback">提交反馈</view>
      </view>
    </view>
  </t-popup>
</view>
<!-- 结束 page-wrapper -->