/* pages/health-chart/index.wxss - 现代轻奢健康图表页面 */

/* ==================== CSS变量系统 ==================== */
page {
  --primary-color: #FFB84D;
  --primary-dark: #FF9800;
  --primary-light: #FFCC80;
  --primary-alpha-05: rgba(255, 184, 77, 0.05);
  --primary-alpha-10: rgba(255, 184, 77, 0.1);
  --primary-alpha-15: rgba(255, 184, 77, 0.15);
  --primary-alpha-20: rgba(255, 184, 77, 0.2);
  --primary-alpha-30: rgba(255, 184, 77, 0.3);

  /* 背景色系 */
  --bg-primary: #FDFCFA;
  --bg-secondary: #FAF8F4;
  --bg-tertiary: #F7F4EF;
  --bg-card: #FFFFFF;

  /* 文字色系 */
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --text-quaternary: #CCCCCC;

  /* 边框和阴影 */
  --border-light: rgba(255, 184, 77, 0.12);
  --border-medium: rgba(255, 184, 77, 0.2);
  --shadow-card:
    0 2rpx 8rpx rgba(255, 184, 77, 0.08),
    0 8rpx 24rpx rgba(255, 184, 77, 0.12),
    0 16rpx 32rpx rgba(255, 184, 77, 0.06);
  --shadow-hover:
    0 4rpx 16rpx rgba(255, 184, 77, 0.15),
    0 12rpx 36rpx rgba(255, 184, 77, 0.18),
    0 24rpx 48rpx rgba(255, 184, 77, 0.08);

  /* 圆角系统 */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 20rpx;
  --radius-2xl: 24rpx;
  --radius-pill: 50rpx;
}

/* ==================== 骨架屏加载动画 ==================== */
.skeleton-wrapper {
  padding: 32rpx 24rpx;
  background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 50%, var(--bg-tertiary) 100%);
  min-height: 100vh;
  animation: skeleton-fade-in 0.3s ease-out;
}

@keyframes skeleton-fade-in {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

.content-hidden {
  opacity: 0;
  pointer-events: none;
}

.content-visible {
  opacity: 1;
  animation: content-fade-in 0.4s ease-out;
}

@keyframes content-fade-in {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.skeleton-shimmer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.6) 50%,
      transparent 100%);
  animation: skeleton-shimmer 1.5s infinite;
}

@keyframes skeleton-shimmer {
  0% {
    transform: translateX(-100%);
  }

  100% {
    transform: translateX(100%);
  }
}

.skeleton-chart-section {
  background: var(--bg-card);
  border-radius: var(--radius-2xl);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.skeleton-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.skeleton-text {
  background: linear-gradient(90deg, #E8E4DD 0%, #F0EDE8 50%, #E8E4DD 100%);
  border-radius: var(--radius-sm);
  height: 28rpx;
}

.skeleton-text-title {
  width: 120rpx;
  height: 32rpx;
}

.skeleton-time-pills {
  display: flex;
  gap: 12rpx;
}

.skeleton-pill {
  width: 60rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #E8E4DD 0%, #F0EDE8 100%);
  border-radius: var(--radius-pill);
}

.skeleton-type-pills {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}

.skeleton-pill-large {
  width: 120rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #E8E4DD 0%, #F0EDE8 100%);
  border-radius: var(--radius-pill);
}

.skeleton-chart {
  width: 100%;
  height: 400rpx;
  background: linear-gradient(135deg, #F7F4EF 0%, #FAF8F4 100%);
  border-radius: var(--radius-lg);
  position: relative;
  overflow: hidden;
}

/* ==================== 页面基础设置 ==================== */
page {
  background: linear-gradient(180deg,
      var(--bg-primary) 0%,
      var(--bg-secondary) 50%,
      var(--bg-tertiary) 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  overflow-x: hidden;
}

.health-chart-page {
  min-height: 100vh;
  background: linear-gradient(180deg,
      var(--bg-primary) 0%,
      var(--bg-secondary) 50%,
      var(--bg-tertiary) 100%);
  position: relative;
}

/* ==================== 主内容区域 ==================== */
.content {
  box-sizing: border-box;
  width: 100%;
  padding: 42rpx 24rpx 100rpx 24rpx;
  position: relative;
  z-index: 1;
}

/* ==================== 图表分组容器 ==================== */
.chart-section {
  margin-bottom: 40rpx;
  position: relative;
}

.chart-section:last-child {
  margin-bottom: 60rpx;
}

/* ==================== 分组头部设计 ==================== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
  position: relative;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  position: relative;
  display: inline-block;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  left: 0;
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(90deg, var(--primary-color) 0%, var(--primary-light) 100%);
  border-radius: 2rpx;
}

/* ==================== 时间选择器 - 原生按钮设计 ==================== */
.time-options {
  display: flex;
  gap: 4rpx;
  background: var(--bg-card);
  padding: 3rpx;
  border-radius: var(--radius-md);
  box-shadow:
    0 1rpx 3rpx var(--primary-alpha-05),
    0 1rpx 2rpx rgba(0, 0, 0, 0.02);
  border: 1rpx solid var(--border-light);
}

.time-option {
  padding: 5rpx 10rpx;
  border-radius: var(--radius-sm);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  min-width: 44rpx;
  text-align: center;
}

.time-option::before {
  content: '';
  position: absolute;
  top: -1rpx;
  left: -1rpx;
  right: -1rpx;
  bottom: -1rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
  border-radius: var(--radius-sm);
  z-index: -1;
}

.time-option.active::before {
  opacity: 1;
}

.time-option.active {
  transform: translateY(-1rpx);
  box-shadow: 0 2rpx 8rpx var(--primary-alpha-20);
}

.time-label {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--text-secondary);
  transition: all 0.3s ease;
  position: relative;
  z-index: 1;
}

.time-option.active .time-label {
  color: white;
  font-weight: 600;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

/* ==================== 类型选择器 - 胶囊式精致设计 ==================== */
.type-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.type-pill {
  padding: 14rpx 24rpx;
  background: var(--bg-card);
  border: 2rpx solid var(--border-light);
  border-radius: var(--radius-pill);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  box-shadow:
    0 2rpx 6rpx var(--primary-alpha-05),
    0 1rpx 2rpx rgba(0, 0, 0, 0.02);
}

.type-pill::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  opacity: 0;
  transition: all 0.4s ease;
  transform: scale(0.8);
  border-radius: var(--radius-pill);
  z-index: -1;
}

.type-pill.active::before {
  opacity: 1;
  transform: scale(1);
}

.type-pill.active {
  border-color: transparent;
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-hover);
}

.type-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
  transition: all 0.3s ease;
  position: relative;
  z-index: 1;
}

.type-pill.active .type-label {
  color: white;
  font-weight: 600;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

/* ==================== 图表区域 - 高级卡片设计 ==================== */
.chart-area {
  background: var(--bg-card);
  border-radius: var(--radius-2xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--border-light);
  position: relative;
  margin-bottom: 8rpx;
}

.chart-area::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      var(--primary-alpha-20) 20%,
      var(--primary-alpha-30) 50%,
      var(--primary-alpha-20) 80%,
      transparent 100%);
}

/* ==================== 图表容器 ==================== */
.chart-container {
  position: relative;
  /* 兼容性优化 */
  overflow: visible;
  -webkit-transform: translateZ(0);
  transform: translateZ(0);
  /* 允许触摸事件穿透，不阻止滚动 */
  touch-action: pan-y;
}

.chart-canvas {
  width: 100%;
  height: 445rpx;
  /* 默认高度 */
  display: block;
  padding: 16rpx;
  box-sizing: border-box;
  overflow: visible;
  /* 优化 */
  -webkit-overflow-scrolling: touch;
  transform: translateZ(0);
  -webkit-transform: translateZ(0);
  /* 强制硬件加速 */
  -webkit-backface-visibility: hidden;
  backface-visibility: hidden;
  /* 解决canvas阻止滚动问题 */
  pointer-events: auto;
}


/* ==================== 图表底部信息栏 ==================== */
.chart-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg,
      var(--bg-secondary) 0%,
      var(--bg-tertiary) 100%);
  border-top: 1rpx solid var(--border-light);
  position: relative;
}

.chart-footer::before {
  content: '';
  position: absolute;
  top: 0;
  left: 24rpx;
  right: 24rpx;
  height: 1rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      var(--primary-alpha-15) 50%,
      transparent 100%);
}

.record-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

.latest-info {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 600;
  background: var(--primary-alpha-10);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--primary-alpha-20);
}

/* ==================== 空状态设计 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 450rpx;
  text-align: center;
  background: linear-gradient(135deg,
      #FFFBF5 0%,
      #FFF8F0 100%);
  position: relative;
  border-radius: var(--radius-2xl);
}


.empty-state::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 184, 77, 0.15) 0%, rgba(255, 184, 77, 0.08) 50%, transparent 100%);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  z-index: 0;
  animation: pulse 3s ease-in-out infinite;
}

.empty-icon {
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
  opacity: 0.9;
  display: flex;
  align-items: center;
  justify-content: center;
  filter: drop-shadow(0 4rpx 12rpx rgba(255, 184, 77, 0.2));
}

.empty-message {
  font-size: 32rpx;
  color: #FFB84D;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
  font-weight: 600;
}

.empty-tip {
  font-size: 26rpx;
  color: #CCCCCC;
  position: relative;
  z-index: 1;
  line-height: 1.4;
  max-width: 400rpx;
}

@keyframes pulse {

  0%,
  100% {
    opacity: 0.4;
    transform: translate(-50%, -50%) scale(1);
  }

  50% {
    opacity: 0.8;
    transform: translate(-50%, -50%) scale(1.1);
  }
}

/* ==================== 底部安全区域 ==================== */
.bottom-space {
  height: 80rpx;
}

/* ==================== 响应式设计 ==================== */
@media (max-width: 375px) {
  .section-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 16rpx;
  }

  .time-options {
    align-self: flex-end;
  }

  .type-selector {
    padding: 0 4rpx;
  }

  .content {
    padding: 20rpx 16rpx;
  }
}

/* ==================== 滚动优化 ==================== */
::-webkit-scrollbar {
  width: 0;
  height: 0;
}

/* ==================== 微交互动画 ==================== */
.chart-section {
  animation: slideInUp 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.chart-section:nth-child(1) {
  animation-delay: 0s;
}

.chart-section:nth-child(2) {
  animation-delay: 0.1s;
}

.chart-section:nth-child(3) {
  animation-delay: 0.2s;
}

@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 点击反馈 */
.type-pill:active {
  transform: translateY(0rpx) scale(0.96);
}

.time-option:active {
  transform: translateY(0rpx) scale(0.95);
}

/* ==================== ECharts画布优化 ==================== */
.chart-canvas canvas {
  width: 100% !important;
  height: 100% !important;
  border-radius: var(--radius-lg);
}

/* ==================== 首页顶部区域 ==================== */
.home-top-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.home-banner {
  border-radius: 36rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.08);
}

.banner-swiper {
  height: 280rpx;
}

.banner-item {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ffd796, #ffb84d);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

.banner-item-image {
  position: relative;
  background: #000;
}

.banner-item-image::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(0, 0, 0, 0.35), rgba(0, 0, 0, 0));
}

.banner-text {
  padding: 0 32rpx;
  text-align: center;
  line-height: 1.5;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.milestone-section {
  box-sizing: border-box;
  width: 712rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 25rpx;
  margin: 0 auto 15rpx auto;
  box-shadow:
    0 16rpx 40rpx rgba(212, 165, 116, 0.15),
    0 8rpx 20rpx rgba(212, 165, 116, 0.12),
    0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(212, 165, 116, 0.15);
  position: relative;
  overflow: hidden;
  z-index: 1;
}

/* 标题栏 - 完全参考个人档案的section-header */
.milestone-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: none;
  position: relative;
}

/* 装饰性下划线 */
.milestone-header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(212, 165, 116, 0.3) 20%,
      rgba(212, 165, 116, 0.6) 50%,
      rgba(212, 165, 116, 0.3) 80%,
      transparent 100%);
  border-radius: 2rpx;
}

.milestone-title-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.milestone-title-group {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 2rpx;
}

.milestone-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF9800;
  letter-spacing: 0.5rpx;
}

.milestone-subtitle {
  font-size: 22rpx;
  color: #999;
  font-weight: 400;
  letter-spacing: 0.2rpx;
}

/* 编辑按钮 - 完全使用公共样式 */
.milestone-edit-btn {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: linear-gradient(145deg, #FFF8F0 0%, #FFFFFF 100%);
  border-radius: 24rpx;
  color: #FF9800;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow:
    0 6rpx 16rpx rgba(212, 165, 116, 0.2),
    0 3rpx 8rpx rgba(212, 165, 116, 0.15),
    0 2rpx 4rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(212, 165, 116, 0.25);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  letter-spacing: 0.5rpx;
}

.milestone-edit-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.8) 50%,
      transparent 100%);
  border-radius: 24rpx 24rpx 0 0;
}

.milestone-edit-btn:active {
  background: linear-gradient(145deg, #FFEFDE 0%, #FFF8F0 100%);
  box-shadow:
    0 3rpx 8rpx rgba(212, 165, 116, 0.25),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.6);
  transform: translateY(1rpx);
}

.milestone-edit-text {
  margin-left: 8rpx;
}

.milestone-content {
  min-height: 140rpx;
}

/* 里程碑网格 - 简单有效的2列布局 */
.milestone-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 16rpx 0;
  width: 100%;
}

/* 滚动视图样式 - 超过6个里程碑时使用 */
.milestone-scroll {
  width: 100%;
  overflow-x: auto;
  overflow-y: hidden;
  -webkit-overflow-scrolling: touch;
}

.milestone-grid-scroll {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  padding-bottom: 10rpx;
  width: max-content;
}

.milestone-grid-scroll .milestone-card {
  width: 320rpx;
  flex-shrink: 0;
}

/* 里程碑卡片 - 简单固定宽度 */
.milestone-card {
  width: 49%;
  background: linear-gradient(135deg, #ffffff 0%, #fefefe 50%, #ffffff 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow:
    0 8rpx 32rpx rgba(212, 165, 116, 0.12),
    0 4rpx 16rpx rgba(212, 165, 116, 0.08),
    0 2rpx 8rpx rgba(0, 0, 0, 0.04),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  border: 1rpx solid rgba(212, 165, 116, 0.15);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

/* 单个里程碑时占满整行 */
.milestone-grid.single-item {
  justify-content: flex-start;
}

.milestone-card.single-card {
  width: 100%;
  /* 横向布局，左右分布 */
  flex-direction: row;
  align-items: center;
  padding: 32rpx 40rpx;
  min-height: 180rpx;
}

/* 单个里程碑的头部信息 */
.milestone-card.single-card .milestone-card-header {
  flex: 1;
  margin-bottom: 0;
  margin-right: 32rpx;
}

/* 单个里程碑的主体（数字区域） */
.milestone-card.single-card .milestone-card-body {
  flex: none;
  width: auto;
  text-align: right;
}

/* 单个里程碑时数字样式调整 - 适配多位数 */
.milestone-card.single-card .milestone-days-text {
  font-size: 88rpx;
  line-height: 1;
}

.milestone-card.single-card .milestone-status-text {
  font-size: 26rpx;
}

.milestone-card.single-card .milestone-unit-text {
  font-size: 30rpx;
}

/* 卡片内光效 */
.milestone-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.9) 50%,
      transparent 100%);
  border-radius: 24rpx 24rpx 0 0;
}

.milestone-card:active {
  transform: scale(0.96) translateY(1rpx);
  box-shadow:
    0 6rpx 24rpx rgba(212, 165, 116, 0.15),
    0 3rpx 12rpx rgba(212, 165, 116, 0.12),
    0 2rpx 6rpx rgba(0, 0, 0, 0.06),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.6);
}

/* 卡片头部 - 精致版式 */
.milestone-card-header {
  margin-bottom: 12rpx;
  position: relative;
  z-index: 2;
}

.milestone-card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2c2c2c;
  line-height: 1.2;
  margin-bottom: 8rpx;
  letter-spacing: 0.5rpx;
}

.milestone-card-date {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
  opacity: 0.8;
  letter-spacing: 0.2rpx;
}

/* 卡片主体 - 左对齐倒数日显示 */
.milestone-card-body {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  text-align: left;
  position: relative;
  z-index: 2;
}

.milestone-text-line {
  display: flex;
  align-items: baseline;
  justify-content: flex-start;
  gap: 6rpx;
  line-height: 1;
}

.milestone-status-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #2c2c2c;
  opacity: 0.8;
  letter-spacing: 0.5rpx;
  min-width: 80rpx;
  white-space: nowrap;
}

.milestone-full-text {
  font-size: 42rpx;
  font-weight: 600;
  background: linear-gradient(135deg,
      #FF9800 0%,
      #FFB84D 40%,
      #FFCC80 70%,
      #FFE0B3 100%);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
  line-height: 1.2;
  text-align: center;
  text-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.2);
}

.milestone-prefix-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #666;
  margin-right: 8rpx;
  line-height: 1.2;
}

.milestone-days-highlight {
  font-size: 34rpx;
  font-weight: 700;
  background: linear-gradient(135deg,
      #FF9800 0%,
      #FFB84D 40%,
      #FFCC80 70%,
      #FFE0B3 100%);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
  line-height: 1.2;
  text-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.2);
}

.milestone-days-text {
  font-size: 72rpx;
  font-weight: 900;
  background: linear-gradient(135deg,
      #FF9800 0%,
      #FFB84D 40%,
      #FFCC80 70%,
      #FFE0B3 100%);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
  line-height: 0.9;
  margin: 0 4rpx;
  text-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.2);
  position: relative;
}

/* 数字阴影效果 */
.milestone-days-text::before {
  content: attr(data-days);
  position: absolute;
  top: 2rpx;
  left: 2rpx;
  color: rgba(255, 152, 0, 0.08);
  z-index: -1;
  font-size: inherit;
  font-weight: inherit;
}

.milestone-unit-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FF9800;
  opacity: 0.9;
  letter-spacing: 0.5rpx;
}

.milestone-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  background: linear-gradient(145deg, #FAFAFA 0%, #F8F8F8 100%);
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 184, 77, 0.2);
  position: relative;
  overflow: hidden;
}

.milestone-empty::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: -10rpx;
  right: -10rpx;
  bottom: -10rpx;
  background: linear-gradient(45deg,
      rgba(255, 184, 77, 0.05) 0%,
      rgba(255, 204, 128, 0.03) 25%,
      rgba(255, 184, 77, 0.05) 50%,
      rgba(255, 204, 128, 0.03) 75%,
      rgba(255, 184, 77, 0.05) 100%);
  background-size: 40rpx 40rpx;
  opacity: 0.3;
  animation: shimmer 3s ease-in-out infinite;
}

@keyframes shimmer {
  0%,
  100% {
    opacity: 0.3;
  }
  50% {
    opacity: 0.1;
  }
}

.milestone-empty .empty-title {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-top: 16rpx;
  font-weight: 600;
  z-index: 2;
  position: relative;
}

.milestone-empty .empty-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
  z-index: 2;
  position: relative;
  opacity: 0.8;
}

.milestone-empty .empty-text {
  margin-top: 12rpx;
  color: #bf7b11;
  font-size: 28rpx;
  font-weight: 500;
  z-index: 2;
  position: relative;
}

.empty-state-premium {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.empty-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.empty-icon-pulse {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 2rpx dashed rgba(191, 123, 17, 0.4);
  animation: emptyPulse 1.6s infinite;
}

@keyframes emptyPulse {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  100% {
    transform: scale(1.2);
    opacity: 0;
  }
}
/* ==================== 背景装饰元素 ==================== */
/* ==================== Canvas层级优化 ==================== */

.health-chart-page::after {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(ellipse at 20% 80%, var(--primary-alpha-05) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 20%, var(--primary-alpha-05) 0%, transparent 50%),
    radial-gradient(ellipse at 40% 40%, var(--primary-alpha-05) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

/* ==================== 里程碑弹窗样式 ==================== */
.popup-content {
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  min-height: 400rpx;
  box-shadow:
    0 -2rpx 8rpx rgba(212, 165, 116, 0.08),
    0 -8rpx 24rpx rgba(212, 165, 116, 0.12);
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.popup-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.close-btn {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(145deg,
      rgba(220, 220, 220, 0.9) 0%,
      rgba(200, 200, 200, 0.95) 50%,
      rgba(180, 180, 180, 0.9) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-card);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  padding: 0;
  position: relative;
  overflow: hidden;
}

.close-btn::before {
  content: '';
  position: absolute;
  top: -1rpx;
  left: -1rpx;
  right: -1rpx;
  bottom: -1rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.3) 0%, transparent 70%);
  z-index: -1;
}

.close-btn:active {
  transform: scale(0.85) translateY(2rpx);
  background: linear-gradient(145deg,
      rgba(200, 200, 200, 0.95) 0%,
      rgba(180, 180, 180, 1) 50%,
      rgba(160, 160, 160, 0.95) 100%);
  box-shadow: var(--shadow-card);
}

.key-date-list {
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}

.key-date-list .key-date-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: white;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.date-info {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex: 1;
  gap: 16rpx;
}

.date-label {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.date-value {
  font-size: 26rpx;
  color: #999;
  background: rgba(255, 184, 77, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  white-space: nowrap;
}

.key-date-actions {
  display: flex;
  gap: 12rpx;
  margin-left: auto;
}

.key-date-action-btn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.key-date-action-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.4) 50%, transparent 100%);
  transition: left 0.4s;
}

.key-date-edit-btn {
  background: #FFB84D;
}

.key-date-edit-btn:active {
  transform: scale(0.9);
  opacity: 0.8;
}

.key-date-delete-btn {
  background: #FF6B6B;
}

.key-date-delete-btn:active {
  transform: scale(0.9);
  opacity: 0.8;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  line-height: 1;
}

.action-btn::after {
  display: none;
}

.add-key-date {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  height: 100rpx;
  padding: 0 40rpx;
  border: none;
  border-radius: 50rpx;
  color: var(--color-primary);
  font-size: 32rpx;
  font-weight: 600;
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.08) 0%,
      rgba(255, 167, 38, 0.12) 100%);
  box-shadow: 0 6rpx 24rpx rgba(255, 184, 77, 0.15);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.add-key-date::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  right: -100%;
  height: 100%;
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.1) 0%,
      rgba(255, 167, 38, 0.15) 100%);
  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.add-key-date t-icon {
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.add-key-date:active {
  transform: scale(0.98) translateY(2rpx);
  box-shadow: 0 3rpx 10rpx rgba(255, 184, 77, 0.15);
}

.add-key-date:active::before {
  transform: translateX(100%);
}

.add-key-date:active t-icon {
  transform: rotate(90deg);
}

/* 统一关闭按钮样式 - 暖色调设计 */
.milestone-close-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.08) 0%,
      rgba(255, 167, 38, 0.12) 100%);
  border: 2rpx solid rgba(255, 184, 77, 0.15);
  border-radius: 50%;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 3rpx 12rpx rgba(255, 184, 77, 0.1);
  position: relative;
  overflow: hidden;
}

.milestone-close-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg,
      rgba(255, 255, 255, 0.8) 0%,
      rgba(255, 248, 240, 0.6) 100%);
  opacity: 0;
  transition: opacity 0.3s;
  border-radius: 50%;
}

.milestone-close-btn:active {
  transform: scale(0.92);
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.15) 0%,
      rgba(255, 167, 38, 0.2) 100%);
  border-color: rgba(255, 184, 77, 0.25);
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 77, 0.15);
}

.milestone-close-btn:active::before {
  opacity: 1;
}

.milestone-close-btn t-icon {
  color: #FF8F00 !important;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 1;
  position: relative;
}

.milestone-close-btn:active t-icon {
  color: #FF6F00 !important;
  transform: rotate(90deg);
}

/* 里程碑编辑表单 */
.milestone-edit-form {
  padding: 32rpx;
  background: white;
  margin: 0;
}

.milestone-form-item {
  margin-bottom: 32rpx;
}

.milestone-form-item:last-child {
  margin-bottom: 0;
}

.milestone-form-label {
  display: block;
  font-size: 32rpx;
  color: #333;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.milestone-form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  font-size: 32rpx;
  color: #333;
}

.milestone-date-picker {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: none;
  box-sizing: border-box;
}

.milestone-date-text {
  font-size: 32rpx;
  color: #333;
  flex: 1;
}

.milestone-popup-footer {
  padding: 24rpx 32rpx 40rpx;
  background: white;
  display: flex;
  gap: 20rpx;
}

.milestone-save-btn {
  flex: 2;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-orange-600) 0%, var(--color-orange-700) 100%);
  box-shadow:
    0 8rpx 24rpx rgba(255, 143, 0, 0.4),
    0 4rpx 12rpx rgba(245, 124, 0, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3);
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: white;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.milestone-save-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.8) 50%,
      transparent 100%);
  border-radius: 12rpx 12rpx 0 0;
}

.milestone-save-btn:active {
  background: linear-gradient(135deg, var(--color-orange-700) 0%, #FF9800 100%);
  transform: scale(0.96) translateY(2rpx);
  box-shadow:
    0 4rpx 12rpx rgba(255, 143, 0, 0.5),
    0 2rpx 6rpx rgba(245, 124, 0, 0.4),
    inset 0 3rpx 6rpx rgba(255, 255, 255, 0.2);
}

.milestone-cancel-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  background: linear-gradient(135deg, #757575 0%, #616161 100%);
  box-shadow:
    0 6rpx 18rpx rgba(117, 117, 117, 0.3),
    0 3rpx 9rpx rgba(97, 97, 97, 0.25),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 12rpx;
  color: white;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.milestone-cancel-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.6) 50%,
      transparent 100%);
  border-radius: 12rpx 12rpx 0 0;
}

.milestone-cancel-btn:active {
  background: linear-gradient(135deg, #616161 0%, #424242 100%);
  transform: scale(0.96) translateY(2rpx);
  box-shadow:
    0 3rpx 9rpx rgba(117, 117, 117, 0.4),
    0 2rpx 6rpx rgba(97, 97, 97, 0.3),
    inset 0 3rpx 6rpx rgba(255, 255, 255, 0.15);
}
