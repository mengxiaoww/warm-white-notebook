<view class="ai-assistant-page">
  <!-- 聊天消息区域 -->
  <scroll-view
    class="message-container"
    scroll-y
    scroll-into-view="{{scrollToId}}"
    bindscroll="onScroll"
    enhanced
    show-scrollbar="{{false}}"
    scroll-with-animation="{{true}}">

    <!-- 欢迎消息 -->
    <view wx:if="{{messages.length === 0}}" class="welcome-message">
      <view class="welcome-icon-wrapper">
        <t-icon name="chat" size="64rpx" color="#FFFFFF" />
      </view>
      <text class="welcome-title">您的智能健康助手</text>
      <text class="welcome-desc">可以解答健康问题，也可以帮您记录健康数据</text>

      <!-- 示例问题 -->
      <view class="example-questions">
        <text class="example-title">试试这些问题</text>
        <view class="example-list">
          <view wx:for="{{exampleQuestions}}" wx:key="index" class="example-item" bindtap="onExampleClick" data-question="{{item}}">
            {{item}}
          </view>
        </view>
      </view>
    </view>

    <!-- 消息列表 -->
    <view wx:for="{{messages}}" wx:key="id" id="msg-{{item.id}}" class="message-item {{item.role}}">
      <!-- 用户消息：无头像，无时间，文字靠右 -->
      <block wx:if="{{item.role === 'user'}}">
        <view class="message-bubble">
          <!-- 如果有图片，显示图片 -->
          <image wx:if="{{item.image}}" class="message-image" src="{{item.image}}" mode="widthFix" />
          <!-- 只有当有文字内容时才显示 -->
          <text wx:if="{{item.content}}" class="message-text">{{item.content}}</text>
        </view>
      </block>

      <!-- AI助手消息：头像在左边 -->
      <block wx:elif="{{item.role === 'assistant'}}">
        <view class="message-avatar assistant">
          <t-icon name="chat" size="40rpx" color="#FFFFFF" />
        </view>
        <view class="message-bubble">
          <rich-text nodes="{{item.htmlContent || item.content}}" class="rich-text-content"></rich-text>
          <text class="message-time">{{item.time}}</text>
        </view>
      </block>

      <!-- 系统消息：头像在左边 -->
      <block wx:elif="{{item.role === 'system'}}">
        <view class="message-avatar {{item.isError ? 'error' : 'system'}}">
          <t-icon name="{{item.isError ? 'error-circle' : 'check-circle'}}" size="40rpx" color="#FFFFFF" />
        </view>
        <view class="message-bubble">
          <text class="message-text">{{item.content}}</text>
          <text class="message-time">{{item.time}}</text>
        </view>
      </block>
    </view>

    <!-- 加载中提示 -->
    <view wx:if="{{isLoading}}" class="message-item assistant">
      <view class="message-avatar assistant">
        <t-icon name="chat" size="40rpx" color="#FFFFFF" />
      </view>
      <view class="message-bubble">
        <view class="loading-dots">
          <view class="dot"></view>
          <view class="dot"></view>
          <view class="dot"></view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 回到底部按钮 -->
  <view wx:if="{{showScrollToBottom}}" class="scroll-to-bottom-btn" bindtap="scrollToBottomClick">
    <t-icon name="chevron-down" size="40rpx" color="#FFFFFF" />
  </view>

  <!-- 输入区域 -->
  <view class="input-container">
    <!-- 左侧功能按钮组 -->
    <view class="input-actions">
      <view class="action-icon-btn" bindtap="chooseImage">
        <t-icon name="image" size="48rpx" color="#999999" />
      </view>
      <view class="action-icon-btn" bindtap="clearAllMessages">
        <t-icon name="delete" size="44rpx" color="#999999" />
      </view>
    </view>

    <!-- 输入框区域 -->
    <view class="input-area">
      <!-- 图片预览 -->
      <view wx:if="{{selectedImage}}" class="image-preview-inline">
        <image class="preview-image-inline" src="{{selectedImage}}" mode="aspectFill" />
        <view class="remove-image-inline" bindtap="removeImage">
          <t-icon name="close-circle-filled" size="32rpx" color="#FF4444" />
        </view>
      </view>

      <!-- 输入框 -->
      <view class="input-wrapper">
        <textarea
          class="message-input"
          value="{{inputValue}}"
          bindinput="onInput"
          bindconfirm="sendMessage"
          placeholder="{{isLoading ? 'AI正在回复中...' : '有什么可以帮您...'}}"
          disabled="{{isLoading}}"
          adjust-position="{{false}}"
          confirm-type="send"
          fixed="{{true}}"
          maxlength="-1"
          show-confirm-bar="{{false}}"
        />
        <view class="send-button {{inputValue || isLoading || selectedImage ? 'active' : ''}}" bindtap="{{isLoading ? 'stopAI' : 'sendMessage'}}">
          <t-icon name="{{isLoading ? 'stop-circle' : 'send'}}" size="44rpx" color="{{inputValue || isLoading || selectedImage ? '#FFFFFF' : '#999999'}}" />
        </view>
      </view>
    </view>
  </view>

  <!-- 去掉历史对话抽屉 -->
</view>
