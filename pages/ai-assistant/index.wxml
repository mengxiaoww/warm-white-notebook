<view class="ai-assistant-page">
  <!-- 顶部浮动按钮 -->
  <view class="float-header">
    <view class="menu-btn" bindtap="showHistoryDrawer">
      <t-icon name="menu" size="48rpx" color="#1A1A1A" />
    </view>
    <view class="new-chat-btn" bindtap="newChat">
      <t-icon name="edit" size="48rpx" color="#1A1A1A" />
    </view>
  </view>

  <!-- 聊天消息区域 -->
  <scroll-view
    class="message-container"
    scroll-y
    scroll-into-view="{{scrollToId}}"
    enhanced
    show-scrollbar="{{false}}"
    scroll-with-animation="{{true}}">

    <!-- 欢迎消息 -->
    <view wx:if="{{messages.length === 0}}" class="welcome-message">
      <view class="welcome-icon-wrapper">
        <t-icon name="chat" size="64rpx" color="#FFFFFF" />
      </view>
      <text class="welcome-title">暖白记事本</text>
      <text class="welcome-desc">您的智能健康助手，可以解答健康问题，也可以帮您记录健康数据</text>

      <!-- 示例问题 -->
      <view class="example-questions">
        <text class="example-title">试试这些问题</text>
        <view class="example-list">
          <view wx:for="{{exampleQuestions}}" wx:key="index" class="example-item" bindtap="onExampleClick" data-question="{{item}}">
            {{item}}
          </view>
        </view>
      </view>
    </view>

    <!-- 消息列表 -->
    <view wx:for="{{messages}}" wx:key="id" id="msg-{{item.id}}" class="message-item {{item.role}}">
      <!-- AI助手头像 -->
      <view wx:if="{{item.role === 'assistant'}}" class="message-avatar assistant">
        <t-icon name="chat" size="40rpx" color="#FFFFFF" />
      </view>

      <!-- 系统消息头像 -->
      <view wx:elif="{{item.role === 'system'}}" class="message-avatar system">
        <t-icon name="check-circle" size="40rpx" color="#FFFFFF" />
      </view>

      <!-- 消息内容 -->
      <view class="message-bubble">
        <text class="message-text">{{item.content}}</text>
        <text class="message-time">{{item.time}}</text>
      </view>

      <!-- 用户头像 -->
      <view wx:if="{{item.role === 'user'}}" class="message-avatar user">
        <t-icon name="user" size="40rpx" color="#FFFFFF" />
      </view>
    </view>

    <!-- 加载中提示 -->
    <view wx:if="{{isLoading}}" class="message-item assistant">
      <view class="message-avatar assistant">
        <t-icon name="chat" size="40rpx" color="#FFFFFF" />
      </view>
      <view class="message-bubble">
        <view class="loading-dots">
          <view class="dot"></view>
          <view class="dot"></view>
          <view class="dot"></view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 输入区域 -->
  <view class="input-container">
    <view class="input-wrapper">
      <input
        class="message-input"
        value="{{inputValue}}"
        bindinput="onInput"
        bindconfirm="sendMessage"
        placeholder="有什么可以帮您..."
        adjust-position="{{false}}"
        confirm-type="send"
      />
      <view class="send-button {{inputValue ? 'active' : ''}}" bindtap="sendMessage">
        <t-icon name="send" size="44rpx" color="{{inputValue ? '#FFFFFF' : '#999999'}}" />
      </view>
    </view>
  </view>

  <!-- 历史对话抽屉 -->
  <view class="history-drawer {{showHistoryDrawer ? 'show' : ''}}" catchtap="hideHistoryDrawer">
    <view class="history-content" catchtap="stopPropagation">
      <view class="history-header">
        <text class="history-title">历史对话</text>
        <view class="history-close" bindtap="hideHistoryDrawer">
          <t-icon name="close" size="40rpx" color="#666666" />
        </view>
      </view>

      <scroll-view class="history-list" scroll-y>
        <view wx:if="{{conversations.length === 0}}" class="history-empty">
          <t-icon name="chat-off" size="120rpx" color="#CCCCCC" />
          <text class="empty-text">暂无历史对话</text>
        </view>

        <view wx:for="{{conversations}}" wx:key="date" class="history-item" bindtap="loadConversation" data-date="{{item.date}}">
          <view class="history-item-header">
            <t-icon name="chat" size="36rpx" color="#10A37F" />
            <text class="history-date">{{item.date}}</text>
          </view>
          <text class="history-preview">{{item.firstMessage}}</text>
          <text class="history-count">{{item.messages.length}} 条消息</text>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
