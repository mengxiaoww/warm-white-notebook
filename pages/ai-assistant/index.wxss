/* ==================== 参考ChatGPT设计的现代化界面 ==================== */

/* 页面整体布局 */
.ai-assistant-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #FAFAFA 0%, #FFFFFF 100%);
  position: relative;
}

/* 清除按钮 */
.clear-chat-btn {
  position: fixed;
  top: 100rpx;
  right: 32rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  transition: all 0.3s ease;
}

.clear-chat-btn:active {
  transform: scale(0.9);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

/* 消息容器 */
.message-container {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  padding-bottom: 180rpx;
  background: transparent;
}

/* 滚动条样式（右侧） */
.message-container::-webkit-scrollbar {
  width: 4rpx;
}

.message-container::-webkit-scrollbar-thumb {
  background: rgba(0, 0, 0, 0.1);
  border-radius: 2rpx;
}

/* ==================== 欢迎界面 ==================== */
.welcome-message {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: calc(100vh - 300rpx);
  padding: 60rpx 48rpx 40rpx;
}

.welcome-icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F4D 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 184, 77, 0.3);
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0px);
  }
  50% {
    transform: translateY(-8px);
  }
}

.welcome-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #2C2C2C;
  margin-bottom: 16rpx;
  letter-spacing: -0.5rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: #999999;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 56rpx;
  max-width: 560rpx;
}

/* 示例问题 - 横向滚动胶囊设计 */
.example-questions {
  width: 100%;
  padding: 0 48rpx;
}

.example-title {
  font-size: 24rpx;
  color: #AAAAAA;
  margin-bottom: 20rpx;
  text-align: center;
  font-weight: 400;
  letter-spacing: 1rpx;
}

.example-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: center;
}

.example-item {
  padding: 16rpx 24rpx;
  background: rgba(255, 184, 77, 0.08);
  border: 1rpx solid rgba(255, 184, 77, 0.2);
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666666;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  line-height: 1.4;
  white-space: nowrap;
}

.example-item:active {
  background: rgba(255, 184, 77, 0.15);
  border-color: #FFB84D;
  transform: scale(0.96);
  color: #FF9F4D;
}

/* 隐藏快捷操作 */
.quick-actions {
  display: none;
}

/* ==================== 聊天消息 ==================== */
.message-item {
  display: flex;
  padding: 24rpx 32rpx;
  gap: 20rpx;
  max-width: 100%;
  box-sizing: border-box;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.message-item.user {
  background: transparent;
  flex-direction: row-reverse;
}

.message-item.assistant {
  background: transparent;
}

.message-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.user-avatar {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F4D 100%);
}

.message-avatar.assistant {
  background: linear-gradient(135deg, #5B8DEF 0%, #6FA3FF 100%);
}

.system-avatar {
  background: linear-gradient(135deg, #34C759 0%, #30D158 100%);
}

/* 消息气泡 */
.message-bubble {
  flex: 1;
  max-width: calc(100% - 76rpx);
}

.message-item.user .message-bubble {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.message-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #2C2C2C;
  word-wrap: break-word;
  word-break: break-word;
  white-space: pre-wrap;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  margin-bottom: 6rpx;
}

.message-item.user .message-text {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F4D 100%);
  color: #FFFFFF;
  border-radius: 18rpx 18rpx 4rpx 18rpx;
  box-shadow: 0 2rpx 12rpx rgba(255, 184, 77, 0.3);
}

.message-item.assistant .message-text {
  background: #FFFFFF;
  color: #2C2C2C;
  border-radius: 18rpx 18rpx 18rpx 4rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.message-time {
  font-size: 22rpx;
  color: #BBBBBB;
  padding: 0 8rpx;
}

/* 加载动画 */
.message-item .loading-dots {
  display: flex;
  gap: 8rpx;
  padding: 16rpx 0;
}

.loading-dots .dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #8E8EA0;
  animation: bounce 1.4s infinite ease-in-out both;
}

.loading-dots .dot:nth-child(1) {
  animation-delay: -0.32s;
}

.loading-dots .dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0.8);
    opacity: 0.5;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 错误消息 */
.message-bubble.error .message-text {
  color: #EF4444;
}

/* ==================== 输入框区域 ==================== */
.input-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom) + 100rpx);
  z-index: 9999;
  box-sizing: border-box;
  border-top: 1rpx solid #F0F0F0;
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #FFFFFF;
  border: 2rpx solid #EEEEEE;
  border-radius: 32rpx;
  padding: 12rpx 12rpx 12rpx 24rpx;
  max-width: 700rpx;
  margin: 0 auto;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.input-wrapper:focus-within {
  border-color: #FFB84D;
  box-shadow: 0 6rpx 32rpx rgba(255, 184, 77, 0.25);
}

.message-input {
  flex: 1;
  font-size: 28rpx;
  color: #2C2C2C;
  background: transparent;
  border: none;
  outline: none;
  min-height: 40rpx;
  max-height: 160rpx;
  line-height: 40rpx;
}

.message-input::placeholder {
  color: #CCCCCC;
}

.send-button {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  background: #F5F5F5;
}

.send-button.active {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F4D 100%);
  box-shadow: 0 4rpx 16rpx rgba(255, 184, 77, 0.5);
}

.send-button:active {
  transform: scale(0.9);
}
