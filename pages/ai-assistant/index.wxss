/* ==================== 暖白记事本AI助手 - 橘黄主题 ==================== */

/* 页面整体布局 */
.ai-assistant-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #FFFFFF;
  position: relative;
}

/* ==================== 顶部操作栏 ==================== */
.float-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  z-index: 1000;
  background: #FFFFFF;
  border-bottom: 1rpx solid #F0F0F0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  pointer-events: none;
}

.menu-btn,
.new-chat-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F4D 100%);
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 77, 0.25);
  transition: all 0.2s ease;
  pointer-events: auto;
  border: none;
}

.menu-btn text,
.new-chat-btn text {
  font-size: 24rpx;
  font-weight: 500;
  color: #FFFFFF;
  letter-spacing: 0.5rpx;
}

.menu-btn:active,
.new-chat-btn:active {
  transform: scale(0.95);
  box-shadow: 0 1rpx 4rpx rgba(255, 184, 77, 0.3);
}

/* ==================== 消息容器 ==================== */
.message-container {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  padding-top: 100rpx;
  padding-bottom: 200rpx;
  background: #FFFFFF;
}

/* 隐藏滚动条 */
.message-container::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

/* ==================== 欢迎界面 ==================== */
.welcome-message {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: calc(100vh - 400rpx);
  padding: 60rpx 40rpx;
}

.welcome-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F4D 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 184, 77, 0.3);
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-8px); }
}

.welcome-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 16rpx;
  letter-spacing: -0.5rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: #999999;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 60rpx;
  max-width: 560rpx;
}

/* 示例问题 */
.example-questions {
  width: 100%;
  max-width: 660rpx;
}

.example-title {
  font-size: 24rpx;
  color: #AAAAAA;
  margin-bottom: 20rpx;
  display: block;
  font-weight: 500;
}

.example-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.example-item {
  padding: 24rpx 28rpx;
  background: #FAFAFA;
  border: 1rpx solid #F0F0F0;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333333;
  transition: all 0.2s ease;
  line-height: 1.5;
}

.example-item:active {
  background: #FFF8F0;
  border-color: #FFB84D;
  transform: scale(0.98);
}

/* ==================== 聊天消息 ==================== */
.message-item {
  display: flex;
  padding: 24rpx 32rpx;
  gap: 16rpx;
  align-items: flex-start;
}

.message-item.user {
  flex-direction: row-reverse;
  background: #FFFFFF;
}

.message-item.assistant {
  background: #FAFAFA;
}

.message-item.system {
  background: #FFFFFF;
  justify-content: center;
}

/* 头像样式 */
.message-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.message-avatar.user {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F4D 100%);
}

.message-avatar.assistant {
  background: linear-gradient(135deg, #FFD7A8 0%, #FFB84D 100%);
}

.message-avatar.system {
  background: linear-gradient(135deg, #FFA07A 0%, #FF8C69 100%);
}

/* 消息气泡 */
.message-bubble {
  flex: 1;
  max-width: calc(100% - 88rpx);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.message-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #1A1A1A;
  word-wrap: break-word;
  word-break: break-word;
  white-space: pre-wrap;
}

.message-time {
  font-size: 22rpx;
  color: #BBBBBB;
}

/* 加载动画 */
.loading-dots {
  display: flex;
  gap: 10rpx;
  padding: 6rpx 0;
}

.loading-dots .dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #FFB84D;
  animation: bounce 1.4s infinite ease-in-out both;
}

.loading-dots .dot:nth-child(1) {
  animation-delay: -0.32s;
}

.loading-dots .dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* ==================== 输入框区域 ==================== */
.input-container {
  position: fixed;
  bottom: 100rpx;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 9999;
  box-sizing: border-box;
  border-top: 1rpx solid #F0F0F0;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #FAFAFA;
  border-radius: 28rpx;
  padding: 12rpx 16rpx;
  border: 1rpx solid #F0F0F0;
  transition: all 0.2s ease;
}

.input-wrapper:focus-within {
  border-color: #FFB84D;
  background: #FFF8F0;
  box-shadow: 0 0 0 2rpx rgba(255, 184, 77, 0.1);
}

.message-input {
  flex: 1;
  font-size: 28rpx;
  color: #1A1A1A;
  background: transparent;
  border: none;
  outline: none;
  min-height: 44rpx;
  max-height: 180rpx;
  line-height: 44rpx;
}

.message-input::placeholder {
  color: #CCCCCC;
}

.send-button {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
  background: #E8E8E8;
}

.send-button.active {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F4D 100%);
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 77, 0.3);
}

.send-button:active {
  transform: scale(0.92);
}

/* ==================== 历史对话抽屉 ==================== */
.history-drawer {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 10000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.history-drawer.show {
  opacity: 1;
  visibility: visible;
}

.history-content {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 600rpx;
  max-width: 80%;
  background: #FFFFFF;
  transform: translateX(-100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
  box-shadow: 4rpx 0 16rpx rgba(0, 0, 0, 0.1);
}

.history-drawer.show .history-content {
  transform: translateX(0);
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F4D 100%);
}

.history-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.history-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  transition: all 0.2s ease;
}

.history-close:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.95);
}

.history-list {
  flex: 1;
  padding: 16rpx;
}

.history-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 26rpx;
  color: #999999;
  margin-top: 20rpx;
}

.history-item {
  padding: 20rpx;
  margin-bottom: 12rpx;
  background: #FAFAFA;
  border: 1rpx solid #F0F0F0;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.history-item:active {
  background: #FFF8F0;
  border-color: #FFB84D;
  transform: scale(0.98);
}

.history-item-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.history-date {
  font-size: 24rpx;
  font-weight: 500;
  color: #FF9F4D;
}

.history-preview {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
  display: block;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-count {
  font-size: 22rpx;
  color: #BBBBBB;
  display: block;
}
