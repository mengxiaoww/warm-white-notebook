/* 页面整体布局 */
.ai-assistant-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(135deg, #FFF8F0 0%, #FFFFFF 100%);
}

/* 头部区域 */
.ai-header {
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx 32rpx;
  background: linear-gradient(135deg, #FFB84D 0%, #FF9800 100%);
  box-shadow: 0 4rpx 20rpx rgba(255, 184, 77, 0.2);
}

.ai-avatar-container {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  margin-right: 24rpx;
}

.ai-avatar-glow {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.4) 0%, transparent 70%);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.8;
  }
  50% {
    transform: scale(1.1);
    opacity: 1;
  }
}

.ai-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  background: linear-gradient(135deg, #FFB84D 0%, #FF9800 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-title-group {
  display: flex;
  flex-direction: column;
}

.ai-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.ai-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 消息容器 */
.message-container {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
}

/* 欢迎消息 */
.welcome-message {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.welcome-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 184, 77, 0.2);
}

.welcome-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 48rpx;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  gap: 24rpx;
  width: 100%;
  justify-content: center;
}

.action-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 16rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.action-card:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
}

.action-card text {
  font-size: 24rpx;
  color: #666;
  margin-top: 16rpx;
}

/* 消息项 */
.message-item {
  display: flex;
  margin-bottom: 32rpx;
  animation: messageSlideIn 0.3s ease;
}

@keyframes messageSlideIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.message-item.user {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
}

.user-avatar {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9800 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 消息气泡 */
.message-bubble {
  max-width: 500rpx;
  padding: 24rpx 28rpx;
  border-radius: 20rpx;
  position: relative;
  word-wrap: break-word;
}

.message-item.assistant .message-bubble {
  background: #FFFFFF;
  margin-left: 16rpx;
  border-top-left-radius: 4rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.message-item.user .message-bubble {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9800 100%);
  margin-right: 16rpx;
  border-top-right-radius: 4rpx;
  box-shadow: 0 2rpx 12rpx rgba(255, 184, 77, 0.3);
}

.message-text {
  font-size: 28rpx;
  line-height: 1.6;
  display: block;
  margin-bottom: 8rpx;
}

.message-item.assistant .message-text {
  color: #333;
}

.message-item.user .message-text {
  color: #FFFFFF;
}

.message-time {
  font-size: 20rpx;
  opacity: 0.6;
  display: block;
}

.message-item.assistant .message-time {
  color: #999;
}

.message-item.user .message-time {
  color: #FFFFFF;
}

/* 加载中动画 */
.message-bubble.loading {
  padding: 32rpx;
}

.loading-dots {
  display: flex;
  gap: 12rpx;
  align-items: center;
  justify-content: center;
}

.loading-dots .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #FFB84D;
  animation: bounce 1.4s infinite ease-in-out both;
}

.loading-dots .dot:nth-child(1) {
  animation-delay: -0.32s;
}

.loading-dots .dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0);
    opacity: 0.5;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 输入区域 */
.input-container {
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #F0F0F0;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: #F8F8F8;
  border-radius: 48rpx;
  padding: 16rpx 24rpx;
}

.message-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  background: transparent;
  border: none;
}

.send-button {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  transition: all 0.3s ease;
}

.send-button.active {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
}

.send-button.active:active {
  transform: scale(0.9);
}
