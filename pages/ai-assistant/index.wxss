/* ==================== 暖白记事本AI助手 - 橘黄主题 ==================== */

/* 页面整体布局 */
.ai-assistant-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #FFFFFF;
  position: relative;
}

/* ==================== 消息容器 ==================== */
.message-container {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  padding-top: 32rpx;
  padding-bottom: 350rpx;
  background: #FFFFFF;
}

/* 隐藏滚动条 */
.message-container::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

/* ==================== 欢迎界面 ==================== */
.welcome-message {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
}

.welcome-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F4D 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 184, 77, 0.3);
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-8px); }
}

.welcome-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 16rpx;
  letter-spacing: -0.5rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: #999999;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 60rpx;
  max-width: 560rpx;
}

/* 示例问题 */
.example-questions {
  width: 100%;
  max-width: 660rpx;
}

.example-title {
  font-size: 24rpx;
  color: #AAAAAA;
  margin-bottom: 20rpx;
  display: block;
  font-weight: 500;
}

.example-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.example-item {
  padding: 24rpx 28rpx;
  background: #FAFAFA;
  border: 1rpx solid #F0F0F0;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333333;
  transition: all 0.2s ease;
  line-height: 1.5;
}

.example-item:active {
  background: #FFF8F0;
  border-color: #FFB84D;
  transform: scale(0.98);
}

/* ==================== 聊天消息 ==================== */
.message-item {
  display: flex;
  padding: 20rpx 32rpx;
  gap: 16rpx;
  align-items: flex-start;
}

.message-item.user {
  background: #FFFFFF;
  justify-content: flex-end;
  padding-left: 80rpx;
  padding-top: 16rpx;
  padding-bottom: 16rpx;
}

.message-item.assistant {
  background: #FAFAFA;
  padding-right: 80rpx;
  padding-top: 16rpx;
  padding-bottom: 16rpx;
}

.message-item.system {
  background: #FFFFFF;
  justify-content: center;
}

/* 头像样式 */
.message-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  margin-top: 4rpx;
}

.message-avatar.user {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F4D 100%);
}

.message-avatar.assistant {
  background: linear-gradient(135deg, #FFD7A8 0%, #FFB84D 100%);
}

.message-avatar.system {
  background: linear-gradient(135deg, #FFA07A 0%, #FF8C69 100%);
}

/* 消息气泡 */
.message-bubble {
  max-width: 560rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

/* 用户消息气泡 */
.message-item.user .message-bubble {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F4D 100%);
  padding: 16rpx 20rpx;
  border-radius: 20rpx 20rpx 4rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 77, 0.2);
}

.message-item.user .message-text {
  color: #FFFFFF;
}

.message-item.user .message-time {
  color: rgba(255, 255, 255, 0.75);
  text-align: right;
  font-size: 20rpx;
}

/* AI消息气泡 */
.message-item.assistant .message-bubble {
  background: transparent;
}

.message-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #1A1A1A;
  word-wrap: break-word;
  word-break: break-word;
  white-space: pre-wrap;
}

.message-time {
  font-size: 22rpx;
  color: #BBBBBB;
}

/* 加载动画 */
.loading-dots {
  display: flex;
  gap: 10rpx;
  padding: 6rpx 0;
}

.loading-dots .dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #FFB84D;
  animation: bounce 1.4s infinite ease-in-out both;
}

.loading-dots .dot:nth-child(1) {
  animation-delay: -0.32s;
}

.loading-dots .dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* ==================== 输入框区域 ==================== */
.input-container {
  position: fixed;
  bottom: 140rpx;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 9999;
  box-sizing: border-box;
  border-top: 1rpx solid #F0F0F0;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

/* 左侧功能按钮组 */
.input-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex-shrink: 0;
}

.action-icon-btn {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FAFAFA;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.action-icon-btn:active {
  transform: scale(0.92);
  background: #F0F0F0;
}

.input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #FAFAFA;
  border-radius: 24rpx;
  padding: 8rpx 12rpx;
  min-height: 148rpx; /* 68rpx + 12rpx + 68rpx = 148rpx */
}

.input-wrapper:focus-within {
  border-color: #FFB84D;
  background: #FFF8F0;
  box-shadow: 0 0 0 2rpx rgba(255, 184, 77, 0.1);
}

.message-input {
  flex: 1;
  font-size: 28rpx;
  color: #1A1A1A;
  background: transparent;
  border: none;
  outline: none;
  min-height: 44rpx;
  max-height: 180rpx;
  line-height: 44rpx;
}

.message-input::placeholder {
  color: #CCCCCC;
}

.send-button {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
  background: #E8E8E8;
}

.send-button.active {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F4D 100%);
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 77, 0.3);
}

.send-button:active {
  transform: scale(0.92);
}

/* 图片预览 */
.image-preview {
  margin-top: 16rpx;
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.remove-image {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}
