/* ==================== ChatGPT风格AI助手界面 ==================== */

/* 页面整体布局 */
.ai-assistant-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #FFFFFF;
  position: relative;
}

/* ==================== 顶部浮动按钮 ==================== */
.float-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: calc(env(safe-area-inset-top) + 96rpx);
  padding-top: env(safe-area-inset-top);
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-left: 32rpx;
  padding-right: 32rpx;
  z-index: 1000;
  background: transparent;
  pointer-events: none;
}

.menu-btn,
.new-chat-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  pointer-events: auto;
}

.menu-btn:active,
.new-chat-btn:active {
  background: rgba(0, 0, 0, 0.05);
  transform: scale(0.95);
}

/* ==================== 消息容器 ==================== */
.message-container {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  padding-top: calc(env(safe-area-inset-top) + 96rpx);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
}

/* 隐藏滚动条 */
.message-container::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

/* ==================== 欢迎界面 ==================== */
.welcome-message {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: calc(100vh - 400rpx);
  padding: 80rpx 48rpx 60rpx;
}

.welcome-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #10A37F 0%, #1A7F64 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  box-shadow: 0 12rpx 40rpx rgba(16, 163, 127, 0.25);
}

.welcome-title {
  font-size: 56rpx;
  font-weight: 600;
  color: #202123;
  margin-bottom: 20rpx;
  letter-spacing: -0.5rpx;
}

.welcome-desc {
  font-size: 30rpx;
  color: #6E6E80;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 80rpx;
  max-width: 580rpx;
}

/* 示例问题 */
.example-questions {
  width: 100%;
  max-width: 680rpx;
}

.example-title {
  font-size: 26rpx;
  color: #8E8EA0;
  margin-bottom: 24rpx;
  display: block;
  font-weight: 500;
}

.example-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.example-item {
  padding: 28rpx 32rpx;
  background: #FFFFFF;
  border: 2rpx solid #D9D9E3;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #202123;
  transition: all 0.2s ease;
  line-height: 1.5;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.example-item:active {
  background: #F7F7F8;
  border-color: #ACACBE;
  transform: scale(0.98);
}

/* ==================== 聊天消息 ==================== */
.message-item {
  display: flex;
  padding: 32rpx 40rpx;
  gap: 24rpx;
  max-width: 100%;
  box-sizing: border-box;
}

.message-item.user {
  flex-direction: row-reverse;
  background: #FFFFFF;
}

.message-item.assistant {
  background: #F7F7F8;
}

.message-item.system {
  background: #FFFFFF;
}

/* 头像样式 */
.message-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.message-avatar.user {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F4D 100%);
}

.message-avatar.assistant {
  background: linear-gradient(135deg, #10A37F 0%, #1A7F64 100%);
}

.message-avatar.system {
  background: linear-gradient(135deg, #0084FF 0%, #0073E6 100%);
}

/* 消息气泡 */
.message-bubble {
  flex: 1;
  max-width: calc(100% - 88rpx);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.message-text {
  font-size: 30rpx;
  line-height: 1.7;
  color: #202123;
  word-wrap: break-word;
  word-break: break-word;
  white-space: pre-wrap;
}

.message-time {
  font-size: 24rpx;
  color: #ACACBE;
}

/* 加载动画 */
.loading-dots {
  display: flex;
  gap: 12rpx;
  padding: 8rpx 0;
}

.loading-dots .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #10A37F;
  animation: bounce 1.4s infinite ease-in-out both;
}

.loading-dots .dot:nth-child(1) {
  animation-delay: -0.32s;
}

.loading-dots .dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* ==================== 输入框区域 ==================== */
.input-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  z-index: 9999;
  box-sizing: border-box;
  border-top: 1rpx solid #D9D9E3;
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #F7F7F8;
  border-radius: 24rpx;
  padding: 16rpx 20rpx;
  max-width: 100%;
  margin: 0 auto;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.input-wrapper:focus-within {
  border-color: #10A37F;
  background: #FFFFFF;
  box-shadow: 0 0 0 4rpx rgba(16, 163, 127, 0.1);
}

.message-input {
  flex: 1;
  font-size: 30rpx;
  color: #202123;
  background: transparent;
  border: none;
  outline: none;
  min-height: 48rpx;
  max-height: 200rpx;
  line-height: 48rpx;
}

.message-input::placeholder {
  color: #ACACBE;
}

.send-button {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
  background: #ECECF1;
}

.send-button.active {
  background: #10A37F;
}

.send-button:active {
  transform: scale(0.92);
}
