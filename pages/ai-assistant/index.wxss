/* ==================== ChatGPT风格AI助手界面 ==================== */

/* 页面整体布局 */
.ai-assistant-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #FFFFFF;
  position: relative;
}

/* ==================== 顶部操作栏 ==================== */
.float-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-left: 24rpx;
  padding-right: 24rpx;
  z-index: 1000;
  background: linear-gradient(135deg, #FFFBF5 0%, #FFF8F0 100%);
  border-bottom: 1rpx solid #FFE4C4;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 77, 0.08);
  pointer-events: none;
}

.menu-btn,
.new-chat-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F4D 100%);
  box-shadow: 0 4rpx 16rpx rgba(255, 184, 77, 0.3);
  transition: all 0.2s ease;
  pointer-events: auto;
  border: none;
}

.menu-btn text,
.new-chat-btn text {
  font-size: 26rpx;
  font-weight: 500;
  color: #FFFFFF;
  letter-spacing: 0.5rpx;
}

.menu-btn:active,
.new-chat-btn:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 77, 0.4);
}

/* ==================== 消息容器 ==================== */
.message-container {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  padding-top: 88rpx;
  padding-bottom: 160rpx;
  background: #FFFFFF;
}

/* 隐藏滚动条 */
.message-container::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

/* ==================== 欢迎界面 ==================== */
.welcome-message {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: calc(100vh - 400rpx);
  padding: 80rpx 48rpx 60rpx;
}

.welcome-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F4D 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  box-shadow: 0 12rpx 40rpx rgba(255, 184, 77, 0.35);
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-12px); }
}

.welcome-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #2C2C2C;
  margin-bottom: 20rpx;
  letter-spacing: -0.5rpx;
}

.welcome-desc {
  font-size: 30rpx;
  color: #999999;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 80rpx;
  max-width: 580rpx;
}

/* 示例问题 */
.example-questions {
  width: 100%;
  max-width: 680rpx;
}

.example-title {
  font-size: 26rpx;
  color: #AAAAAA;
  margin-bottom: 24rpx;
  display: block;
  font-weight: 500;
}

.example-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.example-item {
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #FFFBF5 0%, #FFF8F0 100%);
  border: 2rpx solid #FFE4C4;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #2C2C2C;
  transition: all 0.2s ease;
  line-height: 1.5;
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 77, 0.06);
}

.example-item:active {
  background: linear-gradient(135deg, #FFE4C4 0%, #FFD7A8 100%);
  border-color: #FFB84D;
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(255, 184, 77, 0.15);
}

/* ==================== 聊天消息 ==================== */
.message-item {
  display: flex;
  padding: 32rpx 40rpx;
  gap: 24rpx;
  max-width: 100%;
  box-sizing: border-box;
}

.message-item.user {
  flex-direction: row-reverse;
  background: #FFFFFF;
}

.message-item.assistant {
  background: #FFFBF5;
}

.message-item.system {
  background: #FFFFFF;
}

/* 头像样式 */
.message-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 77, 0.2);
}

.message-avatar.user {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F4D 100%);
}

.message-avatar.assistant {
  background: linear-gradient(135deg, #FFD7A8 0%, #FFB84D 100%);
}

.message-avatar.system {
  background: linear-gradient(135deg, #FFA07A 0%, #FF8C69 100%);
}

/* 消息气泡 */
.message-bubble {
  flex: 1;
  max-width: calc(100% - 88rpx);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.message-text {
  font-size: 30rpx;
  line-height: 1.7;
  color: #2C2C2C;
  word-wrap: break-word;
  word-break: break-word;
  white-space: pre-wrap;
}

.message-time {
  font-size: 24rpx;
  color: #BBBBBB;
}

/* 加载动画 */
.loading-dots {
  display: flex;
  gap: 12rpx;
  padding: 8rpx 0;
}

.loading-dots .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #FFB84D;
  animation: bounce 1.4s infinite ease-in-out both;
}

.loading-dots .dot:nth-child(1) {
  animation-delay: -0.32s;
}

.loading-dots .dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* ==================== 输入框区域 ==================== */
.input-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to top, #FFFBF5 0%, #FFFFFF 100%);
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom) + 100rpx);
  z-index: 9999;
  box-sizing: border-box;
  border-top: 1rpx solid #FFE4C4;
  box-shadow: 0 -4rpx 16rpx rgba(255, 184, 77, 0.08);
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 14rpx 18rpx;
  max-width: 100%;
  margin: 0 auto;
  border: 2rpx solid #FFE4C4;
  transition: all 0.2s ease;
  box-shadow: 0 2rpx 12rpx rgba(255, 184, 77, 0.08);
}

.input-wrapper:focus-within {
  border-color: #FFB84D;
  background: #FFFBF5;
  box-shadow: 0 4rpx 20rpx rgba(255, 184, 77, 0.2);
}

.message-input {
  flex: 1;
  font-size: 30rpx;
  color: #2C2C2C;
  background: transparent;
  border: none;
  outline: none;
  min-height: 48rpx;
  max-height: 200rpx;
  line-height: 48rpx;
}

.message-input::placeholder {
  color: #CCCCCC;
}

.send-button {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
  background: #F5F5F5;
}

.send-button.active {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F4D 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 77, 0.4);
}

.send-button:active {
  transform: scale(0.92);
}

/* ==================== 历史对话抽屉 ==================== */
.history-drawer {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 10000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.history-drawer.show {
  opacity: 1;
  visibility: visible;
}

.history-content {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 620rpx;
  max-width: 85%;
  background: linear-gradient(to bottom, #FFFBF5 0%, #FFFFFF 100%);
  transform: translateX(-100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
  box-shadow: 4rpx 0 24rpx rgba(255, 184, 77, 0.15);
}

.history-drawer.show .history-content {
  transform: translateX(0);
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #FFE4C4;
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F4D 100%);
}

.history-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.history-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  transition: all 0.2s ease;
}

.history-close:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.95);
}

.history-list {
  flex: 1;
  padding: 16rpx;
}

.history-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-top: 24rpx;
}

.history-item {
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: #FFFFFF;
  border: 2rpx solid #FFE4C4;
  border-radius: 16rpx;
  transition: all 0.2s ease;
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 77, 0.08);
}

.history-item:active {
  background: #FFFBF5;
  border-color: #FFB84D;
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(255, 184, 77, 0.2);
}

.history-item-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.history-date {
  font-size: 26rpx;
  font-weight: 500;
  color: #FF9F4D;
}

.history-preview {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.history-count {
  font-size: 22rpx;
  color: #BBBBBB;
  display: block;
}
