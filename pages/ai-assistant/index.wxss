/* 页面整体布局 */
.ai-assistant-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(135deg, #FFF8F0 0%, #FFFFFF 100%);
}

/* 头部区域 */
.ai-header {
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx 32rpx;
  background: linear-gradient(135deg, #FFB84D 0%, #FF9800 100%);
  box-shadow: 0 4rpx 20rpx rgba(255, 184, 77, 0.2);
}

.ai-avatar-container {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  margin-right: 24rpx;
}

.ai-avatar-glow {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.4) 0%, transparent 70%);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.8;
  }
  50% {
    transform: scale(1.1);
    opacity: 1;
  }
}

.ai-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  background: linear-gradient(135deg, #FFB84D 0%, #FF9800 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-title-group {
  display: flex;
  flex-direction: column;
}

.ai-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.ai-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 消息容器 */
.message-container {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
}

/* 欢迎消息 */
.welcome-message {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.welcome-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 184, 77, 0.2);
}

.welcome-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 48rpx;
}

/* 消息项 */
.message-item {
  display: flex;
  margin-bottom: 32rpx;
  animation: messageSlideIn 0.3s ease;
}

@keyframes messageSlideIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.message-item.user {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
}

.user-avatar {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9800 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 消息气泡 */
.message-bubble {
  max-width: 500rpx;
  padding: 24rpx 28rpx;
  border-radius: 20rpx;
  position: relative;
  word-wrap: break-word;
}

.message-item.assistant .message-bubble {
  background: #FFFFFF;
  margin-left: 16rpx;
  border-top-left-radius: 4rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.message-item.user .message-bubble {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9800 100%);
  margin-right: 16rpx;
  border-top-right-radius: 4rpx;
  box-shadow: 0 2rpx 12rpx rgba(255, 184, 77, 0.3);
}

.message-text {
  font-size: 28rpx;
  line-height: 1.6;
  display: block;
  margin-bottom: 8rpx;
}

.message-item.assistant .message-text {
  color: #333;
}

.message-item.user .message-text {
  color: #FFFFFF;
}

.message-time {
  font-size: 20rpx;
  opacity: 0.6;
  display: block;
}

.message-item.assistant .message-time {
  color: #999;
}

.message-item.user .message-time {
  color: #FFFFFF;
}

/* 加载中动画 */
.message-bubble.loading {
  padding: 32rpx;
}

.loading-dots {
  display: flex;
  gap: 12rpx;
  align-items: center;
  justify-content: center;
}

.loading-dots .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #FFB84D;
  animation: bounce 1.4s infinite ease-in-out both;
}

.loading-dots .dot:nth-child(1) {
  animation-delay: -0.32s;
}

.loading-dots .dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0);
    opacity: 0.5;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 输入区域 */
.input-container {
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #F0F0F0;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: #F8F8F8;
  border-radius: 48rpx;
  padding: 16rpx 24rpx;
}

.message-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  background: transparent;
  border: none;
}

.send-button {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  transition: all 0.3s ease;
}

.send-button.active {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
}

.send-button.active:active {
  transform: scale(0.9);
}

/* ==================== 新增样式 ==================== */

/* 清空按钮 */
.clear-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  margin-left: auto;
  transition: all 0.3s ease;
}

.clear-btn:active {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 0.3);
}

/* 模式切换器 */
.mode-switcher {
  display: flex;
  background: #FFFFFF;
  padding: 8rpx;
  margin: 16rpx 32rpx;
  border-radius: 48rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.mode-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #999;
  transition: all 0.3s ease;
  font-weight: 500;
}

.mode-tab.active {
  background: linear-gradient(135deg, rgba(255, 184, 77, 0.1) 0%, rgba(255, 152, 0, 0.15) 100%);
  color: #FFB84D;
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 77, 0.2);
}

.mode-tab:nth-child(2).active {
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.1) 0%, rgba(56, 142, 60, 0.15) 100%);
  color: #4CAF50;
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.2);
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 48rpx;
  width: 100%;
  padding: 0 32rpx;
}

.quick-action-btn {
  flex: 0 0 calc(50% - 8rpx);
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  border: 2rpx solid #E0E0E0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  transition: all 0.3s ease;
}

.quick-action-btn:active {
  transform: scale(0.96);
  border-color: #4CAF50;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.2);
}

/* 示例问题 */
.example-questions {
  margin-top: 48rpx;
  width: 100%;
  padding: 0 32rpx;
}

.example-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 24rpx;
  font-weight: 500;
  display: block;
}

.example-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.example-item {
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 2rpx solid #F0F0F0;
  font-size: 26rpx;
  color: #333;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.04);
}

.example-item:active {
  transform: translateX(8rpx);
  border-color: #FFB84D;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 77, 0.2);
  color: #FFB84D;
}

/* 系统消息头像 */
.system-avatar {
  background: linear-gradient(135deg, #4CAF50 0%, #388E3C 100%);
}

/* 错误消息样式 */
.message-bubble.error {
  background: #FFEBEE !important;
  border: 2rpx solid #FFCDD2;
}

.message-bubble.error .message-text {
  color: #D32F2F;
}
