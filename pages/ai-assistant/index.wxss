/* ==================== 参考ChatGPT设计的现代化界面 ==================== */

/* 页面整体布局 */
.ai-assistant-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #FFFFFF;
  position: relative;
}

/* 消息容器 */
.message-container {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  padding-bottom: 200rpx;
  background: #FAFAFA;
}

/* 滚动条样式（右侧） */
.message-container::-webkit-scrollbar {
  width: 4rpx;
}

.message-container::-webkit-scrollbar-thumb {
  background: rgba(0, 0, 0, 0.1);
  border-radius: 2rpx;
}

/* ==================== 欢迎界面 ==================== */
.welcome-message {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  padding: 80rpx 64rpx;
}

.welcome-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F4D 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  box-shadow: 0 12rpx 40rpx rgba(255, 184, 77, 0.25);
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0px);
  }
  50% {
    transform: translateY(-10px);
  }
}

.welcome-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #2C2C2C;
  margin-bottom: 24rpx;
  letter-spacing: -1rpx;
}

.welcome-desc {
  font-size: 30rpx;
  color: #888888;
  text-align: center;
  line-height: 1.8;
  margin-bottom: 80rpx;
  max-width: 600rpx;
}

/* 示例问题 - 简洁卡片设计 */
.example-questions {
  width: 100%;
  max-width: 640rpx;
}

.example-title {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 24rpx;
  text-align: center;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.example-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.example-item {
  padding: 28rpx 32rpx;
  background: #FFFFFF;
  border: 2rpx solid #F0F0F0;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333333;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  line-height: 1.6;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.example-item:active {
  background: #FFFBF7;
  border-color: #FFB84D;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 77, 0.15);
}

/* 隐藏快捷操作 */
.quick-actions {
  display: none;
}

/* ==================== 聊天消息 ==================== */
.message-item {
  display: flex;
  padding: 32rpx 40rpx;
  gap: 24rpx;
  max-width: 100%;
  box-sizing: border-box;
}

.message-item.user {
  background: transparent;
  flex-direction: row-reverse;
}

.message-item.assistant {
  background: transparent;
}

.message-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.user-avatar {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F4D 100%);
}

.message-avatar.assistant {
  background: linear-gradient(135deg, #4A90E2 0%, #5BA3F5 100%);
}

.system-avatar {
  background: linear-gradient(135deg, #34C759 0%, #30D158 100%);
}

/* 消息气泡 */
.message-bubble {
  flex: 1;
  max-width: calc(100% - 88rpx);
}

.message-item.user .message-bubble {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.message-text {
  font-size: 30rpx;
  line-height: 1.6;
  color: #2C2C2C;
  word-wrap: break-word;
  word-break: break-word;
  white-space: pre-wrap;
  padding: 24rpx 28rpx;
  border-radius: 20rpx;
  margin-bottom: 8rpx;
}

.message-item.user .message-text {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F4D 100%);
  color: #FFFFFF;
  border-radius: 20rpx 20rpx 4rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 184, 77, 0.25);
}

.message-item.assistant .message-text {
  background: #FFFFFF;
  color: #2C2C2C;
  border-radius: 20rpx 20rpx 20rpx 4rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.message-time {
  font-size: 24rpx;
  color: #AAAAAA;
  padding: 0 12rpx;
}

/* 加载动画 */
.message-item .loading-dots {
  display: flex;
  gap: 8rpx;
  padding: 16rpx 0;
}

.loading-dots .dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #8E8EA0;
  animation: bounce 1.4s infinite ease-in-out both;
}

.loading-dots .dot:nth-child(1) {
  animation-delay: -0.32s;
}

.loading-dots .dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0.8);
    opacity: 0.5;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 错误消息 */
.message-bubble.error .message-text {
  color: #EF4444;
}

/* ==================== 输入框区域 ==================== */
.input-container {
  position: fixed;
  bottom: 100rpx;
  left: 0;
  right: 0;
  background: transparent;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 9999;
  box-sizing: border-box;
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #FFFFFF;
  border: 2rpx solid #E8E8E8;
  border-radius: 28rpx;
  padding: 16rpx 24rpx;
  max-width: 720rpx;
  margin: 0 auto;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.input-wrapper:focus-within {
  border-color: #FFB84D;
  box-shadow: 0 8rpx 32rpx rgba(255, 184, 77, 0.2);
}

.message-input {
  flex: 1;
  font-size: 30rpx;
  color: #2C2C2C;
  background: transparent;
  border: none;
  outline: none;
  min-height: 44rpx;
  max-height: 180rpx;
  line-height: 44rpx;
}

.message-input::placeholder {
  color: #BBBBBB;
}

.send-button {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  background: #F5F5F5;
}

.send-button.active {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F4D 100%);
  box-shadow: 0 4rpx 16rpx rgba(255, 184, 77, 0.4);
}

.send-button:active {
  transform: scale(0.92);
}
