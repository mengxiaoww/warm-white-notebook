/* ==================== 参考ChatGPT设计的现代化界面 ==================== */

/* 页面整体布局 */
.ai-assistant-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #FFFFFF;
  position: relative;
}

/* 消息容器 */
.message-container {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  padding-bottom: 160rpx;
  background: #FFFFFF;
}

/* 滚动条样式（右侧） */
.message-container::-webkit-scrollbar {
  width: 4rpx;
}

.message-container::-webkit-scrollbar-thumb {
  background: rgba(0, 0, 0, 0.1);
  border-radius: 2rpx;
}

/* ==================== 欢迎界面 ==================== */
.welcome-message {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx 60rpx;
  max-width: 800rpx;
  margin: 0 auto;
}

.welcome-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8E53 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.2);
}

.welcome-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 16rpx;
  letter-spacing: -0.5rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 64rpx;
}

/* 快捷操作 - 横向滚动卡片 */
.quick-actions {
  width: 100%;
  margin-bottom: 48rpx;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.quick-action-btn {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 32rpx;
  background: #F7F7F8;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #1A1A1A;
  margin-bottom: 16rpx;
  transition: all 0.2s ease;
  width: 100%;
  box-sizing: border-box;
}

.quick-action-btn:active {
  background: #ECECF1;
  transform: scale(0.98);
}

/* 示例问题 */
.example-questions {
  width: 100%;
  padding: 0 48rpx;
}

.example-title {
  font-size: 24rpx;
  color: #8E8EA0;
  margin-bottom: 20rpx;
  display: block;
  font-weight: 500;
}

.example-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.example-item {
  padding: 24rpx 28rpx;
  background: #FFFFFF;
  border: 1rpx solid #E5E5EA;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #1A1A1A;
  transition: all 0.2s ease;
  line-height: 1.5;
}

.example-item:active {
  background: #F7F7F8;
  border-color: #D1D1D6;
}

/* ==================== 聊天消息 ==================== */
.message-item {
  display: flex;
  padding: 24rpx 48rpx;
  gap: 20rpx;
  max-width: 100%;
  box-sizing: border-box;
}

.message-item.user {
  background: #F7F7F8;
  flex-direction: row-reverse;
}

.message-item.assistant {
  background: #FFFFFF;
}

.message-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 8rpx;
}

.user-avatar {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8E53 100%);
}

.message-avatar.assistant {
  background: linear-gradient(135deg, #10A37F 0%, #1DB88E 100%);
}

.system-avatar {
  background: linear-gradient(135deg, #4F46E5 0%, #6366F1 100%);
}

/* 消息气泡 */
.message-bubble {
  flex: 1;
  max-width: 100%;
  padding: 0;
  background: transparent;
}

.message-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: #1A1A1A;
  word-wrap: break-word;
  word-break: break-word;
  white-space: pre-wrap;
  display: block;
  margin-bottom: 12rpx;
}

.message-time {
  font-size: 22rpx;
  color: #8E8EA0;
  display: block;
}

/* 加载动画 */
.message-item .loading-dots {
  display: flex;
  gap: 8rpx;
  padding: 16rpx 0;
}

.loading-dots .dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #8E8EA0;
  animation: bounce 1.4s infinite ease-in-out both;
}

.loading-dots .dot:nth-child(1) {
  animation-delay: -0.32s;
}

.loading-dots .dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0.8);
    opacity: 0.5;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 错误消息 */
.message-bubble.error .message-text {
  color: #EF4444;
}

/* ==================== 输入框区域 ==================== */
.input-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-top: 1rpx solid #E5E5EA;
  padding: 16rpx 48rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom) + 100rpx);
  z-index: 9999;
  box-sizing: border-box;
}

.input-wrapper {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  background: #F7F7F8;
  border-radius: 24rpx;
  padding: 12rpx 20rpx;
  max-width: 1000rpx;
  margin: 0 auto;
}

.message-input {
  flex: 1;
  font-size: 28rpx;
  color: #1A1A1A;
  background: transparent;
  border: none;
  outline: none;
  min-height: 48rpx;
  max-height: 200rpx;
  line-height: 1.5;
}

.send-button {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
  background: transparent;
}

.send-button.active {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8E53 100%);
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 53, 0.3);
}

.send-button:active {
  transform: scale(0.95);
}
