  font-size: 28rpx;
  color: #666;
  margin: 24rpx 0 16rpx;
  font-weight: 500;
}

.date-detail-task-list {
  background: transparent;
  border-radius: 0;
  padding: 0;
  border: none;
  margin-top: 8rpx;
}

.date-detail-task-item {
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.03) 0%, rgba(102, 187, 106, 0.08) 50%, rgba(255, 255, 255, 0.95) 100%);
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  font-size: 26rpx;
  border: 1rpx solid rgba(76, 175, 80, 0.15);
  position: relative;
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  cursor: pointer;
  box-shadow:
    0 8rpx 32rpx rgba(76, 175, 80, 0.12),
    0 2rpx 8rpx rgba(0, 0, 0, 0.04),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.date-detail-task-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.8) 50%, rgba(255, 255, 255, 0) 100%);
  border-radius: 16rpx 16rpx 0 0;
  z-index: 3;
}

.date-detail-task-item:active {
  transform: translateY(1rpx) scale(0.97);
  box-shadow:
    0 2rpx 8rpx rgba(76, 175, 80, 0.15),
    0 1rpx 4rpx rgba(0, 0, 0, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.08) 0%, rgba(102, 187, 106, 0.12) 50%, rgba(255, 255, 255, 0.92) 100%);
}

.date-detail-task-item:last-child {
  margin-bottom: 0;
}

.date-detail-task-item::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20rpx;
  right: 20rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(76, 175, 80, 0.1) 50%, transparent 100%);
}

.date-detail-task-status {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid rgba(76, 175, 80, 0.3);
  border-radius: 50%;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  background: linear-gradient(145deg, #E8F5E8 0%, #C8E6C9 100%);
  box-shadow:
    inset 0 2rpx 4rpx rgba(76, 175, 80, 0.1),
    0 2rpx 8rpx rgba(76, 175, 80, 0.1);
  position: relative;
  font-size: 20rpx;
  font-weight: bold;
}

.date-detail-task-status::before {
  content: '';
  position: absolute;
  top: -1rpx;
  left: -1rpx;
  right: -1rpx;
  bottom: -1rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.8) 0%, rgba(255, 255, 255, 0.2) 100%);
  z-index: -1;
}

.date-detail-task-status.completed {
  background: linear-gradient(145deg, var(--color-orange-500) 0%, var(--color-orange-700) 100%);
  border-color: #2E7D32;
  box-shadow:
    0 6rpx 16rpx rgba(76, 175, 80, 0.4),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3);
  transform: scale(1.05);
  color: white;
}

.date-detail-task-status.pending {
  background: linear-gradient(145deg, #E8F5E8 0%, #C8E6C9 100%);
  border-color: rgba(76, 175, 80, 0.3);
  color: var(--color-orange-700);
}

.date-detail-task-text {
  flex: 1;
  font-size: 30rpx;
  color: #2E7D32;
  font-weight: 500;
  letter-spacing: 0.5rpx;
  line-height: 1.4;
  transition: all 0.3s ease;
}

.date-detail-task-item.completed .date-detail-task-text {
  color: var(--color-orange-500);
  text-decoration: line-through;
  opacity: 0.8;
}

.date-detail-task-item.completed .date-detail-task-text {
  color: var(--color-orange-500);
  text-decoration: line-through;
  opacity: 0.8;
}

.date-detail-empty {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 60rpx 40rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 16rpx;
  border: 2rpx dashed #ddd;
}

.close-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(145deg,
      rgba(255, 255, 255, 0.25) 0%,
      rgba(255, 255, 255, 0.15) 50%,
      rgba(255, 255, 255, 0.05) 100%);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  z-index: 1000;
  box-shadow:
    0 8rpx 32rpx rgba(0, 0, 0, 0.15),
    0 4rpx 16rpx rgba(255, 111, 0, 0.2),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.4),
    inset 0 -2rpx 4rpx rgba(255, 111, 0, 0.3);
}

.close-btn::before {
  content: '';
  position: absolute;
  top: -12rpx;
  left: -12rpx;
  right: -12rpx;
  bottom: -12rpx;
  border-radius: 50%;
  background: radial-gradient(circle at center,
      rgba(255, 255, 255, 0.1) 0%,
      transparent 70%);
  z-index: -1;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.close-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  background: linear-gradient(135deg,
      rgba(255, 255, 255, 0.2) 0%,
      transparent 50%,
      rgba(255, 111, 0, 0.1) 100%);
  z-index: -1;
}

.close-btn:hover::before {
  opacity: 1;
}

.close-btn:active {
  background: linear-gradient(145deg,
      rgba(255, 255, 255, 0.4) 0%,
      rgba(255, 255, 255, 0.25) 50%,
      rgba(255, 255, 255, 0.1) 100%);
  transform: scale(0.92) translateY(2rpx);
  box-shadow:
    0 4rpx 16rpx rgba(0, 0, 0, 0.2),
    0 2rpx 8rpx rgba(255, 111, 0, 0.3),
    inset 0 4rpx 8rpx rgba(255, 255, 255, 0.3),
    inset 0 -1rpx 2rpx rgba(255, 111, 0, 0.5);
  border-color: rgba(255, 255, 255, 0.5);
}

