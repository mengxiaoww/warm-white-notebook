.container {
  min-height: 100vh;
  background: linear-gradient(180deg,
      #FDFCFA 0%,
      #FAF8F4 50%,
      #F7F4EF 100%);
  overflow-x: hidden;
}

/* 通用卡片样式 - 现代轻奢设计 */
.card {
  margin: 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow:
    0 2rpx 8rpx rgba(212, 165, 116, 0.08),
    0 8rpx 24rpx rgba(212, 165, 116, 0.12),
    0 16rpx 32rpx rgba(212, 165, 116, 0.06);
  border: 1rpx solid rgba(212, 165, 116, 0.15);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
}

.banner {
  width: 100%;
  height: 360rpx;
  padding: 20rpx;
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
  border-radius: 0;
}

/* 移除外层复杂光晕以提升性能 */

.banner-swiper {
  width: 100%;
  height: 100%;
  border-radius: 28rpx;
  overflow: hidden;
  position: relative;
  z-index: 2;
  box-shadow: 0 4rpx 20rpx var(--shadow-card);
  border: 1rpx solid var(--border-light);
  /* 移除复杂的边框动画 */
}

/* 移除边框流动动画以提升性能 */

/* 🎆 超级炫酷轮播项 - 暖橙主题豪华渐变 */
.banner-item {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg,
      var(--color-orange-800) 0%,
      var(--color-orange-500) 10%,
      var(--color-orange-700) 20%,
      var(--color-orange-300) 30%,
      var(--color-orange-500) 40%,
      #FF7043 50%,
      #FF5722 60%,
      var(--color-orange-800) 70%,
      var(--color-orange-900) 80%,
      #D84315 90%,
      var(--color-orange-500) 100%);
  background-size: 800% 800%;
  animation: banner-simple-flow 15s ease-in-out infinite;
  padding: 40rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  overflow: hidden;
  position: relative;
}

/* 🌈 简化渐变流动动画 - 高性能版 */
@keyframes banner-simple-flow {

  0%,
  100% {
    background-position: 0% 50%;
  }

  50% {
    background-position: 100% 50%;
  }
}

/* ✨ 全息光束扫描效果 */
.banner-item::before {
  content: '';
  position: absolute;
  top: -100%;
  left: -100%;
  width: 300%;
  height: 300%;
  background: linear-gradient(45deg,
      transparent 0%,
      rgba(255, 255, 255, 0.1) 20%,
      rgba(255, 183, 77, 0.4) 35%,
      rgba(255, 255, 255, 0.6) 50%,
      var(--primary-alpha-40) 65%,
      rgba(255, 255, 255, 0.1) 80%,
      transparent 100%);
  transform: rotate(-45deg);
  animation: banner-simple-scan 12s ease-in-out infinite;
  z-index: 1;
}

/* 🌟 简化扫描动画 - 高性能版 */
@keyframes banner-simple-scan {

  0%,
  100% {
    transform: rotate(-45deg) translate(-120%, -120%);
    opacity: 0;
  }

  50% {
    transform: rotate(-45deg) translate(120%, 120%);
    opacity: 0.6;
  }
}

/* 🔥 数字雨效果线条 */
.banner-item::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 183, 77, 0.8) 15%,
      rgba(255, 255, 255, 1) 30%,
      var(--primary-alpha-90) 50%,
      rgba(255, 255, 255, 1) 70%,
      rgba(255, 183, 77, 0.8) 85%,
      transparent 100%);
  animation: banner-simple-pulse 8s ease-in-out infinite;
  z-index: 2;
  box-shadow: var(--shadow-light);
}

/* 💫 简化脉冲动画 - 高性能版 */
@keyframes banner-simple-pulse {

  0%,
  100% {
    opacity: 0.4;
  }

  50% {
    opacity: 1;
  }
}

/* 🎨 赛博朋克文字样式 - 超清晰全息效果 */
.banner-text {
  color: var(--color-white-pure);
  font-size: 40rpx;
  font-weight: 800;
  text-align: center;
  line-height: 1.4;
  width: 100%;
  position: relative;
  z-index: 3;
  text-shadow:
    0 0 10rpx rgba(255, 183, 77, 0.8),
    0 0 20rpx var(--primary-alpha-60),
    0 0 30rpx rgba(255, 193, 7, 0.4),
    0 2rpx 4rpx rgba(0, 0, 0, 0.8);
  letter-spacing: 2rpx;
  animation: banner-cyber-text 10s ease-in-out infinite;
  /* 文字渲染优化 */
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
  /* 添加数字效果滤镜 */
  filter: contrast(1.2) brightness(1.1);
}

/* 📱 橙色主题文字动画 - 暖光闪烁效果 */
@keyframes banner-cyber-text {

  0%,
  100% {
    text-shadow:
      0 0 10rpx rgba(255, 183, 77, 0.8),
      0 0 20rpx var(--primary-alpha-60),
      0 0 30rpx rgba(255, 193, 7, 0.4),
      0 2rpx 4rpx rgba(0, 0, 0, 0.8);
    transform: scale(1);
  }

  25% {
    text-shadow:
      0 0 15rpx rgba(255, 152, 0, 1),
      0 0 25rpx rgba(255, 183, 77, 0.8),
      0 0 35rpx var(--primary-alpha-60),
      0 2rpx 4rpx rgba(0, 0, 0, 0.8);
    transform: scale(1.02);
  }

  50% {
    text-shadow:
      0 0 20rpx rgba(255, 193, 7, 1),
      0 0 30rpx rgba(255, 255, 255, 0.9),
      0 0 40rpx rgba(255, 183, 77, 0.7),
      0 2rpx 4rpx rgba(0, 0, 0, 0.8);
    transform: scale(1.01);
  }

  75% {
    text-shadow:
      0 0 12rpx var(--primary-alpha-90),
      0 0 22rpx rgba(255, 183, 77, 0.7),
      0 0 32rpx var(--primary-alpha-50),
      0 2rpx 4rpx rgba(0, 0, 0, 0.8);
    transform: scale(1.01);
  }
}

/* 关键日期卡片样式 */
.date-card {
  width: 100%;
}

.key-date-card {
  box-sizing: border-box;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow:
    0 2rpx 8rpx rgba(212, 165, 116, 0.08),
    0 8rpx 24rpx rgba(212, 165, 116, 0.12),
    0 16rpx 32rpx rgba(212, 165, 116, 0.06);
  border: 1rpx solid rgba(212, 165, 116, 0.15);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.edit-btn {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, var(--color-orange-500) 0%, var(--color-orange-700) 100%) !important;
  color: var(--color-white-pure);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-light);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
  padding: 0;
}

.edit-btn:active {
  transform: scale(0.9);
  box-shadow: var(--shadow-light);
}

.key-date-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.key-date-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border: 2rpx solid var(--primary-alpha-15) !important;
  border-bottom: 2rpx solid #F5F5F5;
}

.date-label {
  font-size: 32rpx;
  color: #333;
  max-width: 400rpx;
  font-weight: bold;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.date-value-wrap {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.date-value {
  font-size: 32rpx;
  color: var(--color-orange-400);
  font-weight: 500;
}

.date-status {
  margin-bottom: 5rpx;
  font-size: 24rpx;
  color: #999;
}

.calendar-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 24rpx;
  box-sizing: border-box;
  box-shadow:
    0 2rpx 8rpx rgba(212, 165, 116, 0.08),
    0 8rpx 24rpx rgba(212, 165, 116, 0.12),
    0 16rpx 32rpx rgba(212, 165, 116, 0.06);
  border: 1rpx solid rgba(212, 165, 116, 0.15);
  position: relative;
  overflow: hidden;
}

/* 移除日历卡片动画以提升性能 */

/* 现代轻奢顶部装饰线 */
.calendar-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      #FFB84D 20%,
      #E6C390 50%,
      #FFB84D 80%,
      transparent 100%);
  border-radius: 24rpx 24rpx 0 0;
}

/* 🌈 彩虹流动动画 */
@keyframes calendar-rainbow-flow {
  0% {
    background-position: -200% center;
  }

  100% {
    background-position: 200% center;
  }
}

/* 移除复杂的光粒子动画以提升性能 */

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 0 10rpx;
}

.calendar-title-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg,
      rgba(212, 165, 116, 0.08) 0%,
      rgba(230, 195, 144, 0.12) 50%,
      rgba(212, 165, 116, 0.06) 100%);
  border-radius: 16rpx;
  box-shadow:
    0 2rpx 4rpx rgba(212, 165, 116, 0.08),
    0 4rpx 8rpx rgba(212, 165, 116, 0.04);
  border: 1rpx solid rgba(212, 165, 116, 0.15);
}

.calendar-title {
  font-size: 36rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #FFB84D 0%, #E6C390 100%);
  background-clip: text;
  -webkit-background-clip: text;
  color: transparent;
  text-shadow: 0 2rpx 4rpx rgba(212, 165, 116, 0.2);
}

.calendar-nav {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.calendar-nav-btn {
  width: 56rpx;
  height: 56rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 2rpx 4rpx rgba(212, 165, 116, 0.08),
    0 4rpx 8rpx rgba(212, 165, 116, 0.04);
  border: 1rpx solid rgba(212, 165, 116, 0.12);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.calendar-nav-btn:active {
  transform: scale(0.95) translateY(1rpx);
  background: rgba(212, 165, 116, 0.05);
  box-shadow:
    0 1rpx 2rpx rgba(212, 165, 116, 0.08),
    0 2rpx 4rpx rgba(212, 165, 116, 0.04);
}

.current-month {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  padding: 12rpx 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow:
    0 2rpx 4rpx rgba(212, 165, 116, 0.08),
    0 4rpx 8rpx rgba(212, 165, 116, 0.04);
  border: 1rpx solid rgba(212, 165, 116, 0.12);
}

.weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
  gap: 16rpx;
}

.weekdays text {
  font-size: 26rpx;
  color: #666;
  padding: 16rpx 0;
  font-weight: 600;
  background: rgba(212, 165, 116, 0.04);
  border-radius: 12rpx;
  box-shadow:
    0 1rpx 2rpx rgba(212, 165, 116, 0.06),
    0 2rpx 4rpx rgba(212, 165, 116, 0.03);
  border: 1rpx solid rgba(212, 165, 116, 0.08);
}

.days {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 16rpx;
  padding: 0 8rpx;
}

/* 💎 玻璃透光日期格子 - 超级炫酷效果 */
.day {
  width: 100%;
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: 16rpx;
  background: rgba(212, 165, 116, 0.03);
  box-shadow:
    0 1rpx 3rpx rgba(212, 165, 116, 0.06),
    0 2rpx 6rpx rgba(212, 165, 116, 0.04);
  border: 1rpx solid rgba(212, 165, 116, 0.08);
  transition: all 0.2s ease-out;
  cursor: pointer;
  overflow: hidden;
}

/* ✨ 玻璃表面反光效果 */
.day::before {
  content: '';
  position: absolute;
  top: -80%;
  left: -80%;
  width: 260%;
  height: 260%;
  background: linear-gradient(45deg,
      transparent 20%,
      rgba(255, 255, 255, 0.15) 35%,
      rgba(255, 183, 77, 0.1) 45%,
      rgba(255, 255, 255, 0.3) 50%,
      rgba(255, 204, 128, 0.08) 55%,
      rgba(255, 255, 255, 0.15) 65%,
      transparent 80%);
  transform: rotate(-45deg);
  transition: opacity 0.3s ease-out, transform 0.3s ease-out;
  opacity: 0;
  /* 移除微光动画以提升性能 */
}

/* 移除微光动画定义以提升性能 */

/* 🎯 日期格子炫酷交互效果 - 震动配合视觉反馈 */
.day:active {
  transform: scale3d(0.88, 0.88, 1) translateZ(20rpx);
  box-shadow: var(--shadow-light);
  backdrop-filter: blur(35rpx) saturate(180%) contrast(120%);
  -webkit-backdrop-filter: blur(35rpx) saturate(180%) contrast(120%);
  /* 移除点击时的额外动画，只保留transform变化 */
}

/* 移除点击脉冲动画以提升性能 */

.day:active::before {
  opacity: 1;
  top: -30%;
  left: -30%;
  transform: rotate(-45deg) scale(1.5);
  /* 简化光效，只改变透明度和尺寸 */
}

/* 移除点击光效动画以提升性能 */

.day-number {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  position: relative;
  z-index: 2;
  transition: all 0.3s ease;
}

/* 🌟 今日日期 - 超级炫酷全息玻璃效果 */
.today {
  background: linear-gradient(145deg,
      #FFB84D 0%,
      #E6C390 50%,
      #FFB84D 100%) !important;
  transform: scale(1.08);
  box-shadow:
    0 4rpx 12rpx rgba(212, 165, 116, 0.25),
    0 8rpx 24rpx rgba(212, 165, 116, 0.15),
    0 16rpx 32rpx rgba(212, 165, 116, 0.08) !important;
  border: 2rpx solid rgba(255, 255, 255, 0.8) !important;
  position: relative;
  z-index: 5;
}

/* 🎆 今日日期简化脉冲动画 - 高性能版 */
@keyframes today-simple-pulse {

  0%,
  100% {
    transform: scale3d(1.12, 1.12, 1);
  }

  50% {
    transform: scale3d(1.16, 1.16, 1);
  }
}

/* ✨ 今日日期超级光效 */
.today::before {
  background: linear-gradient(45deg,
      transparent 0%,
      rgba(255, 255, 255, 0.2) 15%,
      rgba(255, 183, 77, 0.3) 25%,
      rgba(255, 255, 255, 0.6) 40%,
      rgba(255, 204, 128, 0.4) 50%,
      rgba(255, 255, 255, 0.6) 60%,
      rgba(255, 183, 77, 0.3) 75%,
      rgba(255, 255, 255, 0.2) 85%,
      transparent 100%);
  opacity: 1;
  animation: today-simple-shine 8s ease-in-out infinite;
}

/* 🌟 今日简化光效动画 - 高性能版 */
@keyframes today-simple-shine {

  0%,
  100% {
    opacity: 0.6;
  }

  50% {
    opacity: 1;
  }
}

.today .day-number {
  color: #FFFFFF !important;
  font-weight: 700 !important;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
  font-size: 32rpx !important;
}

.today:not(.has-event)::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 80%;
  height: 80%;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle,
      rgba(255, 193, 7, 0.1) 0%,
      rgba(255, 167, 38, 0.05) 60%,
      transparent 70%);
  border-radius: 50%;
  animation: todayPulse 3s ease-in-out infinite;
  z-index: 1;
}

@keyframes todayPulse {

  0%,
  100% {
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.6;
  }

  50% {
    transform: translate(-50%, -50%) scale(1.2);
    opacity: 0.3;
  }
}

/* 🌟 选中日期 - 明亮透明橘色 */
.selected {
  background: rgba(255, 152, 0, 0.8) !important;
  border: 2rpx solid rgba(255, 193, 7, 0.6);
  transform: translateY(-3rpx) scale(1.05);
  backdrop-filter: blur(8rpx) saturate(1.2);
  box-shadow:
    0 8rpx 24rpx rgba(255, 152, 0, 0.3),
    0 4rpx 12rpx rgba(255, 152, 0, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3) !important;
}

.selected::before {
  background: linear-gradient(45deg,
      transparent 15%,
      rgba(255, 255, 255, 0.6) 25%,
      rgba(255, 255, 255, 0.4) 40%,
      rgba(255, 193, 7, 0.3) 50%,
      rgba(255, 255, 255, 0.5) 60%,
      rgba(255, 255, 255, 0.7) 75%,
      transparent 85%);
  opacity: 1;
  animation: selectedShimmer 2s ease-in-out infinite;
}

@keyframes selectedShimmer {
  0% {
    transform: rotate(-45deg) translateX(-100%);
  }

  50% {
    transform: rotate(-45deg) translateX(0%);
  }

  100% {
    transform: rotate(-45deg) translateX(100%);
  }
}

.selected .day-number {
  color: var(--color-white-pure) !important;
  font-weight: 700 !important;
  text-shadow:
    0 2rpx 4rpx rgba(0, 0, 0, 0.3),
    0 1rpx 2rpx rgba(255, 152, 0, 0.8);
  font-size: 34rpx !important;
}

.selected:not(.has-event)::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100%;
  height: 100%;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle,
      rgba(255, 255, 255, 0.2) 0%,
      rgba(255, 193, 7, 0.1) 40%,
      transparent 70%);
  border-radius: 50%;
  animation: selectedGlow 2.5s ease-in-out infinite;
  z-index: 1;
}

@keyframes selectedGlow {

  0%,
  100% {
    transform: translate(-50%, -50%) scale(0.8);
    opacity: 0.8;
  }

  50% {
    transform: translate(-50%, -50%) scale(1.3);
    opacity: 0.4;
  }
}

/* 🌟 事件标记点 - 立体微型宝石效果 */
.has-event {
  position: relative;
}

.has-event::after {
  content: '';
  position: absolute;
  bottom: 6rpx;
  right: 6rpx;
  width: 14rpx;
  height: 14rpx;
  background: linear-gradient(145deg,
      #FF6B6B 0%,
      #FF8E53 50%,
      #FF6B6B 100%);
  border-radius: 50%;
  box-shadow: var(--shadow-light);
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  z-index: 5;
  animation: eventDotPulse 2s ease-in-out infinite;
}

@keyframes eventDotPulse {

  0%,
  100% {
    transform: scale(1);
    opacity: 0.9;
  }

  50% {
    transform: scale(1.2);
    opacity: 0.7;
  }
}

.selected.has-event::after {
  background: linear-gradient(145deg,
      rgba(255, 255, 255, 0.95) 0%,
      rgba(255, 255, 255, 0.8) 50%,
      rgba(255, 255, 255, 0.95) 100%) !important;
  box-shadow: var(--shadow-light) !important;
  border: 2rpx solid rgba(255, 255, 255, 0.95) !important;
  width: 14rpx !important;
  height: 14rpx !important;
  bottom: 6rpx !important;
  right: 6rpx !important;
  z-index: 10 !important;
  animation: selectedEventDot 2s ease-in-out infinite !important;
  position: absolute !important;
}

@keyframes selectedEventDot {

  0%,
  100% {
    transform: scale(1);
    opacity: 1;
    box-shadow: var(--shadow-light);
  }

  50% {
    transform: scale(1.3);
    opacity: 0.9;
    box-shadow: var(--shadow-light);
  }
}

.today.has-event::after {
  background: linear-gradient(145deg,
      var(--color-orange-500) 0%,
      var(--color-orange-400) 50%,
      var(--color-orange-500) 100%) !important;
  box-shadow: var(--shadow-light) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.9) !important;
  bottom: 6rpx !important;
  right: 6rpx !important;
  width: 14rpx !important;
  height: 14rpx !important;
  z-index: 10 !important;
  position: absolute !important;
}

/* ==================== 暖光里程碑 - 完全参考个人档案 ==================== */
.milestone-section {
  box-sizing: border-box;
  width: 712rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 25rpx;
  margin: 0 auto 15rpx auto;
  box-shadow:
    0 16rpx 40rpx rgba(212, 165, 116, 0.15),
    0 8rpx 20rpx rgba(212, 165, 116, 0.12),
    0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(212, 165, 116, 0.15);
  position: relative;
  overflow: hidden;
  z-index: 1;
}

/* 标题栏 - 完全参考个人档案的section-header */
.milestone-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: none;
  position: relative;
}

/* 装饰性下划线 */
.milestone-header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(212, 165, 116, 0.3) 20%,
      rgba(212, 165, 116, 0.6) 50%,
      rgba(212, 165, 116, 0.3) 80%,
      transparent 100%);
  border-radius: 2rpx;
}

.milestone-title-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.milestone-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF9800;
  letter-spacing: 0.5rpx;
}

/* 编辑按钮 - 完全使用公共样式 */
.milestone-edit-btn {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: var(--gradient-3d-primary);
  border-radius: 24rpx;
  color: #FF9800;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow:
    0 6rpx 16rpx rgba(212, 165, 116, 0.2),
    0 3rpx 8rpx rgba(212, 165, 116, 0.15),
    0 2rpx 4rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(212, 165, 116, 0.25);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  letter-spacing: 0.5rpx;
}

.milestone-edit-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.8) 50%,
      transparent 100%);
  border-radius: 24rpx 24rpx 0 0;
}

.milestone-edit-btn:active {
  background: var(--gradient-3d-active);
  box-shadow:
    0 3rpx 8rpx rgba(212, 165, 116, 0.25),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.6);
  transform: translateY(1rpx);
}

.milestone-edit-text {
  margin-left: 8rpx;
}

.milestone-content {
  min-height: 140rpx;
}

/* 里程碑网格 - 简单有效的2列布局 */
.milestone-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 16rpx 0;
  width: 100%;
}

/* 里程碑卡片 - 简单固定宽度 */
.milestone-card {
  width: 49%;
  background: linear-gradient(135deg, #ffffff 0%, #fefefe 50%, #ffffff 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow:
    0 8rpx 32rpx rgba(212, 165, 116, 0.12),
    0 4rpx 16rpx rgba(212, 165, 116, 0.08),
    0 2rpx 8rpx rgba(0, 0, 0, 0.04),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  border: 1rpx solid rgba(212, 165, 116, 0.15);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

/* 单个里程碑时占满整行 */
.milestone-grid.single-item {
  justify-content: flex-start;
}

.milestone-card.single-card {
  width: 100%;
  /* 横向布局，左右分布 */
  flex-direction: row;
  align-items: center;
  padding: 32rpx 40rpx;
  min-height: 180rpx;
}

/* 单个里程碑的头部信息 */
.milestone-card.single-card .milestone-card-header {
  flex: 1;
  margin-bottom: 0;
  margin-right: 32rpx;
}

/* 单个里程碑的主体（数字区域） */
.milestone-card.single-card .milestone-card-body {
  flex: none;
  width: auto;
  text-align: right;
}

/* 单个里程碑时数字样式调整 - 适配多位数 */
.milestone-card.single-card .milestone-days-text {
  font-size: 88rpx;
  line-height: 1;
}

.milestone-card.single-card .milestone-status-text {
  font-size: 26rpx;
}

.milestone-card.single-card .milestone-unit-text {
  font-size: 30rpx;
}

/* 卡片内光效 */
.milestone-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.9) 50%,
      transparent 100%);
  border-radius: 24rpx 24rpx 0 0;
}

.milestone-card:active {
  transform: scale(0.96) translateY(1rpx);
  box-shadow:
    0 6rpx 24rpx rgba(212, 165, 116, 0.15),
    0 3rpx 12rpx rgba(212, 165, 116, 0.12),
    0 2rpx 6rpx rgba(0, 0, 0, 0.06),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.6);
}

/* 卡片头部 - 精致版式 */
.milestone-card-header {
  margin-bottom: 12rpx;
  position: relative;
  z-index: 2;
}

.milestone-card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2c2c2c;
  line-height: 1.2;
  margin-bottom: 8rpx;
  letter-spacing: 0.5rpx;
}

.milestone-card-date {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
  opacity: 0.8;
  letter-spacing: 0.2rpx;
}

/* 卡片主体 - 左对齐倒数日显示 */
.milestone-card-body {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  text-align: left;
  position: relative;
  z-index: 2;
}

.milestone-text-line {
  display: flex;
  align-items: baseline;
  justify-content: flex-start;
  gap: 6rpx;
  line-height: 1;
}

.milestone-status-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #2c2c2c;
  opacity: 0.8;
  letter-spacing: 0.5rpx;
  min-width: 80rpx;
  white-space: nowrap;
}

.milestone-full-text {
  font-size: 42rpx;
  font-weight: 600;
  background: linear-gradient(135deg,
      #FF9800 0%,
      #FFB84D 40%,
      #FFCC80 70%,
      #FFE0B3 100%);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
  line-height: 1.2;
  text-align: center;
  text-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.2);
}

.milestone-days-text {
  font-size: 72rpx;
  font-weight: 900;
  background: linear-gradient(135deg,
      #FF9800 0%,
      #FFB84D 40%,
      #FFCC80 70%,
      #FFE0B3 100%);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
  line-height: 0.9;
  margin: 0 4rpx;
  text-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.2);
  position: relative;
}

/* 数字阴影效果 */
.milestone-days-text::before {
  content: attr(data-days);
  position: absolute;
  top: 2rpx;
  left: 2rpx;
  color: rgba(255, 152, 0, 0.08);
  z-index: -1;
  font-size: inherit;
  font-weight: inherit;
}

.milestone-unit-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FF9800;
  opacity: 0.9;
  letter-spacing: 0.5rpx;
}

.milestone-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  background: linear-gradient(145deg, #FAFAFA 0%, #F8F8F8 100%);
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 184, 77, 0.2);
  position: relative;
  overflow: hidden;
}

.milestone-empty::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: -10rpx;
  right: -10rpx;
  bottom: -10rpx;
  background: linear-gradient(45deg,
      rgba(255, 184, 77, 0.05) 0%,
      rgba(255, 204, 128, 0.03) 25%,
      rgba(255, 184, 77, 0.05) 50%,
      rgba(255, 204, 128, 0.03) 75%,
      rgba(255, 184, 77, 0.05) 100%);
  background-size: 40rpx 40rpx;
  opacity: 0.3;
  animation: shimmer 3s ease-in-out infinite;
}

@keyframes shimmer {

  0%,
  100% {
    opacity: 0.3;
  }

  50% {
    opacity: 0.1;
  }
}

.milestone-empty .empty-title {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-top: 16rpx;
  font-weight: 600;
  z-index: 2;
  position: relative;
}

.milestone-empty .empty-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
  z-index: 2;
  position: relative;
  opacity: 0.8;
}

/* ==================== 🎯 紧凑日期选择器设计 ==================== */
.date-selector-section {
  margin: 24rpx 24rpx;
  padding: 0;
}

.date-selector-header {
  margin-bottom: 16rpx;
}

.date-selector-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.date-selector-container {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow:
    0 2rpx 8rpx rgba(0, 0, 0, 0.04),
    0 1rpx 2rpx rgba(0, 0, 0, 0.02);
}

.selected-date {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background: rgba(255, 184, 77, 0.08);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s ease;
  border: 1rpx solid rgba(255, 184, 77, 0.12);
}

.selected-date:active {
  transform: scale(0.98);
  background: var(--primary-alpha-10);
}

.selected-date-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary-dark);
}

.quick-dates {
  display: flex;
  gap: 12rpx;
}

.quick-date-item {
  flex: 1;
  padding: 12rpx 16rpx;
  background: #F8F8F8;
  border-radius: 10rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
  font-weight: 500;
}

.quick-date-item.active {
  background: var(--primary-color);
  color: white;
  border-color: var(--primary-color);
}

.quick-date-item:not(.active):active {
  transform: scale(0.95);
  background: var(--primary-alpha-06);
}

/* ==================== 🔥 高级功能项网格 - 与里程碑风格统一 ==================== */
.functions-grid {
  box-sizing: border-box;
  width: 100%;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 0 24rpx;
  margin-bottom: 32rpx;
}

.function-card {
  box-sizing: border-box;
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 0;
  border: none;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  min-height: 200rpx;
  display: flex;
  flex-direction: column;
  box-shadow:
    0 2rpx 8rpx rgba(0, 0, 0, 0.04),
    0 1rpx 2rpx rgba(0, 0, 0, 0.06);
}

.function-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.02) 0%,
      rgba(255, 204, 128, 0.01) 50%,
      rgba(255, 152, 0, 0.02) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.function-card:active {
  transform: scale(0.985);
  box-shadow:
    0 4rpx 12rpx rgba(255, 152, 0, 0.15),
    0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.function-card:active::before {
  opacity: 1;
}

.function-card-header {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx 16rpx;
  position: relative;
  background: linear-gradient(135deg,
      rgba(255, 248, 240, 0.9) 0%,
      rgba(255, 252, 248, 0.6) 100%);
}

.function-card-icon {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  transition: all 0.3s ease;
  box-shadow:
    0 2rpx 6rpx rgba(255, 152, 0, 0.08);
  position: relative;
}

.function-card-icon::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  background: linear-gradient(45deg,
      rgba(255, 204, 128, 0.1) 0%,
      transparent 50%,
      rgba(255, 184, 77, 0.08) 100%);
  border-radius: 20rpx;
  z-index: -1;
}

.function-card:active .function-card-icon {
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.25) 0%,
      rgba(255, 204, 128, 0.18) 50%,
      rgba(255, 152, 0, 0.22) 100%);
  transform: scale(1.05) rotate(1deg);
  box-shadow:
    0 6rpx 16rpx rgba(255, 152, 0, 0.12),
    inset 0 1rpx 3rpx rgba(255, 255, 255, 0.5);
}

.function-card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c3e50;
  line-height: 1;
  letter-spacing: 0.5rpx;
  flex: 1;
}

.function-card-content {
  flex: 1;
  padding: 20rpx 24rpx 24rpx;
  display: flex;
  flex-direction: column;
}

.function-card-data {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.data-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 16rpx;
  background: rgba(255, 248, 240, 0.5);
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.data-item:last-child {
  margin-bottom: 0;
}

.data-label {
  font-size: 24rpx;
  color: #666;
  font-weight: 400;
  letter-spacing: 0.3rpx;
}

.data-value {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--primary-color);
  letter-spacing: 0.5rpx;
}

.function-card-date {
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
  text-align: right;
  font-weight: 400;
}

.function-card-empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 20rpx;
  min-height: 80rpx;
}

.empty-text {
  font-size: 24rpx;
  color: #b0b0b0;
  text-align: center;
  line-height: 1.5;
  font-weight: 400;
}

/* 用药记录特殊样式 */
.medication-progress-mini {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 8rpx 0;
}

.progress-info {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.medication-count {
  font-size: 34rpx;
  font-weight: 800;
  background: linear-gradient(135deg,
      #FF9800 0%,
      #FFB84D 50%,
      #F57C00 100%);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
  text-shadow: 0 2rpx 4rpx rgba(255, 152, 0, 0.1);
}

.medication-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.progress-bar-mini {
  height: 10rpx;
  background: linear-gradient(90deg,
      rgba(255, 184, 77, 0.08) 0%,
      rgba(255, 204, 128, 0.05) 100%);
  border-radius: 6rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 184, 77, 0.05);
  box-shadow: inset 0 1rpx 2rpx rgba(0, 0, 0, 0.02);
}

.progress-fill-mini {
  height: 100%;
  background: linear-gradient(90deg,
      #FF9800 0%,
      #FFB84D 50%,
      #FFC947 100%);
  border-radius: 5rpx;
  transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow:
    0 1rpx 3rpx rgba(255, 152, 0, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
  position: relative;
}

.progress-fill-mini::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(90deg,
      rgba(255, 255, 255, 0.15) 0%,
      rgba(255, 255, 255, 0.08) 100%);
  border-radius: 5rpx 5rpx 0 0;
}

/* ==================== 📱 响应式优化 ==================== */
@media (max-width: 360px) {
  .functions-grid {
    padding: 0 16rpx;
    gap: 12rpx;
  }

  .function-card {
    padding: 20rpx;
    min-height: 140rpx;
  }

  .function-card-icon {
    width: 56rpx;
    height: 56rpx;
    margin-right: 12rpx;
  }

  .function-card-title {
    font-size: 26rpx;
  }
}

/* 功能列表样式 - 添加外层padding保持一致 */
.function-list {
  width: 100%;
  background: transparent;
  box-sizing: border-box;
}

/* 强制分隔线显示 - 使用全局变量保持一致 */
.function-list .function-item::after {
  content: '' !important;
  position: absolute !important;
  bottom: var(--divider-margin-bottom) !important;
  left: var(--divider-left-offset) !important;
  right: var(--divider-right-offset) !important;
  height: var(--divider-height) !important;
  background: var(--divider-gradient) !important;
  z-index: 10 !important;
  border-radius: 1rpx !important;
}

/* 最后一个功能项不显示分隔线 */
.function-list .function-item:last-child::after {
  display: none !important;
}



/* 使用全局的 .function-icon 样式，已定义在 app.wxss 中 */

/* 使用全局的 .function-info 和 .function-title 样式，已定义在 app.wxss 中 */

/* 使用全局的 .function-info 和 .function-desc 样式，已定义在 app.wxss 中 */

/* 今日事项样式 - 温暖橙色主题 */
.today-tasks {
  width: 100%;
  margin: 24rpx;
  padding: 32rpx;
  box-sizing: border-box;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow:
    0 2rpx 8rpx rgba(212, 165, 116, 0.08),
    0 8rpx 24rpx rgba(212, 165, 116, 0.12),
    0 16rpx 32rpx rgba(212, 165, 116, 0.06);
  border: 1rpx solid rgba(212, 165, 116, 0.15);
  position: relative;
  overflow: hidden;
}

/* 🌟 今日待办轻微跑马灯效果 */
.today-tasks::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      #FFB84D 20%,
      #E6C390 50%,
      #FFB84D 80%,
      transparent 100%);
  border-radius: 24rpx 24rpx 0 0;
  pointer-events: none;
  z-index: 1;
}

/* 🎭 今日待办跑马灯动画 - 更慢更轻微 */
@keyframes task-marquee-flow {
  0% {
    left: -100%;
    opacity: 0;
  }

  15% {
    opacity: 0.4;
  }

  85% {
    opacity: 0.4;
  }

  100% {
    left: 100%;
    opacity: 0;
  }
}

/* 移除今日待办顶部横条 */

.add-btn {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, var(--color-orange-500) 0%, var(--color-orange-700) 100%) !important;
  color: var(--color-white-pure);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-light);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
}

.add-btn:active {
  transform: scale(0.9);
  box-shadow: var(--shadow-light);
}

.task-list {
  margin-top: 24rpx;
  padding-top: 4rpx;
}

.task-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background: linear-gradient(135deg, rgba(255, 152, 0, 0.03) 0%, rgba(255, 183, 77, 0.08) 50%, rgba(255, 255, 255, 0.95) 100%);
  border-radius: 16rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  width: 100%;
  box-sizing: border-box;
  position: relative;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--primary-alpha-15);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

/* 移除今日待办卡片顶部横条 */

.task-item::after {
  content: '';
  position: absolute;
