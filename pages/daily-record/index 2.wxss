/* 日期详情弹窗样式 - 优化版 */
.date-detail-popup {
  background: linear-gradient(135deg, var(--color-white-pure) 0%, #fafafa 100%);
  border-radius: 24rpx;
  padding: 0;
  width: 680rpx;
  max-height: 85vh;
  overflow: hidden;
  box-shadow: var(--shadow-card);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.date-detail-header {
  background: linear-gradient(135deg,
      rgba(255, 184, 0, 0.95) 0%,
      rgba(255, 143, 0, 0.98) 50%,
      rgba(255, 111, 0, 0.92) 100%);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  color: white;
  padding: 32rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  overflow: hidden;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.2);
  box-shadow:
    0 8rpx 32rpx rgba(255, 143, 0, 0.3),
    0 4rpx 16rpx rgba(0, 0, 0, 0.1),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.4),
    inset 0 -1rpx 0 rgba(255, 111, 0, 0.8);
}

.date-detail-header::before {
  content: '';
  position: absolute;
  top: -100%;
  left: -100%;
  width: 300%;
  height: 300%;
  background: radial-gradient(circle at 30% 20%,
      rgba(255, 255, 255, 0.25) 0%,
      rgba(255, 255, 255, 0.1) 40%,
      transparent 70%);
  animation: glassShimmer 4s ease-in-out infinite;
  pointer-events: none;
}

.date-detail-header::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.8) 20%,
      rgba(255, 255, 255, 0.9) 50%,
      rgba(255, 255, 255, 0.8) 80%,
      transparent 100%);
  border-radius: 24rpx 24rpx 0 0;
}

@keyframes glassShimmer {

  0%,
  100% {
    transform: translateX(-50%) translateY(-50%) scale(0.8);
    opacity: 0.6;
  }

  50% {
    transform: translateX(-30%) translateY(-30%) scale(1.1);
    opacity: 1;
  }
}



