/* 🌟 Recent提示样式 */
.recent-hint {
  padding: 6rpx 10rpx;
  background: linear-gradient(135deg,
      var(--primary-alpha-08) 0%,
      rgba(255, 183, 77, 0.12) 100%) !important;
  border-radius: 10rpx !important;
  border: 1rpx solid var(--primary-alpha-20) !important;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  min-height: 32rpx;
  box-sizing: border-box;
  animation: hint-glow 2.5s ease-in-out infinite;
}

.recent-hint-icon {
  font-size: 18rpx;
}

.recent-hint-text {
  font-size: 18rpx !important;
  color: #FF9800 !important;
  font-weight: 500 !important;
}

@keyframes hint-glow {

  0%,
  100% {
    background: linear-gradient(135deg,
        var(--primary-alpha-08) 0%,
        rgba(255, 183, 77, 0.12) 100%);
  }

  50% {
    background: linear-gradient(135deg,
        var(--primary-alpha-12) 0%,
        rgba(255, 183, 77, 0.16) 100%);
  }
}

@keyframes recent-glow {

  0%,
  100% {
    box-shadow:
      0 6rpx 18rpx var(--primary-alpha-20),
      0 3rpx 9rpx rgba(255, 183, 77, 0.15),
      inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
      inset 0 -1rpx 0 var(--primary-alpha-10);
  }

  50% {
    box-shadow:
      0 8rpx 24rpx var(--primary-alpha-25),
      0 4rpx 12rpx rgba(255, 183, 77, 0.2),
      inset 0 1rpx 0 rgba(255, 255, 255, 0.8),
      inset 0 -1rpx 0 var(--primary-alpha-15);
  }
}

.recent-count::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
  transition: left 0.6s ease;
}

.recent-count:hover::before {
  left: 100%;
}

.recent-hint {
  padding: 8rpx 12rpx;
  background: linear-gradient(135deg,
      var(--primary-alpha-08) 0%,
      rgba(255, 183, 77, 0.12) 100%);
  border-radius: 12rpx;
  border: 1rpx solid var(--primary-alpha-25);
  display: inline-flex;
  align-items: center;
  height: 36rpx;
  box-sizing: border-box;
  white-space: nowrap;
  box-shadow:
    0 4rpx 12rpx var(--primary-alpha-12),
    0 2rpx 6rpx var(--primary-alpha-08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.5);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}


.recent-hint-icon {
  font-size: 20rpx;
  margin-right: 6rpx;
  line-height: 1;
}

.recent-hint-text {
  font-size: 22rpx;
  color: #FF9800;
  font-weight: 500;
  letter-spacing: 0.2rpx;
