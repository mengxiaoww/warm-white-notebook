/* ==================== 新日历组件 - 匹配暖光里程碑样式 ==================== */
.calendar-section {
  box-sizing: border-box;
  width: 712rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  padding: 24rpx;
  margin: 0 auto 20rpx auto;
  box-shadow: 0 4rpx 16rpx rgba(212, 165, 116, 0.08);
  border: 1rpx solid rgba(212, 165, 116, 0.08);
  position: relative;
  overflow: hidden;
  z-index: 1;
  backdrop-filter: blur(10rpx);
}

/* 日历标题栏 - 完全匹配里程碑样式 */
.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: none;
  position: relative;
}

/* 装饰性下划线 */
.calendar-header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(212, 165, 116, 0.3) 20%,
      rgba(212, 165, 116, 0.6) 50%,
      rgba(212, 165, 116, 0.3) 80%,
      transparent 100%);
  border-radius: 2rpx;
}

.calendar-title-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.calendar-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF9800;
  letter-spacing: 0.5rpx;
}

/* 展开按钮 - 使用公共样式 */
.calendar-expand-btn {
  margin-left: 25rpx;
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: var(--gradient-3d-primary);
  border-radius: 24rpx;
  color: #FF9800;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow:
    0 6rpx 16rpx rgba(212, 165, 116, 0.2),
    0 3rpx 8rpx rgba(212, 165, 116, 0.15),
    0 2rpx 4rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(212, 165, 116, 0.25);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  letter-spacing: 0.5rpx;
}

.calendar-expand-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.8) 50%,
      transparent 100%);
  border-radius: 24rpx 24rpx 0 0;
}

.calendar-expand-btn:active {
  background: var(--gradient-3d-active);
  box-shadow:
    0 3rpx 8rpx rgba(212, 165, 116, 0.25),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.6);
  transform: translateY(1rpx);
}

/* 日历内容区域 - 极度紧凑设计 */
.calendar-content {
  min-height: 40rpx;
}

/* ==================== 新日历紧凑模式 ==================== */

/* 紧凑模式容器 */
.calendar-compact {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

/* 日期条 - 横向布局 */
.calendar-week-strip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  padding: 8rpx 0;
}

/* 紧凑模式日期单元 */
.calendar-day-compact {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  /* 完美圆形 */
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.5, 1);
  position: relative;
  box-sizing: border-box;
  flex-shrink: 0;
  /* 防止压缩变形 */
}

/* 默认样式 - 清爽简洁风格 */
.calendar-day-compact {
  background: rgba(255, 255, 255, 0.75);
  border: 1rpx solid rgba(255, 184, 77, 0.08);
  box-shadow: 0 2rpx 6rpx rgba(255, 152, 0, 0.04);
  color: #666;
  backdrop-filter: blur(8rpx);
  position: relative;
  overflow: hidden;
}

/* 移除复杂装饰效果 */

/* 选中样式 - 未展开状态明亮透明橘色 */
.calendar-day-compact.selected {
  box-sizing: border-box;
  border: 2rpx solid rgba(255, 193, 7, 0.6);
  color: white;
  font-weight: 700;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.2);
  transform: translateY(-3rpx) scale(1.05);
  backdrop-filter: blur(8rpx) saturate(1.2);
  box-shadow:
    0 8rpx 24rpx rgba(255, 152, 0, 0.3),
    0 4rpx 12rpx rgba(255, 152, 0, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
}


/* 奢华旋转动画 */
@keyframes luxury-rotate {
  0% {
    transform: rotate(0deg);
  }

  100% {
    transform: rotate(360deg);
  }
}

/* ===== 通透橘色动画系统 ===== */

/* 橘色主体脉冲 */
@keyframes orange-pulse {
  0% {
    transform: translateY(-8rpx) scale(1.15) rotateX(3deg) rotateZ(1deg);
    filter: brightness(1) saturate(1.2);
  }

  50% {
    transform: translateY(-12rpx) scale(1.2) rotateX(5deg) rotateZ(-1deg);
    filter: brightness(1.3) saturate(1.5);
  }

  100% {
    transform: translateY(-8rpx) scale(1.15) rotateX(3deg) rotateZ(1deg);
    filter: brightness(1) saturate(1.2);
  }
}

/* 橘色能量环旋转 */
@keyframes orange-rotate {
  0% {
    transform: rotate(0deg) scale(1);
    filter: blur(2rpx) brightness(1.2);
  }

  25% {
    transform: rotate(90deg) scale(1.05);
    filter: blur(1.5rpx) brightness(1.4);
  }

  50% {
    transform: rotate(180deg) scale(1);
    filter: blur(2rpx) brightness(1.2);
  }

  75% {
    transform: rotate(270deg) scale(0.95);
    filter: blur(2.5rpx) brightness(1.1);
  }

  100% {
    transform: rotate(360deg) scale(1);
    filter: blur(2rpx) brightness(1.2);
  }
}

/* 能量脉冲 */
@keyframes energy-pulse {
  0% {
    opacity: 0.8;
    transform: scale(1);
    filter: blur(2rpx) brightness(1.2);
  }

  50% {
    opacity: 1;
    transform: scale(1.1);
    filter: blur(1rpx) brightness(1.5);
  }

  100% {
    opacity: 0.9;
    transform: scale(0.95);
    filter: blur(2.5rpx) brightness(1.1);
  }
}


/* 粒子舞蹈 */
@keyframes particle-dance {
  0% {
    transform: rotate(0deg) scale(1) skewX(0deg);
    filter: blur(1rpx) brightness(1);
  }

  20% {
    transform: rotate(72deg) scale(1.1) skewX(5deg);
    filter: blur(0.5rpx) brightness(1.2);
  }

  40% {
    transform: rotate(144deg) scale(0.9) skewX(-3deg);
    filter: blur(1.5rpx) brightness(0.9);
  }

  60% {
    transform: rotate(216deg) scale(1.05) skewX(8deg);
    filter: blur(1rpx) brightness(1.1);
  }

  80% {
    transform: rotate(288deg) scale(0.95) skewX(-2deg);
    filter: blur(2rpx) brightness(0.8);
  }

  100% {
    transform: rotate(360deg) scale(1) skewX(0deg);
    filter: blur(1rpx) brightness(1);
  }
}

/* 能量波动 */
@keyframes energy-fluctuation {
  0% {
    opacity: 0.6;
    transform: scale(1) rotateX(0deg);
    filter: blur(1rpx) brightness(1) contrast(1);
  }

  33% {
    opacity: 0.9;
    transform: scale(1.15) rotateX(5deg);
    filter: blur(0.5rpx) brightness(1.3) contrast(1.2);
  }

  66% {
    opacity: 0.7;
    transform: scale(0.9) rotateX(-3deg);
    filter: blur(1.5rpx) brightness(0.9) contrast(0.9);
  }

  100% {
    opacity: 0.8;
    transform: scale(1.05) rotateX(2deg);
    filter: blur(1rpx) brightness(1.1) contrast(1.1);
  }
}

/* 反向旋转动画 */
@keyframes counter-rotate {
  0% {
    transform: rotate(0deg) scale(1);
  }

  100% {
    transform: rotate(-360deg) scale(1.05);
  }
}

/* 强度脉冲动画 */
@keyframes pulse-intensity {
  0% {
    opacity: 0.8;
    transform: scale(1);
  }

  50% {
    opacity: 1;
    transform: scale(1.05);
  }

  100% {
    opacity: 0.9;
    transform: scale(0.98);
  }
}

/* 神圣脉冲动画 */
@keyframes divine-pulse {
  0% {
    opacity: 0.6;
    transform: scale(1) rotate(0deg);
    filter: blur(2rpx) brightness(1);
  }

  33% {
    opacity: 0.9;
    transform: scale(1.15) rotate(5deg);
    filter: blur(1rpx) brightness(1.2);
  }

  66% {
    opacity: 0.8;
    transform: scale(1.05) rotate(-3deg);
    filter: blur(1.5rpx) brightness(1.1);
  }

  100% {
    opacity: 0.75;
    transform: scale(0.95) rotate(0deg);
    filter: blur(2rpx) brightness(1);
  }
}

/* 温和发光动画 - 升级版 */
@keyframes gentle-glow {
  0% {
    opacity: 0.4;
    transform: scale(0.95);
    filter: brightness(1);
  }

  50% {
    opacity: 0.8;
    transform: scale(1.02);
    filter: brightness(1.15);
  }

  100% {
    opacity: 0.6;
    transform: scale(0.98);
    filter: brightness(1.05);
  }
}

/* 日期文本样式 */
.day-name {
  font-size: 20rpx;
  font-weight: 500;
  opacity: 0.8;
  line-height: 1;
}

.day-number {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
  margin-top: 2rpx;
}

/* 文字样式增强 */
.day-name {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  opacity: 0.75;
}

.day-number {
  padding-right: 5rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif;
  font-weight: 800;
  letter-spacing: -0.5rpx;
}

/* 选中状态的奢华文字效果 */
.calendar-day-compact.selected .day-name,
.calendar-day-compact.selected .day-number {
  text-shadow:
    0 2rpx 4rpx rgba(0, 0, 0, 0.15),
    0 1rpx 2rpx rgba(0, 0, 0, 0.1),
    0 0 8rpx rgba(255, 255, 255, 0.3);
  font-weight: 900;
}

.calendar-day-compact.selected .day-name {
  opacity: 0.9;
}

/* 奢华点击效果 */
/* 超级奢华点击效果 - 多阶段反馈 */
.calendar-day-compact:active {
  transform: translateY(4rpx) scale(0.92) rotateX(-1deg);
  transition: all 0.12s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  box-shadow:
    /* 压入状态阴影 */
    0 4rpx 16rpx -1rpx rgba(0, 0, 0, 0.15),
    0 2rpx 8rpx rgba(0, 0, 0, 0.12),
    0 1rpx 4rpx rgba(0, 0, 0, 0.1),
    /* 内层按压反馈 */
    inset 0 3rpx 6rpx rgba(230, 225, 215, 0.6),
    inset 0 1rpx 3rpx rgba(200, 190, 180, 0.4);

  /* 触觉反馈增强 */
  backdrop-filter: blur(16rpx) saturate(0.8) brightness(0.95);
}


/* 周标题 */
.calendar-weekday-header {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.calendar-weekday-title {
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(212, 165, 116, 0.8);
  padding: 12rpx 4rpx 16rpx 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
}

/* 周视图样式 - 紧凑圆形设计 */
.calendar-week-view {
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
  padding: 12rpx 10rpx;
  min-height: 76rpx;
}

/* 周视图中的日期卡片 - 圆形设计 */
.calendar-day-week {
  flex: 1;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 500;
  transition: all 0.25s ease-out;
  position: relative;
  box-sizing: border-box;
  max-width: 72rpx;
}

/* 基础样式 - 橘色主题圆形设计 */
.calendar-day-week {
  background: linear-gradient(135deg,
      rgba(255, 248, 240, 0.95) 0%,
      rgba(254, 245, 235, 0.9) 100%);
  color: #8B4513;
  border: 1rpx solid rgba(255, 184, 77, 0.25);
  box-shadow:
    0 2rpx 6rpx rgba(255, 152, 0, 0.08),
    0 1rpx 3rpx rgba(255, 152, 0, 0.05);
}

/* 选中样式 - 橙色高亮 */
.calendar-day-week.selected {
  background: #FF9800;
  color: white;
  font-weight: 700;
  border: none;
  box-shadow:
    0 3rpx 8rpx rgba(255, 152, 0, 0.3),
    0 1rpx 4rpx rgba(255, 152, 0, 0.2);
  transform: scale(1.05);
}

/* 周视图日期内容 */
.week-day-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
}

.week-day-name {
  font-size: 18rpx;
  font-weight: 500;
  opacity: 0.8;
}

.week-day-number {
  font-size: 24rpx;
  font-weight: 600;
}



/* 月视图容器 */
.calendar-month-container {
  padding: 16rpx 0;
}

/* 月视图网格 - 圆形设计 */
.calendar-month-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 12rpx;
  padding: 0 10rpx;
}

/* 月视图导航 */
.calendar-month-nav {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
  gap: 16rpx;
}

.calendar-month-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #FF9800;
  letter-spacing: 0.5rpx;
}

.calendar-nav-btn {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #ffffff 0%, #fefefe 50%, #ffffff 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 6rpx 16rpx rgba(212, 165, 116, 0.15),
    0 3rpx 8rpx rgba(212, 165, 116, 0.12),
    0 2rpx 4rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(212, 165, 116, 0.15);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.calendar-nav-btn:active {
  transform: scale(0.95) translateY(1rpx);
  background: rgba(212, 165, 116, 0.08);
  box-shadow:
    0 3rpx 8rpx rgba(212, 165, 116, 0.2),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.6);
}

/* 日期单元格 - 圆形设计 */
.calendar-day {
  box-sizing: border-box;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  box-sizing: border-box;
  margin: 0 auto;
}

/* 基础样式 - 高级橘色主题液态玻璃质感 */
.calendar-day {
  background:
    /* 表面橘色液态反射 */
    radial-gradient(ellipse at 25% 15%, rgba(255, 204, 128, 0.2) 0%, transparent 40%),
    radial-gradient(ellipse at 75% 85%, rgba(255, 224, 178, 0.15) 0%, transparent 50%),
    /* 主体橘色液态渐变 */
    linear-gradient(145deg,
      rgba(255, 248, 240, 0.98) 0%,
      rgba(254, 245, 235, 0.92) 20%,
      rgba(253, 242, 230, 0.88) 40%,
      rgba(252, 239, 225, 0.85) 60%,
      rgba(251, 236, 220, 0.82) 80%,
      rgba(250, 233, 215, 0.8) 100%);
  background-clip: padding-box;
  position: relative;

  /* 橘色边框渐变效果 */
  background-image:
    /* 内容层 */
    radial-gradient(ellipse at 25% 15%, rgba(255, 204, 128, 0.2) 0%, transparent 40%),
    radial-gradient(ellipse at 75% 85%, rgba(255, 224, 178, 0.15) 0%, transparent 50%),
    linear-gradient(145deg, rgba(255, 248, 240, 0.98) 0%, rgba(250, 233, 215, 0.8) 100%),
    /* 边框层 */
    linear-gradient(145deg,
      rgba(255, 184, 77, 0.4) 0%,
      rgba(255, 204, 128, 0.5) 25%,
      rgba(255, 224, 178, 0.3) 50%,
      rgba(255, 204, 128, 0.4) 75%,
      rgba(255, 184, 77, 0.35) 100%);
  background-origin: padding-box, padding-box, padding-box, border-box;

  /* 橘色液态玻璃阴影系统 */
  box-shadow:
    /* 环境光层 */
    0 16rpx 48rpx -6rpx rgba(255, 152, 0, 0.08),
    0 8rpx 24rpx -3rpx rgba(255, 152, 0, 0.06),
    0 4rpx 12rpx -1rpx rgba(255, 152, 0, 0.04),

    /* 内层液态高光 */
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.95),
    inset 0 1rpx 2rpx rgba(255, 248, 240, 0.9),
    inset 0 -1rpx 2rpx rgba(255, 204, 128, 0.2),

    /* 外层微光环 */
    0 0 0 1rpx rgba(255, 204, 128, 0.4);

  color: #8B4513;
  backdrop-filter: blur(28rpx) saturate(1.4) brightness(1.05);
  font-family: -apple-system, 'SF Pro Display', 'PingFang SC', sans-serif;
}

/* 选中样式 - 展开状态明亮透明橘色 */
.calendar-day.selected {
  height: 74rpx;
  color: white;
  font-weight: 700;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.2);
  transform: translateY(-3rpx) scale(1.05);
  backdrop-filter: blur(8rpx) saturate(1.2);
  box-shadow:
    0 8rpx 24rpx rgba(255, 152, 0, 0.3),
    0 4rpx 12rpx rgba(255, 152, 0, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
}




/* 空日期（月视图中的填充单元格） */
.calendar-day.empty {
  background: transparent;
  border: none;
  pointer-events: none;
}

/* 日期点击效果 - 立体交互 */
.calendar-day:active {
  transform: translateY(1rpx) scale(0.98);
  box-shadow:
    0 2rpx 6rpx rgba(0, 0, 0, 0.08),
    0 1rpx 3rpx rgba(0, 0, 0, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7);
}