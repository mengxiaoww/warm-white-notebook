  align-items: center;
  gap: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 152, 0, 0.25),
              0 2rpx 8rpx rgba(255, 152, 0, 0.15);
  position: relative;
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 横幅光泽效果 */
.selected-date-banner::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.3) 50%,
    transparent 100%);
  transition: left 0.6s ease;
}

.selected-date-banner:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(255, 152, 0, 0.2);
}

/* 图标容器 */
.banner-icon-wrapper {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* 文字容器 */
.banner-text-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.banner-date {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.banner-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

/* 🎬 日期切换动画 */
.date-changed-animation {
  animation: bannerPulse 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.date-changed-animation::before {
  left: 100%;
}

@keyframes bannerPulse {
  0% {
    transform: scale(1);
  }
  25% {
    transform: scale(1.02);
    box-shadow: 0 12rpx 32rpx rgba(255, 152, 0, 0.35);
  }
  50% {
    transform: scale(1);
  }
  75% {
    transform: scale(1.01);
  }
  100% {
    transform: scale(1);
  }
}

/* 🎬 记录区域高亮动画 */
.records-highlight-animation {
  animation: recordsHighlight 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

@keyframes recordsHighlight {
  0% {
    opacity: 1;
  }
  25% {
    opacity: 0.85;
    transform: translateY(-4rpx);
  }
  50% {
    opacity: 1;
    transform: translateY(0);
  }
  75% {
    opacity: 0.92;
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 记录页头部 */
.record-page-header {
  margin: 24rpx 24rpx 16rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(255, 248, 240, 0.95) 0%, rgba(255, 224, 178, 0.85) 100%);
  box-shadow: 0 8rpx 24rpx rgba(255, 152, 0, 0.12),
              0 2rpx 8rpx rgba(255, 152, 0, 0.06);
  border: 1rpx solid rgba(255, 184, 77, 0.15);
  backdrop-filter: blur(10rpx);
  display: flex;
  flex-direction: column;
  gap: 0;
}

.record-title-group {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.record-title-texts {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.record-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
}

.record-subtitle {
  font-size: 24rpx;
  color: #8c6d46;
  opacity: 0.85;
}

.record-header-actions {
  display: flex;
  gap: 20rpx;
}

.record-action {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 0;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.35);
  font-size: 26rpx;
  color: #bf7b11;
  border: 1rpx solid rgba(255, 152, 0, 0.2);
}

/* ==================== 今日事项卡片样式 ==================== */

/* 今日事项卡片容器 - 优化版 */
.today-tasks-card {
  margin: 42rpx 0 16rpx 0;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(255, 248, 240, 0.95) 0%, rgba(255, 232, 204, 0.85) 100%);
  box-shadow: 0 8rpx 24rpx rgba(255, 152, 0, 0.12),
              0 2rpx 8rpx rgba(255, 152, 0, 0.06);
  border: 1rpx solid rgba(255, 184, 77, 0.15);
  backdrop-filter: blur(10rpx);
  position: relative;
  overflow: hidden;
}

/* 事项头部 - 简洁版 */
.tasks-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.tasks-title-group {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.tasks-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #8B5A00;
  letter-spacing: 2rpx;
  text-shadow: 0 1rpx 2rpx rgba(255, 152, 0, 0.1);
}

.tasks-count {
  min-width: 44rpx;
  height: 44rpx;
  padding: 0 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF9800 0%, #FFB84D 100%);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 22rpx;
  box-shadow: 0 6rpx 16rpx rgba(255, 152, 0, 0.35),
              0 2rpx 4rpx rgba(255, 152, 0, 0.2);
}

.tasks-add-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF9800 0%, #FFB84D 100%);
  border-radius: 50%;
  border: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 8rpx 20rpx rgba(255, 152, 0, 0.3),
              0 2rpx 6rpx rgba(255, 152, 0, 0.2);
}

.tasks-add-btn t-icon {
  filter: drop-shadow(0 1rpx 2rpx rgba(0, 0, 0, 0.15));
}

.tasks-add-btn:active {
  transform: scale(0.9);
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.3),
              0 1rpx 4rpx rgba(255, 152, 0, 0.2);
}

/* 事项列表 */
.tasks-list {
  display: flex;
  flex-direction: column;
}

.task-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.08),
              0 1rpx 4rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(255, 184, 77, 0.15);
  backdrop-filter: blur(10rpx);
}

.task-item:active {
  transform: scale(0.97) translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.15),
              0 1rpx 3rpx rgba(0, 0, 0, 0.06);
}

.task-completed {
  opacity: 0.5;
  background: rgba(245, 245, 245, 0.9);
}

.task-checkbox {
  flex-shrink: 0;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.task-checkbox:active {
  transform: scale(0.88);
}

.checkbox-inner {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  border: 4rpx solid #E0E0E0;
  background: #FFFFFF;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.checkbox-inner.checked {
  background: linear-gradient(135deg, #FF9800 0%, #FFB84D 100%);
  border-color: #FF9800;
  box-shadow: 0 6rpx 16rpx rgba(255, 152, 0, 0.4),
              0 2rpx 6rpx rgba(255, 152, 0, 0.2),
              inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
  transform: scale(1.05);
}

.task-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  word-break: break-all;
  font-weight: 500;
}

.task-completed .task-text {
  color: #999;
  text-decoration: line-through;
  font-weight: 400;
}

/* 删除按钮 */
.task-delete-btn {
  flex-shrink: 0;
  width: 42rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 107, 107, 0.1);
  border-radius: 50%;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 1rpx solid rgba(255, 107, 107, 0.2);
}

.task-delete-btn:active {
  transform: scale(0.88);
  background: rgba(255, 107, 107, 0.2);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

/* 空状态 - 简洁版 */
.tasks-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  background: rgba(255, 152, 0, 0.05);
  border-radius: 16rpx;
  border: 2rpx dashed rgba(255, 152, 0, 0.2);
  transition: all 0.3s ease;
}

.tasks-empty:active {
  background: rgba(255, 152, 0, 0.08);
  border-color: rgba(255, 152, 0, 0.3);
}

.tasks-empty-text {
  font-size: 26rpx;
  color: #8c6d46;
  opacity: 0.7;
}

/* ==================== 今日事项样式结束 ==================== */
