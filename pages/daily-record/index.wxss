  font-weight: 600;
}

.medication-completion-new {
  font-size: 28rpx;
  color: #7B1FA2;
  font-weight: 700;
  background: linear-gradient(135deg,
      rgba(255, 143, 0, 0.15) 0%,
      rgba(255, 183, 77, 0.2) 50%,
      rgba(186, 104, 200, 0.25) 100%);
  padding: 6rpx 14rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(255, 143, 0, 0.3);
  position: relative;
  overflow: hidden;
  /* 🌟 核心：数字变化时的轻微缩放动画 */
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow:
    0 8rpx 20rpx rgba(255, 143, 0, 0.25),
    0 4rpx 12rpx rgba(255, 143, 0, 0.15),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.4),
    inset 0 -1rpx 2rpx rgba(255, 143, 0, 0.1);
  transform: translateZ(0) scale(1);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
}

.medication-completion-new::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.4) 50%,
      transparent 100%);
  transition: left 0.6s ease;
  border-radius: 14rpx;
}

.medication-completion-new:active {
  transform: translateZ(0) scale(0.96);
}

.medication-completion-new::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg,
      rgba(255, 255, 255, 0.2) 0%,
      rgba(255, 255, 255, 0.1) 50%,
      rgba(255, 255, 255, 0.05) 100%);
  border-radius: 14rpx;
  pointer-events: none;
}

.medication-progress-bar {
  height: 8rpx;
  background: linear-gradient(90deg,
      rgba(255, 143, 0, 0.05) 0%,
      rgba(255, 143, 0, 0.15) 50%,
      rgba(255, 143, 0, 0.08) 100%);
  border-radius: 6rpx;
  overflow: hidden;
  position: relative;
  box-shadow:
    0 2rpx 8rpx rgba(255, 143, 0, 0.1),
    inset 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(255, 143, 0, 0.08);
}

.medication-progress-bar::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.3) 50%,
      transparent 100%);
  border-radius: 6rpx;
  z-index: 3;
}

.medication-progress-fill {
  height: 100%;
  background: linear-gradient(90deg,
      var(--color-orange-500) 0%,
      var(--color-orange-700) 30%,
      var(--color-orange-300) 60%,
      #E1BEE7 100%);
  border-radius: 6rpx;
  position: relative;
  overflow: hidden;
  /* 🌟 核心动画：缓动过渡 + 数值变化动画 */
  transition: width 1.2s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow:
    0 2rpx 8rpx rgba(255, 143, 0, 0.3),
    0 1rpx 4rpx rgba(255, 143, 0, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.4);
}

.medication-progress-fill::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.6) 50%,
      transparent 100%);
  animation: progressShimmer 3s ease-in-out infinite;
  border-radius: 6rpx;
}

@keyframes progressShimmer {
  0% {
    left: -100%;
    opacity: 0;
  }

  20% {
    opacity: 1;
  }

  50% {
    left: 100%;
    opacity: 0.8;
  }

  100% {
    left: 100%;
    opacity: 0;
  }
}

