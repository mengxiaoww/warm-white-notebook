}

.calendar-expand-btn:active {
  background: var(--gradient-3d-active);
  box-shadow:
    0 3rpx 8rpx rgba(212, 165, 116, 0.25),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.6);
  transform: translateY(1rpx);
}

/* 日历内容区域 - 极度紧凑设计 */
