@keyframes hint-glow {

  0%,
  100% {
    background: linear-gradient(135deg,
        var(--primary-alpha-08) 0%,
        rgba(255, 183, 77, 0.12) 100%);
  }

  50% {
    background: linear-gradient(135deg,
        var(--primary-alpha-12) 0%,
        rgba(255, 183, 77, 0.16) 100%);
  }
}

@keyframes recent-glow {

  0%,
  100% {
    box-shadow:
      0 6rpx 18rpx var(--primary-alpha-20),
      0 3rpx 9rpx rgba(255, 183, 77, 0.15),
      inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
      inset 0 -1rpx 0 var(--primary-alpha-10);
  }

  50% {
    box-shadow:
      0 8rpx 24rpx var(--primary-alpha-25),
      0 4rpx 12rpx rgba(255, 183, 77, 0.2),
      inset 0 1rpx 0 rgba(255, 255, 255, 0.8),
      inset 0 -1rpx 0 var(--primary-alpha-15);
  }
}

.recent-count::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
  transition: left 0.6s ease;
}

.recent-count:hover::before {
  left: 100%;
}

