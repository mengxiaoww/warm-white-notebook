@import './drag-styles.wxss';

.container {
  min-height: 100vh;
  background: linear-gradient(180deg,
      #FDFCFA 0%,
      #FAF8F4 50%,
      #F7F4EF 100%);
  overflow-x: hidden;
  position: relative;
}

/* ================================
   骨架屏加载动画 - 高级流畅设计
   ================================ */

.skeleton-wrapper {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background: linear-gradient(180deg,
      #FDFCFA 0%,
      #FAF8F4 50%,
      #F7F4EF 100%);
  animation: skeleton-fade-in 0.3s ease-out;
}

@keyframes skeleton-fade-in {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

/* 内容显示/隐藏动画 */
.content-hidden {
  opacity: 0;
  pointer-events: none;
}

.content-visible {
  opacity: 1;
  animation: content-fade-in 0.4s ease-out;
}

@keyframes content-fade-in {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 骨架屏基础元素 */
.skeleton-shimmer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.6) 50%,
      transparent 100%);
  animation: skeleton-shimmer 1.5s infinite;
}

@keyframes skeleton-shimmer {
  0% {
    transform: translateX(-100%);
  }

  100% {
    transform: translateX(100%);
  }
}

.skeleton-text {
  height: 28rpx;
  background: linear-gradient(90deg, #E8E4DD 0%, #F0EDE8 50%, #E8E4DD 100%);
  border-radius: 8rpx;
  margin: 8rpx 0;
}

.skeleton-text-short {
  width: 40%;
}

.skeleton-text-medium {
  width: 60%;
}

.skeleton-text-long {
  flex: 1;
  height: 28rpx;
  background: linear-gradient(90deg, #E8E4DD 0%, #F0EDE8 50%, #E8E4DD 100%);
  border-radius: 8rpx;
}

.skeleton-text-title {
  width: 180rpx;
  height: 32rpx;
}

.skeleton-text-subtitle {
  width: 240rpx;
  height: 24rpx;
  margin-top: 8rpx;
}

.skeleton-circle {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8E4DD 0%, #F0EDE8 100%);
}

.skeleton-circle-small {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #E8E4DD 0%, #F0EDE8 100%);
}

/* 页面头部骨架 */
.skeleton-page-header {
  margin: 24rpx 24rpx 16rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, rgba(255, 248, 240, 0.6) 0%, rgba(255, 224, 178, 0.5) 100%);
  border-radius: 24rpx;
  position: relative;
  overflow: hidden;
}

.skeleton-header-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.skeleton-header-texts {
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* 今日事项骨架 */
.skeleton-tasks-card {
  margin: 16rpx 24rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, rgba(255, 248, 240, 0.6) 0%, rgba(255, 232, 204, 0.5) 100%);
  border-radius: 24rpx;
  position: relative;
  overflow: hidden;
}

.skeleton-tasks-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.skeleton-task-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 20rpx;
  margin-bottom: 12rpx;
}

.skeleton-task-item:last-child {
  margin-bottom: 0;
}

/* 日期横幅骨架 */
.skeleton-date-banner {
  margin: 24rpx;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, rgba(255, 152, 0, 0.12) 0%, rgba(255, 183, 77, 0.08) 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  position: relative;
  overflow: hidden;
}

/* 日历骨架 */
.skeleton-calendar {
  margin: 24rpx;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(212, 165, 116, 0.08);
}

.skeleton-calendar-days {
  display: flex;
  justify-content: space-around;
  gap: 12rpx;
}

.skeleton-calendar-day {
  flex: 1;
  display: flex;
  justify-content: center;
}

/* 功能项骨架 */
.skeleton-functions {
  margin: 24rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.skeleton-function-card {
  aspect-ratio: 1;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(212, 165, 116, 0.08);
}

/* 通用卡片样式 - 现代轻奢设计 */
.card {
  margin: 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow:
    0 2rpx 8rpx rgba(212, 165, 116, 0.08),
    0 8rpx 24rpx rgba(212, 165, 116, 0.12),
    0 16rpx 32rpx rgba(212, 165, 116, 0.06);
  border: 1rpx solid rgba(212, 165, 116, 0.15);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
}

.banner {
  width: 100%;
  height: 300rpx;
  padding: 20rpx 0;
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
  border-radius: 0;
}

/* 移除外层复杂光晕以提升性能 */

.banner-swiper {
  width: 100%;
  height: 100%;
  border-radius: 28rpx;
  overflow: hidden;
  position: relative;
  z-index: 2;
  box-shadow: 0 4rpx 20rpx var(--shadow-card);
  border: 1rpx solid var(--border-light);
  /* 移除复杂的边框动画 */
}

/* 移除边框流动动画以提升性能 */

/* 🎆 超级炫酷轮播项 - 暖橙主题豪华渐变 */
.banner-item {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg,
      var(--color-orange-800) 0%,
      var(--color-orange-500) 10%,
      var(--color-orange-700) 20%,
      var(--color-orange-300) 30%,
      var(--color-orange-500) 40%,
      #FF7043 50%,
      #FF5722 60%,
      var(--color-orange-800) 70%,
      var(--color-orange-900) 80%,
      #D84315 90%,
      var(--color-orange-500) 100%);
  background-size: 800% 800%;
  animation: banner-simple-flow 15s ease-in-out infinite;
  padding: 40rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  overflow: hidden;
  position: relative;
}

/* 🌈 简化渐变流动动画 - 高性能版 */
@keyframes banner-simple-flow {

  0%,
  100% {
    background-position: 0% 50%;
  }

  50% {
    background-position: 100% 50%;
  }
}

/* ✨ 全息光束扫描效果 */
.banner-item::before {
  content: '';
  position: absolute;
  top: -100%;
  left: -100%;
  width: 300%;
  height: 300%;
  background: linear-gradient(45deg,
      transparent 0%,
      rgba(255, 255, 255, 0.1) 20%,
      rgba(255, 183, 77, 0.4) 35%,
      rgba(255, 255, 255, 0.6) 50%,
      var(--primary-alpha-40) 65%,
      rgba(255, 255, 255, 0.1) 80%,
      transparent 100%);
  transform: rotate(-45deg);
  animation: banner-simple-scan 12s ease-in-out infinite;
  z-index: 1;
}

/* 🌟 简化扫描动画 - 高性能版 */
@keyframes banner-simple-scan {

  0%,
  100% {
    transform: rotate(-45deg) translate(-120%, -120%);
    opacity: 0;
  }

  50% {
    transform: rotate(-45deg) translate(120%, 120%);
    opacity: 0.6;
  }
}

/* 🔥 数字雨效果线条 */
.banner-item::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 183, 77, 0.8) 15%,
      rgba(255, 255, 255, 1) 30%,
      var(--primary-alpha-90) 50%,
      rgba(255, 255, 255, 1) 70%,
      rgba(255, 183, 77, 0.8) 85%,
      transparent 100%);
  animation: banner-simple-pulse 8s ease-in-out infinite;
  z-index: 2;
  box-shadow: var(--shadow-light);
}

/* 图片轮播样式 - 无padding，占满整个区域 */
.banner-item-image {
  padding: 0 !important;
  background: none !important;
  animation: none !important;
}

.banner-item-image::before,
.banner-item-image::after {
  display: none !important;
}

.banner-item-image .banner-image {
  border-radius: 28rpx;
  width: 100%;
  height: 100%;
}

/* 💫 简化脉冲动画 - 高性能版 */
@keyframes banner-simple-pulse {

  0%,
  100% {
    opacity: 0.4;
  }

  50% {
    opacity: 1;
  }
}

/* 🎨 赛博朋克文字样式 - 超清晰全息效果 */
.banner-text {
  color: var(--color-white-pure);
  font-size: 40rpx;
  font-weight: 800;
  text-align: center;
  line-height: 1.4;
  width: 100%;
  position: relative;
  z-index: 3;
  text-shadow:
    0 0 10rpx rgba(255, 183, 77, 0.8),
    0 0 20rpx var(--primary-alpha-60),
    0 0 30rpx rgba(255, 193, 7, 0.4),
    0 2rpx 4rpx rgba(0, 0, 0, 0.8);
  letter-spacing: 2rpx;
  animation: banner-cyber-text 10s ease-in-out infinite;
  /* 文字渲染优化 */
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
  /* 添加数字效果滤镜 */
  filter: contrast(1.2) brightness(1.1);
}

/* 轮播图图片样式 */
.banner-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 28rpx;
}

/* 📱 橙色主题文字动画 - 暖光闪烁效果 */
@keyframes banner-cyber-text {

  0%,
  100% {
    text-shadow:
      0 0 10rpx rgba(255, 183, 77, 0.8),
      0 0 20rpx var(--primary-alpha-60),
      0 0 30rpx rgba(255, 193, 7, 0.4),
      0 2rpx 4rpx rgba(0, 0, 0, 0.8);
    transform: scale(1);
  }

  25% {
    text-shadow:
      0 0 15rpx rgba(255, 152, 0, 1),
      0 0 25rpx rgba(255, 183, 77, 0.8),
      0 0 35rpx var(--primary-alpha-60),
      0 2rpx 4rpx rgba(0, 0, 0, 0.8);
    transform: scale(1.02);
  }

  50% {
    text-shadow:
      0 0 20rpx rgba(255, 193, 7, 1),
      0 0 30rpx rgba(255, 255, 255, 0.9),
      0 0 40rpx rgba(255, 183, 77, 0.7),
      0 2rpx 4rpx rgba(0, 0, 0, 0.8);
    transform: scale(1.01);
  }

  75% {
    text-shadow:
      0 0 12rpx var(--primary-alpha-90),
      0 0 22rpx rgba(255, 183, 77, 0.7),
      0 0 32rpx var(--primary-alpha-50),
      0 2rpx 4rpx rgba(0, 0, 0, 0.8);
    transform: scale(1.01);
  }
}

/* 关键日期卡片样式 */
.date-card {
  width: 100%;
}

.key-date-card {
  box-sizing: border-box;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow:
    0 2rpx 8rpx rgba(212, 165, 116, 0.08),
    0 8rpx 24rpx rgba(212, 165, 116, 0.12),
    0 16rpx 32rpx rgba(212, 165, 116, 0.06);
  border: 1rpx solid rgba(212, 165, 116, 0.15);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.edit-btn {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, var(--color-orange-500) 0%, var(--color-orange-700) 100%) !important;
  color: var(--color-white-pure);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-light);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
  padding: 0;
}

.edit-btn:active {
  transform: scale(0.9);
  box-shadow: var(--shadow-light);
}

.key-date-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.key-date-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border: 2rpx solid var(--primary-alpha-15) !important;
  border-bottom: 2rpx solid #F5F5F5;
}

.date-label {
  font-size: 32rpx;
  color: #333;
  max-width: 400rpx;
  font-weight: bold;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.date-value-wrap {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.date-value {
  font-size: 32rpx;
  color: var(--color-orange-400);
  font-weight: 500;
}

.date-status {
  margin-bottom: 5rpx;
  font-size: 24rpx;
  color: #999;
}

.calendar-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 24rpx;
  box-sizing: border-box;
  box-shadow:
    0 2rpx 8rpx rgba(212, 165, 116, 0.08),
    0 8rpx 24rpx rgba(212, 165, 116, 0.12),
    0 16rpx 32rpx rgba(212, 165, 116, 0.06);
  border: 1rpx solid rgba(212, 165, 116, 0.15);
  position: relative;
  overflow: hidden;
}

/* 移除日历卡片动画以提升性能 */

/* 现代轻奢顶部装饰线 */
.calendar-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      #FFB84D 20%,
      #E6C390 50%,
      #FFB84D 80%,
      transparent 100%);
  border-radius: 24rpx 24rpx 0 0;
}

/* 🌈 彩虹流动动画 */
@keyframes calendar-rainbow-flow {
  0% {
    background-position: -200% center;
  }

  100% {
    background-position: 200% center;
  }
}

/* 移除复杂的光粒子动画以提升性能 */

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 0 10rpx;
}

.calendar-title-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg,
      rgba(212, 165, 116, 0.08) 0%,
      rgba(230, 195, 144, 0.12) 50%,
      rgba(212, 165, 116, 0.06) 100%);
  border-radius: 16rpx;
  box-shadow:
    0 2rpx 4rpx rgba(212, 165, 116, 0.08),
    0 4rpx 8rpx rgba(212, 165, 116, 0.04);
  border: 1rpx solid rgba(212, 165, 116, 0.15);
}

.calendar-title {
  font-size: 36rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #FFB84D 0%, #E6C390 100%);
  background-clip: text;
  -webkit-background-clip: text;
  color: transparent;
  text-shadow: 0 2rpx 4rpx rgba(212, 165, 116, 0.2);
}

.calendar-nav {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.calendar-nav-btn {
  width: 56rpx;
  height: 56rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 2rpx 4rpx rgba(212, 165, 116, 0.08),
    0 4rpx 8rpx rgba(212, 165, 116, 0.04);
  border: 1rpx solid rgba(212, 165, 116, 0.12);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.calendar-nav-btn:active {
  transform: scale(0.95) translateY(1rpx);
  background: rgba(212, 165, 116, 0.05);
  box-shadow:
    0 1rpx 2rpx rgba(212, 165, 116, 0.08),
    0 2rpx 4rpx rgba(212, 165, 116, 0.04);
}

.current-month {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  padding: 12rpx 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow:
    0 2rpx 4rpx rgba(212, 165, 116, 0.08),
    0 4rpx 8rpx rgba(212, 165, 116, 0.04);
  border: 1rpx solid rgba(212, 165, 116, 0.12);
}

.weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
  gap: 16rpx;
}

.weekdays text {
  font-size: 26rpx;
  color: #666;
  padding: 16rpx 0;
  font-weight: 600;
  background: rgba(212, 165, 116, 0.04);
  border-radius: 12rpx;
  box-shadow:
    0 1rpx 2rpx rgba(212, 165, 116, 0.06),
    0 2rpx 4rpx rgba(212, 165, 116, 0.03);
  border: 1rpx solid rgba(212, 165, 116, 0.08);
}

.days {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 16rpx;
  padding: 0 8rpx;
}

/* 💎 玻璃透光日期格子 - 超级炫酷效果 */
.day {
  width: 100%;
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: 16rpx;
  background: rgba(212, 165, 116, 0.03);
  box-shadow:
    0 1rpx 3rpx rgba(212, 165, 116, 0.06),
    0 2rpx 6rpx rgba(212, 165, 116, 0.04);
  border: 1rpx solid rgba(212, 165, 116, 0.08);
  transition: all 0.2s ease-out;
  cursor: pointer;
  overflow: hidden;
}

/* ✨ 玻璃表面反光效果 */
.day::before {
  content: '';
  position: absolute;
  top: -80%;
  left: -80%;
  width: 260%;
  height: 260%;
  background: linear-gradient(45deg,
      transparent 20%,
      rgba(255, 255, 255, 0.15) 35%,
      rgba(255, 183, 77, 0.1) 45%,
      rgba(255, 255, 255, 0.3) 50%,
      rgba(255, 204, 128, 0.08) 55%,
      rgba(255, 255, 255, 0.15) 65%,
      transparent 80%);
  transform: rotate(-45deg);
  transition: opacity 0.3s ease-out, transform 0.3s ease-out;
  opacity: 0;
  /* 移除微光动画以提升性能 */
}

/* 移除微光动画定义以提升性能 */

/* 🎯 日期格子炫酷交互效果 - 震动配合视觉反馈 */
.day:active {
  transform: scale3d(0.88, 0.88, 1) translateZ(20rpx);
  box-shadow: var(--shadow-light);
  backdrop-filter: blur(35rpx) saturate(180%) contrast(120%);
  -webkit-backdrop-filter: blur(35rpx) saturate(180%) contrast(120%);
  /* 移除点击时的额外动画，只保留transform变化 */
}

/* 移除点击脉冲动画以提升性能 */

.day:active::before {
  opacity: 1;
  top: -30%;
  left: -30%;
  transform: rotate(-45deg) scale(1.5);
  /* 简化光效，只改变透明度和尺寸 */
}

/* 移除点击光效动画以提升性能 */

.day-number {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  position: relative;
  z-index: 2;
  transition: all 0.3s ease;
}

/* 🌟 今日日期 - 超级炫酷全息玻璃效果 */
.today {
  background: linear-gradient(145deg,
      #FFB84D 0%,
      #E6C390 50%,
      #FFB84D 100%) !important;
  transform: scale(1.08);
  box-shadow:
    0 4rpx 12rpx rgba(212, 165, 116, 0.25),
    0 8rpx 24rpx rgba(212, 165, 116, 0.15),
    0 16rpx 32rpx rgba(212, 165, 116, 0.08) !important;
  border: 2rpx solid rgba(255, 255, 255, 0.8) !important;
  position: relative;
  z-index: 5;
}

/* 🎆 今日日期简化脉冲动画 - 高性能版 */
@keyframes today-simple-pulse {

  0%,
  100% {
    transform: scale3d(1.12, 1.12, 1);
  }

  50% {
    transform: scale3d(1.16, 1.16, 1);
  }
}

/* ✨ 今日日期超级光效 */
.today::before {
  background: linear-gradient(45deg,
      transparent 0%,
      rgba(255, 255, 255, 0.2) 15%,
      rgba(255, 183, 77, 0.3) 25%,
      rgba(255, 255, 255, 0.6) 40%,
      rgba(255, 204, 128, 0.4) 50%,
      rgba(255, 255, 255, 0.6) 60%,
      rgba(255, 183, 77, 0.3) 75%,
      rgba(255, 255, 255, 0.2) 85%,
      transparent 100%);
  opacity: 1;
  animation: today-simple-shine 8s ease-in-out infinite;
}

/* 🌟 今日简化光效动画 - 高性能版 */
@keyframes today-simple-shine {

  0%,
  100% {
    opacity: 0.6;
  }

  50% {
    opacity: 1;
  }
}

.today .day-number {
  color: #FFFFFF !important;
  font-weight: 700 !important;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
  font-size: 32rpx !important;
}

.today:not(.has-event)::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 80%;
  height: 80%;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle,
      rgba(255, 193, 7, 0.1) 0%,
      rgba(255, 167, 38, 0.05) 60%,
      transparent 70%);
  border-radius: 50%;
  animation: todayPulse 3s ease-in-out infinite;
  z-index: 1;
}

@keyframes todayPulse {

  0%,
  100% {
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.6;
  }

  50% {
    transform: translate(-50%, -50%) scale(1.2);
    opacity: 0.3;
  }
}

/* 🌟 选中日期 - 明亮透明橘色 */
.selected {
  background: rgba(255, 152, 0, 0.8) !important;
  border: 2rpx solid rgba(255, 193, 7, 0.6);
  transform: translateY(-3rpx) scale(1.05);
  backdrop-filter: blur(8rpx) saturate(1.2);
  box-shadow:
    0 8rpx 24rpx rgba(255, 152, 0, 0.3),
    0 4rpx 12rpx rgba(255, 152, 0, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3) !important;
}

.selected::before {
  background: linear-gradient(45deg,
      transparent 15%,
      rgba(255, 255, 255, 0.6) 25%,
      rgba(255, 255, 255, 0.4) 40%,
      rgba(255, 193, 7, 0.3) 50%,
      rgba(255, 255, 255, 0.5) 60%,
      rgba(255, 255, 255, 0.7) 75%,
      transparent 85%);
  opacity: 1;
  animation: selectedShimmer 2s ease-in-out infinite;
}

@keyframes selectedShimmer {
  0% {
    transform: rotate(-45deg) translateX(-100%);
  }

  50% {
    transform: rotate(-45deg) translateX(0%);
  }

  100% {
    transform: rotate(-45deg) translateX(100%);
  }
}

.selected .day-number {
  color: var(--color-white-pure) !important;
  font-weight: 700 !important;
  text-shadow:
    0 2rpx 4rpx rgba(0, 0, 0, 0.3),
    0 1rpx 2rpx rgba(255, 152, 0, 0.8);
  font-size: 34rpx !important;
}

.selected:not(.has-event)::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100%;
  height: 100%;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle,
      rgba(255, 255, 255, 0.2) 0%,
      rgba(255, 193, 7, 0.1) 40%,
      transparent 70%);
  border-radius: 50%;
  animation: selectedGlow 2.5s ease-in-out infinite;
  z-index: 1;
}

@keyframes selectedGlow {

  0%,
  100% {
    transform: translate(-50%, -50%) scale(0.8);
    opacity: 0.8;
  }

  50% {
    transform: translate(-50%, -50%) scale(1.3);
    opacity: 0.4;
  }
}

/* 🌟 事件标记点 - 立体微型宝石效果 */
.has-event {
  position: relative;
}

.has-event::after {
  content: '';
  position: absolute;
  bottom: 6rpx;
  right: 6rpx;
  width: 14rpx;
  height: 14rpx;
  background: linear-gradient(145deg,
      #FF6B6B 0%,
      #FF8E53 50%,
      #FF6B6B 100%);
  border-radius: 50%;
  box-shadow: var(--shadow-light);
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  z-index: 5;
  animation: eventDotPulse 2s ease-in-out infinite;
}

@keyframes eventDotPulse {

  0%,
  100% {
    transform: scale(1);
    opacity: 0.9;
  }

  50% {
    transform: scale(1.2);
    opacity: 0.7;
  }
}

.selected.has-event::after {
  background: linear-gradient(145deg,
      rgba(255, 255, 255, 0.95) 0%,
      rgba(255, 255, 255, 0.8) 50%,
      rgba(255, 255, 255, 0.95) 100%) !important;
  box-shadow: var(--shadow-light) !important;
  border: 2rpx solid rgba(255, 255, 255, 0.95) !important;
  width: 14rpx !important;
  height: 14rpx !important;
  bottom: 6rpx !important;
  right: 6rpx !important;
  z-index: 10 !important;
  animation: selectedEventDot 2s ease-in-out infinite !important;
  position: absolute !important;
}

@keyframes selectedEventDot {

  0%,
  100% {
    transform: scale(1);
    opacity: 1;
    box-shadow: var(--shadow-light);
  }

  50% {
    transform: scale(1.3);
    opacity: 0.9;
    box-shadow: var(--shadow-light);
  }
}

.today.has-event::after {
  background: linear-gradient(145deg,
      var(--color-orange-500) 0%,
      var(--color-orange-400) 50%,
      var(--color-orange-500) 100%) !important;
  box-shadow: var(--shadow-light) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.9) !important;
  bottom: 6rpx !important;
  right: 6rpx !important;
  width: 14rpx !important;
  height: 14rpx !important;
  z-index: 10 !important;
  position: absolute !important;
}

/* ==================== 暖光里程碑 - 完全参考个人档案 ==================== */
.milestone-section {
  box-sizing: border-box;
  width: 712rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 25rpx;
  margin: 0 auto 15rpx auto;
  box-shadow:
    0 16rpx 40rpx rgba(212, 165, 116, 0.15),
    0 8rpx 20rpx rgba(212, 165, 116, 0.12),
    0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(212, 165, 116, 0.15);
  position: relative;
  overflow: hidden;
  z-index: 1;
}

/* 标题栏 - 完全参考个人档案的section-header */
.milestone-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: none;
  position: relative;
}

/* 装饰性下划线 */
.milestone-header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(212, 165, 116, 0.3) 20%,
      rgba(212, 165, 116, 0.6) 50%,
      rgba(212, 165, 116, 0.3) 80%,
      transparent 100%);
  border-radius: 2rpx;
}

.milestone-title-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.milestone-title-group {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 2rpx;
}

.milestone-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF9800;
  letter-spacing: 0.5rpx;
}

.milestone-subtitle {
  font-size: 22rpx;
  color: #999;
  font-weight: 400;
  letter-spacing: 0.2rpx;
}

/* 编辑按钮 - 完全使用公共样式 */
.milestone-edit-btn {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: var(--gradient-3d-primary);
  border-radius: 24rpx;
  color: #FF9800;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow:
    0 6rpx 16rpx rgba(212, 165, 116, 0.2),
    0 3rpx 8rpx rgba(212, 165, 116, 0.15),
    0 2rpx 4rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(212, 165, 116, 0.25);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  letter-spacing: 0.5rpx;
}

.milestone-edit-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.8) 50%,
      transparent 100%);
  border-radius: 24rpx 24rpx 0 0;
}

.milestone-edit-btn:active {
  background: var(--gradient-3d-active);
  box-shadow:
    0 3rpx 8rpx rgba(212, 165, 116, 0.25),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.6);
  transform: translateY(1rpx);
}

.milestone-edit-text {
  margin-left: 8rpx;
}

.milestone-content {
  min-height: 140rpx;
}

/* 里程碑网格 - 简单有效的2列布局 */
.milestone-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 16rpx 0;
  width: 100%;
}

/* 滚动视图样式 - 超过6个里程碑时使用 */
.milestone-scroll {
  width: 100%;
  overflow-x: auto;
  overflow-y: hidden;
  -webkit-overflow-scrolling: touch;
}

.milestone-grid-scroll {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  padding-bottom: 10rpx;
  width: max-content;
}

.milestone-grid-scroll .milestone-card {
  width: 320rpx;
  flex-shrink: 0;
}

/* 里程碑卡片 - 简单固定宽度 */
.milestone-card {
  width: 49%;
  background: linear-gradient(135deg, #ffffff 0%, #fefefe 50%, #ffffff 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow:
    0 8rpx 32rpx rgba(212, 165, 116, 0.12),
    0 4rpx 16rpx rgba(212, 165, 116, 0.08),
    0 2rpx 8rpx rgba(0, 0, 0, 0.04),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  border: 1rpx solid rgba(212, 165, 116, 0.15);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

/* 单个里程碑时占满整行 */
.milestone-grid.single-item {
  justify-content: flex-start;
}

.milestone-card.single-card {
  width: 100%;
  /* 横向布局，左右分布 */
  flex-direction: row;
  align-items: center;
  padding: 32rpx 40rpx;
  min-height: 180rpx;
}

/* 单个里程碑的头部信息 */
.milestone-card.single-card .milestone-card-header {
  flex: 1;
  margin-bottom: 0;
  margin-right: 32rpx;
}

/* 单个里程碑的主体（数字区域） */
.milestone-card.single-card .milestone-card-body {
  flex: none;
  width: auto;
  text-align: right;
}

/* 单个里程碑时数字样式调整 - 适配多位数 */
.milestone-card.single-card .milestone-days-text {
  font-size: 88rpx;
  line-height: 1;
}

.milestone-card.single-card .milestone-status-text {
  font-size: 26rpx;
}

.milestone-card.single-card .milestone-unit-text {
  font-size: 30rpx;
}

/* 卡片内光效 */
.milestone-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.9) 50%,
      transparent 100%);
  border-radius: 24rpx 24rpx 0 0;
}

.milestone-card:active {
  transform: scale(0.96) translateY(1rpx);
  box-shadow:
    0 6rpx 24rpx rgba(212, 165, 116, 0.15),
    0 3rpx 12rpx rgba(212, 165, 116, 0.12),
    0 2rpx 6rpx rgba(0, 0, 0, 0.06),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.6);
}

/* 卡片头部 - 精致版式 */
.milestone-card-header {
  margin-bottom: 12rpx;
  position: relative;
  z-index: 2;
}

.milestone-card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2c2c2c;
  line-height: 1.2;
  margin-bottom: 8rpx;
  letter-spacing: 0.5rpx;
}

.milestone-card-date {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
  opacity: 0.8;
  letter-spacing: 0.2rpx;
}

/* 卡片主体 - 左对齐倒数日显示 */
.milestone-card-body {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  text-align: left;
  position: relative;
  z-index: 2;
}

.milestone-text-line {
  display: flex;
  align-items: baseline;
  justify-content: flex-start;
  gap: 6rpx;
  line-height: 1;
}

.milestone-status-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #2c2c2c;
  opacity: 0.8;
  letter-spacing: 0.5rpx;
  min-width: 80rpx;
  white-space: nowrap;
}

.milestone-full-text {
  font-size: 42rpx;
  font-weight: 600;
  background: linear-gradient(135deg,
      #FF9800 0%,
      #FFB84D 40%,
      #FFCC80 70%,
      #FFE0B3 100%);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
  line-height: 1.2;
  text-align: center;
  text-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.2);
}

.milestone-prefix-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #666;
  margin-right: 8rpx;
  line-height: 1.2;
}

.milestone-days-highlight {
  font-size: 34rpx;
  font-weight: 700;
  background: linear-gradient(135deg,
      #FF9800 0%,
      #FFB84D 40%,
      #FFCC80 70%,
      #FFE0B3 100%);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
  line-height: 1.2;
  text-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.2);
}

.milestone-days-text {
  font-size: 72rpx;
  font-weight: 900;
  background: linear-gradient(135deg,
      #FF9800 0%,
      #FFB84D 40%,
      #FFCC80 70%,
      #FFE0B3 100%);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
  line-height: 0.9;
  margin: 0 4rpx;
  text-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.2);
  position: relative;
}

/* 数字阴影效果 */
.milestone-days-text::before {
  content: attr(data-days);
  position: absolute;
  top: 2rpx;
  left: 2rpx;
  color: rgba(255, 152, 0, 0.08);
  z-index: -1;
  font-size: inherit;
  font-weight: inherit;
}

.milestone-unit-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FF9800;
  opacity: 0.9;
  letter-spacing: 0.5rpx;
}

.milestone-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  background: linear-gradient(145deg, #FAFAFA 0%, #F8F8F8 100%);
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 184, 77, 0.2);
  position: relative;
  overflow: hidden;
}

.milestone-empty::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: -10rpx;
  right: -10rpx;
  bottom: -10rpx;
  background: linear-gradient(45deg,
      rgba(255, 184, 77, 0.05) 0%,
      rgba(255, 204, 128, 0.03) 25%,
      rgba(255, 184, 77, 0.05) 50%,
      rgba(255, 204, 128, 0.03) 75%,
      rgba(255, 184, 77, 0.05) 100%);
  background-size: 40rpx 40rpx;
  opacity: 0.3;
  animation: shimmer 3s ease-in-out infinite;
}

@keyframes shimmer {

  0%,
  100% {
    opacity: 0.3;
  }

  50% {
    opacity: 0.1;
  }
}

.milestone-empty .empty-title {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-top: 16rpx;
  font-weight: 600;
  z-index: 2;
  position: relative;
}

.milestone-empty .empty-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
  z-index: 2;
  position: relative;
  opacity: 0.8;
}


/* ==================== 🎯 紧凑日期选择器设计 ==================== */
.date-selector-section {
  margin: 24rpx 24rpx;
  padding: 0;
}

.date-selector-header {
  margin-bottom: 16rpx;
}

.date-selector-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.date-selector-container {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow:
    0 2rpx 8rpx rgba(0, 0, 0, 0.04),
    0 1rpx 2rpx rgba(0, 0, 0, 0.02);
}

.selected-date {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background: rgba(255, 184, 77, 0.08);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s ease;
  border: 1rpx solid rgba(255, 184, 77, 0.12);
}

.selected-date:active {
  transform: scale(0.98);
  background: var(--primary-alpha-10);
}

.selected-date-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary-dark);
}

.quick-dates {
  display: flex;
  gap: 12rpx;
}

.quick-date-item {
  flex: 1;
  padding: 12rpx 16rpx;
  background: #F8F8F8;
  border-radius: 10rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
  font-weight: 500;
}

.quick-date-item.active {
  background: var(--primary-color);
  color: white;
  border-color: var(--primary-color);
}

.quick-date-item:not(.active):active {
  transform: scale(0.95);
  background: var(--primary-alpha-06);
}

/* ==================== 🔥 高级功能项网格 - 与里程碑风格统一 ==================== */
.functions-grid {
  box-sizing: border-box;
  width: 100%;
  display: grid;
  /* 保证两列等宽且不被内部内容撑破 */
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  padding: 0 24rpx;
  margin-bottom: 32rpx;
}

/* 提高选择器优先级，避免弹窗中的通用 .function-card 规则干扰 */
.functions-grid .function-card {
  box-sizing: border-box;
  width: 100%;
  min-height: 180rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  padding: 0;
  border: 1rpx solid rgba(0, 0, 0, 0.03);
  transition: all 0.15s ease;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow:
    0 2rpx 8rpx rgba(0, 0, 0, 0.02),
    0 1rpx 2rpx rgba(0, 0, 0, 0.01);
}

.function-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.02) 0%,
      rgba(255, 204, 128, 0.01) 50%,
      rgba(255, 152, 0, 0.02) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.function-card:active {
  transform: scale(0.985);
  box-shadow:
    0 4rpx 12rpx rgba(255, 152, 0, 0.15),
    0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.function-card:active::before {
  opacity: 1;
}

.function-card-header {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx 16rpx;
  position: relative;
  background: linear-gradient(135deg,
      rgba(255, 248, 240, 0.9) 0%,
      rgba(255, 252, 248, 0.6) 100%);
}

.function-card-icon {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  transition: all 0.3s ease;
  box-shadow:
    0 2rpx 6rpx rgba(255, 152, 0, 0.08);
  position: relative;
}

.function-card-icon::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  background: linear-gradient(45deg,
      rgba(255, 204, 128, 0.1) 0%,
      transparent 50%,
      rgba(255, 184, 77, 0.08) 100%);
  border-radius: 20rpx;
  z-index: -1;
}

.function-card:active .function-card-icon {
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.25) 0%,
      rgba(255, 204, 128, 0.18) 50%,
      rgba(255, 152, 0, 0.22) 100%);
  transform: scale(1.05) rotate(1deg);
  box-shadow:
    0 6rpx 16rpx rgba(255, 152, 0, 0.12),
    inset 0 1rpx 3rpx rgba(255, 255, 255, 0.5);
}

.function-card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c3e50;
  line-height: 1;
  letter-spacing: 0.5rpx;
  flex: 1;
}

.function-card-content {
  box-sizing: border-box;
  flex: 1;
  padding: 20rpx 24rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  /* 防止子元素宽度缩成内容宽 */
  background: transparent;
}

.function-card-data {
  box-sizing: border-box;
  flex: 1;
  padding: 10rpx 0;
  /* 直接承担内层容器的内边距 */
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: stretch;
  /* 默认为flex布局 */
}

/* 血常规类型：网格布局 */
.function-card--blood .function-card-data,
.function-card--liver .function-card-data,
.function-card--kidney .function-card-data {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

/* 用药记录：两行垂直布局 */
.function-card--medication .function-card-data {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  justify-content: space-between;
}

/* 单指标类型：垂直居中 */
.function-card--urine .function-card-data,
.function-card--stool .function-card-data {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  text-align: center;
  min-height: 150rpx;
}

/* EB病毒等单一数据类型：垂直布局 */
.function-card--ebv .function-card-data,
.function-card--cmv .function-card-data,
.function-card--ldh .function-card-data {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 94rpx;
}

/* ============================
   🩺 简洁血常规展示设计
   ============================ */
.medical-data-preview {
  padding: 20rpx;
  background: rgba(255, 248, 240, 0.6);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 184, 77, 0.15);
  position: relative;
}

.medical-data-preview::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, #E53935 0%, #FF5722 50%, #8D6E63 100%);
  border-radius: 16rpx 16rpx 0 0;
}

.data-summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid rgba(255, 184, 77, 0.1);
}

.summary-label {
  font-size: 28rpx;
  color: #2D1810;
  font-weight: 600;
}

.data-count-badge {
  background: #FF9800;
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 600;
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
}

.medical-indicators {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 4rpx;
}

.medical-indicator {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 184, 77, 0.1);
  position: relative;
}

.medical-indicator::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4rpx;
  border-radius: 12rpx 0 0 12rpx;
}

.medical-indicator:nth-child(1)::before {
  background: #E53935;
}

.medical-indicator:nth-child(2)::before {
  background: #FF5722;
}

.medical-indicator:nth-child(3)::before {
  background: #8D6E63;
}

.indicator-icon {
  width: 32rpx;
  height: 32rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.blood-wbc {
  background: #E53935;
}

.blood-hgb {
  background: #FF5722;
}

.blood-plt {
  background: #8D6E63;
}

.indicator-icon::after {
  content: '';
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
}

.indicator-info {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-width: 0;
}

.indicator-name {
  font-size: 26rpx;
  color: #2D1810;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
}

.indicator-value {
  font-size: 30rpx;
  color: #FF6B35;
  font-weight: 700;
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
  margin-left: 8rpx;
  line-height: 1.2;
  font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  text-shadow: 0 1rpx 3rpx rgba(255, 107, 53, 0.2);
}

/* ============================
   🦠 简洁病毒检测展示设计
   ============================ */
.virus-data-preview {
  padding: 20rpx;
  background: rgba(232, 245, 233, 0.6);
  border-radius: 16rpx;
  border: 1rpx solid rgba(76, 175, 80, 0.15);
  position: relative;
}

.virus-data-preview::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: #4CAF50;
  border-radius: 16rpx 16rpx 0 0;
}

.virus-result {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 12rpx;
  border: 1rpx solid rgba(76, 175, 80, 0.1);
  margin-top: 4rpx;
}

.virus-info {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.virus-icon {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #4CAF50;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16rpx;
  flex-shrink: 0;
}

.virus-icon::after {
  content: '🦠';
}

.virus-name {
  font-size: 24rpx;
  color: #2E7D32;
  font-weight: 500;
}

.virus-status {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #FFFFFF;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
}

.virus-status.negative {
  background: #4CAF50;
}

.virus-status.positive {
  background: #FF5722;
}

.virus-positive {
  background: linear-gradient(135deg, #FF5722 0%, #FF7043 50%, #FF8A65 100%);
  color: #FFFFFF;
  box-shadow:
    0 8rpx 24rpx rgba(255, 87, 34, 0.35),
    0 4rpx 12rpx rgba(255, 87, 34, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
}

.virus-status:active {
  transform: scale(0.95);
}

/* ============================
   🫀 简洁器官功能展示设计
   ============================ */
.organ-data-preview {
  padding: 20rpx;
  background: rgba(255, 243, 224, 0.6);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 193, 7, 0.15);
  position: relative;
}

.organ-data-preview::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: #FFC107;
  border-radius: 16rpx 16rpx 0 0;
}

.organ-indicators {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.organ-indicator {
  padding: 16rpx 14rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 193, 7, 0.1);
  text-align: center;
  transition: all 0.2s ease;
}

.organ-indicator:active {
  transform: scale(0.98);
  background: rgba(255, 255, 255, 0.9);
}

.organ-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #E65100;
  margin-bottom: 6rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
}

.organ-name {
  font-size: 22rpx;
  font-weight: 500;
  color: #BF360C;
}

.organ-unit {
  font-size: 18rpx;
  color: #8D6E63;
  opacity: 0.7;
  margin-top: 2rpx;
}

/* 精致空状态卡片 */
.empty-state-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 50rpx 24rpx;
  background: linear-gradient(135deg, rgba(248, 250, 252, 0.9) 0%, rgba(241, 245, 249, 0.7) 100%);
  border: 2rpx dashed rgba(203, 213, 225, 0.5);
  border-radius: 18rpx;
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  position: relative;
  overflow: hidden;
}

.empty-state-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, transparent 0%, rgba(255, 184, 77, 0.02) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.empty-state-card:active {
  background: linear-gradient(135deg, rgba(255, 248, 240, 0.9) 0%, rgba(255, 245, 235, 0.8) 100%);
  border-color: rgba(255, 184, 77, 0.3);
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(255, 184, 77, 0.1);
}

.empty-state-card:active::before {
  opacity: 1;
}

.empty-state-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(203, 213, 225, 0.2) 0%, rgba(148, 163, 184, 0.1) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: rgba(148, 163, 184, 0.7);
  margin-bottom: 16rpx;
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  border: 2rpx solid rgba(203, 213, 225, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(148, 163, 184, 0.1);
}

.empty-state-card:active .empty-state-icon {
  background: linear-gradient(135deg, rgba(255, 184, 77, 0.15) 0%, rgba(255, 184, 77, 0.08) 100%);
  color: #FF9800;
  transform: rotate(90deg) scale(1.1);
  border-color: rgba(255, 184, 77, 0.3);
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 77, 0.2);
}

.empty-state-text {
  font-size: 28rpx;
  color: rgba(100, 116, 139, 0.8);
  font-weight: 500;
  letter-spacing: 0.5rpx;
  transition: all 0.3s ease;
}

.empty-state-card:active .empty-state-text {
  color: rgba(255, 152, 0, 0.8);
  transform: translateY(-2rpx);
}

.general-indicators {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160rpx, 1fr));
  gap: 18rpx;
}

.general-indicator {
  padding: 24rpx 18rpx;
  background: linear-gradient(135deg,
      rgba(255, 255, 255, 0.98) 0%,
      rgba(237, 231, 246, 0.9) 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(156, 39, 176, 0.15);
  text-align: center;
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  position: relative;
  box-shadow:
    0 8rpx 32rpx rgba(156, 39, 176, 0.08),
    0 2rpx 8rpx rgba(156, 39, 176, 0.04);
  overflow: hidden;
}

.general-indicator::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 4rpx;
  height: 100%;
  background: linear-gradient(180deg, #9C27B0 0%, #BA68C8 50%, #CE93D8 100%);
  transition: all 0.3s ease;
  opacity: 0.8;
}

.general-indicator:hover {
  transform: translateY(-4rpx);
  border-color: rgba(156, 39, 176, 0.3);
  box-shadow:
    0 16rpx 48rpx rgba(156, 39, 176, 0.15),
    0 8rpx 24rpx rgba(156, 39, 176, 0.1);
}

.general-value {
  font-size: 36rpx;
  font-weight: 800;
  color: #6A1B9A;
  line-height: 1.2;
  margin-bottom: 8rpx;
  font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  text-shadow: 0 1rpx 3rpx rgba(106, 27, 154, 0.2);
}

.general-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #8E24AA;
  letter-spacing: 0.8rpx;
  opacity: 0.9;
}

/* ============================
   ✨ 专业级空状态设计
   ============================ */
.no-data-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  text-align: center;
  background: linear-gradient(135deg,
      rgba(248, 250, 252, 0.8) 0%,
      rgba(241, 245, 249, 0.6) 100%);
  border-radius: 20rpx;
  border: 2rpx dashed rgba(148, 163, 184, 0.3);
  margin: 20rpx 0;
}

.no-data-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.4;
  animation: gentleBounce 3s ease-in-out infinite;
}

@keyframes gentleBounce {

  0%,
  100% {
    transform: translateY(0rpx) scale(1);
    opacity: 0.4;
  }

  50% {
    transform: translateY(-8rpx) scale(1.05);
    opacity: 0.6;
  }
}

.no-data-text {
  font-size: 28rpx;
  color: #64748B;
  line-height: 1.5;
  opacity: 0.8;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.no-data-subtext {
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 8rpx;
  opacity: 0.6;
}

/* 响应式设计优化 */
@media (max-width: 375px) {

  .medical-data-preview,
  .virus-data-preview,
  .organ-data-preview,
  .general-data-preview {
    padding: 24rpx 20rpx;
    margin: 16rpx 0;
  }

  .medical-indicators,
  .virus-indicators {
    gap: 14rpx;
  }

  .organ-indicators {
    grid-template-columns: 1fr;
    gap: 14rpx;
  }

  .general-indicators {
    grid-template-columns: 1fr;
    gap: 14rpx;
  }

  .indicator-name,
  .virus-name {
    font-size: 26rpx;
  }

  .indicator-value {
    font-size: 32rpx;
  }

  .organ-value {
    font-size: 36rpx;
  }

  .summary-label {
    font-size: 32rpx;
  }

  .data-count-badge {
    font-size: 22rpx;
    padding: 8rpx 16rpx;
  }
}

/* 平板设备优化 */
@media (min-width: 768px) {

  .medical-indicators,
  .virus-indicators {
    grid-template-columns: repeat(2, 1fr);
  }

  .organ-indicators {
    grid-template-columns: repeat(3, 1fr);
  }

  .general-indicators {
    grid-template-columns: repeat(4, 1fr);
  }
}


/* 极简现代设计 */
.data-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 0;
  background: transparent;
  border: none;
  box-shadow: none;
  transition: all 0.2s ease;
  position: relative;
}

.data-item-single {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 0;
  text-align: center;
  background: transparent;
  border: none;
  box-shadow: none;
  transition: all 0.2s ease;
  position: relative;
}

.single-item {
  grid-template-columns: 1fr;
  justify-items: center;
}

/* 极简设计，移除所有动画 */

.data-label {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.35);
  font-weight: 500;
  letter-spacing: 0.3rpx;
  margin-bottom: 4rpx;
}

.data-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: -0.8rpx;
  line-height: 1.1;
}

.data-placeholder {
  font-size: 44rpx;
  font-weight: 400;
  color: rgba(0, 0, 0, 0.08);
  letter-spacing: -0.8rpx;
  line-height: 1.1;
}

/* 移除渐变动画 */

.function-card-date {
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
  text-align: right;
  font-weight: 400;
}

.function-card-empty {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 24rpx;
  min-height: 100rpx;
}

.empty-state-clean {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.02);
  border: 2rpx dashed rgba(0, 0, 0, 0.08);
  transition: all 0.2s ease;
}

.function-card:active .empty-state-clean {
  background: rgba(0, 0, 0, 0.04);
  border-color: rgba(0, 0, 0, 0.12);
  transform: scale(0.95);
}

/* 百万年薪级别的空状态设计 */
.empty-state-premium {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  width: 100%;
  animation: fadeInUp 0.5s ease forwards;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.empty-icon-wrapper {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.03);
  border-radius: 50%;
  transition: all 0.3s ease;
}

.empty-icon-pulse {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 28rpx;
  background: radial-gradient(circle at center,
      rgba(255, 184, 77, 0.15) 0%,
      transparent 70%);
  animation: pulse 2.5s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

@keyframes pulse {

  0%,
  100% {
    transform: scale(1);
    opacity: 0.6;
  }

  50% {
    transform: scale(1.3);
    opacity: 0;
  }
}

.empty-hint {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.2);
  font-weight: 400;
  letter-spacing: 0.5rpx;
  opacity: 1;
  transition: color 0.3s ease;
}

.function-card:active .empty-icon-wrapper {
  transform: scale(0.95);
  box-shadow:
    0 4rpx 12rpx rgba(255, 184, 77, 0.12),
    inset 0 2rpx 6rpx rgba(255, 184, 77, 0.08);
}

.function-card:active .empty-hint {
  opacity: 1;
  color: rgba(255, 184, 77, 0.6);
}

.empty-text {
  font-size: 26rpx;
  color: rgba(60, 60, 67, 0.3);
  font-weight: 500;
  letter-spacing: 0.5rpx;
  position: relative;
}

.empty-text::before {
  content: '';
  position: absolute;
  left: -16rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 8rpx;
  background: radial-gradient(circle,
      rgba(255, 184, 77, 0.4) 0%,
      rgba(255, 184, 77, 0.1) 70%,
      transparent 100%);
  border-radius: 50%;
  opacity: 0.7;
}

.empty-modern {
  width: 100%;
  height: 120rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg,
      rgba(255, 255, 255, 0.4) 0%,
      rgba(248, 249, 250, 0.2) 100%);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  position: relative;
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  overflow: hidden;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.2),
    0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-modern::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: conic-gradient(from 0deg at 50% 50%,
      transparent 0deg,
      rgba(255, 184, 77, 0.03) 90deg,
      transparent 180deg,
      rgba(255, 184, 77, 0.02) 270deg,
      transparent 360deg);
  animation: rotate 20s linear infinite;
  opacity: 0;
  transition: opacity 0.5s ease;
}

.empty-modern::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 60%;
  height: 60%;
  background: radial-gradient(circle,
      rgba(255, 184, 77, 0.08) 0%,
      transparent 70%);
  transform: translate(-50%, -50%);
  opacity: 0;
  transition: all 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

@keyframes rotate {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.function-card:active .empty-modern {
  transform: scale(0.94);
  background: linear-gradient(135deg,
      rgba(255, 255, 255, 0.2) 0%,
      rgba(255, 184, 77, 0.05) 100%);
  border-color: rgba(255, 184, 77, 0.08);
  box-shadow:
    inset 0 2rpx 8rpx rgba(255, 184, 77, 0.04),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.15),
    0 4rpx 20rpx rgba(255, 184, 77, 0.03);
}

.function-card:active .empty-modern::before {
  opacity: 1;
}

.function-card:active .empty-modern::after {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1.2);
}

.empty-add-icon {
  opacity: 0.3;
  transition: opacity 0.3s ease, transform 0.3s ease;
}

.function-card:active .empty-add-icon {
  opacity: 0.6;
