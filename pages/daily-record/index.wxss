/* ==================== 新日历组件 - 匹配暖光里程碑样式 ==================== */
.calendar-section {
  box-sizing: border-box;
  width: 712rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  padding: 24rpx;
  margin: 0 auto 20rpx auto;
  box-shadow: 0 4rpx 16rpx rgba(212, 165, 116, 0.08);
  border: 1rpx solid rgba(212, 165, 116, 0.08);
  position: relative;
  overflow: hidden;
  z-index: 1;
  backdrop-filter: blur(10rpx);
}

/* 日历标题栏 - 完全匹配里程碑样式 */
.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: none;
  position: relative;
}

/* 装饰性下划线 */
.calendar-header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(212, 165, 116, 0.3) 20%,
      rgba(212, 165, 116, 0.6) 50%,
      rgba(212, 165, 116, 0.3) 80%,
      transparent 100%);
  border-radius: 2rpx;
}

.calendar-title-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.calendar-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF9800;
  letter-spacing: 0.5rpx;
}

/* 展开按钮 - 使用公共样式 */
.calendar-expand-btn {
  margin-left: 25rpx;
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: var(--gradient-3d-primary);
  border-radius: 24rpx;
  color: #FF9800;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow:
    0 6rpx 16rpx rgba(212, 165, 116, 0.2),
    0 3rpx 8rpx rgba(212, 165, 116, 0.15),
    0 2rpx 4rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(212, 165, 116, 0.25);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  letter-spacing: 0.5rpx;
}

.calendar-expand-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.8) 50%,
      transparent 100%);
