  border: 2rpx solid rgba(255, 193, 7, 0.6) !important;
  color: white !important;
  font-weight: 700 !important;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.2) !important;
  transform: translateY(-3rpx) scale(1.05) !important;
  backdrop-filter: blur(8rpx) saturate(1.2) !important;
  box-shadow:
    0 8rpx 24rpx rgba(255, 152, 0, 0.3),
    0 4rpx 12rpx rgba(255, 152, 0, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3) !important;
}

.calendar-day-compact.selected .day-number {
  color: inherit !important;
  /* 继承选中状态的白色 */
