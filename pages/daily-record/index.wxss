/* 移除复杂装饰效果 */



/* 奢华旋转动画 */
@keyframes luxury-rotate {
  0% {
    transform: rotate(0deg);
  }

  100% {
    transform: rotate(360deg);
  }
}

/* ===== 通透橘色动画系统 ===== */

/* 橘色主体脉冲 */
@keyframes orange-pulse {
  0% {
    transform: translateY(-8rpx) scale(1.15) rotateX(3deg) rotateZ(1deg);
    filter: brightness(1) saturate(1.2);
  }

  50% {
    transform: translateY(-12rpx) scale(1.2) rotateX(5deg) rotateZ(-1deg);
    filter: brightness(1.3) saturate(1.5);
  }

  100% {
    transform: translateY(-8rpx) scale(1.15) rotateX(3deg) rotateZ(1deg);
    filter: brightness(1) saturate(1.2);
  }
}

/* 橘色能量环旋转 */
@keyframes orange-rotate {
  0% {
    transform: rotate(0deg) scale(1);
    filter: blur(2rpx) brightness(1.2);
  }

  25% {
    transform: rotate(90deg) scale(1.05);
    filter: blur(1.5rpx) brightness(1.4);
  }

  50% {
    transform: rotate(180deg) scale(1);
    filter: blur(2rpx) brightness(1.2);
  }

  75% {
    transform: rotate(270deg) scale(0.95);
    filter: blur(2.5rpx) brightness(1.1);
  }

  100% {
    transform: rotate(360deg) scale(1);
    filter: blur(2rpx) brightness(1.2);
  }
}

/* 能量脉冲 */
@keyframes energy-pulse {
  0% {
    opacity: 0.8;
    transform: scale(1);
    filter: blur(2rpx) brightness(1.2);
  }

  50% {
    opacity: 1;
    transform: scale(1.1);
    filter: blur(1rpx) brightness(1.5);
  }

  100% {
    opacity: 0.9;
    transform: scale(0.95);
    filter: blur(2.5rpx) brightness(1.1);
  }
}


/* 粒子舞蹈 */
@keyframes particle-dance {
  0% {
    transform: rotate(0deg) scale(1) skewX(0deg);
    filter: blur(1rpx) brightness(1);
  }

  20% {
    transform: rotate(72deg) scale(1.1) skewX(5deg);
    filter: blur(0.5rpx) brightness(1.2);
  }

  40% {
    transform: rotate(144deg) scale(0.9) skewX(-3deg);
    filter: blur(1.5rpx) brightness(0.9);
  }

  60% {
    transform: rotate(216deg) scale(1.05) skewX(8deg);
    filter: blur(1rpx) brightness(1.1);
  }

  80% {
    transform: rotate(288deg) scale(0.95) skewX(-2deg);
    filter: blur(2rpx) brightness(0.8);
  }

  100% {
    transform: rotate(360deg) scale(1) skewX(0deg);
    filter: blur(1rpx) brightness(1);
  }
}

/* 能量波动 */
@keyframes energy-fluctuation {
  0% {
    opacity: 0.6;
    transform: scale(1) rotateX(0deg);
    filter: blur(1rpx) brightness(1) contrast(1);
  }

  33% {
    opacity: 0.9;
    transform: scale(1.15) rotateX(5deg);
    filter: blur(0.5rpx) brightness(1.3) contrast(1.2);
  }

  66% {
    opacity: 0.7;
    transform: scale(0.9) rotateX(-3deg);
    filter: blur(1.5rpx) brightness(0.9) contrast(0.9);
  }

  100% {
    opacity: 0.8;
    transform: scale(1.05) rotateX(2deg);
    filter: blur(1rpx) brightness(1.1) contrast(1.1);
  }
}

/* 反向旋转动画 */
@keyframes counter-rotate {
  0% {
    transform: rotate(0deg) scale(1);
  }

  100% {
    transform: rotate(-360deg) scale(1.05);
  }
}

/* 强度脉冲动画 */
@keyframes pulse-intensity {
  0% {
    opacity: 0.8;
    transform: scale(1);
  }

  50% {
    opacity: 1;
    transform: scale(1.05);
  }

  100% {
    opacity: 0.9;
    transform: scale(0.98);
  }
}

/* 神圣脉冲动画 */
@keyframes divine-pulse {
  0% {
    opacity: 0.6;
    transform: scale(1) rotate(0deg);
    filter: blur(2rpx) brightness(1);
  }

  33% {
    opacity: 0.9;
    transform: scale(1.15) rotate(5deg);
    filter: blur(1rpx) brightness(1.2);
  }

  66% {
    opacity: 0.8;
    transform: scale(1.05) rotate(-3deg);
    filter: blur(1.5rpx) brightness(1.1);
  }

  100% {
    opacity: 0.75;
    transform: scale(0.95) rotate(0deg);
    filter: blur(2rpx) brightness(1);
  }
}

/* 温和发光动画 - 升级版 */
@keyframes gentle-glow {
  0% {
    opacity: 0.4;
    transform: scale(0.95);
    filter: brightness(1);
  }

  50% {
    opacity: 0.8;
    transform: scale(1.02);
    filter: brightness(1.15);
  }

  100% {
    opacity: 0.6;
    transform: scale(0.98);
    filter: brightness(1.05);
  }
}

/* 收起状态日历样式 - 与展开状态保持一致 */
.calendar-day-compact {
  width: 64rpx !important;
  height: 64rpx !important;
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  justify-content: center !important;
  border-radius: 50% !important;
  /* 和展开状态一样的圆形 */
  font-weight: 500 !important;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
  position: relative !important;
  box-sizing: border-box !important;
  margin: 0 auto !important;

  /* 使用和展开状态相同的橙色渐变背景 */
  background:
    radial-gradient(ellipse at 25% 15%, rgba(255, 204, 128, 0.2) 0%, transparent 40%),
    radial-gradient(ellipse at 75% 85%, rgba(255, 224, 178, 0.15) 0%, transparent 50%),
    linear-gradient(145deg,
      rgba(255, 248, 240, 0.98) 0%,
      rgba(254, 245, 235, 0.92) 20%,
      rgba(253, 242, 230, 0.88) 40%,
      rgba(252, 239, 225, 0.85) 60%,
      rgba(251, 236, 220, 0.82) 80%,
      rgba(250, 233, 215, 0.8) 100%) !important;
  background-clip: padding-box !important;

  color: #8B4513 !important;
  backdrop-filter: blur(28rpx) saturate(1.4) brightness(1.05) !important;
}

/* 点击反馈效果 - 与展开状态一致 */
.calendar-day-compact:not(.selected):active {
  transform: translateY(1rpx) scale(0.98) !important;
}

/* 日期数字 - 大字在上，继承整体颜色 */
.calendar-day-compact .day-number {
  font-size: 26rpx !important;
  font-weight: 600 !important;
  color: inherit !important;
  /* 继承父元素的 #8B4513 颜色 */
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif;
  letter-spacing: -0.3rpx;
  line-height: 1;
}

/* 星期几 - 小字在下，继承整体颜色但稍淡 */
.calendar-day-compact .day-name {
  font-size: 16rpx !important;
  font-weight: 400 !important;
  color: inherit !important;
  /* 继承父元素的 #8B4513 颜色 */
  opacity: 0.7 !important;
  /* 通过透明度让星期几显得更淡 */
  margin-top: 1rpx;
  line-height: 1;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif;
}

/* 选中状态 - 完全与展开状态一致 */
.calendar-day-compact.selected {
  background: rgba(255, 152, 0, 0.8) !important;
