  margin: 0 auto;
}

/* 基础样式 - 高级橘色主题液态玻璃质感 */
.calendar-day {
  background:
    /* 表面橘色液态反射 */
    radial-gradient(ellipse at 25% 15%, rgba(255, 204, 128, 0.2) 0%, transparent 40%),
    radial-gradient(ellipse at 75% 85%, rgba(255, 224, 178, 0.15) 0%, transparent 50%),
    /* 主体橘色液态渐变 */
    linear-gradient(145deg,
      rgba(255, 248, 240, 0.98) 0%,
      rgba(254, 245, 235, 0.92) 20%,
      rgba(253, 242, 230, 0.88) 40%,
      rgba(252, 239, 225, 0.85) 60%,
      rgba(251, 236, 220, 0.82) 80%,
      rgba(250, 233, 215, 0.8) 100%);
  background-clip: padding-box;
  position: relative;

  /* 橘色边框渐变效果 */
  background-image:
    /* 内容层 */
    radial-gradient(ellipse at 25% 15%, rgba(255, 204, 128, 0.2) 0%, transparent 40%),
    radial-gradient(ellipse at 75% 85%, rgba(255, 224, 178, 0.15) 0%, transparent 50%),
    linear-gradient(145deg, rgba(255, 248, 240, 0.98) 0%, rgba(250, 233, 215, 0.8) 100%),
    /* 边框层 */
    linear-gradient(145deg,
      rgba(255, 184, 77, 0.4) 0%,
      rgba(255, 204, 128, 0.5) 25%,
      rgba(255, 224, 178, 0.3) 50%,
      rgba(255, 204, 128, 0.4) 75%,
      rgba(255, 184, 77, 0.35) 100%);
  background-origin: padding-box, padding-box, padding-box, border-box;

  /* 橘色液态玻璃阴影系统 */
  box-shadow:
    /* 环境光层 */
    0 16rpx 48rpx -6rpx rgba(255, 152, 0, 0.08),
    0 8rpx 24rpx -3rpx rgba(255, 152, 0, 0.06),
    0 4rpx 12rpx -1rpx rgba(255, 152, 0, 0.04),

    /* 内层液态高光 */
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.95),
    inset 0 1rpx 2rpx rgba(255, 248, 240, 0.9),
    inset 0 -1rpx 2rpx rgba(255, 204, 128, 0.2),

    /* 外层微光环 */
    0 0 0 1rpx rgba(255, 204, 128, 0.4);

  color: #8B4513;
  backdrop-filter: blur(28rpx) saturate(1.4) brightness(1.05);
  font-family: -apple-system, 'SF Pro Display', 'PingFang SC', sans-serif;
}

/* 选中样式 - 展开状态明亮透明橘色 */
.calendar-day.selected {
  height: 74rpx;
  color: white;
  font-weight: 700;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.2);
  transform: translateY(-3rpx) scale(1.05);
  backdrop-filter: blur(8rpx) saturate(1.2);
  box-shadow:
    0 8rpx 24rpx rgba(255, 152, 0, 0.3),
    0 4rpx 12rpx rgba(255, 152, 0, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
}




/* 空日期（月视图中的填充单元格） */
.calendar-day.empty {
  background: transparent;
  border: none;
  pointer-events: none;
}

/* 日期点击效果 - 立体交互 */
.calendar-day:active {
  transform: translateY(1rpx) scale(0.98);
  box-shadow:
    0 2rpx 6rpx rgba(0, 0, 0, 0.08),
    0 1rpx 3rpx rgba(0, 0, 0, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7);
}


.edit-btn-bottom {
  display: flex;
  justify-content: center;
  align-items: center;
}

.edit-btn-circle {
  width: 96rpx;
  height: 96rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 6rpx 24rpx rgba(0, 0, 0, 0.08),
    0 2rpx 8rpx rgba(0, 0, 0, 0.04),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(255, 184, 77, 0.12);
  transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  position: relative;
  overflow: hidden;
}

/* 内部微妙渐变 */
.edit-btn-circle::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(180deg,
      rgba(255, 255, 255, 0.8) 0%,
      transparent 100%);
  border-radius: 50% 50% 0 0;
  pointer-events: none;
}

/* 背景光晕 */
.edit-btn-circle::after {
  content: '';
  position: absolute;
  top: -30rpx;
  left: -30rpx;
  width: 156rpx;
  height: 156rpx;
  background: radial-gradient(circle,
      rgba(255, 184, 77, 0.06) 0%,
      rgba(255, 184, 77, 0.02) 60%,
      transparent 100%);
  border-radius: 50%;
  z-index: -1;
  transition: all 0.4s ease;
}

/* 悬停效果 */
.edit-btn-bottom:hover .edit-btn-circle {
  transform: translateY(-2rpx);
  box-shadow:
    0 12rpx 40rpx rgba(255, 184, 77, 0.15),
    0 4rpx 16rpx rgba(255, 184, 77, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 1);
  border-color: rgba(255, 184, 77, 0.2);
}

.edit-btn-bottom:hover .edit-btn-circle::after {
  background: radial-gradient(circle,
      rgba(255, 184, 77, 0.12) 0%,
      rgba(255, 184, 77, 0.04) 60%,
      transparent 100%);
  transform: scale(1.1);
}

/* 按压效果 */
.edit-btn-bottom:active .edit-btn-circle {
  transform: translateY(0) scale(0.96);
  box-shadow:
    0 4rpx 16rpx rgba(255, 184, 77, 0.12),
    0 1rpx 4rpx rgba(255, 184, 77, 0.08),
    inset 0 2rpx 4rpx rgba(0, 0, 0, 0.08);
}

/* 图标颜色调整 */
.edit-btn-circle .t-icon {
  color: #FF9800 !important;
}

/* 暖白记事本 - 温暖优雅弹窗 */
.function-custom-popup {
  background: linear-gradient(180deg,
      #FFFBF7 0%,
      #FFF8F0 50%,
      #FFF5E6 100%);
  border-radius: 28rpx 28rpx 0 0;
  padding: 0;
  max-height: 85vh;
  min-height: 65vh;
  height: 78vh;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow:
    0 -8rpx 32rpx rgba(255, 184, 77, 0.15),
    0 -2rpx 8rpx rgba(255, 184, 77, 0.1),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.6);
}

/* 温暖的顶部指示条 */
.popup-drag-indicator {
  width: 100%;
  height: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx 0 16rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.3) 0%, transparent 100%);
}

.drag-bar {
  width: 80rpx;
  height: 6rpx;
  background: linear-gradient(90deg, rgba(212, 165, 116, 0.4) 0%, #D4A574 50%, rgba(212, 165, 116, 0.4) 100%);
  border-radius: 3rpx;
  box-shadow: 0 1rpx 3rpx rgba(212, 165, 116, 0.3);
}

/* 温暖的关闭按钮 */
.popup-close-btn {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(255, 248, 240, 0.8) 100%);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  transition: all 0.3s ease;
  border: 1rpx solid rgba(255, 184, 77, 0.2);
  backdrop-filter: blur(10rpx);
  box-shadow: 0 4rpx 12rpx rgba(212, 165, 116, 0.15);
}

.popup-close-btn:active {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.8) 0%, rgba(255, 248, 240, 0.7) 100%);
  transform: scale(0.92);
  box-shadow: 0 2rpx 8rpx rgba(212, 165, 116, 0.2);
}

/* 温暖的标题区 - 保持正确的头部布局 */
.popup-header {
  padding: 32rpx 0 28rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.3) 0%, transparent 100%);
  position: relative;
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

/* 针对不同弹窗的特殊处理 */
.popup-content .popup-header {
  position: relative;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0;
  margin-bottom: 30rpx;
  background: transparent;
}

.popup-header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 184, 77, 0.25) 50%, transparent 100%);
}

.header-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, rgba(255, 184, 77, 0.12) 0%, rgba(255, 184, 77, 0.06) 100%);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 0 16rpx 0;
  border: 1.5rpx solid rgba(255, 184, 77, 0.18);
  box-shadow: 0 4rpx 16rpx rgba(255, 184, 77, 0.08);
  position: relative;
  overflow: hidden;
}

.header-icon::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(45deg, transparent 30%, rgba(255, 255, 255, 0.25) 50%, transparent 70%);
  animation: iconShimmer 5s ease-in-out infinite;
}

@keyframes iconShimmer {
  0% {
    transform: translateX(-100%) translateY(-100%) rotate(30deg);
  }

  100% {
    transform: translateX(100%) translateY(100%) rotate(30deg);
  }
}

.popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D1810;
  line-height: 1.3;
  letter-spacing: 0.6rpx;
  text-shadow: 0 1rpx 2rpx rgba(255, 184, 77, 0.06);
  margin: 0;
  text-align: center;
}

/* 统一关闭按钮样式 */
.close-btn {
  width: 52rpx;
  height: 52rpx;
  background: linear-gradient(135deg,
      rgba(212, 165, 116, 0.15) 0%,
      rgba(212, 165, 116, 0.2) 50%,
      rgba(212, 165, 116, 0.12) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 6rpx 16rpx rgba(212, 165, 116, 0.2),
    0 3rpx 8rpx rgba(212, 165, 116, 0.15),
    0 2rpx 4rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(212, 165, 116, 0.25);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.close-btn:active {
  transform: scale(0.95);
  box-shadow:
    0 4rpx 12rpx rgba(212, 165, 116, 0.25),
    0 2rpx 6rpx rgba(212, 165, 116, 0.2);
}

.header-divider {
  width: 100%;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 184, 77, 0.2) 50%, transparent 100%);
  margin-top: 16rpx;
}

.function-custom-content {
  padding: 20rpx 12rpx;
  flex: 1;
  overflow: visible;
  position: relative;
  display: flex;
  flex-direction: column;
  width: 100%;
  box-sizing: border-box;
}

/* 简洁的操作提示 */
.custom-hint-card {
  display: flex;
  align-items: center;
  margin: 0 0 16rpx 0;
  padding: 18rpx 20rpx;
  box-shadow: 0 1rpx 6rpx rgba(255, 184, 77, 0.04);
  box-sizing: border-box;
  flex-shrink: 0;
}

.hint-text-wrapper {
  flex: 1;
}

.hint-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2D1810;
  margin-bottom: 4rpx;
  letter-spacing: 0.5rpx;
}

.hint-subtitle {
  font-size: 24rpx;
  color: #8B6C42;
  line-height: 1.4;
  font-weight: 400;
  opacity: 0.85;
}

/* 功能项自定义弹窗内的网格，限制作用域避免影响主页面 */
.function-custom-popup .function-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-bottom: 32rpx;
  max-height: 65vh;
  overflow-y: auto;
  padding: 20rpx;
}

/* 功能卡片（仅用于弹窗区域） */
.function-custom-popup .function-card {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
  position: relative;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  min-height: 280rpx;
  overflow: visible;
  display: flex;
  flex-direction: column;
  padding: 20rpx;
}

.function-custom-popup .function-card.card-visible {
  border-color: rgba(255, 152, 0, 0.25);
  background: rgba(255, 248, 240, 0.95);
  box-shadow: 0 6rpx 24rpx rgba(255, 152, 0, 0.18);
}

.function-custom-popup .function-card.card-hidden {
  opacity: 0.4;
  background: rgba(240, 240, 240, 0.8);
  border-color: rgba(0, 0, 0, 0.08);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.function-custom-popup .function-card:active {
  transform: scale(0.96);
}

/* 拖拽手柄 */
.drag-handle {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  width: 48rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 152, 0, 0.15);
  border-radius: 16rpx;
  cursor: grab;
  z-index: 10;
  transition: all 0.3s ease;
}

.drag-icon {
  font-size: 24rpx;
  color: #FF9800;
  font-weight: bold;
}

/* 开关 */
.toggle-switch {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  cursor: pointer;
  z-index: 10;
}

.switch-track {
  width: 68rpx;
  height: 40rpx;
  border-radius: 20rpx;
  position: relative;
  transition: all 0.3s ease;
}

.switch-on {
  background: #FF9800;
  box-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.3);
}

.switch-off {
  background: #DDDDDD;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.switch-thumb {
  width: 36rpx;
  height: 36rpx;
  background: white;
  border-radius: 18rpx;
  position: absolute;
  top: 2rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.2);
}

.switch-on .switch-thumb {
  transform: translateX(28rpx);
}

.switch-off .switch-thumb {
  transform: translateX(2rpx);
}

.drag-handle:active {
  cursor: grabbing;
  background: rgba(255, 152, 0, 0.3);
  transform: scale(1.05);
}

/* 卡片主内容 */
.card-main {
  text-align: center;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  margin-top: 60rpx;
  padding: 20rpx 0;
}

.function-icon {
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 152, 0, 0.08);
  border-radius: 50rpx;
  transition: all 0.3s ease;
}

.function-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
  line-height: 1.2;
}

.function-status {
  font-size: 24rpx;
  font-weight: 500;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  display: inline-block;
}

.status-on {
  color: #FF9800;
  background: rgba(255, 152, 0, 0.12);
}

.status-off {
  color: #999999;
  background: rgba(0, 0, 0, 0.06);
}

/* 温暖优雅的操作按钮 - 位置优化 */
.action-buttons {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg,
      rgba(255, 251, 247, 0.95) 0%,
      rgba(255, 248, 240, 1) 100%);
  border-top: 1rpx solid rgba(255, 184, 77, 0.12);
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.03);
  flex-shrink: 0;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 18rpx 16rpx;
  border-radius: 14rpx;
  font-weight: 500;
  transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  height: 72rpx;
  position: relative;
  overflow: hidden;
}

.btn-text {
  font-size: 28rpx;
  letter-spacing: 0.5rpx;
  z-index: 1;
  position: relative;
}

.action-btn.secondary {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.8) 0%, rgba(245, 240, 232, 0.7) 100%);
  color: #8B6C42;
  border: 1.5rpx solid rgba(212, 165, 116, 0.25);
  box-shadow: 0 2rpx 8rpx rgba(212, 165, 116, 0.1);
}

.action-btn.secondary::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.25) 50%, transparent 100%);
  transition: left 0.5s ease;
}

.action-btn.secondary:active::before {
  left: 100%;
}

.action-btn.secondary:active {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.7) 0%, rgba(245, 240, 232, 0.6) 100%);
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(212, 165, 116, 0.15);
}

.action-btn.primary {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9800 100%);
  color: white;
  border: 1.5rpx solid rgba(255, 255, 255, 0.15);
  box-shadow: 0 4rpx 16rpx rgba(255, 184, 77, 0.25);
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.08);
}

.action-btn.primary::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.15) 0%, transparent 50%, rgba(255, 255, 255, 0.08) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.action-btn.primary:active::before {
  opacity: 1;
}

.action-btn.primary:active {
  background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(255, 184, 77, 0.3);
}

/* 拖拽效果 */
.function-card.card-dragging {
  z-index: 1000;
  transform: scale(1.05) rotate(1deg);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.2), 0 8rpx 24rpx rgba(255, 184, 77, 0.4);
  opacity: 0.95;
  border-color: rgba(255, 184, 77, 0.5);
  background: linear-gradient(135deg, rgba(255, 184, 77, 0.12) 0%, rgba(255, 184, 77, 0.06) 100%);
}


/* ==========================================
   全新数据展示布局 - 简洁小程序风格
   ========================================== */

/* 主容器 */
.data-display-simple {
  box-sizing: border-box;
  width: 100%;
  align-self: stretch;
  /* 在flex容器中占满 */
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin: 0;
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #F8F8F8;
  min-height: 180rpx;
  /* 与单值面板统一高度基线 */
}

/* 数据行 */
.data-item-row {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  column-gap: 16rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #F8F8F8;
  min-height: 44rpx;
  line-height: 44rpx;
}

.data-item-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.data-item-row:first-child {
  padding-top: 0;
}

/* 数据标签 */
.data-label {
  font-size: 30rpx;
  color: #666666;
  flex: 0 0 160rpx;
  /* 固定标签列宽，保证右侧数值列对齐 */
  line-height: 44rpx;
  text-align: left;
  margin-right: 0;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

/* 数据值 */
.data-value {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
  text-align: right;
  flex: 1 1 auto;
  line-height: 44rpx;
}

/* 病毒检测状态 */
.data-status {
  font-size: 30rpx;
  font-weight: 500;
  text-align: right;
  flex: 1 1 auto;
  line-height: 44rpx;
}

.data-status.positive {
  color: #FF6B6B;
}

.data-status.negative {
  color: #51CF66;
}

/* 空数据提示 */
.data-empty {
  text-align: center;
  color: #999999;
  font-size: 28rpx;
  padding: 40rpx 0;
  line-height: 1.5;
}

/* —— 单指标精简展示（用于 EBV/CMV） —— */
.single-metric-panel {
  width: 100%;
  box-sizing: border-box;
  padding: 18rpx 20rpx;
  background: #FFFFFF;
  /* 与其他数据卡一致 */
  border-radius: 16rpx;
  border: 1rpx solid #F8F8F8;
