.page-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 自定义导航栏 - 橙色主题 */
.navbar {
  background: linear-gradient(135deg, var(--color-orange-600), var(--color-orange-700));
  border-bottom: none;
  padding-top: 44px;
  padding-top: env(safe-area-inset-top);
  box-shadow: 0 2rpx 16rpx rgba(255, 143, 0, 0.2);
}

.navbar-right {
  padding-right: 30rpx;
}

/* 内容区域 */
.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  height: 0;
}

/* 临时配置预览提示 */
.temp-config-hint {
  background: linear-gradient(135deg, var(--color-orange-50), var(--color-orange-100));
  border: 1rpx solid rgba(255, 152, 0, 0.3);
  border-radius: 12rpx;
  margin: 20rpx 30rpx 20rpx 30rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.1);
  animation: pulse-preview 2s ease-in-out infinite;
}

.temp-config-text {
  font-size: 26rpx;
  color: var(--color-orange-600);
  font-weight: 500;
  line-height: 1.4;
}

@keyframes pulse-preview {

  0%,
  100% {
    opacity: 1;
  }

  50% {
    opacity: 0.88;
  }
}

/* 日期选择区域 */
.date-section {
  background: white;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.date-selector {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 18rpx 28rpx;
  background: linear-gradient(135deg, var(--color-white-pure) 0%, #f8f8f8 100%);
  border: 1rpx solid rgba(255, 143, 0, 0.05);
  border-radius: 30rpx;
  min-width: 200rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.date-selector:active {
  background: linear-gradient(135deg, #f8f8f8 0%, #f0f0f0 100%);
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.08);
}

.date-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

/* 快捷输入按钮 */
.quick-input-btns {
  display: flex;
  gap: 24rpx;
}

.quick-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: white;
  border: 1rpx solid #e0e0e0;
  border-radius: 30rpx;
  transition: all 0.3s;
}

.quick-btn:active {
  background: #f5f5f5;
  transform: scale(0.98);
}

.quick-btn text {
  font-size: 28rpx;
  color: #666;
}

/* 滚动容器 */
.scroll-container {
  flex: 1;
  width: 100%;
  background: #f5f5f5;
  overflow-y: auto;
}

/* 表单容器 */
.form-container {
  padding: 20rpx;
  padding-bottom: 240rpx;
}

/* 指标列表 */
.indicators-list {
  background: white;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(255, 143, 0, 0.1);
}

/* 指标项 */
.indicator-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.indicator-item-textarea {
  align-items: flex-start;
}

.indicator-item:last-child {
  border-bottom: none;
}

/* 注释掉不再使用的 indicator-header */
/* .indicator-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
} */

.indicator-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  min-width: 210rpx;
  flex-shrink: 0;
}

/* 已删除参考范围相关样式 */

.indicator-input {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.input-field {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  font-size: 32rpx;
  color: #333;
}

/* 文本域样式 */
.textarea-field {
  flex: 1;
  min-height: 120rpx;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

.unit {
  font-size: 28rpx;
  color: #666;
  min-width: 100rpx;
  text-align: right;
}

/* 浮动的下一项按钮 - 固定在键盘上方右侧 */
.floating-next-btn {
  position: fixed;
  right: 40rpx;
  bottom: calc(env(safe-area-inset-bottom) + 580rpx);
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F2E 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 184, 77, 0.5);
  z-index: 99999;
  animation: bounceIn 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  animation-fill-mode: both;
  will-change: transform;
}

@keyframes bounceIn {
  0% {
    opacity: 0;
    transform: scale(0.3);
  }

  50% {
    opacity: 1;
    transform: scale(1.05);
  }

  70% {
    transform: scale(0.9);
  }

  100% {
    transform: scale(1);
  }
}

/* 空状态 */
.empty-indicators {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  background: white;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-top: 24rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #ccc;
  margin-top: 12rpx;
}

/* 编辑录入项按钮 */
.add-more-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 100rpx;
  background: white;
  border-radius: 20rpx;
  color: var(--color-orange-600);
  font-size: 30rpx;
  transition: all 0.3s;
}

.add-more-btn:active {
  background: var(--color-orange-50);
  transform: scale(0.98);
}

/* 底部操作按钮 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
  display: flex;
  gap: 20rpx;
  z-index: 100;
}

/* 立体化保存按钮 */
.save-btn {
  flex: 2;
  height: 92rpx !important;
  font-size: 30rpx;
  font-weight: 500;
  background: linear-gradient(135deg, var(--color-orange-600) 0%, var(--color-orange-700) 100%) !important;
  box-shadow:
    0 8rpx 24rpx rgba(255, 143, 0, 0.4),
    0 4rpx 12rpx rgba(245, 124, 0, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3) !important;
  border: 2rpx solid rgba(255, 255, 255, 0.4) !important;
  border-radius: 12rpx !important;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
  position: relative !important;
  overflow: hidden !important;
  color: white !important;
}

.save-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.8) 50%,
      transparent 100%);
  border-radius: 12rpx 12rpx 0 0;
}

.save-btn:active {
  background: linear-gradient(135deg, var(--color-orange-700) 0%, #FF9800 100%) !important;
  transform: scale(0.96) translateY(2rpx) !important;
  box-shadow:
    0 4rpx 12rpx rgba(255, 143, 0, 0.5),
    0 2rpx 6rpx rgba(245, 124, 0, 0.4),
    inset 0 3rpx 6rpx rgba(255, 255, 255, 0.2) !important;
}

/* 立体化删除按钮 - 灰色主题区分 */
.delete-btn {
  flex: 1;
  height: 88rpx;
  font-size: 30rpx;
  font-weight: 500;
  background: linear-gradient(135deg, #757575 0%, #616161 100%);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow:
    0 8rpx 24rpx rgba(117, 117, 117, 0.4),
    0 4rpx 12rpx rgba(97, 97, 97, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3);
  position: relative;
  overflow: hidden;
}

.delete-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.8) 50%,
      transparent 100%);
  border-radius: 12rpx 12rpx 0 0;
}

.delete-btn:active {
  background: linear-gradient(135deg, #616161 0%, #424242 100%);
  transform: scale(0.96) translateY(2rpx);
  box-shadow:
    0 4rpx 12rpx rgba(117, 117, 117, 0.5),
    0 2rpx 6rpx rgba(97, 97, 97, 0.4),
    inset 0 3rpx 6rpx rgba(255, 255, 255, 0.2);
}

/* 修复导航栏样式 */
.t-navbar__placeholder {
  visibility: hidden;
}

.t-navbar {
  --td-navbar-bg-color: transparent;
}

/* 强制设置导航栏标题样式 - 使用更具体的选择器 */
.navbar .t-navbar__title,
.navbar .t-navbar__center,
.navbar .t-navbar__center text,
.navbar .t-navbar__center .t-navbar__title {
  color: white !important;
  font-size: 34rpx !important;
  font-weight: 500 !important;
}

/* 导航栏所有图标颜色 */
.navbar .t-icon,
.navbar .t-navbar__left .t-icon,
.navbar .t-navbar__right .t-icon {
  color: white !important;
}

/* 更强的选择器确保样式生效 */
.page-container .navbar .t-navbar__title {
  color: white !important;
  font-size: 34rpx !important;
  font-weight: 500 !important;
}

/* 自定义返回按钮样式 */
.custom-back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  transition: all 0.3s;
}

.custom-back-btn:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.95);
}

/* 自定义日期选择器样式 - 橙色主题 */
.custom-date-picker {
  --td-picker-title-color: var(--color-orange-600);
  --td-picker-confirm-btn-color: var(--color-orange-600);
  --td-picker-cancel-btn-color: #666;
  --td-picker-item-color: #333;
  --td-picker-item-selected-color: var(--color-orange-600);
  --td-picker-toolbar-bg-color: var(--color-white-pure);
  --td-picker-bg-color: var(--color-white-pure);
  --td-popup-border-radius: 24rpx 24rpx 0 0;
}

/* 自定义日期选择器样式 - 橙色主题 */
.t-date-time-picker__confirm {
  color: white !important;
  background: linear-gradient(135deg, var(--color-orange-600) 0%, var(--color-orange-700) 100%) !important;
  border-radius: 12rpx !important;
  padding: 12rpx 24rpx !important;
  font-weight: 500 !important;
  box-shadow: 0 4rpx 12rpx rgba(255, 143, 0, 0.3) !important;
  border: 2rpx solid rgba(255, 255, 255, 0.4) !important;
  transition: all 0.3s !important;
}

.t-date-time-picker__confirm:active {
  background: linear-gradient(135deg, var(--color-orange-700) 0%, #FF9800 100%) !important;
  transform: scale(0.96) !important;
  box-shadow: 0 2rpx 8rpx rgba(255, 143, 0, 0.4) !important;
}

/* 自定义日期选择器样式 - 兼容picker组件 */
.t-picker__confirm {
  color: white !important;
  background: linear-gradient(135deg, var(--color-orange-600) 0%, var(--color-orange-700) 100%) !important;
  border-radius: 12rpx !important;
  padding: 12rpx 24rpx !important;
  font-weight: 500 !important;
  box-shadow: 0 4rpx 12rpx rgba(255, 143, 0, 0.3) !important;
  border: 2rpx solid rgba(255, 255, 255, 0.4) !important;
  transition: all 0.3s !important;
}

.t-picker__confirm:active {
  background: linear-gradient(135deg, var(--color-orange-700) 0%, #FF9800 100%) !important;
  transform: scale(0.96) !important;
  box-shadow: 0 2rpx 8rpx rgba(255, 143, 0, 0.4) !important;
}

/* 全局覆盖所有日期选择器确定按钮样式 - 橙色主题 */
page .t-date-time-picker .t-picker__toolbar .t-button--primary,
page .t-picker .t-button--primary,
page .t-date-time-picker__confirm,
page .t-picker__confirm {
  width: 137rpx;
  height: 80rpx;
  color: var(--color-white-pure) !important;
  background: linear-gradient(135deg, var(--color-orange-600) 0%, var(--color-orange-700) 100%) !important;
  border-radius: 12rpx !important;
  font-weight: 500 !important;
  box-shadow: 0 4rpx 12rpx rgba(255, 143, 0, 0.3) !important;
  border: 2rpx solid rgba(255, 255, 255, 0.4) !important;
  transition: all 0.3s !important;
  padding: 12rpx 24rpx !important;
}

page .t-date-time-picker .t-picker__toolbar .t-button--primary:active,
page .t-picker .t-button--primary:active,
page .t-date-time-picker__confirm:active,
page .t-picker__confirm:active {
  background: linear-gradient(135deg, var(--color-orange-700) 0%, #FF9800 100%) !important;
  transform: scale(0.96) !important;
  box-shadow: 0 2rpx 8rpx rgba(255, 143, 0, 0.4) !important;
}

/* 日期选择器工具栏 - 橙色主题 */
.t-picker__toolbar {
  background: linear-gradient(135deg, rgba(255, 143, 0, 0.05) 0%, rgba(245, 124, 0, 0.08) 50%, rgba(255, 255, 255, 0.95) 100%) !important;
  border-bottom: 1rpx solid rgba(255, 143, 0, 0.15) !important;
  padding: 20rpx 30rpx !important;
  box-shadow: 0 2rpx 8rpx rgba(255, 143, 0, 0.08) !important;
}

/* 优化日期选择器标题 - 橙色主题 */
.t-date-time-picker .t-picker__title {
  font-size: 32rpx !important;
  font-weight: 600 !important;
  color: var(--color-orange-600) !important;
  text-shadow: 0 1rpx 3rpx rgba(255, 143, 0, 0.1) !important;
}

/* 日期选择器选中项 - 橙色主题 */
.t-date-time-picker .t-picker-item--selected {
  color: var(--color-orange-600) !important;
  font-weight: 500 !important;
}

/* 日期选择器取消按钮 */
.t-date-time-picker .t-picker__cancel {
  color: #666 !important;
}

/* 日期选择器容器 */
.t-date-time-picker .t-popup__content {
  border-radius: 24rpx 24rpx 0 0 !important;
}