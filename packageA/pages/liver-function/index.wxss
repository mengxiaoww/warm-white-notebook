/* 引用血常规页面的样式 */
@import "../blood-test/index.wxss";

/* AI智能导入按钮 - 简洁优雅设计 */
.ai-smart-import-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 32rpx;
  background: linear-gradient(135deg, #FFB84D 0%, #FFA726 100%);
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 152, 0, 0.35);
  transition: all 0.3s ease;
}

.ai-smart-import-btn:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.4);
}

.ai-btn-label {
  font-size: 28rpx;
  font-weight: 600;
  color: white;
  letter-spacing: 0.5rpx;
}

/* AI导入方式选择弹窗 */
.ai-import-menu {
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0;
}

.ai-menu-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.ai-menu-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.ai-menu-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f5f5;
  transition: all 0.2s;
}

.ai-menu-close:active {
  background: #e0e0e0;
  transform: scale(0.95);
}

/* 选项列表 */
.ai-menu-options {
  padding: 24rpx 32rpx;
}

.ai-option-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 24rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #f5f6f8 100%);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  transition: all 0.3s;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.ai-option-item:last-child {
  margin-bottom: 0;
}

.ai-option-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.option-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.option-icon-wrapper.camera {
  background: linear-gradient(135deg, rgba(255, 152, 0, 0.15) 0%, rgba(255, 152, 0, 0.08) 100%);
}

.option-icon-wrapper.album {
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.15) 0%, rgba(76, 175, 80, 0.08) 100%);
}

.option-icon-wrapper.voice {
  background: linear-gradient(135deg, rgba(33, 150, 243, 0.15) 0%, rgba(33, 150, 243, 0.08) 100%);
}

.option-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.option-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.option-desc {
  font-size: 24rpx;
  color: #999;
}

.ai-menu-safe-area {
  height: env(safe-area-inset-bottom);
  background: white;
}

/* 语音录音弹窗 */
.voice-record-popup {
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0;
  min-height: 600rpx;
}

.voice-record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.voice-record-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.voice-close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f5f5;
  transition: all 0.2s;
}

.voice-close-btn:active {
  background: #e0e0e0;
  transform: scale(0.95);
}

/* 录音动画区域 */
.voice-record-animation {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.voice-wave-container {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
}

.voice-wave {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 152, 0, 0.1) 0%, rgba(255, 152, 0, 0) 70%);
  opacity: 0;
}

.voice-wave.recording {
  animation: voice-pulse 2s ease-out infinite;
}

.voice-wave:nth-child(2) {
  animation-delay: 0.6s;
}

.voice-wave:nth-child(3) {
  animation-delay: 1.2s;
}

@keyframes voice-pulse {
  0% {
    transform: scale(0.5);
    opacity: 0.8;
  }
  100% {
    transform: scale(2.5);
    opacity: 0;
  }
}

.voice-icon-wrapper {
  z-index: 10;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFF8F0 0%, #FFF5EB 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 152, 0, 0.2);
  transition: all 0.3s;
}

/* 录音时长显示 */
.voice-duration {
  text-align: center;
  margin-bottom: 40rpx;
}

.duration-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #FF9800;
  font-family: 'DIN Alternate', 'SF Pro Display', -apple-system, sans-serif;
}

/* 提示文字 */
.voice-hint {
  text-align: center;
  padding: 0 60rpx;
  margin-bottom: 60rpx;
}

.hint-text {
  display: block;
  font-size: 30rpx;
  color: #666;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.recognized-text {
  display: block;
  font-size: 32rpx;
  color: #FF9800;
  font-weight: 600;
  line-height: 1.6;
  margin: 20rpx 0;
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(255, 152, 0, 0.08) 0%, rgba(255, 152, 0, 0.05) 100%);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 152, 0, 0.2);
  min-height: 100rpx;
  word-break: break-all;
}

.hint-subtext {
  display: block;
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

/* 操作按钮 */
.voice-record-actions {
  display: flex;
  gap: 20rpx;
  padding: 0 32rpx 24rpx;
}

.voice-action-btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.voice-action-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.voice-action-btn.cancel:active {
  background: #e0e0e0;
  transform: scale(0.98);
}

.voice-action-btn.record {
  background: linear-gradient(135deg, #FF9800 0%, #FFA726 100%);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(255, 152, 0, 0.35);
  flex: 2;
}

.voice-action-btn.record.recording {
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.35);
}

.voice-action-btn.record:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(255, 152, 0, 0.4);
}

.voice-safe-area {
  height: env(safe-area-inset-bottom);
  background: white;
}

/* AI识别结果弹窗 */
.ai-result-popup {
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  width: 100%;
  overflow: hidden;
  box-sizing: border-box;
}

/* 弹窗标题栏 */
.ai-result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: linear-gradient(135deg, rgba(255, 152, 0, 0.03) 0%, rgba(255, 184, 77, 0.05) 100%);
}

.ai-header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ai-result-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.ai-close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f5f5;
  transition: all 0.2s;
}

.ai-close-btn:active {
  background: #e0e0e0;
  transform: scale(0.95);
}

/* 识别结果内容区 */
.ai-result-content {
  flex: 1;
  padding: 24rpx 32rpx;
  max-height: 50vh;
  overflow-x: hidden;
  box-sizing: border-box;
}

/* 识别结果项 */
.ai-result-item {
  background: linear-gradient(135deg, #FFF8F0 0%, #FFF5EB 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(255, 152, 0, 0.15);
  box-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.08);
  width: 100%;
  box-sizing: border-box;
}

.ai-item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
  gap: 8rpx;
}

.ai-item-name {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
  flex: 1;
  min-width: 120rpx;
  word-break: break-all;
}

.ai-confidence-badge {
  padding: 4rpx 12rpx;
  background: rgba(255, 152, 0, 0.12);
  border-radius: 12rpx;
}

.confidence-text {
  font-size: 22rpx;
  color: #FF9800;
  font-weight: 600;
}

.ai-item-value {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.value-number {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  font-family: 'DIN Alternate', 'SF Pro Display', -apple-system, sans-serif;
  word-break: break-all;
}

.value-unit {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}

/* 置信度进度条 */
.ai-confidence-bar {
  height: 6rpx;
  background: #e5e7eb;
  border-radius: 3rpx;
  overflow: hidden;
}

.confidence-fill {
  height: 100%;
  transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  border-radius: 3rpx;
}

/* 空状态 */
.ai-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

/* 底部操作按钮 */
.ai-result-actions {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
  background: white;
}

.ai-action-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.ai-action-btn.secondary {
  background: #f5f5f5;
  color: #666;
}

.ai-action-btn.secondary:active {
  background: #e0e0e0;
  transform: scale(0.98);
}

.ai-action-btn.primary {
  background: linear-gradient(135deg, #FF9800 0%, #FFA726 100%);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(255, 152, 0, 0.35);
}

.ai-action-btn.primary:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(255, 152, 0, 0.4);
}

.ai-result-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 32rpx;
  background: #f9f9f9;
  border-bottom: 1rpx solid #f0f0f0;
}

.ai-result-tip-text {
  font-size: 22rpx;
  color: #999;
}
