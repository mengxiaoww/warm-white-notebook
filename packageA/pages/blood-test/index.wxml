<view class="page-container">
  <!-- 自定义导航栏 -->
  <t-navbar title="血常规" class="navbar" style="--td-navbar-title-color: white; --td-navbar-title-font-size: 34rpx; --td-navbar-title-font-weight: 500;">
    <view slot="left" class="custom-back-btn" bindtap="goBack">
      <t-icon name="chevron-left" size="48rpx" color="white" />
    </view>
    <view slot="right" class="navbar-right">
      <view class="ai-identify-btn" bindtap="showAIIdentifyOptions">
        <t-icon name="gesture-click" size="40rpx" color="white" />
        <text class="ai-btn-text">AI</text>
      </view>
      <t-icon name="ellipsis" size="48rpx" color="white" bindtap="showMoreMenu" />
    </view>
  </t-navbar>
  <!-- 内容区域 -->
  <view class="content">
    <!-- 临时配置预览提示 -->
    <view class="temp-config-hint" wx:if="{{isTemporaryConfig}}">
      <t-icon name="info-circle" size="28rpx" color="#ff6b35" />
      <text class="temp-config-text">📋 正在预览配置效果，点击"保存配置"后生效</text>
    </view>
    <!-- 日期选择 -->
    <view class="date-section">
      <view class="date-selector" bindtap="showDatePicker">
        <text class="date-text">{{selectedDate}}</text>
        <t-icon name="caret-down" size="24rpx" color="#666" />
      </view>
      <!-- AI智能导入按钮 -->
      <view class="ai-smart-import-btn" bindtap="showAIIdentifyOptions">
        <view class="ai-icon-badge">
          <t-icon name="browse" size="40rpx" color="white" />
        </view>
        <text class="ai-btn-label">智能导入</text>
      </view>
    </view>
    <!-- 血常规指标列表 -->
    <scroll-view class="scroll-container" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="form-container">
        <!-- 基础指标 -->
        <view class="indicators-list" wx:if="{{(displayedBasicIndicators && displayedBasicIndicators.length > 0) || (customIndicators && customIndicators.length > 0)}}">
          <!-- 动态显示基础指标 -->
          <view class="indicator-item" wx:for="{{displayedBasicIndicators}}" wx:key="id">
            <text class="indicator-name">{{item.name}}</text>
            <view class="indicator-input">
              <input id="input-{{index}}" type="digit" value="{{formData[item.id]}}" focus="{{focusIndex === index}}" bindinput="onInputChange" bindfocus="onInputFocus" bindblur="onInputBlur" data-field="{{item.id}}" data-index="{{index}}" data-total="{{displayedBasicIndicators.length + customIndicators.length}}" placeholder="请输入" class="input-field" />
              <text class="unit">{{item.unit || 'g/L'}}</text>
            </view>
          </view>
          <!-- 自定义指标 -->
          <view class="indicator-item" wx:for="{{customIndicators}}" wx:key="id" wx:for-index="customIndex">
            <text class="indicator-name">{{item.name}}</text>
            <view class="indicator-input">
              <input id="input-{{displayedBasicIndicators.length + customIndex}}" type="digit" value="{{formData[item.id]}}" focus="{{focusIndex === displayedBasicIndicators.length + customIndex}}" bindinput="onInputChange" bindfocus="onInputFocus" bindblur="onInputBlur" data-field="{{item.id}}" data-index="{{displayedBasicIndicators.length + customIndex}}" data-total="{{displayedBasicIndicators.length + customIndicators.length}}" placeholder="请输入" class="input-field" />
              <text class="unit">{{item.unit}}</text>
            </view>
          </view>
        </view>
        <!-- 空状态提示 -->
        <view class="empty-indicators" wx:if="{{(!displayedBasicIndicators || displayedBasicIndicators.length === 0) && (!customIndicators || customIndicators.length === 0)}}">
          <medical-icon name="blood-drop" size="120" color="#ccc" />
          <text class="empty-text">暂无录入项</text>
          <text class="empty-hint">点击下方按钮添加录入项</text>
        </view>
        <!-- 添加更多录入项 -->
        <view class="add-more-btn" bindtap="configIndicators">
          <text>编辑录入项</text>
        </view>
      </view>
    </scroll-view>
    <!-- 底部操作按钮 -->
    <view class="bottom-actions">
      <view class="delete-btn" bindtap="deleteRecord">
        <t-icon name="delete" size="32rpx" color="white" />
        <text>删除</text>
      </view>
      <t-button theme="primary" size="large" class="save-btn" bindtap="saveData">保存配置</t-button>
    </view>
  </view>
  <!-- 日期选择器 -->
  <t-date-time-picker title="选择日期" visible="{{datePickerVisible}}" mode="date" value="{{selectedDate}}" bind:confirm="onDateConfirm" bind:cancel="onDateCancel" confirm-btn="确定" cancel-btn="取消" class="custom-date-picker" />

  <!-- AI识别结果预览弹窗 -->
  <t-popup visible="{{aiResultVisible}}" bind:visible-change="onAIResultClose" placement="bottom" show-overlay="{{true}}" overlay-props="{{ { preventScrollThrough: true } }}">
    <view class="ai-result-popup">
      <!-- 标题栏 -->
      <view class="ai-result-header">
        <view class="ai-header-left">
          <t-icon name="check-circle" size="40rpx" color="#7c3aed" />
          <text class="ai-result-title">AI识别结果</text>
        </view>
        <view class="ai-close-btn" catchtap="onAIResultClose">
          <t-icon name="close" size="28rpx" color="#666" />
        </view>
      </view>

      <!-- 识别结果列表 -->
      <scroll-view class="ai-result-content" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
        <view class="ai-result-item" wx:for="{{aiRecognizedData}}" wx:key="field" wx:if="{{item.value}}">
          <view class="ai-item-header">
            <text class="ai-item-name">{{item.label}}</text>
            <view class="ai-confidence-badge" wx:if="{{item.confidence}}">
              <text class="confidence-text">{{item.confidence}}%</text>
            </view>
          </view>
          <view class="ai-item-value">
            <text class="value-number">{{item.value}}</text>
            <text class="value-unit">{{item.unit}}</text>
          </view>
          <!-- 置信度进度条 -->
          <view class="ai-confidence-bar" wx:if="{{item.confidence}}">
            <view class="confidence-fill" style="width: {{item.confidence}}%; background: {{item.confidenceColor}};"></view>
          </view>
        </view>

        <!-- 空状态 -->
        <view class="ai-empty-state" wx:if="{{aiRecognizedData.length === 0}}">
          <t-icon name="info-circle" size="80rpx" color="#ddd" />
          <text class="empty-text">未识别到有效数据</text>
          <text class="empty-hint">请重新拍摄或选择更清晰的图片</text>
        </view>
      </scroll-view>

      <!-- 底部按钮 -->
      <view class="ai-result-actions">
        <view class="ai-action-btn secondary" bindtap="retryAIIdentify">
          <t-icon name="refresh" size="32rpx" color="#666" />
          <text>重新识别</text>
        </view>
        <view class="ai-action-btn primary" bindtap="confirmAIResult">
          <t-icon name="check" size="32rpx" color="white" />
          <text>确认填充</text>
        </view>
      </view>
    </view>
  </t-popup>

  <!-- Toast -->
  <t-toast id="t-toast" />
  <!-- 浮动的下一项/完成按钮 -->
  <view wx:if="{{focusIndex >= 0}}" class="floating-next-btn" catchtap="{{focusIndex === displayedBasicIndicators.length + customIndicators.length - 1 ? 'completeInput' : 'goToNextInput'}}" data-index="{{focusIndex}}">
    <t-icon name="{{focusIndex === displayedBasicIndicators.length + customIndicators.length - 1 ? 'check' : 'chevron-down'}}" size="48rpx" color="white" />
  </view>
</view>
