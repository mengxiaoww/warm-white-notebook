/* 页面整体布局 */
.page-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 自定义导航栏 - 黄色主题 */
.navbar {
  background: linear-gradient(135deg, #FFB84D, #FFB84D);
  border-bottom: none;
  padding-top: 44px;
  padding-top: env(safe-area-inset-top);
  box-shadow: 0 2rpx 16rpx var(--primary-alpha-20);
}

.navbar-right {
  padding-right: 30rpx;
}

/* 修复导航栏样式 */
.t-navbar__placeholder {
  visibility: hidden;
}

.t-navbar {
  --td-navbar-bg-color: transparent;
}

/* 强制设置导航栏标题样式 - 使用更具体的选择器 */
.navbar .t-navbar__title,
.navbar .t-navbar__center,
.navbar .t-navbar__center text,
.navbar .t-navbar__center .t-navbar__title {
  color: white !important;
  font-size: 34rpx !important;
  font-weight: 500 !important;
}

/* 导航栏所有图标颜色 */
.navbar .t-icon,
.navbar .t-navbar__left .t-icon,
.navbar .t-navbar__right .t-icon {
  color: white !important;
}

/* 更强的选择器确保样式生效 */
.page-container .navbar .t-navbar__title {
  color: white !important;
  font-size: 34rpx !important;
  font-weight: 500 !important;
}

/* 自定义返回按钮样式 */
.custom-back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  transition: all 0.3s;
}

.custom-back-btn:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.95);
}

/* 内容区域 */
.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  height: 0;
}

/* 日期选择区域 */
.date-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 30rpx 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.9);
  margin: 20rpx 20rpx 0 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx var(--primary-alpha-10);
  border: 1rpx solid var(--primary-alpha-10);
}

.date-selector {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: rgba(255, 184, 77, 0.05);
  border-radius: 16rpx;
  border: 2rpx solid var(--primary-alpha-20);
  transition: all 0.3s;
}

.date-selector:active {
  background: var(--primary-alpha-10);
  border-color: #FFB84D;
}

.date-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.quick-input-btns {
  display: flex;
  gap: 20rpx;
}

.quick-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%);
  color: white;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx var(--primary-alpha-30);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  transition: all 0.3s;
}

.quick-btn:active {
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%);
  transform: scale(0.95);
}

.quick-btn text {
  color: white;
  font-weight: 500;
}

/* 滚动容器 */
.scroll-container {
  height: calc(100vh - 160rpx);
  width: 100%;
  background: #f5f5f5;
}

/* 表单容器 */
.form-container {
  padding: 20rpx;
  padding-bottom: 90rpx;
}

/* 血糖统计卡片 */
.blood-sugar-summary {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--primary-alpha-10);
  box-shadow: 0 4rpx 20rpx var(--primary-alpha-10);
}

.summary-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.summary-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.summary-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.summary-count {
  font-size: 28rpx;
  color: #FFB84D;
  background: var(--primary-alpha-10);
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

.summary-total {
  display: flex;
  align-items: center;
}

.total-volume {
  font-size: 26rpx;
  color: #FFB84D;
  background: var(--primary-alpha-10);
  padding: 8rpx 16rpx;
  border-radius: 14rpx;
  font-weight: 600;
  border: 1rpx solid var(--primary-alpha-20);
}

/* 统计数据区域 */
.summary-stats {
  display: flex;
  gap: 24rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 184, 77, 0.15);
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  background: white;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
  display: block;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFB84D;
  margin-bottom: 4rpx;
  display: block;
}

.stat-unit {
  font-size: 22rpx;
  color: #999;
  margin-left: 4rpx;
}

/* 血糖记录列表 */
.blood-sugar-records-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.blood-sugar-record-item {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid var(--primary-alpha-10);
}

.record-content {
  padding: 32rpx 28rpx;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.record-content::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, var(--primary-alpha-30) 50%, transparent 100%);
  z-index: 1;
}

.record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--primary-alpha-10);
}

.time-info {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.record-time {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.volume-info {
  display: flex;
  align-items: center;
}

.volume-amount {
  font-size: 32rpx;
  color: #FFB84D;
  font-weight: 700;
  background: var(--primary-alpha-10);
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--primary-alpha-20);
}

.record-details {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
  background: rgba(255, 184, 77, 0.05);
  border-radius: 12rpx;
  border: 1rpx solid var(--primary-alpha-10);
}

.detail-label {
  font-size: 24rpx;
  color: #FFB84D;
  font-weight: 600;
}

.detail-value {
  font-size: 24rpx;
  color: #555;
  font-weight: 500;
}

.notes-preview {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-bottom: 20rpx;
  padding: 16rpx;
  background: rgba(255, 184, 77, 0.05);
  border-radius: 12rpx;
  border-left: 4rpx solid #FFB84D;
}

.notes-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.5;
  flex: 1;
}

/* 临时操作按钮 */
.temp-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.temp-btn {
  flex: 1;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: white;
  transition: all 0.3s;
}

.edit-temp-btn {
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%);
  box-shadow: 0 4rpx 12rpx var(--primary-alpha-30);
}

.edit-temp-btn:active {
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%);
  transform: scale(0.96);
}

.delete-temp-btn {
  background: linear-gradient(135deg, #757575 0%, #616161 100%);
  box-shadow: 0 4rpx 12rpx rgba(117, 117, 117, 0.3);
}

.delete-temp-btn:active {
  background: linear-gradient(135deg, #616161 0%, #424242 100%);
  transform: scale(0.96);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  background: white;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-top: 24rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #ccc;
  margin-top: 12rpx;
}



/* 血糖记录弹窗样式 */
.blood-sugar-popup-content {
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
}

.blood-sugar-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 40rpx 20rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: linear-gradient(135deg, rgba(255, 184, 77, 0.05) 0%, rgba(245, 124, 0, 0.08) 100%);
}

.blood-sugar-popup-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.blood-sugar-popup-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.3s;
}

.blood-sugar-popup-close:active {
  background: #f5f5f5;
}

.blood-sugar-form-container {
  flex: 1;
  min-height: 200rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.blood-sugar-form-content {
  padding: 40rpx;
  padding-bottom: 20rpx;
}

/* 表单区块 */
.form-section {
  margin-bottom: 40rpx;
}

.section-label {
  display: block;
  font-size: 30rpx;
  color: #FFB84D;
  font-weight: 600;
  margin-bottom: 24rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid var(--primary-alpha-10);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

/* 选项卡片布局 */
.option-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.option-card {
  position: relative;
  flex: 0 0 calc(25% - 46rpx);
  padding: 20rpx 16rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.option-card:active {
  transform: scale(0.96);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.08);
}

.option-card-active {
  background: linear-gradient(135deg, rgba(255, 184, 77, 0.1) 0%, rgba(255, 184, 77, 0.05) 100%);
  border: 2rpx solid #FFB84D;
  box-shadow: 0 4rpx 12rpx rgba(212, 165, 116, 0.2);
}

.option-card-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.option-card-active .option-card-text {
  color: #FFB84D;
  font-weight: 600;
}

.option-check-icon {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
}

.form-input {
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.form-input:focus-within {
  background: white;
  border-color: #FFB84D;
  box-shadow: 0 0 0 4rpx var(--primary-alpha-10);
}

.form-textarea {
  width: 100%;
  box-sizing: border-box;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
  min-height: 120rpx;
}

.form-textarea:focus-within {
  background: white;
  border-color: #FFB84D;
  box-shadow: 0 0 0 4rpx var(--primary-alpha-10);
}

/* 选择器输入框 */
.picker-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.picker-input:active {
  background: white;
  border-color: #FFB84D;
  box-shadow: 0 0 0 4rpx var(--primary-alpha-10);
}

.picker-text {
  font-size: 28rpx;
  color: #333;
}

/* 弹窗按钮区域 */
.blood-sugar-popup-buttons {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  background: #f8f8f8;
}

.blood-sugar-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

/* 取消按钮 */
.blood-sugar-cancel-btn {
  background: linear-gradient(135deg, #f0f0f0 0%, #e6e6e6 100%);
  color: #666;
  box-shadow:
    0 8rpx 24rpx rgba(102, 102, 102, 0.2),
    0 4rpx 12rpx rgba(230, 230, 230, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.8);
  border: 2rpx solid rgba(255, 255, 255, 0.6);
}

.blood-sugar-cancel-btn:active {
  background: linear-gradient(135deg, #e6e6e6 0%, #d9d9d9 100%);
  transform: scale(0.96) translateY(2rpx);
}

/* 确认按钮 */
.blood-sugar-confirm-btn {
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%);
  color: white;
  box-shadow:
    0 8rpx 24rpx var(--primary-alpha-40),
    0 4rpx 12rpx rgba(245, 124, 0, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3);
  border: 2rpx solid rgba(255, 255, 255, 0.4);
}

.blood-sugar-confirm-btn:active {
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%);
  transform: scale(0.96) translateY(2rpx);
}

/* 自定义日期选择器样式 - 黄色主题 */
.t-date-time-picker__confirm {
  color: white !important;
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%) !important;
  border-radius: 12rpx !important;
  padding: 12rpx 24rpx !important;
  font-weight: 500 !important;
  box-shadow: 0 4rpx 12rpx var(--primary-alpha-30) !important;
  border: 2rpx solid rgba(255, 255, 255, 0.4) !important;
  transition: all 0.3s !important;
}

.t-date-time-picker__confirm:active {
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%) !important;
  transform: scale(0.96) !important;
  box-shadow: 0 2rpx 8rpx var(--primary-alpha-40) !important;
}

/* 全局覆盖所有日期选择器确定按钮样式 - 黄色主题 */
page .t-date-time-picker .t-picker__toolbar .t-button--primary,
page .t-picker .t-button--primary,
page .t-date-time-picker__confirm,
page .t-picker__confirm {
  width: 137rpx;
  height: 80rpx;
  color: #fff !important;
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%) !important;
  border-radius: 12rpx !important;
  font-weight: 500 !important;
  box-shadow: 0 4rpx 12rpx var(--primary-alpha-30) !important;
  border: 2rpx solid rgba(255, 255, 255, 0.4) !important;
  transition: all 0.3s !important;
  padding: 12rpx 24rpx !important;
}

/* 日期选择器工具栏 - 黄色主题 */
.t-picker__toolbar {
  background: linear-gradient(135deg, rgba(255, 184, 77, 0.05) 0%, rgba(245, 124, 0, 0.08) 50%, rgba(255, 255, 255, 0.95) 100%) !important;
  border-bottom: 1rpx solid var(--primary-alpha-15) !important;
  padding: 20rpx 30rpx !important;
  box-shadow: 0 2rpx 8rpx var(--primary-alpha-08) !important;
}

/* 优化日期选择器标题 - 黄色主题 */
.t-date-time-picker .t-picker__title {
  font-size: 32rpx !important;
  font-weight: 600 !important;
  color: #FFB84D !important;
  text-shadow: 0 1rpx 3rpx var(--primary-alpha-10) !important;
}

/* 日期选择器选中项 - 黄色主题 */
.t-date-time-picker .t-picker-item--selected {
  color: #FFB84D !important;
  font-weight: 500 !important;
}

/* 日期选择器取消按钮 */
.t-date-time-picker .t-picker__cancel {
  color: #666 !important;
}

/* 日期选择器容器 */
.t-date-time-picker .t-popup__content {
  border-radius: 24rpx 24rpx 0 0 !important;
}

/* 选择器弹窗样式 */
.picker-popup {
  background: white;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: linear-gradient(135deg, rgba(255, 184, 77, 0.05) 0%, rgba(245, 124, 0, 0.08) 100%);
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.picker-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.3s;
}

.picker-close:active {
  background: #f5f5f5;
}

.picker-options {
  max-height: 60vh;
  overflow-y: auto;
  padding: 20rpx;
}

.picker-option-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.picker-option-item:last-child {
  margin-bottom: 0;
}

.picker-option-item:active {
  background: var(--primary-alpha-10);
  border-color: var(--primary-alpha-30);
}

.picker-option-active {
  background: var(--primary-alpha-10) !important;
  border-color: #FFB84D !important;
}

.option-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.picker-option-active .option-text {
  color: #FFB84D;
  font-weight: 600;
}

/* 血糖记录详情弹窗样式 */
.record-detail-popup {
  background: white;
  border-radius: 20rpx;
  width: 90vw;
  max-width: 640rpx;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  margin: 0 auto;
}

.detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: linear-gradient(135deg, rgba(255, 184, 77, 0.05) 0%, rgba(245, 124, 0, 0.08) 100%);
}

.detail-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.detail-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.3s;
}

.detail-close:active {
  background: #f5f5f5;
}

.detail-content {
  flex: 1;
  padding: 0;
  overflow-y: auto;
  max-height: calc(80vh - 200rpx);
}

.detail-section {
  margin-bottom: 0;
  background: white;
}

.detail-section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: white;
  margin: 0;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%);
  box-shadow: 0 2rpx 8rpx var(--primary-alpha-20);
}

.detail-section .detail-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  min-height: 80rpx;
  background: white;
}

.detail-section .detail-item:last-child {
  border-bottom: none;
}

.detail-section .detail-label {
  font-size: 30rpx;
  color: #666;
  font-weight: 500;
  flex-shrink: 0;
  min-width: 140rpx;
}

.detail-section .detail-value {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  text-align: right;
  flex: 1;
}

.volume-highlight {
  color: #FFB84D !important;
  font-weight: 700 !important;
}

.frequency-highlight {
  color: #FFB84D !important;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.detail-text-item {
  padding: 0 !important;
  border: none !important;
  background: white !important;
  align-items: stretch !important;
  flex-direction: column !important;
}

.detail-text-value {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  padding: 24rpx 32rpx;
  background: rgba(255, 184, 77, 0.05);
  border-radius: 0;
  border-left: 4rpx solid #FFB84D;
  margin: 0;
  text-align: left;
}

.detail-buttons {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
  background: #f8f8f8;
}

.detail-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.3s;
}

.detail-close-btn {
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%);
  color: white;
  box-shadow: 0 4rpx 12rpx var(--primary-alpha-30);
  border: 2rpx solid rgba(255, 255, 255, 0.4);
}

.detail-close-btn:active {
  background: linear-gradient(135deg, #FFB84D 0%, #FFB84D 100%);
  transform: scale(0.96);
}

.detail-close-only {
  flex: 0 0 200rpx;
  margin: 0 auto;
}

/* 统一暖色主题关闭按钮 */
.milestone-close-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.08) 0%,
      rgba(255, 167, 38, 0.12) 100%);
  border: 2rpx solid rgba(255, 184, 77, 0.15);
  border-radius: 50%;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 3rpx 12rpx rgba(255, 184, 77, 0.1);
  position: relative;
}

.milestone-close-btn::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  border-radius: 50%;
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.15) 0%,
      rgba(255, 167, 38, 0.08) 100%);
  z-index: -1;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.milestone-close-btn:hover::before {
  opacity: 1;
}

.milestone-close-btn:active {
  background: linear-gradient(135deg,
      rgba(255, 184, 77, 0.15) 0%,
      rgba(255, 167, 38, 0.18) 100%);
  border-color: rgba(255, 184, 77, 0.25);
  transform: scale(0.94);
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 77, 0.2);
}

/* 浮动的下一项/完成按钮 - 固定在键盘上方右侧 */
.floating-next-btn {
  position: fixed;
  right: 40rpx;
  bottom: calc(env(safe-area-inset-bottom) + 580rpx);
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F2E 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 184, 77, 0.5);
  z-index: 99999;
  animation: bounceIn 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  animation-fill-mode: both;
  will-change: transform;
}

@keyframes bounceIn {
  0% {
    opacity: 0;
    transform: scale(0.3);
  }

  50% {
    opacity: 1;
    transform: scale(1.05);
  }

  70% {
    transform: scale(0.9);
  }

  100% {
    transform: scale(1);
  }
}

/* 血糖记录弹窗样式 */
.record-popup-content {
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
}

.record-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 40rpx 20rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: linear-gradient(135deg, rgba(255, 184, 77, 0.05) 0%, rgba(212, 165, 116, 0.08) 100%);
}

.record-popup-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.record-popup-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.3s;
}

.record-popup-close:active {
  background: #f5f5f5;
}

.record-form-container {
  flex: 1;
  min-height: 200rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.record-form-content {
  padding: 40rpx;
  padding-bottom: 20rpx;
}

/* 表单组 */
.form-group {
  margin-bottom: 32rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.required {
  color: #ff4757;
  margin-left: 4rpx;
  font-size: 28rpx;
}

/* 表单输入框包装器 */
.form-input-wrapper {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.form-input-wrapper:focus-within {
  background: white;
  border-color: #FFB84D;
  box-shadow: 0 0 0 4rpx rgba(255, 184, 77, 0.1);
}

/* 时间选择器样式 */
.time-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
}

.time-value {
  flex: 1;
  margin-left: 16rpx;
  margin-right: 16rpx;
  font-size: 28rpx;
  color: #333;
}

/* 表单输入框 */
.form-input {
  flex: 1;
  border: none;
  outline: none;
  background: transparent;
  font-size: 28rpx;
  color: #333;
}

.input-unit {
  margin-left: 12rpx;
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
}

/* 文本域 */
.form-textarea {
  width: 100%;
  box-sizing: border-box;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-textarea:focus {
  background: white;
  border-color: #FFB84D;
  box-shadow: 0 0 0 4rpx rgba(255, 184, 77, 0.1);
}

/* 弹窗操作按钮区域 */
.record-form-actions {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  background: #f8f8f8;
  border-top: 1rpx solid #f0f0f0;
}

.cancel-btn,
.save-btn {
  flex: 1;
  height: 88rpx !important;
  border-radius: 16rpx !important;
  font-size: 30rpx !important;
  font-weight: 600 !important;
}

/* 覆盖TDesign按钮默认样式 */
.cancel-btn {
  --td-button-default-bg-color: white !important;
  --td-button-default-border-color: #e0e0e0 !important;
  --td-button-default-color: #666 !important;
}

.save-btn {
  --td-button-primary-bg-color: #FFB84D !important;
  --td-button-primary-border-color: #FFB84D !important;
  --td-button-primary-color: white !important;
}

/* 统计区域样式优化 */
.stat-value.high {
  color: #ff4757;
}

.stat-value.low {
  color: #26de81;
}

/* 值徽章样式 */
.value-badge {
  display: flex;
  align-items: baseline;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, rgba(255, 184, 77, 0.1) 0%, rgba(255, 184, 77, 0.05) 100%);
  border-radius: 12rpx;
}

.main-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFB84D;
  margin-right: 4rpx;
}

.unit {
  font-size: 24rpx;
  color: #999;
}
