.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FDFCFA 0%, #FAF8F4 50%, #F7F4EF 100%);
  padding: 24rpx;
  padding-bottom: 140rpx;
}

/* 日期选择区域 */
.date-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(212, 165, 116, 0.08);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.date-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.date-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 32rpx;
  color: #D4A574;
  font-weight: 600;
}

/* 指标区域 */
.indicators-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(212, 165, 116, 0.08);
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 28rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid rgba(212, 165, 116, 0.1);
}

/* 指标项 */
.indicator-item {
  margin-bottom: 32rpx;
}

.indicator-item:last-child {
  margin-bottom: 0;
}

.indicator-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.indicator-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.indicator-unit {
  font-size: 24rpx;
  color: #999;
}

.indicator-input {
  margin-bottom: 12rpx;
}

.indicator-range {
  padding-left: 8rpx;
}

.indicator-range text {
  font-size: 24rpx;
  color: #8c6d46;
  opacity: 0.8;
}

/* 操作区域 */
.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: linear-gradient(to top, #FDFCFA, rgba(253, 252, 250, 0.95));
  box-shadow: 0 -2rpx 8rpx rgba(212, 165, 116, 0.08);
}

.action-section t-button {
  background: linear-gradient(135deg, #D4A574 0%, #C4956F 100%);
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(212, 165, 116, 0.3);
}
