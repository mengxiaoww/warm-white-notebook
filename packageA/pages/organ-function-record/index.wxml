<view class="page-container">
  <!-- 导航栏 -->
  <t-navbar title="肝肾功能" left-arrow bind:go-back="goBack" />

  <!-- 页面内容 -->
  <view class="content-container">
    <!-- 今日统计 -->
    <view class="today-stats">
      <view class="stats-header">
        <view class="stats-title">今日检测</view>
        <view class="stats-count">{{todayStats.count}}次</view>
      </view>
      
      <view class="stats-details" wx:if="{{todayStats.count > 0}}">
        <view class="stats-item">
          <text class="stats-label">状态：</text>
          <view class="stats-status {{todayStats.hasAbnormal ? 'status-warning' : 'status-normal'}}">
            <view class="status-indicator"></view>
            <text class="status-text">{{todayStats.hasAbnormal ? '有异常' : '正常'}}</text>
          </view>
        </view>
        
        <view class="stats-item" wx:if="{{todayStats.hasAbnormal}}">
          <text class="stats-label">异常：</text>
          <text class="abnormal-info">{{todayStats.abnormalInfo}}</text>
        </view>
      </view>
    </view>

    <!-- 记录列表 -->
    <view class="records-section">
      <view class="section-header">
        <text class="section-title">检测记录</text>
      </view>
      
      <view class="records-list" wx:if="{{records.length > 0}}">
        <view class="record-item {{item.hasAbnormal ? 'record-abnormal' : ''}}" 
              wx:for="{{records}}" 
              wx:key="_id"
              bindtap="showDetail"
              data-id="{{item._id}}">
          
          <view class="record-header">
            <view class="record-date-time">
              <text class="record-date">{{item.displayDate}}</text>
              <text class="record-time">{{item.time}}</text>
            </view>
            <view class="record-status {{item.hasAbnormal ? 'status-warning' : 'status-normal'}}">
              <view class="status-indicator-small"></view>
              <text class="status-text">{{item.hasAbnormal ? '异常' : '正常'}}</text>
            </view>
          </view>

          <view class="record-content">
            <!-- 简化显示：只显示关键指标 -->
            <view class="function-summary">
              <!-- 肝功能 -->
              <view class="function-group" wx:if="{{item.alt || item.ast}}">
                <text class="group-label">肝功能：</text>
                <view class="function-values">
                  <view class="function-value {{item.alt > 50 ? 'value-abnormal' : 'value-normal'}}" wx:if="{{item.alt}}">
                    ALT {{item.alt}}
                  </view>
                  <view class="function-value {{item.ast > 40 ? 'value-abnormal' : 'value-normal'}}" wx:if="{{item.ast}}">
                    AST {{item.ast}}
                  </view>
                </view>
              </view>
              
              <!-- 肾功能 -->
              <view class="function-group" wx:if="{{item.creatinine || item.gfr}}">
                <text class="group-label">肾功能：</text>
                <view class="function-values">
                  <view class="function-value {{item.creatinine > 104 ? 'value-abnormal' : 'value-normal'}}" wx:if="{{item.creatinine}}">
                    肌酐 {{item.creatinine}}
                  </view>
                  <view class="function-value {{item.gfr < 90 ? 'value-abnormal' : 'value-normal'}}" wx:if="{{item.gfr}}">
                    GFR {{item.gfr}}
                  </view>
                </view>
              </view>
            </view>

            <view class="record-extra" wx:if="{{item.hospital || item.notesPreview}}">
              <text class="extra-info" wx:if="{{item.hospital}}">医院：{{item.hospital}}</text>
              <text class="extra-info" wx:if="{{item.notesPreview}}">备注：{{item.notesPreview}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{records.length === 0}}">
        <medical-icon name="liver" size="120" color="#ddd" />
        <text class="empty-text">暂无肝肾功能记录</text>
        <text class="empty-hint">点击下方按钮添加检测结果</text>
      </view>
    </view>
  </view>

  <!-- 添加按钮 -->
  <view class="add-button-container">
    <t-button theme="primary" size="large" icon="add" bind:tap="showAddDialog">
      添加检测记录
    </t-button>
  </view>
</view>

<!-- 添加/编辑记录弹窗 -->
<t-popup visible="{{showAddPopup}}" bind:visible-change="closeAddDialog" placement="bottom" show-overlay="{{true}}">
  <view class="organ-popup-content">
    <view class="organ-popup-header">
      <text class="organ-popup-title">{{isEditing ? '编辑' : '添加'}}肝肾功能记录</text>
      <view class="organ-popup-close" bindtap="closeAddDialog">
        <t-icon name="close" size="32rpx" color="#666" />
      </view>
    </view>

    <scroll-view class="organ-form-container" scroll-y="true" enhanced="true" show-scrollbar="false">
      <view class="organ-form-content">
        <!-- 基本信息 -->
        <view class="form-section">
          <text class="section-label">基本信息</text>
          
          <view class="form-item">
            <text class="form-label">检测日期</text>
            <view class="picker-input" bindtap="showDateSelector">
              <text class="picker-text">{{formData.date || '请选择日期'}}</text>
              <t-icon name="chevron-right" size="32rpx" color="#999" />
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">检测时间</text>
            <view class="picker-input" bindtap="showTimeSelector">
              <text class="picker-text">{{formData.time || '请选择时间'}}</text>
              <t-icon name="chevron-right" size="32rpx" color="#999" />
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">检测类型</text>
            <view class="picker-input" bindtap="showTestTypeSelector">
              <text class="picker-text">{{formData.testType || '请选择检测类型'}}</text>
              <t-icon name="chevron-right" size="32rpx" color="#999" />
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">检测医院</text>
            <t-input 
              value="{{formData.hospital}}" 
              placeholder="请输入检测医院"
              bind:change="onHospitalInput"
              class="form-input" />
          </view>
        </view>

        <!-- 肝功能指标 -->
        <view class="form-section" wx:if="{{showLiverFunction}}">
          <text class="section-label">肝功能指标</text>
          
          <view class="form-item">
            <text class="form-label">ALT 丙氨酸转氨酶</text>
            <view class="input-with-unit">
              <t-input 
                value="{{formData.alt}}" 
                placeholder="正常范围：9-50 U/L"
                type="number"
                bind:change="onAltInput"
                class="form-input" />
              <text class="input-unit">U/L</text>
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">AST 天门冬氨酸转氨酶</text>
            <view class="input-with-unit">
              <t-input 
                value="{{formData.ast}}" 
                placeholder="正常范围：15-40 U/L"
                type="number"
                bind:change="onAstInput"
                class="form-input" />
              <text class="input-unit">U/L</text>
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">总胆红素</text>
            <view class="input-with-unit">
              <t-input 
                value="{{formData.bilirubin}}" 
                placeholder="正常范围：5.1-17.1 μmol/L"
                type="number"
                bind:change="onBilirubinInput"
                class="form-input" />
              <text class="input-unit">μmol/L</text>
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">白蛋白</text>
            <view class="input-with-unit">
              <t-input 
                value="{{formData.albumin}}" 
                placeholder="正常范围：35-50 g/L"
                type="number"
                bind:change="onAlbuminInput"
                class="form-input" />
              <text class="input-unit">g/L</text>
            </view>
          </view>
        </view>

        <!-- 肾功能指标 -->
        <view class="form-section" wx:if="{{showKidneyFunction}}">
          <text class="section-label">肾功能指标</text>
          
          <view class="form-item">
            <text class="form-label">肌酐</text>
            <view class="input-with-unit">
              <t-input 
                value="{{formData.creatinine}}" 
                placeholder="正常范围：59-104 μmol/L"
                type="number"
                bind:change="onCreatinineInput"
                class="form-input" />
              <text class="input-unit">μmol/L</text>
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">尿素</text>
            <view class="input-with-unit">
              <t-input 
                value="{{formData.urea}}" 
                placeholder="正常范围：3.1-8.2 mmol/L"
                type="number"
                bind:change="onUreaInput"
                class="form-input" />
              <text class="input-unit">mmol/L</text>
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">肾小球滤过率 (GFR)</text>
            <view class="input-with-unit">
              <t-input 
                value="{{formData.gfr}}" 
                placeholder="正常范围：>90 ml/min/1.73m²"
                type="number"
                bind:change="onGfrInput"
                class="form-input" />
              <text class="input-unit">ml/min/1.73m²</text>
            </view>
          </view>
        </view>

        <!-- 提示信息 -->
        <view class="form-section" wx:if="{{!showLiverFunction && !showKidneyFunction}}">
          <view class="type-hint">
            <t-icon name="info-circle" size="48rpx" color="#4CAF50" />
            <text class="hint-text">请先选择检测类型，然后填写相应的指标数值</text>
          </view>
        </view>

        <!-- 备注信息 -->
        <view class="form-section">
          <text class="section-label">备注信息</text>
          
          <view class="form-item">
            <text class="form-label">备注</text>
            <t-textarea
              value="{{formData.notes}}"
              placeholder="请输入备注信息（可选）"
              bind:change="onNotesInput"
              maxlength="200"
              class="form-textarea" />
          </view>
        </view>
      </view>
    </scroll-view>

    <!-- 按钮区域 -->
    <view class="organ-popup-buttons">
      <view class="organ-btn organ-cancel-btn" bindtap="closeAddDialog">取消</view>
      <view class="organ-btn organ-confirm-btn" bindtap="saveRecord">{{isEditing ? '更新' : '保存'}}</view>
    </view>
  </view>
</t-popup>

<!-- 详情弹窗 -->
<t-popup visible="{{showDetailPopup}}" bind:visible-change="closeDetailDialog" placement="center" show-overlay="{{true}}">
  <view class="record-detail-popup" wx:if="{{selectedRecord}}">
    <view class="detail-header">
      <text class="detail-title">肝肾功能详情</text>
      <view class="detail-close" bindtap="closeDetailDialog">
        <t-icon name="close" size="32rpx" color="#666" />
      </view>
    </view>

    <scroll-view class="detail-content" scroll-y="true" enhanced="true" show-scrollbar="false" style="padding: 32rpx;">
      <!-- 基本信息 -->
      <view class="detail-section">
        <view class="detail-section-title">
          <t-icon name="time" size="32rpx" color="white" />
          基本信息
        </view>
        
        <view class="detail-item">
          <text class="detail-label">检测时间</text>
          <text class="detail-value">{{selectedRecord.time}}</text>
        </view>
        
        <view class="detail-item" wx:if="{{selectedRecord.testType}}">
          <text class="detail-label">检测类型</text>
          <text class="detail-value">{{selectedRecord.testType}}</text>
        </view>
        
        <view class="detail-item" wx:if="{{selectedRecord.hospital}}">
          <text class="detail-label">检测医院</text>
          <text class="detail-value">{{selectedRecord.hospital}}</text>
        </view>
      </view>

      <!-- 肝功能指标 -->
      <view class="detail-section" wx:if="{{selectedRecord.alt || selectedRecord.ast || selectedRecord.bilirubin || selectedRecord.albumin}}">
        <view class="detail-section-title">
          <medical-icon name="liver" size="32" color="white" />
          肝功能指标
        </view>
        
        <view class="detail-item" wx:if="{{selectedRecord.alt}}">
          <text class="detail-label">ALT 丙氨酸转氨酶</text>
          <text class="detail-value result-highlight {{selectedRecord.alt > 50 ? 'result-abnormal' : 'result-normal'}}">
            {{selectedRecord.alt}} U/L
          </text>
        </view>
        
        <view class="detail-item" wx:if="{{selectedRecord.ast}}">
          <text class="detail-label">AST 天门冬氨酸转氨酶</text>
          <text class="detail-value result-highlight {{selectedRecord.ast > 40 ? 'result-abnormal' : 'result-normal'}}">
            {{selectedRecord.ast}} U/L
          </text>
        </view>
        
        <view class="detail-item" wx:if="{{selectedRecord.bilirubin}}">
          <text class="detail-label">总胆红素</text>
          <text class="detail-value result-highlight {{selectedRecord.bilirubin > 17 ? 'result-abnormal' : 'result-normal'}}">
            {{selectedRecord.bilirubin}} μmol/L
          </text>
        </view>
        
        <view class="detail-item" wx:if="{{selectedRecord.albumin}}">
          <text class="detail-label">白蛋白</text>
          <text class="detail-value result-highlight {{selectedRecord.albumin < 35 ? 'result-abnormal' : 'result-normal'}}">
            {{selectedRecord.albumin}} g/L
          </text>
        </view>
      </view>

      <!-- 肾功能指标 -->
      <view class="detail-section" wx:if="{{selectedRecord.creatinine || selectedRecord.urea || selectedRecord.gfr}}">
        <view class="detail-section-title">
          <t-icon name="filter" size="32rpx" color="white" />
          肾功能指标
        </view>
        
        <view class="detail-item" wx:if="{{selectedRecord.creatinine}}">
          <text class="detail-label">肌酐</text>
          <text class="detail-value result-highlight {{selectedRecord.creatinine > 104 ? 'result-abnormal' : 'result-normal'}}">
            {{selectedRecord.creatinine}} μmol/L
          </text>
        </view>
        
        <view class="detail-item" wx:if="{{selectedRecord.urea}}">
          <text class="detail-label">尿素</text>
          <text class="detail-value result-highlight {{selectedRecord.urea > 8.2 ? 'result-abnormal' : 'result-normal'}}">
            {{selectedRecord.urea}} mmol/L
          </text>
        </view>
        
        <view class="detail-item" wx:if="{{selectedRecord.gfr}}">
          <text class="detail-label">肾小球滤过率 (GFR)</text>
          <text class="detail-value result-highlight {{selectedRecord.gfr < 90 ? 'result-abnormal' : 'result-normal'}}">
            {{selectedRecord.gfr}} ml/min/1.73m²
          </text>
        </view>
      </view>

      <!-- 备注信息 -->
      <view class="detail-section" wx:if="{{selectedRecord.notes}}">
        <view class="detail-section-title">
          <t-icon name="chat" size="32rpx" color="white" />
          备注信息
        </view>
        
        <view class="detail-item detail-text-item">
          <view class="detail-text-value">{{selectedRecord.notes}}</view>
        </view>
      </view>
    </scroll-view>

    <!-- 操作按钮 -->
    <view class="detail-buttons">
      <view class="detail-btn detail-edit-btn" bindtap="editRecord" data-id="{{selectedRecord._id}}">编辑</view>
      <view class="detail-btn detail-delete-btn" bindtap="deleteRecord" data-id="{{selectedRecord._id}}">删除</view>
      <view class="milestone-close-btn" bindtap="closeDetailDialog">
        <t-icon name="close" size="28rpx" />
      </view>
    </view>
  </view>
</t-popup>

<!-- 日期选择器 -->
<t-date-time-picker
  visible="{{showDatePicker}}"
  mode="date"
  title="选择日期"
  value="{{formData.date}}"
  bind:confirm="onDateConfirm"
  bind:cancel="onDateCancel" />

<!-- 时间选择器 -->
<t-date-time-picker
  visible="{{showTimePicker}}"
  mode="time"
  title="选择时间"
  value="{{formData.time}}"
  bind:confirm="onTimeConfirm"
  bind:cancel="onTimeCancel" />

<!-- 检测类型选择器 -->
<t-popup visible="{{showTestTypePicker}}" bind:visible-change="closeTestTypePicker" placement="bottom">
  <view class="picker-popup">
    <view class="picker-header">
      <text class="picker-title">选择检测类型</text>
      <view class="picker-close" bindtap="closeTestTypePicker">
        <t-icon name="close" size="32rpx" color="#666" />
      </view>
    </view>
    <scroll-view class="picker-options" scroll-y="true">
      <view class="picker-option-item {{item.value === currentTestType ? 'picker-option-active' : ''}}"
            wx:for="{{testTypeOptions}}" 
            wx:key="value"
            bindtap="selectTestType"
            data-value="{{item.value}}">
        <text class="option-text">{{item.label}}</text>
        <t-icon name="check" size="32rpx" color="#4CAF50" wx:if="{{item.value === currentTestType}}" />
      </view>
    </scroll-view>
  </view>
</t-popup>