/* pages/organ-function-record/index.wxss */
.page-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 自定义导航栏 - 绿色主题 */
page {
  --td-navbar-bg-color: linear-gradient(135deg, #4CAF50, #388E3C);
  --td-navbar-title-color: white;
  --td-navbar-title-font-size: 34rpx;
  --td-navbar-title-font-weight: 500;
}

.t-navbar {
  background: linear-gradient(135deg, #4CAF50, #388E3C) !important;
  border-bottom: none !important;
  box-shadow: 0 2rpx 16rpx rgba(76, 175, 80, 0.2) !important;
  --td-navbar-bg-color: linear-gradient(135deg, #4CAF50, #388E3C);
  --td-navbar-title-color: white;
  --td-navbar-title-font-size: 34rpx;
  --td-navbar-title-font-weight: 500;
}

/* 强制设置导航栏标题样式 */
.t-navbar__title,
.t-navbar__center,
.t-navbar__center text {
  color: white !important;
  font-size: 34rpx !important;
  font-weight: 500 !important;
}

/* 导航栏所有图标颜色 */
.t-navbar .t-icon,
.t-navbar__left .t-icon,
.t-navbar__right .t-icon {
  color: white !important;
}

.content-container {
  flex: 1;
  padding: 20rpx;
  padding-top: 40rpx;
  overflow-y: auto;
  padding-bottom: 160rpx;
}

/* 今日统计 */
.today-stats {
  background: linear-gradient(135deg, #4CAF50 0%, #C8E6C9 100%);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(76, 175, 80, 0.25);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  position: relative;
  overflow: hidden;
}

.today-stats::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 255, 255, 0.8) 50%, 
    transparent 100%
  );
  border-radius: 20rpx 20rpx 0 0;
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.stats-title {
  color: white;
  font-size: 34rpx;
  font-weight: 600;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.stats-count {
  color: white;
  font-size: 28rpx;
  font-weight: 500;
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.stats-details {
  margin-top: 16rpx;
}

.stats-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.stats-item:last-child {
  margin-bottom: 0;
}

.stats-label {
  color: rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
  margin-right: 12rpx;
}

.stats-status {
  display: flex;
  align-items: center;
}

.status-indicator {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.status-normal .status-indicator {
  background-color: #81C784;
}

.status-warning .status-indicator {
  background-color: #FF5722;
}

.status-text {
  color: white;
  font-size: 24rpx;
}

.abnormal-info {
  color: #FFEB3B;
  font-size: 24rpx;
  font-weight: 500;
  background: rgba(255, 235, 59, 0.2);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 235, 59, 0.3);
}

/* 记录列表 */
.records-section {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(76, 175, 80, 0.1);
}

.section-header {
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.05) 0%, rgba(200, 230, 201, 0.15) 100%);
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(76, 175, 80, 0.1);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.records-list {
  background: white;
}

.record-item {
  padding: 32rpx;
  border-bottom: 1rpx solid #f8f8f8;
  transition: all 0.3s ease;
  position: relative;
}

.record-item:last-child {
  border-bottom: none;
}

.record-item:active {
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.02) 0%, rgba(200, 230, 201, 0.08) 100%);
  transform: scale(0.99);
}

.record-abnormal {
  border-left: 6rpx solid #FF5722;
  background: linear-gradient(90deg, rgba(255, 87, 34, 0.05) 0%, rgba(255, 87, 34, 0) 20%);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.record-date-time {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.record-date {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.record-time {
  font-size: 24rpx;
  color: #666;
  background: rgba(76, 175, 80, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.record-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
  border: 1rpx solid;
}

.status-normal {
  background: rgba(76, 175, 80, 0.1);
  border-color: rgba(76, 175, 80, 0.3);
}

.status-warning {
  background: rgba(255, 87, 34, 0.1);
  border-color: rgba(255, 87, 34, 0.3);
}

.status-indicator-small {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.status-normal .status-indicator-small {
  background-color: #4CAF50;
}

.status-warning .status-indicator-small {
  background-color: #FF5722;
}

.status-normal .status-text {
  color: #4CAF50;
  font-weight: 500;
}

.status-warning .status-text {
  color: #FF5722;
  font-weight: 500;
}

.record-content {
  margin-top: 16rpx;
}

/* 新的简化功能展示样式 */
.function-summary {
  margin-bottom: 16rpx;
}

.function-group {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
  gap: 8rpx;
}

.function-group:last-child {
  margin-bottom: 0;
}

.group-label {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.function-values {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.function-value {
  font-size: 24rpx;
  font-weight: 500;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid;
  white-space: nowrap;
}

.value-normal {
  color: #4CAF50;
  background: rgba(76, 175, 80, 0.1);
  border-color: rgba(76, 175, 80, 0.3);
}

.value-abnormal {
  color: #FF5722;
  background: rgba(255, 87, 34, 0.1);
  border-color: rgba(255, 87, 34, 0.3);
}

.record-extra {
  margin-top: 12rpx;
  background: rgba(76, 175, 80, 0.02);
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(76, 175, 80, 0.08);
}

.extra-info {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.extra-info:last-child {
  margin-bottom: 0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.02) 0%, rgba(200, 230, 201, 0.08) 100%);
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin: 32rpx 0 16rpx;
  font-weight: 500;
}

.empty-hint {
  display: block;
  font-size: 24rpx;
  color: #ccc;
}

/* 添加按钮 */
.add-button-container {
  position: fixed;
  bottom: 80rpx;
  left: 40rpx;
  right: 40rpx;
  z-index: 100;
}

.add-button-container .t-button {
  height: 92rpx !important;
  font-size: 30rpx !important;
  font-weight: 500 !important;
  background: linear-gradient(135deg, #4CAF50 0%, #388E3C 100%) !important;
  box-shadow: 
    0 8rpx 24rpx rgba(76, 175, 80, 0.4),
    0 4rpx 12rpx rgba(56, 142, 60, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3) !important;
  border: 2rpx solid rgba(255, 255, 255, 0.4) !important;
  border-radius: 12rpx !important;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
  position: relative !important;
  overflow: hidden !important;
  color: white !important;
}

.add-button-container .t-button::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 255, 255, 0.8) 50%, 
    transparent 100%
  );
  border-radius: 12rpx 12rpx 0 0;
}

.add-button-container .t-button:active {
  background: linear-gradient(135deg, #388E3C 0%, #2E7D32 100%) !important;
  transform: scale(0.96) translateY(2rpx) !important;
  box-shadow: 
    0 4rpx 12rpx rgba(76, 175, 80, 0.5),
    0 2rpx 6rpx rgba(56, 142, 60, 0.4),
    inset 0 3rpx 6rpx rgba(255, 255, 255, 0.2) !important;
}

/* 弹窗样式 */
.organ-popup-content {
  background: white;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -8rpx 32rpx rgba(76, 175, 80, 0.15);
}

.organ-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(76, 175, 80, 0.1);
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.05) 0%, rgba(200, 230, 201, 0.15) 100%);
}

.organ-popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #4CAF50;
}

.organ-popup-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.3s;
}

.organ-popup-close:active {
  background: rgba(76, 175, 80, 0.1);
  transform: scale(0.95);
}

.organ-form-container {
  flex: 1;
  max-height: calc(85vh - 200rpx);
  overflow-y: auto;
}

.organ-form-content {
  padding: 24rpx 32rpx;
}

.form-section {
  margin-bottom: 40rpx;
}

.section-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #4CAF50;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.picker-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 20rpx;
  background: #fafafa;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.picker-input:active {
  background: rgba(76, 175, 80, 0.05);
  border-color: #4CAF50;
}

.picker-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.picker-text[class*="placeholder"] {
  color: #999;
}

.input-with-unit {
  display: flex;
  align-items: center;
  background: #fafafa;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  overflow: hidden;
  transition: all 0.3s ease;
}

.input-with-unit:focus-within {
  border-color: #4CAF50;
  background: rgba(76, 175, 80, 0.05);
}

.input-with-unit .form-input {
  flex: 1;
  border: none !important;
  background: transparent !important;
  padding: 24rpx 20rpx !important;
}

.input-unit {
  font-size: 24rpx;
  color: #666;
  padding: 0 20rpx;
  border-left: 1rpx solid #e8e8e8;
  background: rgba(76, 175, 80, 0.05);
  white-space: nowrap;
}

.form-input {
  width: 100% !important;
  padding: 24rpx 20rpx !important;
  background: #fafafa !important;
  border: 2rpx solid #e8e8e8 !important;
  border-radius: 12rpx !important;
  font-size: 28rpx !important;
  transition: all 0.3s ease !important;
}

.form-input:focus {
  border-color: #4CAF50 !important;
  background: rgba(76, 175, 80, 0.05) !important;
}

.form-textarea {
  width: 100% !important;
  min-height: 120rpx !important;
  padding: 20rpx !important;
  background: #fafafa !important;
  border: 2rpx solid #e8e8e8 !important;
  border-radius: 12rpx !important;
  font-size: 28rpx !important;
  resize: none !important;
  transition: all 0.3s ease !important;
}

.form-textarea:focus {
  border-color: #4CAF50 !important;
  background: rgba(76, 175, 80, 0.05) !important;
}

.type-hint {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: rgba(76, 175, 80, 0.05);
  border-radius: 12rpx;
  border: 1rpx solid rgba(76, 175, 80, 0.2);
}

.hint-text {
  font-size: 26rpx;
  color: #4CAF50;
  margin-left: 16rpx;
  line-height: 1.4;
}

.organ-popup-buttons {
  display: flex;
  padding: 24rpx 32rpx;
  gap: 16rpx;
  border-top: 1rpx solid rgba(76, 175, 80, 0.1);
  background: rgba(76, 175, 80, 0.02);
}

.organ-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.organ-cancel-btn {
  background: #f5f5f5;
  color: #666;
  border: 2rpx solid #e8e8e8;
}

.organ-cancel-btn:active {
  background: #eeeeee;
  transform: scale(0.98);
}

.organ-confirm-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #388E3C 100%);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.organ-confirm-btn:active {
  background: linear-gradient(135deg, #388E3C 0%, #2E7D32 100%);
  transform: scale(0.98);
  box-shadow: 0 2rpx 6rpx rgba(76, 175, 80, 0.4);
}

/* 详情弹窗样式 */
.record-detail-popup {
  background: white;
  border-radius: 24rpx;
  width: 96vw;
  max-width: 800rpx;
  max-height: 85vh;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  box-shadow: 
    0 24rpx 80rpx rgba(76, 175, 80, 0.25),
    0 8rpx 32rpx rgba(0, 0, 0, 0.1),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.8);
  overflow: hidden;
  position: relative;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 32rpx;
  border-bottom: 1rpx solid rgba(76, 175, 80, 0.15);
  background: linear-gradient(135deg, #4CAF50 0%, #C8E6C9 100%);
  position: relative;
  color: white;
}

.detail-header::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 255, 255, 0.8) 50%, 
    transparent 100%
  );
  border-radius: 24rpx 24rpx 0 0;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: white;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.detail-title::before {
  content: '🫀';
  font-size: 32rpx;
}

.detail-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  backdrop-filter: blur(10rpx);
}

.detail-close .t-icon {
  color: white !important;
}

.detail-close:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.95) rotate(90deg);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.detail-content {
  flex: 1;
  width: auto;
  max-height: calc(85vh - 350rpx);
  padding: 0;
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.02) 0%, rgba(255, 255, 255, 0.98) 50%, rgba(200, 230, 201, 0.05) 100%);
}

.detail-section {
  margin-bottom: 32rpx;
  background: rgba(76, 175, 80, 0.02);
  border-radius: 16rpx;
  border: 1rpx solid rgba(76, 175, 80, 0.1);
  overflow: hidden;
}

.detail-section:last-child {
  margin-bottom: 0;
}

.detail-section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #388E3C 100%);
  color: white;
  font-size: 26rpx;
  font-weight: 600;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid rgba(76, 175, 80, 0.05);
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.detail-value {
  font-size: 26rpx;
  color: #333;
  text-align: right;
  flex: 1;
  word-break: break-all;
}

.result-highlight {
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  border: 1rpx solid;
}

.result-normal {
  color: #4CAF50;
  background: rgba(76, 175, 80, 0.1);
  border-color: rgba(76, 175, 80, 0.3);
}

.result-abnormal {
  color: #FF5722;
  background: rgba(255, 87, 34, 0.1);
  border-color: rgba(255, 87, 34, 0.3);
}

.detail-text-item {
  flex-direction: column;
  align-items: stretch;
}

.detail-text-value {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  word-break: break-all;
  margin-top: 8rpx;
}

.detail-buttons {
  display: flex;
  padding: 24rpx;
  gap: 16rpx;
  border-top: 1rpx solid rgba(76, 175, 80, 0.1);
  background: rgba(76, 175, 80, 0.02);
}

.detail-btn {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.detail-edit-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #388E3C 100%);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.detail-edit-btn:active {
  background: linear-gradient(135deg, #388E3C 0%, #2E7D32 100%);
  transform: scale(0.98);
}

.detail-delete-btn {
  background: linear-gradient(135deg, #FF5722 0%, #D32F2F 100%);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.detail-delete-btn:active {
  background: linear-gradient(135deg, #D32F2F 0%, #B71C1C 100%);
  transform: scale(0.98);
}

.detail-close-btn {
  background: #f5f5f5;
  color: #666;
  border: 2rpx solid #e8e8e8;
}

.detail-close-btn:active {
  background: #eeeeee;
  transform: scale(0.98);
}

/* 选择器弹窗样式 */
.picker-popup {
  background: white;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 60vh;
  display: flex;
  flex-direction: column;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(76, 175, 80, 0.1);
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.05) 0%, rgba(200, 230, 201, 0.15) 100%);
}

.picker-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #4CAF50;
}

.picker-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.3s;
}

.picker-close:active {
  background: rgba(76, 175, 80, 0.1);
  transform: scale(0.95);
}

.picker-options {
  flex: 1;
  padding: 16rpx 0;
  overflow-y: auto;
}

.picker-option-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  transition: all 0.3s ease;
  border-bottom: 1rpx solid #f8f8f8;
}

.picker-option-item:last-child {
  border-bottom: none;
}

.picker-option-item:active {
  background: rgba(76, 175, 80, 0.05);
}

.picker-option-active {
  background: rgba(76, 175, 80, 0.1) !important;
}

.option-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.picker-option-active .option-text {
  color: #4CAF50;
  font-weight: 600;
}

/* 统一暖色主题关闭按钮 */
.milestone-close-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, 
    rgba(255, 184, 77, 0.08) 0%, 
    rgba(255, 167, 38, 0.12) 100%
  );
  border: 2rpx solid rgba(255, 184, 77, 0.15);
  border-radius: 50%;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 3rpx 12rpx rgba(255, 184, 77, 0.1);
  position: relative;
}

.milestone-close-btn::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, 
    rgba(255, 184, 77, 0.15) 0%, 
    rgba(255, 167, 38, 0.08) 100%
  );
  z-index: -1;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.milestone-close-btn:hover::before {
  opacity: 1;
}

.milestone-close-btn:active {
  background: linear-gradient(135deg, 
    rgba(255, 184, 77, 0.15) 0%, 
    rgba(255, 167, 38, 0.18) 100%
  );
  border-color: rgba(255, 184, 77, 0.25);
  transform: scale(0.94);
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 77, 0.2);
}