<view class="page-container">
  <!-- 自定义导航栏 -->
  <t-navbar title="配置录入项" class="navbar" style="--td-navbar-title-color: white; --td-navbar-title-font-size: 34rpx; --td-navbar-title-font-weight: 500;">
    <view slot="left" class="custom-back-btn" bindtap="goBack">
      <t-icon name="chevron-left" size="48rpx" color="white" />
    </view>
  </t-navbar>
  <!-- 内容区域 -->
  <view class="content">
    <!-- 提示文字 -->
    <view class="tips">
      <text>提示：前1项为必选核心指标，其他项目可自由配置</text>
    </view>
    <!-- 当前编辑日期提示 -->
    <view class="date-status-tips">
      <view class="date-status-header">
        <view class="date-text-wrapper">
          <t-icon name="calendar" size="32rpx" color="#FFB84D" />
          <text class="date-text">正在配置：{{editingDate || '未指定日期'}}</text>
        </view>
        <view class="date-type-badge {{dateType}}">
          <text wx:if="{{dateType === 'today'}}">今日</text>
          <text wx:elif="{{dateType === 'past'}}">历史</text>
          <text wx:elif="{{dateType === 'future'}}">未来</text>
        </view>
      </view>
      <view class="data-hint">
        <view wx:if="{{dateType === 'today'}}" class="hint-item">
          <t-icon name="lightbulb" size="28rpx" color="#FFB84D" />
          <text>今日修改将对未来所有日期生效，让您无需重复配置</text>
        </view>
        <view wx:elif="{{dateType === 'past'}}" class="hint-item">
          <t-icon name="lock-on" size="28rpx" color="#999" />
          <text>历史日期修改仅对{{editingDate}}生效，不影响其他日期</text>
        </view>
        <view wx:elif="{{dateType === 'future'}}" class="hint-item">
          <t-icon name="play-circle" size="28rpx" color="#1890ff" />
          <text>未来日期修改仅对{{editingDate}}生效</text>
        </view>
        <text wx:else>每个日期的配置项是独立的</text>
      </view>
      <!-- 配置继承提示 -->
      <view class="inherit-hint" wx:if="{{configInheritInfo.isInherited}}">
        <t-icon name="info-circle" size="28rpx" color="#1890ff" />
        <text class="inherit-text">当前配置继承自 {{configInheritInfo.inheritedFrom}}</text>
      </view>
    </view>
    <!-- 指标列表 -->
    <scroll-view scroll-y="{{true}}" class="scroll-container" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="indicators-container">
        <!-- 预设指标组 -->
        <view class="indicator-group">
          <!-- HCMV-DNA (必选) -->
          <view class="indicator-item required-item">
            <t-checkbox checked="{{selectedIndicators.hcmvDna}}" class="custom-checkbox required-checkbox" disabled="{{true}}" />
            <view class="indicator-info">
              <view class="indicator-name">HCMV</view>
              <view class="indicator-text">
                <text class="indicator-fullname">{{indicatorConfigs.hcmvDna.name}}</text>
                <text class="required-tag">必选</text>
              </view>
            </view>
          </view>
          <!-- 更多预设指标 -->
          <view class="indicator-item">
            <view class="checkbox-area" bindtap="toggleIndicator" data-id="pp65" data-type="preset">
              <t-checkbox checked="{{selectedIndicators.pp65}}" class="custom-checkbox" />
            </view>
            <view class="indicator-content" bindtap="editIndicator" data-id="pp65">
              <view class="indicator-info">
                <view class="indicator-name">P</view>
                <text class="indicator-fullname">{{indicatorConfigs.pp65.name}}</text>
              </view>
              <t-icon name="chevron-right" size="32rpx" color="#999" />
            </view>
          </view>
          <view class="indicator-item">
            <view class="checkbox-area" bindtap="toggleIndicator" data-id="igM" data-type="preset">
              <t-checkbox checked="{{selectedIndicators.igM}}" class="custom-checkbox" />
            </view>
            <view class="indicator-content" bindtap="editIndicator" data-id="igM">
              <view class="indicator-info">
                <view class="indicator-name">M</view>
                <text class="indicator-fullname">{{indicatorConfigs.igM.name}}</text>
              </view>
              <t-icon name="chevron-right" size="32rpx" color="#999" />
            </view>
          </view>
          <view class="indicator-item">
            <view class="checkbox-area" bindtap="toggleIndicator" data-id="igA" data-type="preset">
              <t-checkbox checked="{{selectedIndicators.igA}}" class="custom-checkbox" />
            </view>
            <view class="indicator-content" bindtap="editIndicator" data-id="igA">
              <view class="indicator-info">
                <view class="indicator-name">A</view>
                <text class="indicator-fullname">{{indicatorConfigs.igA.name}}</text>
              </view>
              <t-icon name="chevron-right" size="32rpx" color="#999" />
            </view>
          </view>
          <view class="indicator-item">
            <view class="checkbox-area" bindtap="toggleIndicator" data-id="antigenP52" data-type="preset">
              <t-checkbox checked="{{selectedIndicators.antigenP52}}" class="custom-checkbox" />
            </view>
            <view class="indicator-content" bindtap="editIndicator" data-id="antigenP52">
              <view class="indicator-info">
                <view class="indicator-name">P</view>
                <text class="indicator-fullname">{{indicatorConfigs.antigenP52.name}}</text>
              </view>
              <t-icon name="chevron-right" size="32rpx" color="#999" />
            </view>
          </view>
          <view class="indicator-item">
            <view class="checkbox-area" bindtap="toggleIndicator" data-id="earlyAntigen" data-type="preset">
              <t-checkbox checked="{{selectedIndicators.earlyAntigen}}" class="custom-checkbox" />
            </view>
            <view class="indicator-content" bindtap="editIndicator" data-id="earlyAntigen">
              <view class="indicator-info">
                <view class="indicator-name">早</view>
                <text class="indicator-fullname">{{indicatorConfigs.earlyAntigen.name}}</text>
              </view>
              <t-icon name="chevron-right" size="32rpx" color="#999" />
            </view>
          </view>
        </view>
        <!-- 自定义指标组 -->
        <view class="indicator-group" wx:if="{{customIndicators.length > 0}}">
          <view class="group-title">自定义指标</view>
          <view class="indicator-item" wx:for="{{customIndicators}}" wx:key="id">
            <view class="checkbox-area" bindtap="toggleIndicator" data-id="{{item.id}}" data-type="custom">
              <t-checkbox checked="{{selectedIndicators[item.id]}}" class="custom-checkbox" />
            </view>
            <view class="indicator-content" bindtap="editIndicator" data-id="{{item.id}}">
              <view class="indicator-info">
                <text class="indicator-fullname">{{item.fullName}}</text>
              </view>
              <t-icon name="chevron-right" size="32rpx" color="#999" />
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
    <!-- 底部按钮组 - 固定在页面底部 -->
    <view class="bottom-buttons">
      <!-- 返回按钮 -->
      <view class="bottom-back-btn" bindtap="goBack">
        <t-icon name="chevron-left" size="32rpx" color="white" />
        <text>返回</text>
      </view>
      <!-- 定义更多指标按钮 -->
      <view class="define-more-btn" bindtap="defineMoreIndicators">
        <t-icon name="add" size="32rpx" color="white" />
        <text>定义更多指标</text>
      </view>
    </view>
  </view>
  <!-- 编辑指标底部弹窗 -->
  <t-popup visible="{{editDialogVisible}}" placement="bottom" bind:visible-change="onPopupVisibleChange">
    <view class="edit-popup-content">
      <!-- 弹窗头部 -->
      <view class="edit-popup-header">
        <view class="edit-popup-title">{{isAddMode ? '添加指标' : '编辑指标'}}</view>
        <view class="edit-popup-close" bindtap="cancelEdit">
          <t-icon name="close" size="40rpx" color="#666" />
        </view>
      </view>
      <!-- 表单内容 -->
      <view class="edit-form-content">
        <view class="edit-form-item">
          <text class="edit-label">指标名称</text>
          <input class="edit-input" value="{{editForm.name}}" placeholder="请输入指标名称" bindinput="onEditFormInput" data-field="name" />
        </view>
        <view class="edit-form-item">
          <text class="edit-label">单位</text>
          <input class="edit-input" value="{{editForm.unit}}" placeholder="请输入单位" bindinput="onEditFormInput" data-field="unit" />
        </view>
      </view>
      <!-- 底部按钮 -->
      <view class="edit-popup-buttons">
        <view class="edit-btn edit-cancel-btn" bindtap="cancelEdit">取消</view>
        <view class="edit-btn edit-delete-btn" wx:if="{{isCustomIndicator}}" bindtap="deleteCustomIndicator">
          删除
        </view>
        <view class="edit-btn edit-confirm-btn" bindtap="confirmEdit">确定</view>
      </view>
    </view>
  </t-popup>
</view>