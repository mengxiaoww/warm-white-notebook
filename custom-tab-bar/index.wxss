/* TabBar容器 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(to top, #FFFFFF 0%, #FAFAFA 100%);
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 1000;
  padding-bottom: env(safe-area-inset-bottom);
}

/* TabBar项 */
.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  position: relative;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.tab-bar-text {
  font-size: 20rpx;
  margin-top: 8rpx;
  transition: all 0.3s ease;
}

/* 中间按钮容器 */
.tab-bar-center {
  flex: 1.2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  position: relative;
}

/* 中间凸起按钮 */
.center-btn {
  position: absolute;
  top: -32rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #FFC069 0%, #FF9500 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 149, 0, 0.4), inset 0 2rpx 4rpx rgba(255, 255, 255, 0.4);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  border: 6rpx solid #FFFFFF;
}

/* 中间按钮文字 */
.center-label {
  margin-top: 70rpx;
  font-size: 20rpx;
  color: #FF9500;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* 点击反馈 */
.tab-bar-item:active {
  opacity: 0.7;
}

.tab-bar-center:active .center-btn {
  transform: scale(0.9);
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.3);
}
