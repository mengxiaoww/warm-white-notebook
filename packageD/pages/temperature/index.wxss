.page-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 自定义导航栏 - 橘黄色主题 */
.navbar {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F2E 100%);
  border-bottom: none;
  padding-top: 44px;
  padding-top: env(safe-area-inset-top);
  box-shadow: 0 2rpx 16rpx rgba(255, 184, 77, 0.2);
}

.t-navbar__placeholder {
  visibility: hidden;
}

.t-navbar {
  --td-navbar-bg-color: transparent;
}

.navbar .t-navbar__title,
.navbar .t-navbar__center,
.navbar .t-navbar__center text,
.navbar .t-navbar__center .t-navbar__title {
  color: white !important;
  font-size: 34rpx !important;
  font-weight: 500 !important;
}

.navbar .t-icon,
.navbar .t-navbar__left .t-icon,
.navbar .t-navbar__right .t-icon {
  color: white !important;
}

.page-container .navbar .t-navbar__title {
  color: white !important;
  font-size: 34rpx !important;
  font-weight: 500 !important;
}

.custom-back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  transition: all 0.3s;
}

.custom-back-btn:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.95);
}

/* 内容区域 */
.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  height: 0;
}

/* 日期选择区域 */
.date-section {
  background: white;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.date-selector {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 18rpx 28rpx;
  background: linear-gradient(135deg, #fff 0%, #f8f8f8 100%);
  border: 1rpx solid rgba(255, 184, 77, 0.15);
  border-radius: 30rpx;
  min-width: 200rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.date-selector:active {
  background: linear-gradient(135deg, #f8f8f8 0%, #f0f0f0 100%);
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.08);
}

.date-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.quick-input-btns {
  display: flex;
  gap: 24rpx;
}

.add-record-btn {
  padding: 14rpx 28rpx !important;
  border-radius: 30rpx !important;
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F2E 100%) !important;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 77, 0.3) !important;
  font-weight: 500 !important;
}

/* 滚动容器 */
.scroll-container {
  flex: 1;
  height: 0;
  width: 100%;
  background: #f5f5f5;
}

.form-container {
  padding: 16rpx;
  padding-bottom: 32rpx;
}

/* 体温统计卡片 */
.temperature-summary {
  background: linear-gradient(135deg, #FFF8F0 0%, #FFF5EB 100%);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 184, 77, 0.12);
  border: 1rpx solid rgba(255, 184, 77, 0.2);
}

.summary-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.summary-left {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.summary-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.summary-count {
  font-size: 24rpx;
  color: #FFB84D;
  font-weight: 500;
}

.summary-right {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  background: white;
  border-radius: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.avg-label {
  font-size: 24rpx;
  color: #999;
}

.avg-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFB84D;
}

.avg-unit {
  font-size: 24rpx;
  color: #666;
}

/* 体温记录列表 */
.temperature-records-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.temperature-record-item {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s;
}

.temperature-record-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.record-content {
  padding: 24rpx;
}

.record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.time-info {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.record-time {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.value-badge {
  display: flex;
  align-items: baseline;
  padding: 10rpx 20rpx;
  background: linear-gradient(135deg, #FFF8F0 0%, #FFF5EB 100%);
  border-radius: 30rpx;
  border: 1rpx solid rgba(255, 184, 77, 0.2);
}

.main-value {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFB84D;
}

.unit {
  font-size: 22rpx;
  color: #666;
  margin-left: 4rpx;
}

.record-details {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
}

.detail-label {
  color: #999;
  min-width: 120rpx;
}

.detail-value {
  color: #333;
  font-weight: 500;
}

.notes-preview {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  padding: 16rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.notes-text {
  flex: 1;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.temp-actions {
  display: flex;
  gap: 12rpx;
  justify-content: flex-end;
}

.temp-btn {
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.3s;
}

.edit-temp-btn {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F2E 100%);
  color: white;
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 77, 0.25);
}

.edit-temp-btn:active {
  transform: scale(0.95);
  box-shadow: 0 1rpx 4rpx rgba(255, 184, 77, 0.35);
}

.delete-temp-btn {
  background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
  color: #666;
}

.delete-temp-btn:active {
  transform: scale(0.95);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #ccc;
}

/* 弹窗样式 */
.record-popup-content {
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.record-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.record-popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.record-popup-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f8f8f8;
}

.record-form-container {
  flex: 1;
  overflow-y: auto;
  max-height: 60vh;
}

.record-form-content {
  padding: 32rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.required {
  color: #ff4d4f;
  margin-left: 4rpx;
  font-size: 28rpx;
}

.form-input-wrapper {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  border: 1rpx solid transparent;
  transition: all 0.3s;
}

.form-input-wrapper.time-picker {
  justify-content: space-between;
}

.form-input-wrapper:focus-within {
  background: white;
  border-color: #FFB84D;
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 77, 0.15);
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  background: transparent;
  border: none;
}

.time-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  margin-left: 12rpx;
}

.input-unit {
  font-size: 26rpx;
  color: #999;
  margin-left: 12rpx;
}

.form-textarea {
  width: 100%;
  min-height: 150rpx;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  border: 1rpx solid transparent;
  transition: all 0.3s;
}

.form-textarea:focus {
  background: white;
  border-color: #FFB84D;
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 77, 0.15);
}

.record-form-actions {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
  background: white;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.cancel-btn,
.save-btn {
  flex: 1;
  border-radius: 30rpx !important;
  font-weight: 500 !important;
}

.save-btn {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F2E 100%) !important;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 77, 0.3) !important;
}
