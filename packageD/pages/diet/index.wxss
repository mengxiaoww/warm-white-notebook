.page-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 自定义导航栏 - 橘黄色主题 */
.navbar {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F2E 100%);
  border-bottom: none;
  padding-top: 44px;
  padding-top: env(safe-area-inset-top);
  box-shadow: 0 2rpx 16rpx rgba(255, 184, 77, 0.2);
}

/* 修复导航栏样式 */
.t-navbar__placeholder {
  visibility: hidden;
}

.t-navbar {
  --td-navbar-bg-color: transparent;
}

/* 强制设置导航栏标题样式 - 使用更具体的选择器 */
.navbar .t-navbar__title,
.navbar .t-navbar__center,
.navbar .t-navbar__center text,
.navbar .t-navbar__center .t-navbar__title {
  color: white !important;
  font-size: 34rpx !important;
  font-weight: 500 !important;
}

/* 导航栏所有图标颜色 */
.navbar .t-icon,
.navbar .t-navbar__left .t-icon,
.navbar .t-navbar__right .t-icon {
  color: white !important;
}

/* 更强的选择器确保样式生效 */
.page-container .navbar .t-navbar__title {
  color: white !important;
  font-size: 34rpx !important;
  font-weight: 500 !important;
}

/* 自定义返回按钮 */
.custom-back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  transition: all 0.3s;
}

.custom-back-btn:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.95);
}

/* 内容区域 */
.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  height: 0;
}

/* 日期选择区域 */
.date-section {
  background: white;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.date-selector {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 18rpx 28rpx;
  background: linear-gradient(135deg, #fff 0%, #f8f8f8 100%);
  border: 1rpx solid rgba(255, 184, 77, 0.15);
  border-radius: 30rpx;
  min-width: 200rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.date-selector:active {
  background: linear-gradient(135deg, #f8f8f8 0%, #f0f0f0 100%);
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.08);
}

.date-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

/* 快捷输入按钮 */
.quick-input-btns {
  display: flex;
  gap: 24rpx;
}

.add-record-btn {
  padding: 14rpx 28rpx !important;
  border-radius: 30rpx !important;
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F2E 100%) !important;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 77, 0.3) !important;
  font-weight: 500 !important;
}

/* 滚动容器 */
.scroll-container {
  flex: 1;
  width: 100%;
  background: #f5f5f5;
}

/* 表单容器 */
.form-container {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 血氧统计卡片 */
.diet-summary {
  background: linear-gradient(135deg, #FFF8F0 0%, #FFF5EB 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 184, 77, 0.15);
  border: 1rpx solid rgba(255, 184, 77, 0.2);
}

.summary-header {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.summary-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.summary-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.summary-count {
  font-size: 28rpx;
  color: #FFB84D;
  font-weight: 500;
}

/* 统计数据区域 */
.summary-stats {
  display: flex;
  gap: 24rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 184, 77, 0.15);
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  background: white;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
  display: block;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFB84D;
  margin-bottom: 4rpx;
  display: block;
}

.stat-unit {
  font-size: 22rpx;
  color: #999;
  margin-left: 4rpx;
}

/* 血氧记录列表 */
.diet-records-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.diet-record-item {
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(255, 184, 77, 0.1);
  transition: all 0.3s;
}

.diet-record-item:active {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.12);
}

.record-content {
  padding: 32rpx;
}

.record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.time-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.record-time {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.value-badge {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, rgba(255, 184, 77, 0.1) 0%, rgba(255, 184, 77, 0.05) 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 184, 77, 0.2);
}

.main-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFB84D;
  font-family: 'DIN Alternate', 'SF Pro Display', -apple-system, sans-serif;
}

.unit {
  font-size: 24rpx;
  color: #FFB84D;
  font-weight: 500;
}

.record-details {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  font-size: 28rpx;
}

.detail-label {
  color: #999;
  margin-right: 8rpx;
}

.detail-value {
  color: #333;
  font-weight: 500;
}

/* 备注预览 */
.notes-preview {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  padding: 16rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.notes-text {
  flex: 1;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  word-break: break-all;
}

/* 操作按钮 */
.temp-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.temp-btn {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s;
}

.edit-temp-btn {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F2E 100%);
  color: white;
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 77, 0.3);
}

.edit-temp-btn:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(255, 184, 77, 0.4);
}

.delete-temp-btn {
  background: #f5f5f5;
  color: #666;
}

.delete-temp-btn:active {
  background: #e0e0e0;
  transform: scale(0.98);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  background: white;
  border-radius: 24rpx;
  margin-top: 40rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-top: 24rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #ccc;
  margin-top: 12rpx;
}

/* 记录弹窗 */
.record-popup-content {
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.record-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.record-popup-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f5f5;
  transition: all 0.2s;
}

.record-popup-close:active {
  background: #e0e0e0;
  transform: scale(0.95);
}

.record-form-container {
  flex: 1;
  max-height: 60vh;
  overflow-y: auto;
}

.record-form-content {
  padding: 24rpx 32rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.required {
  color: #ff4757;
  margin-left: 4rpx;
}

.form-input-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  border: 1rpx solid #e0e0e0;
}

.form-input-wrapper.time-picker {
  justify-content: space-between;
}

.time-value {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  border: none;
  background: transparent;
}

.input-unit {
  font-size: 26rpx;
  color: #999;
  white-space: nowrap;
}

/* 快捷输入按钮 */
.quick-buttons {
  display: flex;
  gap: 12rpx;
  margin-bottom: 32rpx;
  flex-wrap: wrap;
}

.quick-btn {
  flex: 1;
  min-width: 0;
  padding: 16rpx 8rpx;
  text-align: center;
  background: linear-gradient(135deg, rgba(255, 184, 77, 0.1) 0%, rgba(255, 184, 77, 0.05) 100%);
  border: 1rpx solid rgba(255, 184, 77, 0.3);
  border-radius: 12rpx;
  color: #FFB84D;
  font-size: 26rpx;
  font-weight: 500;
  transition: all 0.2s;
}

.quick-btn:active {
  background: linear-gradient(135deg, rgba(255, 184, 77, 0.2) 0%, rgba(255, 184, 77, 0.1) 100%);
  transform: scale(0.95);
}

.form-textarea {
  width: 100%;
  box-sizing: border-box;
  min-height: 160rpx;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  border: 1rpx solid #e0e0e0;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.record-form-actions {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
}

.cancel-btn {
  flex: 1;
  height: 88rpx !important;
  background: #f5f5f5 !important;
  color: #666 !important;
  border-radius: 16rpx !important;
}

.save-btn {
  flex: 2;
  height: 88rpx !important;
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F2E 100%) !important;
  color: white !important;
  border-radius: 16rpx !important;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 77, 0.3) !important;
  font-weight: 500 !important;
}

.save-btn:active {
  transform: scale(0.98) !important;
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 77, 0.4) !important;
}

/* 餐次选择按钮组 */
.meal-type-buttons {
  display: flex;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.meal-type-btn {
  flex: 1;
  padding: 20rpx 8rpx;
  text-align: center;
  background: linear-gradient(135deg, rgba(255, 184, 77, 0.08) 0%, rgba(255, 184, 77, 0.03) 100%);
  border: 2rpx solid rgba(255, 184, 77, 0.2);
  border-radius: 16rpx;
  color: #666;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.meal-type-btn.active {
  background: linear-gradient(135deg, #FFB84D 0%, #FF9F2E 100%);
  border: 2rpx solid #FFB84D;
  color: white;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 77, 0.3);
  transform: translateY(-2rpx);
}

.meal-type-btn:active {
  transform: scale(0.96);
}
