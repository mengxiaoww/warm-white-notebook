<view class="page-container">
  <!-- 自定义导航栏 -->
  <t-navbar title="饮食" class="navbar" style="--td-navbar-title-color: white; --td-navbar-title-font-size: 34rpx; --td-navbar-title-font-weight: 500;">
    <view slot="left" class="custom-back-btn" bindtap="goBack">
      <t-icon name="chevron-left" size="48rpx" color="white" />
    </view>
    <view slot="right" class="navbar-right">
      <t-icon name="ellipsis" size="48rpx" color="white" bindtap="showMoreMenu" />
    </view>
  </t-navbar>
  <!-- 内容区域 -->
  <view class="content">
    <!-- 临时配置预览提示 -->
    <view class="temp-config-hint" wx:if="{{isTemporaryConfig}}">
      <t-icon name="info-circle" size="28rpx" color="#ff6b35" />
      <text class="temp-config-text">📋 正在预览配置效果，点击"保存配置"后生效</text>
    </view>
    <!-- 日期选择 -->
    <view class="date-section">
      <view class="date-selector" bindtap="showDatePicker">
        <text class="date-text">{{selectedDate}}</text>
        <t-icon name="caret-down" size="24rpx" color="#666" />
      </view>
      <!-- 快捷输入按钮 -->
      <!-- <view class="quick-input-btns">
        <view class="quick-btn" bindtap="scanOCR">
          <t-icon name="scan" size="36rpx" color="#666" />
          <text>扫描录入</text>
        </view>
      </view> -->
    </view>
    <!-- 饮食指标列表 -->
    <scroll-view class="scroll-container" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="form-container">
        <!-- 基础指标 -->
        <view class="indicators-list" wx:if="{{(displayedBasicIndicators && displayedBasicIndicators.length > 0) || (customIndicators && customIndicators.length > 0)}}">
          <!-- 动态显示基础指标 -->
          <view class="indicator-item {{item.type === 'text' ? 'indicator-item-textarea' : ''}}" wx:for="{{displayedBasicIndicators}}" wx:key="id">
            <text class="indicator-name">{{item.name}}</text>
            <view class="indicator-input">
              <!-- 备注字段使用textarea -->
              <textarea wx:if="{{item.type === 'text'}}"
                id="input-{{index}}"
                value="{{formData[item.id]}}"
                bindinput="onInputChange"
                data-field="{{item.id}}"
                placeholder="记录今日饮食内容..."
                class="textarea-field"
                maxlength="200"
                auto-height="{{true}}"
              />
              <!-- 数值字段使用input -->
              <input wx:else
                id="input-{{index}}"
                type="digit"
                value="{{formData[item.id]}}"
                focus="{{focusIndex === index}}"
                bindinput="onInputChange"
                bindfocus="onInputFocus"
                bindblur="onInputBlur"
                data-field="{{item.id}}"
                data-index="{{index}}"
                data-total="{{displayedBasicIndicators.length + customIndicators.length}}"
                placeholder="请输入"
                class="input-field"
              />
              <text class="unit" wx:if="{{item.unit}}">{{item.unit}}</text>
            </view>
          </view>
          <!-- 自定义指标 -->
          <view class="indicator-item" wx:for="{{customIndicators}}" wx:key="id" wx:for-index="customIndex">
            <text class="indicator-name">{{item.name}}</text>
            <view class="indicator-input">
              <input id="input-{{displayedBasicIndicators.length + customIndex}}" type="digit" value="{{formData[item.id]}}" focus="{{focusIndex === displayedBasicIndicators.length + customIndex}}" bindinput="onInputChange" bindfocus="onInputFocus" bindblur="onInputBlur" data-field="{{item.id}}" data-index="{{displayedBasicIndicators.length + customIndex}}" data-total="{{displayedBasicIndicators.length + customIndicators.length}}" placeholder="请输入" class="input-field" />
              <text class="unit">{{item.unit}}</text>
            </view>
          </view>
        </view>
        <!-- 空状态提示 -->
        <view class="empty-indicators" wx:if="{{(!displayedBasicIndicators || displayedBasicIndicators.length === 0) && (!customIndicators || customIndicators.length === 0)}}">
          <medical-icon name="glucose" size="120" color="#ccc" />
          <text class="empty-text">暂无录入项</text>
          <text class="empty-hint">点击下方按钮添加录入项</text>
        </view>
        <!-- 添加更多录入项 -->
        <view class="add-more-btn" bindtap="configIndicators">
          <text>编辑录入项</text>
        </view>
      </view>
    </scroll-view>
    <!-- 底部操作按钮 -->
    <view class="bottom-actions">
      <view class="delete-btn" bindtap="deleteRecord">
        <t-icon name="delete" size="32rpx" color="white" />
        <text>删除</text>
      </view>
      <t-button theme="primary" size="large" class="save-btn" bindtap="saveData">保存配置</t-button>
    </view>
  </view>
  <!-- 日期选择器 -->
  <t-date-time-picker title="选择日期" visible="{{datePickerVisible}}" mode="date" value="{{selectedDate}}" bind:confirm="onDateConfirm" bind:cancel="onDateCancel" confirm-btn="确定" cancel-btn="取消" class="custom-date-picker" />
  <!-- Toast -->
  <t-toast id="t-toast" />
  <!-- 浮动的下一项/完成按钮 -->
  <view wx:if="{{focusIndex >= 0}}" class="floating-next-btn" catchtap="{{focusIndex === displayedBasicIndicators.length + customIndicators.length - 1 ? 'completeInput' : 'goToNextInput'}}" data-index="{{focusIndex}}">
    <t-icon name="{{focusIndex === displayedBasicIndicators.length + customIndicators.length - 1 ? 'check' : 'chevron-down'}}" size="48rpx" color="white" />
  </view>
</view>
