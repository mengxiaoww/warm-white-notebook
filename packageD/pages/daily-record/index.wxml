<wxs module="numFmt" src="/utils/number-format.wxs"></wxs>

<view class="container">
  <!-- 实际内容 -->
  <view class="content-wrapper">


    <!-- ✅ 今日事项卡片 -->
    <view class="today-tasks-card">
      <view class="tasks-header">
        <view class="tasks-title-group">
          <t-icon name="bulletpoint" size="32rpx" color="#FF9800" />
          <text class="tasks-title">今日事项</text>
          <text class="tasks-count" wx:if="{{todayTasks.length > 0}}">{{todayTasks.length}}</text>
        </view>
        <view class="tasks-add-btn" bindtap="showAddTaskDialog">
          <t-icon name="add" size="32rpx" color="#FFFFFF" />
        </view>
      </view>

      <!-- 事项列表 -->
      <view class="tasks-list" wx:if="{{todayTasks.length > 0}}">
        <view class="task-item {{item.completed ? 'task-completed' : ''}}"
          wx:for="{{todayTasks}}" wx:key="_id">
          <view class="task-checkbox" bindtap="toggleTaskComplete" data-id="{{item._id}}">
            <view class="checkbox-inner {{item.completed ? 'checked' : ''}}">
              <t-icon name="check" size="20rpx" color="#FFFFFF" wx:if="{{item.completed}}" />
            </view>
          </view>
          <text class="task-text">{{item.title}}</text>
          <view class="task-delete-btn" bindtap="confirmDeleteTask" data-id="{{item._id}}">
            <t-icon name="delete" size="24rpx" color="#FF6B6B" />
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="tasks-empty" wx:else bindtap="showAddTaskDialog">
        <text class="tasks-empty-text">暂无事项，点击 + 添加</text>
      </view>
    </view>

    <!-- 日历组件 -->
    <view class="calendar-section">
      <!-- 未展开状态：直接显示日期条在顶部 -->
      <view class="calendar-compact" wx:if="{{!calendarExpanded}}">
        <view class="calendar-week-strip">
          <view class="calendar-day calendar-day-compact {{item.isSelected ? 'selected' : ''}} {{item.hasRecord ? 'has-record-mark' : ''}}" wx:for="{{weekDays}}"
            wx:key="date" bindtap="selectDate" data-date="{{item.date}}">
            <text class="day-number">{{item.day}}</text>
            <text class="day-name">{{item.dayName}}</text>
            <view wx:if="{{item.hasRecord}}" class="record-indicator"></view>
          </view>
        </view>
        <view class="calendar-expand-btn" bindtap="toggleCalendarExpanded">
          <t-icon name="chevron-down" size="32rpx" color="#FF9800" />
        </view>
      </view>
      <!-- 展开状态：完整月视图 -->
      <view class="calendar-expanded" wx:if="{{calendarExpanded}}">
        <!-- 月份导航 -->
        <view class="calendar-month-nav">
          <view class="calendar-nav-btn" bindtap="prevMonth">
            <t-icon name="chevron-left" size="28rpx" color="#FF9800" />
          </view>
          <text class="calendar-month-title">{{currentYear}}年{{currentMonth}}月</text>
          <view class="calendar-nav-btn" bindtap="nextMonth">
            <t-icon name="chevron-right" size="28rpx" color="#FF9800" />
          </view>
          <view class="calendar-expand-btn" bindtap="toggleCalendarExpanded">
            <t-icon name="chevron-up" size="32rpx" color="#FF9800" />
          </view>
        </view>
        <!-- 星期标题 -->
        <view class="calendar-weekday-header">
          <text class="calendar-weekday-title" wx:for="{{weekdayTitles}}" wx:key="*this">
            {{item}}
          </text>
        </view>
        <!-- 日期网格 -->
        <view class="calendar-month-grid">
          <view class="calendar-day {{item.isSelected ? 'selected' : ''}} {{item.isEmpty ? 'empty' : ''}} {{item.hasRecord ? 'has-record-mark' : ''}}"
            wx:for="{{monthDays}}" wx:key="date" bindtap="selectDate" data-date="{{item.date}}">
            {{item.day}}
            <view wx:if="{{item.hasRecord && !item.isEmpty}}" class="record-indicator"></view>
          </view>
        </view>
      </view>
    </view>
    <!-- 📅 日期指示横幅 - 连接日历和记录区域 -->
    <view class="selected-date-banner {{dateChanged ? 'date-changed-animation' : ''}}">
      <view class="banner-icon-wrapper">
        <t-icon name="calendar" size="40rpx" color="#FFFFFF" />
      </view>
      <view class="banner-text-wrapper">
        <text class="banner-date">{{selectedDateText}}</text>
        <text class="banner-hint">为这一天添加健康记录</text>
      </view>
    </view>


    <!-- 功能项网格 - 动态渲染 -->
    <view class="functions-grid {{dateChanged ? 'records-highlight-animation' : ''}}">
      <!-- 骨架屏加载 -->
      <block wx:if="{{isPageLoading}}">
        <view class="function-card-skeleton" wx:for="{{[1, 2, 3, 4, 5, 6]}}" wx:key="*this">
          <view class="skeleton-header-wrapper">
            <view class="skeleton-icon-circle"></view>
            <view class="skeleton-title-line"></view>
          </view>
          <view class="skeleton-content-wrapper">
            <view class="skeleton-data-line"></view>
            <view class="skeleton-data-line short"></view>
          </view>
          <view class="skeleton-shimmer-effect"></view>
        </view>
      </block>
      <!-- 动态功能项 -->
      <block wx:else>
        <view wx:for="{{mainPageFunctions}}" wx:key="id"
        class="function-card function-card--{{item.id}} {{selectedDateData[item.dataKey] ? 'has-data' : 'no-data'}}"
        bindtap="handleFunctionTap" data-navigate="{{item.navigate}}" data-function-id="{{item.id}}">
        <view class="function-card-status" wx:if="{{selectedDateData[item.dataKey]}}"></view>
        <view class="function-card-header">
          <view class="function-card-icon">
            <medical-icon name="{{item.icon}}" size="40" color="var(--primary-color)" />
          </view>
          <text class="function-card-title">{{item.name}}</text>
        </view>
        <view class="function-card-content">
          <view class="function-card-empty" wx:if="{{!selectedDateData[item.dataKey]}}">
            <view class="empty-state-premium">
              <view class="empty-icon-wrapper">
                <view class="empty-icon-pulse"></view>
                <t-icon name="add" size="28rpx" color="#999" />
              </view>
              <text class="empty-text">轻触记录</text>
            </view>
          </view>
          <view class="function-card-data" wx:else>
            <!-- 血常规数据展示 - 极简设计 -->
            <block wx:if="{{item.id === 'blood' && selectedDateData.bloodData}}">
              <view class="blood-simple-item"
                wx:if="{{selectedDateData.bloodData.wbc || selectedDateData.bloodData.wbc === 0}}">
                <text class="bs-label">白细胞</text>
                <view class="bs-value-group">
                  <view class="bs-value">{{numFmt.formatValue(selectedDateData.bloodData.wbc)}}</view>
                  <view class="bs-unit">10⁹/L</view>
                </view>
              </view>
              <view class="blood-simple-item"
                wx:if="{{selectedDateData.bloodData.neut || selectedDateData.bloodData.neut === 0}}">
                <view class="bs-label">中性粒细胞</view>
                <view class="bs-value-group">
                  <view class="bs-value">{{numFmt.formatValue(selectedDateData.bloodData.neut)}}</view>
                  <view class="bs-unit">10⁹/L</view>
                </view>
              </view>
              <view class="blood-simple-item"
                wx:if="{{selectedDateData.bloodData.hgb || selectedDateData.bloodData.hgb === 0}}">
                <view class="bs-label">血红蛋白</view>
                <view class="bs-value-group">
                  <view class="bs-value">{{numFmt.formatValue(selectedDateData.bloodData.hgb)}}</view>
                  <view class="bs-unit">g/L</view>
                </view>
              </view>
              <view class="blood-simple-item"
                wx:if="{{selectedDateData.bloodData.plt || selectedDateData.bloodData.plt === 0}}">
                <view class="bs-label">血小板</view>
                <view class="bs-value-group">
                  <view class="bs-value">{{numFmt.formatValue(selectedDateData.bloodData.plt)}}</view>
                  <view class="bs-unit">10⁹/L</view>
                </view>
              </view>
            </block>
            <!-- 血糖数据展示 - 统一单值显示样式 -->
            <block wx:elif="{{item.id === 'bloodSugar' && selectedDateData.bloodSugarData}}">
              <view class="ldh-single-data">
                <view class="ldh-header">
                  <view class="ldh-label">数值</view>
                </view>
                <view class="ldh-value-container">
                  <text class="ldh-big-value">{{selectedDateData.bloodSugarData.bloodSugar || selectedDateData.bloodSugarData.fbg || selectedDateData.bloodSugarData.pbg || '0'}}</text>
                  <text class="ldh-unit">mmol/L</text>
                </view>
                <view class="ldh-range-hint">参考范围: 3.9-6.1 (空腹)</view>
              </view>
            </block>
            <!-- 血氧数据展示 - 统一单值显示样式 -->
            <block wx:elif="{{item.id === 'bloodOxygen' && selectedDateData.bloodOxygenData}}">
              <view class="ldh-single-data">
                <view class="ldh-header">
                  <view class="ldh-label">数值</view>
                </view>
                <view class="ldh-value-container">
                  <text class="ldh-big-value">{{selectedDateData.bloodOxygenData.spo2 || '0'}}</text>
                  <text class="ldh-unit">%</text>
                </view>
                <view class="ldh-range-hint">参考范围: 95-100%</view>
              </view>
            </block>
            <!-- 血压数据展示 - 简洁专业设计 -->
            <block wx:elif="{{item.id === 'bloodPressure' && selectedDateData.bloodPressureData}}">
              <view class="bp-display-container">
                <view class="bp-reading-card">
                  <view class="bp-systolic-section">
                    <text class="bp-label">高压</text>
                    <text class="bp-value-large">{{selectedDateData.bloodPressureData.systolic || '--'}}</text>
                  </view>
                  <view class="bp-divider"></view>
                  <view class="bp-diastolic-section">
                    <text class="bp-label">低压</text>
                    <text class="bp-value-large">{{selectedDateData.bloodPressureData.diastolic || '--'}}</text>
                  </view>
                </view>
                <view class="bp-reference-hint">参考: 90-140 / 60-90</view>
              </view>
            </block>
            <!-- 身高体重数据展示 - 简洁专业设计 -->
            <block wx:elif="{{item.id === 'bodyMeasurement' && selectedDateData.bodyMeasurementData}}">
              <view class="bp-display-container">
                <view class="bp-reading-card">
                  <view class="bp-systolic-section">
                    <text class="bp-label">身高</text>
                    <text class="bp-value-large">{{selectedDateData.bodyMeasurementData.height || '--'}}</text>
                  </view>
                  <view class="bp-divider"></view>
                  <view class="bp-diastolic-section">
                    <text class="bp-label">体重</text>
                    <text class="bp-value-large">{{selectedDateData.bodyMeasurementData.weight || '--'}}</text>
                  </view>
                </view>
                <view class="bp-reference-hint">身高(cm) / 体重(kg)</view>
              </view>
            </block>
            <!-- 饮水数据展示 - 统一单值显示样式 -->
            <block wx:elif="{{(item.id === 'water' || item.id === 'waterIntake') && selectedDateData.waterData}}">
              <view class="ldh-single-data">
                <view class="ldh-header">
                  <view class="ldh-label">饮水量</view>
                </view>
                <view class="ldh-value-container">
                  <text class="ldh-big-value">{{selectedDateData.waterData.water || '0'}}</text>
                  <text class="ldh-unit">ml</text>
                </view>
                <view class="ldh-range-hint">参考: 1500-2000 ml/天</view>
              </view>
            </block>
            <!-- 饮食数据展示 - 营养记录 -->
            <block wx:elif="{{item.id === 'diet' && selectedDateData.dietData}}">
              <view class="ldh-single-data">
                <view class="ldh-header">
                  <view class="ldh-label">总热量</view>
                </view>
                <view class="ldh-value-container">
                  <text class="ldh-big-value">{{selectedDateData.dietData.calories || '0'}}</text>
                  <text class="ldh-unit">kcal</text>
                </view>
                <view class="ldh-range-hint">蛋白{{selectedDateData.dietData.protein || 0}}g · 碳水{{selectedDateData.dietData.carbs || 0}}g</view>
              </view>
            </block>
            <!-- 体温数据展示 - 统一单值显示样式 -->
            <block wx:elif="{{item.id === 'temperature' && selectedDateData.temperatureData}}">
              <view class="ldh-single-data">
                <view class="ldh-header">
                  <view class="ldh-label">体温</view>
                </view>
                <view class="ldh-value-container">
                  <text class="ldh-big-value">{{selectedDateData.temperatureData.temperature || '0'}}</text>
                  <text class="ldh-unit">℃</text>
                </view>
                <view class="ldh-range-hint">正常范围: 36.0-37.3 ℃</view>
              </view>
            </block>
            <!-- EB病毒 - 使用血常规相同高度布局 -->
            <!-- EB病毒：与乳酸脱氢酶统一，显示「数值」 -->
            <block wx:elif="{{item.id === 'ebv' && selectedDateData.ebvData}}">
              <view class="ldh-single-data">
                <view class="ldh-header">
                  <view class="ldh-label">数值</view>
                </view>
                <view class="ldh-value-container">
                  <text class="ldh-big-value">{{selectedDateData.ebvData.ebvDna || '0'}}</text>
                  <text class="ldh-unit">IU/mL</text>
                </view>
                <view class="ebv-status-row">
                  <view
                    class="ebv-status-text {{(selectedDateData.ebvData && (selectedDateData.ebvData.ebvDna == '0' || selectedDateData.ebvData.ebvDna === 0 || selectedDateData.ebvData.ebvDna === '' || !selectedDateData.ebvData.ebvDna || selectedDateData.ebvData.result === '阴性')) ? 'negative' : 'positive'}}">
                    {{(selectedDateData.ebvData && (selectedDateData.ebvData.ebvDna == '0' ||
                    selectedDateData.ebvData.ebvDna === 0 || selectedDateData.ebvData.ebvDna === '' ||
                    !selectedDateData.ebvData.ebvDna || selectedDateData.ebvData.result === '阴性')) ? '阴性' : '阳性'}}
                  </view>
                </view>
              </view>
            </block>
            <!-- 巨细胞病毒：与乳酸脱氢酶统一，显示「数值」 -->
            <block wx:elif="{{item.id === 'cmv' && selectedDateData.cmvData}}">
              <view class="ldh-single-data">
                <view class="ldh-header">
                  <view class="ldh-label">数值</view>
                </view>
                <view class="ldh-value-container">
                  <text class="ldh-big-value">{{selectedDateData.cmvData.hcmvDna || '0'}}</text>
                  <text class="ldh-unit">IU/mL</text>
                </view>
                <view class="ebv-status-row">
                  <view
                    class="ebv-status-text {{(selectedDateData.cmvData && (selectedDateData.cmvData.hcmvDna == '0' || selectedDateData.cmvData.hcmvDna === 0 || selectedDateData.cmvData.hcmvDna === '' || !selectedDateData.cmvData.hcmvDna || selectedDateData.cmvData.result === '阴性')) ? 'negative' : 'positive'}}">
                    {{(selectedDateData.cmvData && (selectedDateData.cmvData.hcmvDna == '0' ||
                    selectedDateData.cmvData.hcmvDna === 0 || selectedDateData.cmvData.hcmvDna === '' ||
                    !selectedDateData.cmvData.hcmvDna || selectedDateData.cmvData.result === '阴性')) ? '阴性' : '阳性'}}
                  </view>
                </view>
              </view>
            </block>
            <!-- 乳酸脱氢酶：无阴阳性，优化展示样式 -->
            <block wx:elif="{{item.id === 'ldh' && selectedDateData.ldhData}}">
              <view class="ldh-single-data">
                <view class="ldh-header">
                  <view class="ldh-label">数值</view>
                </view>
                <view class="ldh-value-container">
                  <text class="ldh-big-value">{{selectedDateData.ldhData.ldh}}</text>
                  <text class="ldh-unit">U/L</text>
                </view>
                <view class="ldh-range-hint">参考范围: 100-300</view>
              </view>
            </block>
            <!-- 肝功能数据展示 - 紧凑4指标网格布局 -->
            <block wx:elif="{{item.id === 'liver' && selectedDateData.liverData}}">
              <view class="liver-indicator-item"
                wx:if="{{selectedDateData.liverData.alt || selectedDateData.liverData.alt === 0}}">
                <view class="bs-label">ALT</view>
                <view class="bs-value-group">
                  <view class="bs-value">{{selectedDateData.liverData.alt}}</view>
                  <view class="bs-unit">U/L</view>
                </view>
              </view>
              <view class="liver-indicator-item"
                wx:if="{{selectedDateData.liverData.ast || selectedDateData.liverData.ast === 0}}">
                <view class="bs-label">AST</view>
                <view class="bs-value-group">
                  <view class="bs-value">{{selectedDateData.liverData.ast}}</view>
                  <view class="bs-unit">U/L</view>
                </view>
              </view>
              <view class="liver-indicator-item"
                wx:if="{{selectedDateData.liverData.tbil || selectedDateData.liverData.tbil === 0 || selectedDateData.liverData.totalBilirubin || selectedDateData.liverData.totalBilirubin === 0 || selectedDateData.liverData.bilirubin || selectedDateData.liverData.bilirubin === 0}}">
                <text class="bs-label">总胆红素</text>
                <view class="bs-value-group">
                  <view class="bs-value">
                    {{selectedDateData.liverData.tbil || selectedDateData.liverData.totalBilirubin ||
                    selectedDateData.liverData.bilirubin}}
                  </view>
                  <view class="bs-unit">μmol/L</view>
                </view>
              </view>
              <view class="liver-indicator-item"
                wx:if="{{selectedDateData.liverData.dbil || selectedDateData.liverData.dbil === 0 || selectedDateData.liverData.directBilirubin || selectedDateData.liverData.directBilirubin === 0}}">
                <text class="bs-label">直接胆红素</text>
                <view class="bs-value-group">
                  <view class="bs-value">
                    {{selectedDateData.liverData.dbil || selectedDateData.liverData.directBilirubin}}
                  </view>
                  <view class="bs-unit">μmol/L</view>
                </view>
              </view>
            </block>
            <!-- 肾功能数据展示 - 紧凑4指标网格布局 -->
            <block wx:elif="{{item.id === 'kidney' && selectedDateData.kidneyData}}">
              <view class="kidney-indicator-item"
                wx:if="{{selectedDateData.kidneyData.cr || selectedDateData.kidneyData.cr === 0 || selectedDateData.kidneyData.creatinine || selectedDateData.kidneyData.creatinine === 0}}">
                <view class="bs-label">肌酐</view>
                <view class="bs-value-group">
                  <view class="bs-value">
                    {{selectedDateData.kidneyData.cr || selectedDateData.kidneyData.creatinine}}
                  </view>
                  <view class="bs-unit">μmol/L</view>
                </view>
              </view>
              <view class="kidney-indicator-item"
                wx:if="{{selectedDateData.kidneyData.bun || selectedDateData.kidneyData.bun === 0 || selectedDateData.kidneyData.urea || selectedDateData.kidneyData.urea === 0}}">
                <view class="bs-label">尿素氮</view>
                <view class="bs-value-group">
                  <view class="bs-value">
                    {{selectedDateData.kidneyData.bun || selectedDateData.kidneyData.urea}}
                  </view>
                  <text class="bs-unit">mmol/L</text>
                </view>
              </view>
              <view class="kidney-indicator-item"
                wx:if="{{selectedDateData.kidneyData.ua || selectedDateData.kidneyData.ua === 0 || selectedDateData.kidneyData.uricAcid || selectedDateData.kidneyData.uricAcid === 0}}">
                <view class="bs-label">尿酸</view>
                <view class="bs-value-group">
                  <view class="bs-value">
                    {{selectedDateData.kidneyData.ua || selectedDateData.kidneyData.uricAcid}}
                  </view>
                  <view class="bs-unit">μmol/L</view>
                </view>
              </view>
              <view class="kidney-indicator-item"
                wx:if="{{selectedDateData.kidneyData.egfr || selectedDateData.kidneyData.egfr === 0 || selectedDateData.kidneyData.gfr || selectedDateData.kidneyData.gfr === 0}}">
                <view class="bs-label">eGFR</view>
                <view class="bs-value-group">
                  <view class="bs-value">
                    {{selectedDateData.kidneyData.egfr || selectedDateData.kidneyData.gfr}}
                  </view>
                  <view class="bs-unit">ml/min</view>
                </view>
              </view>
            </block>
            <!-- 用药记录数据展示 - 两行布局 -->
            <block wx:elif="{{item.id === 'medication' && selectedDateData.medicationData}}">
              <!-- 第一行：用药进度+进度条 -->
              <view class="med-progress-row-full">
                <view class="med-progress-info">
                  <view class="bs-label">用药进度</view>
                  <view class="bs-value-group">
                    <view class="bs-value">{{selectedDateData.medicationData.progress}}</view>
                    <view class="bs-unit">%</view>
                  </view>
                </view>
                <view class="med-progress-bar">
                  <view
                    class="med-progress-fill {{selectedDateData.medicationData.progress >= 100 ? 'med-progress-completed' : ''}}"
                    style="width: {{selectedDateData.medicationData.progress}}%;"></view>
                </view>
              </view>
              <!-- 第二行：今日用药统计 -->
              <view class="med-stats-row-full">
                <text class="bs-label">今日用药</text>
                <view class="bs-value-group">
                  <view class="bs-value">
                    {{selectedDateData.medicationData.takenMedicines}}/{{selectedDateData.medicationData.totalMedicines}}
                  </view>
                  <view class="bs-unit">种</view>
                </view>
              </view>
            </block>
            <!-- 门诊记录数据展示 - 对称均衡设计 -->
            <block wx:elif="{{item.id === 'clinic' && selectedDateData.clinicData}}">
              <!-- 第一行：医院 + 科室（左右对称） -->
              <view class="clinic-symmetric-row">
                <view class="clinic-left-text">{{selectedDateData.clinicData.hospital}}</view>
                <view class="clinic-right-text">{{selectedDateData.clinicData.department}}</view>
              </view>
              <!-- 第二行：费用 + 时间（左右对称） -->
              <view class="clinic-symmetric-row">
                <view class="clinic-left-text clinic-cost-color" wx:if="{{selectedDateData.clinicData.cost}}">
                  ￥{{selectedDateData.clinicData.cost}}
                </view>
                <view class="clinic-right-text clinic-date-color">{{selectedDateShort}}</view>
              </view>
            </block>
            <!-- 尿量记录数据展示 - 左右对称布局 -->
            <block wx:elif="{{item.id === 'urine' && selectedDateData.urineData}}">
              <!-- 总尿量 - 最重要指标 -->
              <view class="urine-symmetric-row">
                <view class="urine-label">总尿量</view>
                <view class="urine-value-group">
                  <view class="urine-value">{{selectedDateData.urineData.total || 0}}</view>
                  <view class="urine-unit">ml</view>
                </view>
              </view>
              <!-- 排尿次数 - 频率指标 -->
              <view class="urine-symmetric-row">
                <view class="urine-label">排尿次数</view>
                <view class="urine-value-group">
                  <view class="urine-value">{{selectedDateData.urineData.times || 0}}</view>
                  <view class="urine-unit">次</view>
                </view>
              </view>
            </block>
            <!-- 排便记录数据展示 - 左右对称布局 -->
            <block
              wx:elif="{{item.id === 'stool' && selectedDateData.stoolData && selectedDateData.stoolData.count > 0}}">
              <!-- 排便记录 - 显示记录数量和状态 -->
              <view class="stool-symmetric-row">
                <view class="stool-label">记录数量</view>
                <view class="stool-value-group">
                  <view class="stool-value">{{selectedDateData.stoolData.count}}</view>
                  <view class="stool-unit">次</view>
                </view>
              </view>
              <!-- 异常状态 - 健康状态指标 -->
              <view class="stool-symmetric-row">
                <view class="stool-label">健康状态</view>
                <view class="stool-type {{selectedDateData.stoolData.hasAbnormal ? 'stool-abnormal' : 'stool-normal'}}">
                  {{selectedDateData.stoolData.hasAbnormal ? '异常' : '正常'}}
                </view>
              </view>
            </block>
            <!-- 费用记录数据展示 - 左右对称布局 -->
            <block wx:elif="{{item.id === 'expense' && selectedDateData.expenseData}}">
              <!-- 费用总额 - 最重要指标 -->
              <view class="expense-symmetric-row">
                <view class="expense-label">费用总额</view>
                <view class="expense-value-group">
                  <view class="expense-value">￥{{selectedDateData.expenseData.total || 0}}</view>
                </view>
              </view>
              <!-- 记录数量 - 次数指标 -->
              <view class="expense-symmetric-row">
                <view class="expense-label">记录数量</view>
                <view class="expense-value-group">
                  <view class="expense-count">{{selectedDateData.expenseData.count || 0}}</view>
                  <view class="expense-unit">笔</view>
                </view>
              </view>
            </block>
            <!-- 检查报告数据展示 - 门诊记录样式 -->
            <block wx:elif="{{item.id === 'checkReport' && selectedDateData.checkReportData}}">
              <!-- 第一行：检查项目名称 + 检查结果（左右对称） -->
              <view class="clinic-symmetric-row">
                <view class="clinic-left-text">
                  {{selectedDateData.checkReportData.projectName || '检查报告'}}
                </view>
                <view class="clinic-right-text">
                  {{selectedDateData.checkReportData.resultTypeLabel || '未知'}}
                </view>
              </view>
              <!-- 第二行：详细结果状态 + 记录日期（左右对称） -->
              <view class="clinic-symmetric-row">
                <view class="clinic-left-text checkReport-result-color">
                  {{selectedDateData.checkReportData.detailedResultsDisplay}}
                </view>
                <view class="clinic-right-text clinic-date-color">
                  {{selectedDateData.checkReportData.recordDateShort || selectedDateShort}}
                </view>
              </view>
              <!-- 如果有多条记录，显示总数量 -->
              <view wx:if="{{selectedDateData.checkReportData.totalCount > 1}}" class="check-report-count-badge">
                今日检查报告 {{selectedDateData.checkReportData.totalCount}} 份
              </view>
            </block>
