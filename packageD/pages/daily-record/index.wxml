      <view class="edit-btn-circle">
        <t-icon name="setting" size="40rpx" color="#FFFFFF" />
      </view>
    </view>
    <!-- 功能项自定义弹窗 -->
    <t-popup visible="{{showFunctionCustomPopup}}" bind:visible-change="onFunctionCustomPopupClose" placement="bottom"
      show-overlay="{{true}}" overlay-props="{{ { preventScrollThrough: true } }}">
      <view class="function-custom-popup">
        <!-- 拖拽指示条 -->
        <view class="popup-drag-indicator">
          <view class="drag-bar"></view>
        </view>
        <!-- 关闭按钮 -->
        <view class="popup-close-btn" bindtap="closeFunctionCustomPopup">
          <t-icon name="close" size="26rpx" color="#8E8E93" />
        </view>
        <view class="function-custom-content">
          <view class="custom-hint-card">
            <view class="hint-text-wrapper">
              <text class="hint-title">操作说明</text>
              <text class="hint-subtitle">长按拖拽调整顺序，右侧开关控制显示</text>
            </view>
          </view>
          <!-- iOS风格拖拽列表 -->
          <scroll-view class="ios-drag-container" scroll-y="{{!isDragging}}" enhanced="true" show-scrollbar="false">
            <view
              class="ios-drag-item {{item.visible ? 'item-visible' : 'item-hidden'}} {{item.isDragging ? 'item-dragging' : ''}}"
              wx:for="{{customFunctionList}}" wx:key="id" data-index="{{index}}" bindlongpress="onItemLongPress"
              bindtouchstart="onItemTouchStart" bindtouchmove="onItemTouchMove" bindtouchend="onItemTouchEnd"
              style="{{item.isDragging ? 'transform: translateY(' + (item.translateY || 0) + 'rpx); z-index: 999;' : ''}}">
              <!-- 拖拽手柄 -->
              <view class="ios-drag-handle">
                <view class="drag-lines">
                  <view class="drag-line"></view>
                  <view class="drag-line"></view>
                  <view class="drag-line"></view>
                  <view class="drag-line"></view>
                  <view class="drag-line"></view>
                  <view class="drag-line"></view>
                </view>
              </view>
              <!-- 功能项内容 -->
              <view class="ios-item-content">
                <view class="ios-item-icon">
                  <medical-icon name="{{item.icon}}" size="44" color="{{item.visible ? '#FF9800' : '#999'}}" />
                </view>
                <view class="ios-item-info">
                  <text class="ios-item-name">{{item.name}}</text>
                  <text class="ios-item-status">{{item.visible ? '显示' : '隐藏'}}</text>
                </view>
              </view>
              <!-- iOS风格开关 -->
              <view class="ios-switch" catchtap="onFunctionToggle" data-id="{{item.id}}">
                <view class="ios-switch-bg {{item.visible ? 'switch-on' : 'switch-off'}}">
                  <view class="ios-switch-circle"></view>
                </view>
              </view>
            </view>
            <!-- 拖拽引导线 -->
            <view class="drop-line" wx:if="{{isDragging && dropLineIndex >= 0}}"
              style="top: {{dropLineIndex * 120 - 2}}rpx;"></view>
          </scroll-view>
          <view class="action-buttons">
            <view class="action-btn secondary" bindtap="resetFunctionOrder">
              <text class="btn-text">恢复默认</text>
            </view>
            <view class="action-btn primary" bindtap="saveFunctionCustom">
              <text class="btn-text">保存设置</text>
            </view>
          </view>
        </view>
      </view>
    </t-popup>
