                            </view>
                          </view>
                          <view class="indicator-item-enhanced" wx:if="{{item.albumin}}">
                            <text class="indicator-name-enhanced">白蛋白</text>
                            <text class="indicator-value-enhanced">{{item.albumin}} g/L</text>
                            <view
                              class="indicator-status-enhanced {{item.albumin < 35 ? 'status-low' : 'status-normal'}}">
                            </view>
                          </view>
                        </view>
                      </view>
                      <!-- 肾功能指标 -->
                      <view class="function-group-enhanced kidney-function"
                        wx:if="{{item.creatinine || item.urea || item.gfr}}">
                        <view class="function-group-header-enhanced">
                          <t-icon name="filter" size="20rpx" color="#FF8F00" />
                          <text class="group-title-enhanced">肾功能指标</text>
                        </view>
                        <view class="indicators-grid-enhanced">
                          <view class="indicator-item-enhanced" wx:if="{{item.creatinine}}">
                            <text class="indicator-name-enhanced">肌酐</text>
                            <text class="indicator-value-enhanced">{{item.creatinine}} μmol/L</text>
                            <view
                              class="indicator-status-enhanced {{item.creatinine > 104 ? 'status-high' : 'status-normal'}}">
                            </view>
                          </view>
                          <view class="indicator-item-enhanced" wx:if="{{item.urea}}">
                            <text class="indicator-name-enhanced">尿素</text>
                            <text class="indicator-value-enhanced">{{item.urea}} mmol/L</text>
                            <view
                              class="indicator-status-enhanced {{item.urea > 8.2 ? 'status-high' : 'status-normal'}}">
                            </view>
                          </view>
                          <view class="indicator-item-enhanced" wx:if="{{item.gfr}}">
                            <text class="indicator-name-enhanced">GFR</text>
                            <text class="indicator-value-enhanced">{{item.gfr}} ml/min/1.73m²</text>
                            <view class="indicator-status-enhanced {{item.gfr < 90 ? 'status-low' : 'status-normal'}}">
                            </view>
                          </view>
                        </view>
                      </view>
                    </view>
                    <view class="organ-notes-enhanced" wx:if="{{item.notes}}">
                      <t-icon name="chat" size="18rpx" color="#FF8F00" />
                      <text class="notes-text-enhanced">{{item.notes}}</text>
                    </view>
                  </view>
                </view>
              </view>
            </view>
          </block>
          <!-- 用药记录 -->
          <block wx:if="{{currentDateDetail.medicationData}}">
            <view class="date-detail-section unified-section">
              <view class="date-detail-section-title unified-title">
                <view class="section-icon unified-icon">
                  <t-icon name="candy" size="24rpx" color="white" />
                </view>
                用药记录
              </view>
              <view class="unified-data-detail">
                <view class="medication-summary">
                  <text>共 {{currentDateDetail.medicationData.count}} 种药品</text>
                  <text wx:if="{{currentDateDetail.medicationData.taken > 0}}">
                    ，已服用 {{currentDateDetail.medicationData.taken}} 种
                  </text>
                </view>
                <view class="medication-progress" wx:if="{{currentDateDetail.medicationData.totalTimeSlots > 0}}">
                  <view class="progress-text">
                    <text>
                      服药进度：{{currentDateDetail.medicationData.completedTimeSlots}}/{{currentDateDetail.medicationData.totalTimeSlots}}
                      次
                    </text>
                    <text class="progress-status"
                      style="color: {{currentDateDetail.medicationData.isFullyCompleted ? '#FF8F00' : '#FFB74D'}};">
                      <text wx:if="{{currentDateDetail.medicationData.isFullyCompleted}}">已完成</text>
                      <text wx:else>未完成</text>
                    </text>
                  </view>
                  <view class="progress-bar">
                    <view
                      class="progress-fill {{currentDateDetail.medicationData.isFullyCompleted ? 'progress-completed' : ''}}"
                      style="width: {{animatedProgress}}%"></view>
                  </view>
                </view>
                <view class="medication-list-detail">
                  <view class="medication-item-detail" wx:for="{{currentDateDetail.medicationData.medicines}}"
                    wx:key="id">
                    <view class="medication-info-detail">
                      <view class="medication-name-detail">
                        <text class="medicine-name">{{item.name}}</text>
                        <text class="medicine-dosage">{{item.dosage}}</text>
                      </view>
                      <view class="medication-notes-detail" wx:if="{{item.notes}}">
                        <t-icon name="chat" size="20" color="#FF8F00" />
                        <text>{{item.notes}}</text>
                      </view>
                    </view>
                    <!-- 分时段服药状态显示 -->
                    <view class="medication-time-slots-detail"
                      wx:if="{{item.timesPerDay && item.timesPerDay.length > 0}}">
                      <view
                        class="time-slot-status {{item.timeSlotStatus && item.timeSlotStatus[timeSlot] ? 'taken' : 'pending'}}"
                        wx:for="{{item.timesPerDay}}" wx:key="*this" wx:for-item="timeSlot"
                        bindtap="toggleTimeSlotInPopup" data-medicine-id="{{item.id}}" data-time-slot="{{timeSlot}}">
                        <text class="time-slot-name">{{timeSlot}}</text>
                        <view
                          class="time-slot-indicator {{item.timeSlotStatus && item.timeSlotStatus[timeSlot] ? 'taken' : 'pending'}}">
                          <t-icon name="check" size="16" color="#fff"
                            wx:if="{{item.timeSlotStatus && item.timeSlotStatus[timeSlot]}}" />
                        </view>
                      </view>
                    </view>
                    <!-- 没有分时段时显示总状态 -->
                    <view class="medication-status {{item.taken ? 'taken' : 'pending'}}"
                      wx:if="{{!item.timesPerDay || item.timesPerDay.length === 0}}">
                      <text wx:if="{{item.taken}}">已服用</text>
                      <text wx:else>待服用</text>
                    </view>
                  </view>
                </view>
              </view>
            </view>
          </block>
          <!-- 门诊记录 -->
          <block wx:if="{{currentDateDetail.clinicData && currentDateDetail.clinicData.length > 0}}">
            <view class="date-detail-section unified-section">
              <view class="date-detail-section-title unified-title">
                <view class="section-icon unified-icon">
                  <t-icon name="hospital" size="24rpx" color="white" />
                </view>
                门诊记录
              </view>
              <view class="clinic-detail">
                <view class="clinic-item-detail" wx:for="{{currentDateDetail.clinicData}}" wx:key="id">
                  <view class="clinic-header-detail">
                    <view class="clinic-hospital-detail">
                      <text class="hospital-name">{{item.hospital}}</text>
                      <text class="department-name">{{item.department}}</text>
                    </view>
                    <view class="clinic-time-detail" wx:if="{{item.visitTime}}">
                      <text>{{item.visitTime}}</text>
                    </view>
                  </view>
                  <view class="clinic-doctor-detail">
                    <t-icon name="user" size="20rpx" color="#FF8F00" />
                    <text class="doctor-name">{{item.doctor}}</text>
                    <text class="doctor-title" wx:if="{{item.doctorTitle}}">
                      {{item.doctorTitle}}
                    </text>
                  </view>
                  <view class="clinic-diagnosis-detail" wx:if="{{item.diagnosis}}">
                    <view class="diagnosis-label">
                      <t-icon name="precise-monitor" size="20rpx" color="#FF8F00" />
                      <text>诊断：</text>
                    </view>
                    <text class="diagnosis-text">
                      {{item.diagnosis.length > 40 ? item.diagnosis.substring(0, 40) + '...' : item.diagnosis}}
                    </text>
                  </view>
                  <view class="clinic-extra-detail">
                    <view class="clinic-cost-detail" wx:if="{{item.cost}}">
                      <t-icon name="money-circle" size="20rpx" color="#FF8F00" />
                      <text>¥{{item.cost}}</text>
                    </view>
                    <view class="clinic-followup-detail" wx:if="{{item.followUpDate}}">
                      <t-icon name="time" size="20rpx" color="#FF8F00" />
                      <text>复诊 {{item.followUpDate}}</text>
                    </view>
                  </view>
                </view>
              </view>
            </view>
          </block>
          <!-- 尿量记录 -->
          <block wx:if="{{currentDateDetail.urineData}}">
            <view class="date-detail-section unified-section">
              <view class="date-detail-section-title unified-title">
                <view class="section-icon unified-icon">
                  <t-icon name="fill-color-1" size="24rpx" color="white" />
                </view>
                尿量记录
              </view>
              <view class="urine-detail">
                <view class="urine-summary-detail">
                  <text>共 {{currentDateDetail.urineData.count}} 次记录</text>
                  <text style="margin-left: 25rpx;" class="urine-total">
                    总量 {{currentDateDetail.urineData.totalVolume}} ml
                  </text>
                </view>
                <view class="urine-list-detail">
                  <view class="urine-item-detail" wx:for="{{currentDateDetail.urineData.records}}" wx:key="id">
                    <view class="urine-time-detail">
                      <t-icon name="time" size="20rpx" color="#FF8F00" />
                      <text>{{item.time}}</text>
                    </view>
                    <view class="urine-info-detail">
                      <text class="urine-volume">{{item.volume}} ml</text>
                      <text class="urine-color" wx:if="{{item.color}}">{{item.color}}</text>
                      <text class="urine-clarity" wx:if="{{item.clarity}}">{{item.clarity}}</text>
                    </view>
                  </view>
                </view>
              </view>
            </view>
          </block>
          <!-- 排便记录 -->
          <block wx:if="{{currentDateDetail.stoolData}}">
            <view class="date-detail-section unified-section">
              <view class="date-detail-section-title unified-title">
                <view class="section-icon unified-icon">
                  <t-icon name="layers" size="24rpx" color="white" />
                </view>
                排便记录
              </view>
              <view class="stool-detail">
                <view class="stool-summary-detail">
                  <text>共 {{currentDateDetail.stoolData.count}} 次记录</text>
                  <text class="stool-warning" wx:if="{{currentDateDetail.stoolData.hasAbnormal}}">
                    （有异常）
                  </text>
                </view>
                <view class="stool-list-detail">
                  <view class="stool-item-detail" wx:for="{{currentDateDetail.stoolData.records}}" wx:key="id">
                    <view class="stool-time-detail">
                      <t-icon name="time" size="20rpx" color="#FF8F00" />
                      <text>{{item.time}}</text>
                    </view>
                    <view class="stool-info-detail">
                      <text class="stool-type">{{item.type}}</text>
                      <text class="stool-color" wx:if="{{item.color}}">{{item.color}}</text>
                      <text class="stool-consistency" wx:if="{{item.consistency}}">
                        {{item.consistency}}
                      </text>
                    </view>
                    <view class="stool-abnormal-detail" wx:if="{{item.hasBlood || item.hasMucus}}">
                      <text class="abnormal-tag" wx:if="{{item.hasBlood}}">有血液</text>
                      <text class="abnormal-tag" wx:if="{{item.hasMucus}}">有粘液</text>
                    </view>
                  </view>
                </view>
              </view>
            </view>
          </block>
          <!-- 空状态 -->
          <block
            wx:if="{{(!currentDateDetail.bloodData || currentDateDetail.bloodData.length === 0) && (!currentDateDetail.keyDates || currentDateDetail.keyDates.length === 0) && currentDateDetail.tasks.length === 0 && !currentDateDetail.medicationData && (!currentDateDetail.clinicData || currentDateDetail.clinicData.length === 0) && !currentDateDetail.urineData && !currentDateDetail.stoolData && !currentDateDetail.virusData && !currentDateDetail.organData}}">
            <view class="date-detail-empty">
              <t-icon name="calendar" size="80rpx" color="#ddd" />
              <text>这一天暂无记录</text>
              <text style="font-size: 24rpx; margin-top: 10rpx; color: #bbb;">点击功能项添加记录吧</text>
            </view>
          </block>
        </scroll-view>
      </view>
    </t-popup>
  </view>
  <!-- 结束 content-wrapper -->
</view>
